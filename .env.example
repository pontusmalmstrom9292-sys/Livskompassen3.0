# Gemini / Google AI
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# Firebase Web SDK
VITE_FIREBASE_API_KEY=
# Firebase Web SDK — authDomain: använd firebaseapp.com (OAuth redirect_uri är förregistrerad).
# Lägg till *.web.app under Console → Authentication → Authorized domains, inte som authDomain,
# om du inte manuellt lagt till https://<projekt>.web.app/__/auth/handler i GCP OAuth-klient.
VITE_FIREBASE_AUTH_DOMAIN=gen-lang-client-0481875058.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Seed Kunskapsvalvet / kampspar (terminal — samma ägare som appen)
# Rekommenderat för Google-inloggning (ingen lösenords-Auth):
# SEED_FIREBASE_EMAIL=pontus.malmstrom9292@gmail.com
# SEED_OWNER_UID=   # valfritt — annars slås e-post upp via Admin SDK
# Kräver: gcloud auth application-default login (eller GOOGLE_APPLICATION_CREDENTIALS)
# Legacy email/lösenord (endast Email/Password-provider): --email-auth
# SEED_FIREBASE_PASSWORD=

# Valv: server-session via issueVaultSession (WebAuthn/Fyren) — ingen client-PIN i prod.
# Prod-kanon: ember (guld/brons). Se docs/design/CHROME-EMBER-KANON.md
# VITE_HEADER_PANEL_STYLE=ember

# Botten-dock: classic (Familjen · kompass · Dagbok) | band (7-kol) | orbit
# VITE_DOCK_MODE=classic

# Kräv e-postinloggning (ingen anonym session). Prod-kanon — se docs/DEPLOY.md § Fas 1.2.
# VITE_REQUIRE_EMAIL_AUTH=true
#
# Firebase App Check — krävs när APP_CHECK_ENFORCE=true på Functions.
# Web: Console → App Check → reCAPTCHA v3 site key.
# Android: registrera com.livskompassen.app med Play Integrity (samma projekt).
# Lokal dev / Android Studio: debug token i Console + nedan (adb logcat | grep DebugAppCheckProvider):
# VITE_APP_CHECK_RECAPTCHA_SITE_KEY=
# VITE_APP_CHECK_DEBUG_TOKEN=
#
# Google-inlogg: aktivera "Google" under Firebase Console → Authentication → Sign-in method.
# Fingeravtryck: aktiveras i appen under Konto efter Google/e-post-inlogg (WebAuthn).
# Valfri hint i Google-popup (din primära e-post):
# VITE_GOOGLE_LOGIN_HINT=pontus.malmstrom9292@gmail.com
# Dev only — felsök redirect lokalt (committa aldrig =true; ej Hosting secrets):
# VITE_GOOGLE_SIGNIN_REDIRECT=

# Google Drive OAuth / server routes
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google Cloud / Vertex AI
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
# Vector Search (GCP west1 — se scripts/setup_vector_search_west1.sh)
VECTOR_SEARCH_INDEX_ID=2686894156982255616
VECTOR_SEARCH_ENDPOINT_ID=4956462078572363776
VECTOR_SEARCH_DEPLOYED_INDEX_ID=livskompassen_kv_deployed_v1

# Drive webhook (Apps Script → notifyNewFile)
# Sätts i produktion via Firebase Functions secrets — committa aldrig värdet:
#   firebase functions:secrets:set NOTIFY_WEBHOOK_SECRET
# Samma värde ska ligga i Apps Script Script Property WEBHOOK_SECRET.
NOTIFY_WEBHOOK_SECRET=
