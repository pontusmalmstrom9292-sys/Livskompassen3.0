# Gemini / Google AI
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# Firebase Web SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: seed Kampspår profil via terminal (samma konto som appen)
# SEED_FIREBASE_EMAIL=
# SEED_FIREBASE_PASSWORD=

# Optional: dev-only vault PIN (never commit real PIN)
VITE_VAULT_PIN=

# Google Drive OAuth / server routes
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google Cloud / Vertex AI
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
# Vector Search (GCP west1 — se scripts/setup_vector_search_west1.sh)
VECTOR_SEARCH_INDEX_ID=2686894156982255616
VECTOR_SEARCH_ENDPOINT_ID=4956462078572363776
VECTOR_SEARCH_DEPLOYED_INDEX_ID=livskompassen_kv_deployed_v1

# Drive webhook (Apps Script → notifyNewFile)
# Sätts i produktion via Firebase Functions secrets — committa aldrig värdet:
#   firebase functions:secrets:set NOTIFY_WEBHOOK_SECRET
# Samma värde ska ligga i Apps Script Script Property WEBHOOK_SECRET.
NOTIFY_WEBHOOK_SECRET=
