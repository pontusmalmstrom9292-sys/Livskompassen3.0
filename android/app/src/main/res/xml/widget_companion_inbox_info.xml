<?xml version="1.0" encoding="utf-8"?>
<!-- Inbox — min 1 plats, default 4×2. Krympbart utan funktionsbortfall. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_companion_inbox_desc"
    android:initialLayout="@layout/widget_companion_inbox"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:previewLayout="@layout/widget_companion_inbox"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="86400000"
    android:widgetCategory="home_screen" />
