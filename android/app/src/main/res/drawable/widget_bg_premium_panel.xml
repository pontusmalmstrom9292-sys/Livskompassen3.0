<?xml version="1.0" encoding="utf-8"?>
<!-- Kap 6 safirglas ×10 — Obsidian + soft gold bloom lip + stroke -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Soft outer bloom (muted gold, never neon) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#18D4AF37" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <item
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp"
        android:top="1.5dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="#0D0B09"
                android:endColor="#020617"
                android:startColor="#1A2233"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#44D4AF37" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
