<?xml version="1.0" encoding="utf-8"?>
<!-- Kap 6 safirglas ×10 — Obsidian + soft bloom + 1px guldkant -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22D4AF37" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#18020A18" />
            <corners android:radius="27dp" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:centerColor="#0D0B09"
                android:endColor="#020617"
                android:startColor="#1A2233"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#66D4AF37" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>
