<?xml version="1.0" encoding="utf-8"?>
<!-- Kap 6 Capture — deep inset brunn inuti guldring (soft bloom lip) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#22000000" />
        </shape>
    </item>
    <item
        android:bottom="1.5dp"
        android:left="1dp"
        android:right="1dp"
        android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="160"
                android:endColor="#FF050B14"
                android:startColor="#FF121A28"
                android:type="linear" />
            <stroke
                android:width="1.25dp"
                android:color="#55FDE68A" />
        </shape>
    </item>
</layer-list>
