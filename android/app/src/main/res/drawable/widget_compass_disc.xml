<?xml version="1.0" encoding="utf-8"?>
<!-- Kap 6 Compass — disc depth: gold rim · inset · ethereal ring · gold gem -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#28D4AF37" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <gradient
                android:angle="160"
                android:endColor="#FF0A0E18"
                android:startColor="#FF1A2233"
                android:type="linear" />
            <stroke
                android:width="2.75dp"
                android:color="#E0D4AF37" />
        </shape>
    </item>
    <item
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:top="16dp">
        <shape android:shape="oval">
            <stroke
                android:width="1.25dp"
                android:color="#887BA3C9" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <item
        android:bottom="34dp"
        android:left="34dp"
        android:right="34dp"
        android:top="34dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#FF9A7B2F"
                android:startColor="#FFFDE68A"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
