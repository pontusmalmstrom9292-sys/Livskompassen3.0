<?xml version="1.0" encoding="utf-8"?>
<!-- Kap 6 CTA outline — gold rim · recessed fill · ≥56dp friendly -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22D4AF37" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#E6050B14" />
            <stroke
                android:width="1.25dp"
                android:color="#CCD4AF37" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
