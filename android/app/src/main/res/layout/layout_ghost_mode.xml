<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0B09"
    android:orientation="vertical">

    <TextView
        android:id="@+id/ghost_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:text="Mina Anteckningar"
        android:textColor="#D4AF37"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/ghost_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- Items added dynamically or static boring ones -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Handla mat (mjölk, bröd, ägg)" android:textColor="#94A3B8" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Ring mamma på söndag" android:textColor="#94A3B8" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Boka tvättid kl 17:00" android:textColor="#94A3B8" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Kom ihåg att vattna växterna" android:textColor="#94A3B8" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Hämta ut medicin på Apoteket" android:textColor="#94A3B8" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Svara på jobbmailet från igår" android:textColor="#94A3B8" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="15dp" android:text="Träning: Benpass kl 18" android:textColor="#94A3B8" />

        </LinearLayout>
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp"
        android:text="+"
        android:textColor="#D4AF37"
        android:textSize="32sp"
        android:gravity="center"
        android:background="?attr/selectableItemBackground" />

</LinearLayout>
