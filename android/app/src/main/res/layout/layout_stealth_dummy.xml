<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0B09"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/stealth_dummy_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mina Anteckningar"
        android:textColor="#D4AF37"
        android:textSize="22sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="#33D4AF37" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/stealth_dummy_item_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Handla mat"
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:padding="10dp" />

        <TextView
            android:id="@+id/stealth_dummy_item_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Ring tandläkaren"
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:padding="10dp" />

        <TextView
            android:id="@+id/stealth_dummy_item_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Hämta paket"
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:padding="10dp" />

        <TextView
            android:id="@+id/stealth_dummy_item_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Träning kl 18"
            android:textColor="#94A3B8"
            android:textSize="16sp"
            android:padding="10dp" />
    </LinearLayout>
</LinearLayout>
