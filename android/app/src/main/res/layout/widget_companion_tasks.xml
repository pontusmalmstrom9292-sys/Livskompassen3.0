<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Tasks Small — max 3 rows + Visa alla -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_tasks_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_companion_tasks_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:letterSpacing="0.1"
            android:maxLines="1"
            android:text="@string/widget_companion_tasks_title"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_companion_tasks_badge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:gravity="center"
            android:text="@string/widget_companion_tasks_badge"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_tasks_row1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_inset_well"
        android:contentDescription="@string/widget_companion_tasks_row1"
        android:gravity="center_vertical"
        android:minHeight="40dp"
        android:paddingHorizontal="10dp"
        android:text="@string/widget_companion_tasks_row1"
        android:textColor="@color/widget_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_companion_tasks_row2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/widget_bg_inset_well"
        android:contentDescription="@string/widget_companion_tasks_row2"
        android:gravity="center_vertical"
        android:minHeight="40dp"
        android:paddingHorizontal="10dp"
        android:text="@string/widget_companion_tasks_row2"
        android:textColor="@color/widget_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_companion_tasks_row3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/widget_bg_inset_well"
        android:contentDescription="@string/widget_companion_tasks_row3"
        android:gravity="center_vertical"
        android:minHeight="40dp"
        android:paddingHorizontal="10dp"
        android:text="@string/widget_companion_tasks_row3"
        android:textColor="@color/widget_text"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_companion_tasks_all"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_cta_outline"
        android:contentDescription="@string/widget_companion_tasks_all"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:minHeight="44dp"
        android:paddingVertical="8dp"
        android:text="@string/widget_companion_tasks_all"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
