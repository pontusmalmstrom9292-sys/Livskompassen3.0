<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Tasks Small — max 3 rows + Visa alla -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_tasks_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_lock_sacred"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/widget_companion_tasks_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:letterSpacing="0.1"
            android:text="@string/widget_tasks_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_companion_tasks_badge"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:text="@string/widget_companion_tasks_badge"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_inset_well"
        android:orientation="vertical"
        android:padding="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="12dp">
            <ImageView android:layout_width="12dp" android:layout_height="12dp" android:src="@drawable/widget_ic_lock_gold" android:alpha="0.6" android:contentDescription="@null"/>
            <TextView android:layout_width="35dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="@string/widget_tasks_time_1" android:textColor="@color/widget_muted" android:textSize="9sp"/>
            <TextView android:id="@+id/widget_companion_tasks_row1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:minHeight="56dp" android:text="@string/widget_companion_tasks_row1" android:textColor="@color/widget_text" android:textSize="10sp"/>
            <ImageView android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/widget_bg_pill_category" android:alpha="0.5" android:contentDescription="@null" android:importantForAccessibility="no"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="12dp">
            <ImageView android:layout_width="12dp" android:layout_height="12dp" android:src="@drawable/widget_ic_lock_gold" android:alpha="0.6" android:contentDescription="@null"/>
            <TextView android:layout_width="35dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="@string/widget_tasks_time_2" android:textColor="@color/widget_muted" android:textSize="9sp"/>
            <TextView android:id="@+id/widget_companion_tasks_row2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:minHeight="56dp" android:text="@string/widget_companion_tasks_row2" android:textColor="@color/widget_text" android:textSize="10sp"/>
            <ImageView android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/widget_bg_pill_category" android:alpha="0.5" android:contentDescription="@null" android:importantForAccessibility="no"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="12dp">
            <ImageView android:layout_width="12dp" android:layout_height="12dp" android:src="@drawable/widget_ic_lock_gold" android:alpha="0.6" android:contentDescription="@null"/>
            <TextView android:layout_width="35dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="@string/widget_tasks_time_3" android:textColor="@color/widget_muted" android:textSize="9sp"/>
            <TextView android:id="@+id/widget_companion_tasks_row3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_vertical" android:minHeight="56dp" android:text="@string/widget_tasks_row3_short" android:textColor="@color/widget_text" android:textSize="10sp"/>
            <ImageView android:layout_width="12dp" android:layout_height="12dp" android:background="@drawable/widget_bg_pill_category" android:alpha="0.5" android:contentDescription="@null" android:importantForAccessibility="no"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_tasks_all"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/widget_btn_all"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold_dim"
        android:textSize="9sp"
        android:textStyle="bold" />
</LinearLayout>
