<?xml version="1.0" encoding="utf-8"?>
<!-- Translucent widget overlay — Obsidian + gold, no app chrome -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <View
        android:id="@+id/widget_overlay_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC020617"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/widget_bg_premium_panel"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_overlay_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:textColor="@color/widget_gold"
                android:textSize="13sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/widget_overlay_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/widget_bg_stamp_pill_muted"
                android:contentDescription="@string/widget_overlay_close"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_close_clear_cancel" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_overlay_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/widget_muted"
            android:textSize="12sp" />

        <!-- Capture hold surface -->
        <FrameLayout
            android:id="@+id/widget_overlay_capture_hold"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:contentDescription="@string/widget_overlay_capture_hint"
            android:minHeight="56dp"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_overlay_capture_hold_label"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/widget_overlay_capture_start_label"
                android:textColor="@color/widget_gold_light"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/widget_overlay_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/widget_overlay_mood_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_overlay_mood_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/widget_bg_stamp_pill_muted"
                    android:gravity="center"
                    android:minWidth="44dp"
                    android:minHeight="44dp"
                    android:text="1"
                    android:textColor="@color/widget_text"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_overlay_mood_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/widget_bg_stamp_pill_muted"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/widget_text"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_overlay_mood_3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:alpha="1"
                    android:background="@drawable/widget_bg_gold_ring"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/widget_gold_light"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_overlay_mood_4"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/widget_bg_stamp_pill_muted"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="@color/widget_text"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_overlay_mood_5"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/widget_bg_stamp_pill_muted"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="@color/widget_text"
                    android:textSize="16sp" />
            </LinearLayout>

            <EditText
                android:id="@+id/widget_overlay_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/widget_bg_inset_well"
                android:gravity="top|start"
                android:hint="@string/widget_companion_note_compose"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="88dp"
                android:padding="12dp"
                android:textColor="@color/widget_text"
                android:textColorHint="@color/widget_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/widget_overlay_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/widget_bg_stamp_pill"
                android:gravity="center"
                android:letterSpacing="0.12"
                android:minHeight="56dp"
                android:text="@string/widget_overlay_save"
                android:textAllCaps="true"
                android:textColor="@color/widget_background"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Secure local library: download / share latest capture -->
        <LinearLayout
            android:id="@+id/widget_overlay_library"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_overlay_library_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_bg_inset_well"
                android:padding="12dp"
                android:textColor="@color/widget_text"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/widget_overlay_library_download"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/widget_bg_stamp_pill"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:minHeight="56dp"
                android:text="@string/widget_capture_download"
                android:textAllCaps="true"
                android:textColor="@color/widget_background"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_overlay_library_share"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/widget_bg_cta_outline"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:minHeight="56dp"
                android:text="@string/widget_capture_share"
                android:textAllCaps="true"
                android:textColor="@color/widget_gold"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
