<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Harbor Small/Medium — lotus · affirmation · 4 quick -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_harbor_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/widget_companion_harbor_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:letterSpacing="0.12"
        android:maxLines="1"
        android:text="@string/widget_companion_harbor_title"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="11sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/widget_bg_gold_ring"
        android:padding="10dp">

        <ImageView
            android:id="@+id/widget_companion_harbor_lotus"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/widget_companion_harbor_title"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_ic_lotus_ethereal" />
    </FrameLayout>

    <TextView
        android:id="@+id/widget_companion_harbor_affirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/widget_companion_harbor_affirm"
        android:textColor="@color/widget_text"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_companion_harbor_breath"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:gravity="center"
            android:minHeight="48dp"
            android:text="@string/widget_companion_harbor_breath"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_harbor_focus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:gravity="center"
            android:minHeight="48dp"
            android:text="@string/widget_companion_harbor_focus"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_harbor_thanks"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:gravity="center"
            android:minHeight="48dp"
            android:text="@string/widget_companion_harbor_thanks"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_harbor_sleep"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:gravity="center"
            android:minHeight="48dp"
            android:text="@string/widget_companion_harbor_sleep"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />
    </LinearLayout>
</LinearLayout>
