<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Harbor Small/Medium — lotus · affirmation · 4 quick -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_harbor_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/widget_ic_companion_harbor" />

        <TextView
            android:id="@+id/widget_companion_harbor_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.18"
            android:text="@string/widget_harbor_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_harbor_hint"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_bg_gold_ring"
        android:padding="12dp">

        <ImageView
            android:id="@+id/widget_companion_harbor_lotus"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.9"
            android:src="@drawable/widget_ic_lotus_ethereal" />
    </FrameLayout>

    <TextView
        android:id="@+id/widget_companion_harbor_affirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/widget_companion_harbor_affirm"
        android:textColor="@color/widget_muted"
        android:textSize="9sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <!-- Andning -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_companion_harbor_breath"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_bg_pill_category"
                android:padding="14dp"
                android:contentDescription="@string/widget_companion_harbor_breath"
                android:src="@drawable/widget_progress_ethereal" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/widget_companion_harbor_breath"
                android:textColor="@color/widget_muted"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Fokus -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_companion_harbor_focus"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_bg_pill_category"
                android:padding="14dp"
                android:contentDescription="@string/widget_companion_harbor_focus"
                android:src="@drawable/widget_chip_kompass" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/widget_companion_harbor_focus"
                android:textColor="@color/widget_muted"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Tacksamhet -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_companion_harbor_thanks"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_bg_pill_category"
                android:padding="14dp"
                android:contentDescription="@string/widget_companion_harbor_thanks"
                android:src="@drawable/widget_ic_anchor_gold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/widget_companion_harbor_thanks"
                android:textColor="@color/widget_muted"
                android:textSize="7sp" />
        </LinearLayout>

        <!-- Sömn -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:id="@+id/widget_companion_harbor_sleep"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/widget_bg_pill_category"
                android:padding="14dp"
                android:contentDescription="@string/widget_companion_harbor_sleep"
                android:src="@drawable/widget_ic_lock_gold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/widget_companion_harbor_sleep"
                android:textColor="@color/widget_muted"
                android:textSize="7sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
