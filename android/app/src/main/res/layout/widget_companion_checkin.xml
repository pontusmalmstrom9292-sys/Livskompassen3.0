<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_checkin_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/widget_ic_lock_gold"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_companion_checkin_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.22"
            android:text="@string/widget_checkin_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_checkin_hint"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_mood_1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:background="@drawable/widget_bg_mood_inset"
            android:gravity="center"
            android:text="☹️"
            android:textSize="20sp"
            android:alpha="0.4"
            android:contentDescription="Mycket dåligt" />

        <TextView
            android:id="@+id/widget_mood_2"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_bg_mood_inset"
            android:gravity="center"
            android:text="🙁"
            android:textSize="20sp"
            android:alpha="0.4"
            android:contentDescription="Dåligt" />

        <TextView
            android:id="@+id/widget_mood_3"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_bg_mood_inset"
            android:gravity="center"
            android:text="😐"
            android:textSize="20sp"
            android:alpha="0.4"
            android:contentDescription="Okej" />

        <TextView
            android:id="@+id/widget_mood_4"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_bg_mood_inset"
            android:gravity="center"
            android:text="🙂"
            android:textSize="20sp"
            android:alpha="0.4"
            android:contentDescription="Bra" />

        <TextView
            android:id="@+id/widget_mood_5"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:minHeight="56dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:gravity="center"
            android:text="😊"
            android:textSize="20sp"
            android:contentDescription="Utmärkt" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_checkin_note"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@drawable/widget_bg_inset_well"
        android:gravity="top|start"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:text="Lägg till en kort notis..."
        android:textColor="@color/widget_muted"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/widget_companion_checkin_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/widget_bg_cta_outline"
        android:gravity="center"
        android:minHeight="56dp"
        android:text="@string/widget_checkin_save"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold_light"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
