<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_companion_beacon_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/widget_ic_companion_beacon"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/widget_companion_beacon_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:letterSpacing="0.18"
                android:text="@string/widget_beacon_header"
                android:textAllCaps="true"
                android:textColor="@color/widget_gold_light"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_error_outline"
            android:alpha="0.5"
            android:contentDescription="@null" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/widget_beacon_sub"
        android:textColor="@color/widget_muted"
        android:textSize="8sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginTop="10dp">

        <ImageView
            android:id="@+id/widget_beacon_main_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/splash"
            android:alpha="0.6"
            android:contentDescription="@null" />

        <FrameLayout
            android:id="@+id/widget_companion_beacon_ring"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center">

            <ProgressBar
                android:id="@+id/widget_companion_beacon_capacity_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:max="100"
                android:progress="72"
                android:progressDrawable="@drawable/widget_capacity_ring_progress"
                android:background="@drawable/widget_bg_capacity_ring" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_companion_beacon_pct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_beacon_pct_demo"
                    android:textColor="@color/widget_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_beacon_capacity_label"
                    android:textAllCaps="true"
                    android:textColor="@color/widget_muted"
                    android:textSize="8sp" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_beacon_energy_label" android:textSize="8sp" android:textColor="@color/widget_muted" android:textAllCaps="true"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/widget_beacon_energy_value" android:textColor="@color/widget_blue_light" android:textSize="10sp" android:textStyle="bold" />
            <FrameLayout android:layout_width="4dp" android:layout_height="4dp" android:layout_marginTop="4dp" android:background="@color/widget_blue_light" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_beacon_stress_label" android:textSize="8sp" android:textColor="@color/widget_muted" android:textAllCaps="true"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/widget_beacon_stress_value" android:textColor="@color/widget_yellow" android:textSize="10sp" android:textStyle="bold" />
            <FrameLayout android:layout_width="4dp" android:layout_height="4dp" android:layout_marginTop="4dp" android:background="@color/widget_yellow" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_beacon_sleep_label" android:textSize="8sp" android:textColor="@color/widget_muted" android:textAllCaps="true"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp" android:text="@string/widget_beacon_sleep_value" android:textColor="@color/widget_blue_light" android:textSize="10sp" android:textStyle="bold" />
            <FrameLayout android:layout_width="4dp" android:layout_height="4dp" android:layout_marginTop="4dp" android:background="@color/widget_blue_light" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/widget_bg_inset_well"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/widget_ic_anchor_gold"
            android:alpha="0.7"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_beacon_advice_title" android:textSize="8sp" android:textColor="@color/widget_muted" android:textAllCaps="true"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_beacon_advice_text" android:textSize="8sp" android:textColor="@color/widget_text" />
        </LinearLayout>

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_error_outline"
            android:alpha="0.5"
            android:contentDescription="@null" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#11FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_beacon_updated"
            android:textSize="8sp"
            android:textColor="@color/widget_muted" />

        <TextView
            android:id="@+id/widget_companion_beacon_cta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_beacon_details"
            android:textColor="@color/widget_teal"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
