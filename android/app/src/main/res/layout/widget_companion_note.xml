<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Note — Kap 6 Gold ×10: inset well · pills · cam/mic/+ · ≥56dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_note_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_ic_companion_note" />

        <TextView
            android:id="@+id/widget_companion_note_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:ellipsize="end"
            android:gravity="center"
            android:letterSpacing="0.16"
            android:maxLines="1"
            android:text="@string/widget_companion_note_title"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_note_compose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_bg_inset_well"
        android:contentDescription="@string/widget_companion_note_compose"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:paddingHorizontal="14dp"
        android:paddingVertical="12dp"
        android:text="@string/widget_companion_note_compose"
        android:textColor="@color/widget_muted"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/widget_companion_note_pills"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_companion_note_pill_tanke"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:text="@string/widget_companion_note_pill_tanke"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_note_pill_ide"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:text="@string/widget_companion_note_pill_ide"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_note_pill_paminnelse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:text="@string/widget_companion_note_pill_paminnelse"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_note_pill_annat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="56dp"
            android:paddingHorizontal="4dp"
            android:text="@string/widget_companion_note_pill_annat"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_bg_stamp_pill_muted"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp">

        <ImageView
            android:id="@+id/widget_companion_note_photo"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:contentDescription="@string/widget_companion_note_photo"
            android:minHeight="56dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_ic_wh2_note" />

        <ImageView
            android:id="@+id/widget_companion_note_voice"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:contentDescription="@string/widget_companion_note_voice"
            android:minHeight="56dp"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_ic_companion_mic" />

        <TextView
            android:id="@+id/widget_companion_note_add"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_bg_stamp_pill"
            android:contentDescription="@string/widget_companion_note_add"
            android:gravity="center"
            android:minWidth="56dp"
            android:minHeight="56dp"
            android:text="+"
            android:textColor="@color/widget_background"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
