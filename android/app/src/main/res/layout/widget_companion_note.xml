<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Note — multi-intent: compose / photo / voice / save-open -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_note_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/widget_companion_note_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:maxLines="1"
        android:text="@string/widget_companion_note_title"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_companion_note_compose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_stamp_pill_muted"
        android:contentDescription="@string/widget_companion_note_compose"
        android:gravity="center_vertical"
        android:minHeight="44dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:text="@string/widget_companion_note_compose"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_companion_note_photo"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:contentDescription="@string/widget_companion_note_photo"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_ic_wh2_note" />

        <ImageView
            android:id="@+id/widget_companion_note_voice"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:contentDescription="@string/widget_companion_note_voice"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_ic_companion_mic" />

        <TextView
            android:id="@+id/widget_companion_note_add"
            android:layout_width="48dp"
            android:layout_height="44dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_bg_stamp_pill"
            android:contentDescription="@string/widget_companion_note_add"
            android:gravity="center"
            android:text="+"
            android:textColor="@color/widget_background"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
