<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Note — Kap 6 Gold ×10: inset well · pills · cam/mic/+ · ≥56dp -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_note_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_ic_companion_note" />

        <TextView
            android:id="@+id/widget_companion_note_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:letterSpacing="0.16"
            android:text="@string/widget_note_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_note_hint"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_note_compose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_inset_well"
        android:gravity="top|start"
        android:minHeight="64dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:text="@string/widget_companion_note_compose"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/widget_companion_note_pills"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_companion_note_pill_tanke"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/widget_companion_note_pill_tanke"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_note_pill_ide"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/widget_companion_note_pill_ide"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_note_pill_paminnelse"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/widget_companion_note_pill_paminnelse"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/widget_companion_note_pill_annat"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:minHeight="32dp"
            android:text="@string/widget_companion_note_pill_annat"
            android:textColor="@color/widget_muted"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_companion_note_photo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/widget_bg_pill_category"
            android:padding="14dp"
            android:src="@drawable/widget_ic_wh2_note"
            android:alpha="0.8"
            android:contentDescription="@string/widget_companion_note_photo" />

        <ImageView
            android:id="@+id/widget_companion_note_voice"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/widget_bg_pill_category"
            android:padding="14dp"
            android:src="@drawable/widget_ic_companion_mic"
            android:alpha="0.8"
            android:contentDescription="@string/widget_companion_note_voice" />

        <ImageView android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:contentDescription="@null" android:importantForAccessibility="no"/>

        <TextView
            android:id="@+id/widget_companion_note_add"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:gravity="center"
            android:minHeight="56dp"
            android:text="+"
            android:textColor="@color/widget_gold_light"
            android:textSize="22sp"
            android:textStyle="bold"
            android:contentDescription="@string/widget_companion_note_add" />
    </LinearLayout>
</LinearLayout>
