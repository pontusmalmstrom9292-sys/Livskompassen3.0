<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Compass Large — Kap 6 Gold: disc · intention · progress · CTA -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_compass_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/widget_chip_kompass" />

        <TextView
            android:id="@+id/widget_companion_compass_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.18"
            android:text="@string/widget_compass_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_compass_hint"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_companion_compass_disc"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/widget_compass_disc"
        android:contentDescription="@string/widget_compass_header" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Fokus för idag"
        android:textColor="@color/widget_muted"
        android:textSize="9sp" />

    <TextView
        android:id="@+id/widget_companion_compass_intention"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:text="Närvaro i det jag gör"
        android:textColor="@color/widget_text"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ProgressBar
            android:id="@+id/widget_companion_compass_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="72"
            android:progressDrawable="@drawable/widget_progress_gold" />

        <TextView
            android:id="@+id/widget_companion_compass_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="72%"
            android:textColor="@color/widget_gold_dim"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_compass_cta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/widget_bg_cta_outline"
        android:gravity="center"
        android:minHeight="56dp"
        android:text="@string/widget_btn_intention"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold_light"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
