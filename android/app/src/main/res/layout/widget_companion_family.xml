<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/widget_companion_family_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/widget_ic_companion_child"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/widget_companion_family_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:letterSpacing="0.18"
                android:text="@string/widget_family_header"
                android:textAllCaps="true"
                android:textColor="@color/widget_gold_light"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/ic_error_outline"
            android:alpha="0.5"
            android:contentDescription="@null" />
    </RelativeLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/widget_family_today"
        android:textColor="@color/widget_muted"
        android:textSize="8sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="10dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/splash" android:background="@drawable/widget_bg_gold_ring" android:padding="2dp" android:scaleType="centerCrop" android:contentDescription="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_child_1" android:textColor="@color/widget_text" android:textSize="8sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_child_1_age" android:textColor="@color/widget_muted" android:textSize="8sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="10dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/splash" android:background="@drawable/widget_bg_gold_ring" android:padding="2dp" android:scaleType="centerCrop" android:contentDescription="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_child_2" android:textColor="@color/widget_text" android:textSize="8sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_child_2_age" android:textColor="@color/widget_muted" android:textSize="8sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical" android:layout_marginEnd="10dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/splash" android:background="@drawable/widget_bg_gold_ring" android:padding="2dp" android:scaleType="centerCrop" android:contentDescription="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_child_3" android:textColor="@color/widget_text" android:textSize="8sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_child_3_age" android:textColor="@color/widget_muted" android:textSize="8sp"/>
        </LinearLayout>

        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_lock_sacred" android:background="@drawable/widget_bg_pill_category" android:padding="12dp" app:tint="@color/widget_muted" android:contentDescription="@null"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/widget_bg_inset_well"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/widget_ic_wh8_moduler"
            app:tint="@color/widget_yellow"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_schedule_title" android:textSize="8sp" android:textColor="@color/widget_gold_light" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_family_schedule_sub" android:textSize="8sp" android:textColor="@color/widget_muted" />
        </LinearLayout>

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_error_outline"
            android:alpha="0.5"
            android:contentDescription="@null" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="@string/widget_family_event_1_time" android:textColor="@color/widget_muted" android:textSize="8sp"/>
            <FrameLayout android:layout_width="4dp" android:layout_height="4dp" android:layout_marginHorizontal="8dp" android:layout_gravity="center_vertical" android:background="@color/widget_yellow"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/widget_family_event_1" android:textColor="@color/widget_text" android:textSize="8sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="@string/widget_family_event_2_time" android:textColor="@color/widget_muted" android:textSize="8sp"/>
            <FrameLayout android:layout_width="4dp" android:layout_height="4dp" android:layout_marginHorizontal="8dp" android:layout_gravity="center_vertical" android:background="@color/widget_yellow"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/widget_family_event_2" android:textColor="@color/widget_text" android:textSize="8sp" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="@string/widget_family_event_3_time" android:textColor="@color/widget_muted" android:textSize="8sp"/>
            <FrameLayout android:layout_width="4dp" android:layout_height="4dp" android:layout_marginHorizontal="8dp" android:layout_gravity="center_vertical" android:background="@color/widget_yellow"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/widget_family_event_3" android:textColor="@color/widget_text" android:textSize="8sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/widget_family_btn_log"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:text="@string/widget_family_btn_log"
            android:textColor="@color/widget_teal"
            android:textSize="8sp" />
        <TextView
            android:id="@+id/widget_family_btn_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:text="@string/widget_family_btn_message"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
        <TextView
            android:id="@+id/widget_family_btn_memories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_pill_category"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:text="@string/widget_family_btn_memories"
            android:textColor="@color/widget_yellow"
            android:textSize="8sp" />
    </LinearLayout>

</LinearLayout>
