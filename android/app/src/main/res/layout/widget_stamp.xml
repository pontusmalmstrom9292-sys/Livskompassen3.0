<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_stamp_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_chip"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="10dp">

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/widget_stamp_title"
        android:scaleType="fitCenter"
        android:src="@drawable/widget_chip_stampla" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_stamp_in"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill"
            android:gravity="center"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="@string/widget_stamp_in"
            android:textColor="@color/widget_gold"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_stamp_out"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/widget_bg_stamp_pill_muted"
            android:gravity="center"
            android:minHeight="48dp"
            android:paddingVertical="8dp"
            android:text="@string/widget_stamp_out"
            android:textColor="@color/widget_muted"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
