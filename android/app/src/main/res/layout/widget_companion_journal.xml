<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Journal Small — quote + SKRIV (rich multi-PI) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_journal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/widget_companion_journal_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:letterSpacing="0.12"
        android:maxLines="1"
        android:text="@string/widget_companion_journal_title"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_companion_journal_quote"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/widget_bg_inset_well"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="3"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:text="@string/widget_companion_journal_quote"
        android:textColor="@color/widget_text"
        android:textSize="12sp"
        android:textStyle="italic" />

    <TextView
        android:id="@+id/widget_companion_journal_attr"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="end"
        android:text="@string/widget_companion_journal_attr"
        android:textColor="@color/widget_muted"
        android:textSize="9sp" />

    <TextView
        android:id="@+id/widget_companion_journal_write"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_stamp_pill"
        android:contentDescription="@string/widget_companion_journal_write"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:minHeight="48dp"
        android:paddingVertical="10dp"
        android:text="@string/widget_companion_journal_write"
        android:textAllCaps="true"
        android:textColor="@color/widget_background"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
