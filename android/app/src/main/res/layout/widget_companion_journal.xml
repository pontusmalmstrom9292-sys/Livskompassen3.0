<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Journal Small — quote + SKRIV (rich multi-PI) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_journal_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/widget_ic_companion_journal"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_companion_journal_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.18"
            android:text="@string/widget_journal_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_journal_hint"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:background="@drawable/widget_bg_inset_well">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="“"
                android:textColor="@color/widget_gold_dim"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_gravity="start"/>

            <TextView
                android:id="@+id/widget_companion_journal_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-16dp"
                android:gravity="center"
                android:text="Att förstå sig själv är början på all förändring."
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="italic" />

            <TextView
                android:id="@+id/widget_companion_journal_attr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="– Okänd"
                android:textColor="@color/widget_gold_dim"
                android:textSize="9sp" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/widget_companion_journal_write"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/widget_bg_cta_outline"
        android:gravity="center"
        android:minHeight="56dp"
        android:text="@string/widget_btn_write"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold_light"
        android:textSize="10sp"
        android:textStyle="bold" />
</LinearLayout>
