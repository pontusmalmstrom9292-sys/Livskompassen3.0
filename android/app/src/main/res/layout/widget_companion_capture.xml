<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Capture — multi-intent: mic = autostart, recent = focus open -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_capture_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/widget_companion_capture_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:maxLines="1"
        android:text="@string/widget_companion_capture_title"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_companion_capture_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:text="@string/widget_companion_capture_sub"
        android:textColor="@color/widget_muted"
        android:textSize="10sp" />

    <FrameLayout
        android:id="@+id/widget_companion_capture_mic"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/widget_bg_icon_ring"
        android:contentDescription="@string/widget_companion_capture_mic_cd"
        android:padding="14dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_ic_companion_mic" />
    </FrameLayout>

    <TextView
        android:id="@+id/widget_companion_capture_recent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_stamp_pill_muted"
        android:contentDescription="@string/widget_companion_capture_recent"
        android:gravity="center"
        android:minHeight="40dp"
        android:paddingVertical="6dp"
        android:text="@string/widget_companion_capture_recent"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />
</LinearLayout>
