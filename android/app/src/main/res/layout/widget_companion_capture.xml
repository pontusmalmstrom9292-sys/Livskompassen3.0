<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Capture XS (1 plats / 2×2) — mic-first, Kap 6 trust kompakt -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_capture_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_ic_lock_gold" />

        <TextView
            android:id="@+id/widget_companion_capture_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:ellipsize="end"
            android:letterSpacing="0.14"
            android:maxLines="1"
            android:text="@string/widget_companion_capture_title"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Sub used as dynamic status (recording) — compact -->
    <TextView
        android:id="@+id/widget_companion_capture_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/widget_companion_capture_sub"
        android:textColor="@color/widget_muted"
        android:textSize="8sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_companion_capture_wave_l"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_waveform_ethereal" />

        <FrameLayout
            android:id="@+id/widget_companion_capture_mic"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:contentDescription="@string/widget_companion_capture_mic_cd"
            android:minWidth="56dp"
            android:minHeight="56dp"
            android:padding="4dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_bg_mic_inset"
                android:padding="10dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/widget_ic_companion_mic" />
            </FrameLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/widget_companion_capture_wave_r"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:scaleX="-1"
            android:src="@drawable/widget_waveform_ethereal" />
    </LinearLayout>

    <!-- Keep id for WIS PendingIntent; compact status chip -->
    <TextView
        android:id="@+id/widget_companion_capture_recent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:contentDescription="@string/widget_companion_capture_recent"
        android:gravity="center"
        android:letterSpacing="0.06"
        android:maxLines="1"
        android:minHeight="20dp"
        android:text="@string/widget_companion_capture_recent"
        android:textAllCaps="true"
        android:textColor="@color/widget_muted"
        android:textSize="8sp" />

    <!-- Kap 6.4 trust — en rad i XS -->
    <LinearLayout
        android:id="@+id/widget_companion_capture_trust"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center"
            android:letterSpacing="0.04"
            android:maxLines="1"
            android:text="@string/widget_companion_capture_trust"
            android:textAllCaps="true"
            android:textColor="@color/widget_muted"
            android:textSize="6sp" />
    </LinearLayout>
</LinearLayout>
