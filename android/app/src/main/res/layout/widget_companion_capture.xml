<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Capture XS — Kap 6 guldstjärna: mic inset · ethereal wave · trust -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_capture_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_ic_lock_gold" />

        <TextView
            android:id="@+id/widget_companion_capture_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:letterSpacing="0.22"
            android:text="@string/widget_capture_header"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold_light"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_companion_capture_sub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="@string/widget_capture_hint"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_companion_capture_wave_l"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:alpha="0.8"
            android:contentDescription="@null"
            android:src="@drawable/widget_waveform_ethereal" />

        <FrameLayout
            android:id="@+id/widget_companion_capture_mic"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:contentDescription="@string/widget_capture_header"
            android:minWidth="56dp"
            android:minHeight="56dp"
            android:padding="7dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_bg_mic_inset"
                android:padding="14dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.95"
                    android:contentDescription="@null"
                    android:src="@drawable/widget_ic_companion_mic" />
            </FrameLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/widget_companion_capture_wave_r"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:alpha="0.8"
            android:contentDescription="@null"
            android:scaleX="-1"
            android:src="@drawable/widget_waveform_ethereal" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_capture_recent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/widget_capture_footer"
        android:textColor="@color/widget_muted"
        android:textSize="8sp" />

    <LinearLayout
        android:id="@+id/widget_companion_capture_trust"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@drawable/widget_ic_shield_tiny" android:alpha="0.7" android:contentDescription="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_companion_capture_trust_e2e" android:textSize="7sp" android:textColor="@color/widget_gold_dim" android:gravity="center" android:textAllCaps="true"/>
        </LinearLayout>

        <!-- ImageView spacer — bare View is illegal in RemoteViews (lint RemoteViewLayout) -->
        <ImageView android:layout_width="20dp" android:layout_height="1dp" android:contentDescription="@null" android:importantForAccessibility="no"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@drawable/widget_ic_lock_gold" android:alpha="0.7" android:contentDescription="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_companion_capture_trust_private" android:textSize="7sp" android:textColor="@color/widget_gold_dim" android:gravity="center" android:textAllCaps="true"/>
        </LinearLayout>

        <ImageView android:layout_width="20dp" android:layout_height="1dp" android:contentDescription="@null" android:importantForAccessibility="no"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@drawable/widget_ic_shield_tiny" android:alpha="0.7" android:contentDescription="@null"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/widget_companion_capture_trust_you" android:textSize="7sp" android:textColor="@color/widget_gold_dim" android:gravity="center" android:textAllCaps="true"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
