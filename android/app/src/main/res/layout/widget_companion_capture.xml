<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Capture — Kap 6 Gold: waveform · guldring · trust-rad · ≥56dp mic -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_capture_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_ic_lock_gold" />

        <TextView
            android:id="@+id/widget_companion_capture_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:letterSpacing="0.12"
            android:maxLines="1"
            android:text="@string/widget_companion_capture_title"
            android:textAllCaps="true"
            android:textColor="@color/widget_gold"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_capture_sub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="@string/widget_companion_capture_sub"
        android:textColor="@color/widget_muted"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_companion_capture_wave_l"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_waveform_ethereal" />

        <FrameLayout
            android:id="@+id/widget_companion_capture_mic"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginHorizontal="6dp"
            android:background="@drawable/widget_bg_gold_ring"
            android:contentDescription="@string/widget_companion_capture_mic_cd"
            android:minWidth="56dp"
            android:minHeight="56dp"
            android:padding="5dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/widget_bg_mic_inset"
                android:padding="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/widget_ic_companion_mic" />
            </FrameLayout>
        </FrameLayout>

        <ImageView
            android:id="@+id/widget_companion_capture_wave_r"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:scaleType="fitCenter"
            android:scaleX="-1"
            android:src="@drawable/widget_waveform_ethereal" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_companion_capture_recent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/widget_bg_stamp_pill_muted"
        android:contentDescription="@string/widget_companion_capture_recent"
        android:gravity="center"
        android:minHeight="40dp"
        android:paddingVertical="6dp"
        android:text="@string/widget_companion_capture_recent"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />

    <!-- Trust-rad — Kap 6 Capture signature -->
    <LinearLayout
        android:id="@+id/widget_companion_capture_trust"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:contentDescription="@null"
            android:src="@drawable/widget_ic_shield_tiny" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_companion_capture_trust"
            android:textColor="@color/widget_muted"
            android:textSize="8sp" />
    </LinearLayout>
</LinearLayout>
