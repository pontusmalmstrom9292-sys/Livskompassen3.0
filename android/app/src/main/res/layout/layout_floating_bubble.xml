<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/bubble_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/widget_bg_icon_ring"
        android:padding="12dp"
        android:contentDescription="Livskompassen Bubbla"
        android:src="@drawable/widget_ic_wh8_moduler" />

    <ImageView
        android:id="@+id/close_bubble"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_gravity="top|end"
        android:background="@drawable/widget_bg_icon_ring"
        android:padding="4dp"
        android:contentDescription="Stäng"
        android:src="@drawable/ic_error_outline"
        app:tint="@color/widget_gold" />
</FrameLayout>
