<?xml version="1.0" encoding="utf-8"?>
<!-- Companion Child Medium — dagens fråga + Svara (§12 Barnfokus additiv) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_companion_child_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_premium_panel"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/widget_companion_child_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:gravity="center"
        android:letterSpacing="0.16"
        android:maxLines="1"
        android:text="@string/widget_companion_child_title"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_companion_child_question"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@drawable/widget_bg_inset_well"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="4"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:text="@string/widget_companion_child_question"
        android:textColor="@color/widget_text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/widget_companion_child_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_bg_cta_outline"
        android:contentDescription="@string/widget_companion_child_answer"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:minHeight="56dp"
        android:paddingVertical="10dp"
        android:text="@string/widget_companion_child_answer"
        android:textAllCaps="true"
        android:textColor="@color/widget_gold"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
