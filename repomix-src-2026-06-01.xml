function ThemeLabCard({
  pack,
  active,
  applied,
  draft,
  onPreview,
  onApply,
  applyLabel,
  extra,
}: {
  pack: ThemePack;
  active: boolean;
  applied: boolean;
  draft?: boolean;
  onPreview: () => void;
  onApply: () => void;
  applyLabel?: string;
  extra?: ReactNode;
}) {
