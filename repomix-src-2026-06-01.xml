          open.map((item) => (
            <li key={item.id} className="planering-quicklist__row">
              <button
                type="button"
                className="planering-quicklist__check"
                aria-label={`Klar: ${item.text}`}
                onClick={() => {
                  setList(toggleQuickListItem(pin.listId, item.id));
