    background: color-mix(in srgb, var(--accent) 18%, rgba(8, 10, 16, 0.9));
  }

  .mabra-low-energy-toggle__thumb {
    @apply absolute left-0.5 top-0.5 h-5 w-5 rounded-full bg-text-dim transition-transform;
  }

  .mabra-low-energy-toggle__switch[aria-checked='true'] .mabra-low-energy-toggle__thumb {
    transform: translateX(1.25rem);
    background: var(--accent-light);
  }

  .mabra-complete-strip {
    @apply flex gap-2 overflow-x-auto pb-1 pt-2;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    mask-image: linear-gradient(90deg, #000 92%, transparent 100%);
  }

  .mabra-complete-strip__chip {
    @apply relative shrink-0 rounded-full border border-border-strong px-4 py-2 text-sm text-accent-light transition-colors;
    background: rgba(12, 16, 20, 0.55);
    touch-action: manipulation;
  }

  .mabra-complete-strip__chip:hover {
    border-color: color-mix(in srgb, var(--accent-light) 45%, transparent);
    background: rgba(18, 22, 28, 0.65);
  }

  .mabra-feel-grid {
    @apply grid grid-cols-4 gap-1.5 sm:grid-cols-5;
  }

  .mabra-feel-card {
    @apply flex flex-col items-center justify-center gap-0.5 rounded-xl border border-border-strong/80 py-2 transition-colors;
    background: rgba(12, 16, 20, 0.5);
  }

  .mabra-feel-card--active {
    @apply border-accent/45 bg-accent/10;
  }

  .mabra-feel-card__emoji {
    @apply text-lg leading-none;
  }

  .mabra-feel-card__label {
    @apply text-[9px] font-medium text-text-muted;
  }

  .mabra-feel-card--active .mabra-feel-card__label {
    @apply text-accent;
  }

  .biff-triage-bait {
    @apply rounded-lg border border-border-strong bg-surface/80 px-3 py-2 text-sm text-text-dim select-none;
    filter: blur(4px);
    user-select: none;
    pointer-events: none;
  }

  .biff-triage-bait--revealed {
    @apply rounded-lg border border-danger/20 bg-danger/5 px-3 py-2 text-sm text-text-muted;
    filter: none;
    user-select: text;
    pointer-events: auto;
  }

  .biff-triage-fact {
    @apply rounded-lg border border-success/25 bg-success/5 px-3 py-2 text-sm text-text-muted;
  }
}
