    @apply pr-1 text-[11px] font-medium text-accent/95;
  }

  @keyframes nav-drawer-in {
    from {
      transform: translateX(-100%);
      opacity: 0.6;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .nav-drawer__backdrop {
    @apply fixed inset-0 z-[200] cursor-pointer border-0 bg-black/50 backdrop-blur-[3px];
    pointer-events: auto;
  }

  .nav-drawer {
    @apply fixed inset-y-0 left-0 z-[201] flex w-[68vw] max-w-[22rem] flex-col overflow-hidden border-r pt-[env(safe-area-inset-top)];
    pointer-events: auto;
    touch-action: manipulation;
    border-color: color-mix(in srgb, var(--accent) 22%, transparent);
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    box-shadow: 20px 0 56px rgba(0, 0, 0, 0.65);
    animation: nav-drawer-in 0.26s ease-out;
  }

  .nav-drawer__scenic {
    @apply pointer-events-none absolute inset-0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-dusk) 92%, transparent) 0%,
        color-mix(in srgb, var(--bg) 75%, transparent) 42%,
        color-mix(in srgb, var(--bg) 55%, transparent) 100%
      ),
      url('/design/home-hero-scenic.png') center bottom / cover no-repeat;
    filter: blur(0);
  }

  .nav-drawer__scenic::after {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--bg) 58%, transparent);
    backdrop-filter: blur(5px);
    pointer-events: none;
  }

  .nav-drawer__header,
  .nav-drawer__list {
    position: relative;
    z-index: 1;
  }

  .nav-drawer__header {
    @apply relative px-5 pb-5 pt-6;
  }

  .nav-drawer__close {
    @apply absolute left-4 top-5 z-20 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-accent transition-colors;
    border: none;
    background: transparent;
    pointer-events: auto;
    touch-action: manipulation;
  }

  .nav-drawer__close:hover {
    color: var(--accent-light);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .nav-drawer__brand {
    @apply mt-10 flex flex-col items-center gap-2.5;
  }

  .nav-drawer__mark {
    @apply h-11 w-11 text-accent;
    filter: drop-shadow(0 0 12px color-mix(in srgb, var(--accent) 35%, transparent));
  }

  .nav-drawer__title {
    font-family: 'Cinzel', 'Outfit', serif;
    @apply text-sm font-semibold uppercase tracking-[0.32em] text-accent;
    text-shadow: 0 1px 12px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .nav-drawer__ornament {
    @apply mt-1 flex items-center gap-1.5;
  }

  .nav-drawer__ornament span {
    @apply block h-1.5 w-1.5 rounded-sm;
    background: color-mix(in srgb, var(--accent) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 75%, transparent);
  }

  .nav-drawer__ornament span:nth-child(2) {
    @apply h-2 w-2;
    background: color-mix(in srgb, var(--accent) 75%, transparent);
  }

  .nav-drawer__quick {
    @apply relative z-10 border-b px-4 pb-4 pt-1;
    border-color: color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .nav-drawer__quick-eyebrow {
    @apply mb-2.5 text-center text-[10px] font-medium uppercase tracking-[0.28em] text-text-dim;
  }

  .nav-drawer__quick-grid {
    @apply grid grid-cols-2 gap-2;
  }

  .nav-drawer__quick-chip {
    @apply flex cursor-pointer items-center gap-2 rounded-xl border-0 px-2.5 py-2 text-left transition-colors;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);
    background: rgba(10, 10, 10, 0.55);
    color: var(--text);
    touch-action: manipulation;
  }

  .nav-drawer__quick-chip:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--accent) 42%, transparent);
  }

  .nav-drawer__quick-chip-icon {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-accent;
    border: 1px solid color-mix(in srgb, var(--accent) 38%, transparent);
    background: rgba(10, 10, 10, 0.65);
  }

  .nav-drawer__quick-chip-label {
    @apply text-xs font-medium text-accent/95;
  }

  .nav-drawer__mode {
    @apply relative z-10 mx-4 mb-3 flex rounded-xl border p-0.5;
    border-color: color-mix(in srgb, var(--accent) 28%, transparent);
    background: rgba(10, 10, 10, 0.55);
  }

  .nav-drawer__mode-btn {
    @apply flex-1 cursor-pointer rounded-[0.65rem] border-0 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] transition-colors;
    color: var(--text-muted);
    background: transparent;
    touch-action: manipulation;
  }

  .nav-drawer__mode-btn--active {
    color: var(--accent-light);
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 35%, transparent);
  }

  .nav-drawer__mode-btn--solo {
    @apply w-full flex-none;
  }

  .nav-drawer__sections {
    @apply flex flex-1 flex-col gap-1 overflow-y-auto pb-2;
  }

  .nav-drawer__quick {
    @apply shrink-0 border-t border-white/10 px-4 py-3;
  }

  .nav-drawer__quick-title {
    @apply mb-2 text-[10px] font-semibold uppercase tracking-[0.22em] text-accent/85;
  }

  .nav-drawer__quick-grid {
    @apply grid grid-cols-2 gap-2;
  }

  .nav-drawer__quick-btn {
    @apply flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-3 py-2.5 text-left transition-colors hover:border-accent/30 hover:bg-accent/10;
    touch-action: manipulation;
  }

  .nav-drawer__quick-icon {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-accent/30 bg-bg/50;
  }

  .nav-drawer__quick-label {
    @apply text-xs font-medium text-text;
  }

  .nav-drawer__quick-hint {
    @apply mt-3 text-[10px] leading-relaxed text-text-dim;
  }

  .nav-drawer__footer {
    @apply shrink-0 border-t border-white/10 px-4 py-3;
  }

  .nav-drawer__account-btn {
    @apply flex w-full cursor-pointer items-center justify-center gap-2 rounded-xl border border-accent/35 bg-accent/10 px-4 py-3 text-sm font-medium text-accent transition-colors hover:bg-accent/15;
    touch-action: manipulation;
  }

  .nav-drawer__hub-children {
    @apply flex flex-col gap-0.5;
  }

  .nav-drawer__hub-hint {
    @apply px-3 pb-1 pt-0.5 text-[0.68rem] leading-snug text-text-dim;
  }

  .nav-drawer__row-wrap--sub {
    @apply pl-1;
  }

  .nav-drawer__row--group .nav-drawer__row-label {
    @apply font-semibold uppercase tracking-[0.12em] text-accent/90;
  }

  .nav-drawer__row-expand {
    @apply flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-lg text-accent/60 transition-colors;
    touch-action: manipulation;
  }

  .nav-drawer__row-expand:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .nav-drawer__section {
    @apply flex flex-col;
  }

  .nav-drawer__section-title {
    @apply px-5 pb-1 pt-3 text-[10px] font-semibold uppercase tracking-[0.35em] text-accent/70;
  }

  .nav-drawer__category-title {
    @apply px-5 pb-0.5 pt-4 text-[9px] font-medium uppercase tracking-[0.28em] text-text-muted/80;
  }

  .nav-drawer__category:first-child .nav-drawer__category-title {
    @apply pt-2;
  }

  .nav-drawer__list {
    @apply flex flex-col gap-0.5 overflow-visible px-3 pb-2;
  }

  .nav-drawer__row--sub {
    @apply pl-4;
  }

  .nav-drawer__row--sub .nav-drawer__row-icon {
    @apply h-9 w-9;
  }

  .nav-drawer__row--sub .nav-drawer__row-label {
    @apply text-sm text-text-muted;
  }

  .nav-drawer__row {
    @apply relative z-10 flex min-h-[44px] w-full cursor-pointer items-center gap-3 rounded-xl border-0 px-2 py-2.5 text-left transition-colors;
    background: transparent;
    color: var(--text);
    pointer-events: auto;
    touch-action: manipulation;
    -webkit-tap-highlight-color: color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .nav-drawer__row:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .nav-drawer__row--active {
    background: linear-gradient(
      90deg,
      color-mix(in srgb, #d4af37 24%, transparent) 0%,
      color-mix(in srgb, #d4af37 6%, transparent) 72%,
      transparent 100%
    );
    box-shadow: inset 4px 0 0 #d4af37;
  }

  .nav-drawer__row--active .nav-drawer__row-label {
    color: var(--accent-light);
  }

  .nav-drawer__row-icon {
    @apply flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-accent;
    border: 1.5px solid color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .nav-drawer__row-icon .chrome-v4-icon {
    @apply h-9 w-9;
  }

  .nav-drawer__row-icon .drawer-l2-icon {
    @apply h-9 w-9;
  }

  .nav-drawer__row--active .nav-drawer__row-icon {
    border-color: color-mix(in srgb, var(--accent) 70%, transparent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
    box-shadow: 0 0 18px color-mix(in srgb, var(--accent) 22%, transparent);
  }

  .nav-drawer__row-label {
    @apply flex-1 text-[15px] font-medium tracking-wide;
  }

  .nav-drawer__row-badge {
    @apply flex h-5 min-w-5 shrink-0 items-center justify-center rounded-full px-1.5 text-[10px] font-semibold tabular-nums;
    background: color-mix(in srgb, #d4af37 28%, transparent);
    color: var(--accent-light);
    border: 1px solid color-mix(in srgb, #d4af37 45%, transparent);
  }

  .nav-drawer__row-chevron {
    @apply h-4 w-4 shrink-0 text-accent/50;
  }

  .nav-drawer__row--active .nav-drawer__row-chevron {
    @apply text-accent opacity-90;
  }

  /* Konto / inlogg — portal till body (inte klippt i header) */
  body.account-auth-open {
    overflow: hidden;
  }

  .account-auth-backdrop {
    @apply fixed inset-0 z-[230] cursor-pointer border-0 bg-black/50 backdrop-blur-[2px];
    pointer-events: auto;
  }

  .account-auth-dialog {
    @apply fixed left-4 right-4 top-1/2 z-[231] mx-auto max-w-sm -translate-y-1/2;
    pointer-events: auto;
  }

  .app-unlock-gate {
    @apply fixed inset-0 z-[225] flex items-center justify-center bg-black/40 px-6;
    pointer-events: auto;
  }

  .app-unlock-gate__card {
    @apply w-full max-w-sm rounded-[2rem] border border-border p-6;
  }

  /* Block underliggande widget/dock när menyn är öppen */
  body.nav-drawer-open .fyren-smart-bar,
  body.nav-drawer-open .fyren-home-rail,
  body.nav-drawer-open .fyren-header-strip,
  body.nav-drawer-open .dock-nav--hub,
  body.nav-drawer-open .dock-classic {
    pointer-events: none;
  }

  .projekt-picker-sheet {
    @apply fixed inset-0 z-[60] flex items-end justify-center;
  }

  .projekt-picker-sheet__backdrop {
    @apply absolute inset-0 bg-black/55;
  }

  .projekt-picker-sheet__panel {
    @apply relative z-10 w-full max-w-2xl rounded-t-[2rem] border border-white/10 p-4 pb-8;
    background: linear-gradient(168deg, rgba(42, 34, 22, 0.98), rgba(6, 8, 18, 0.95));
  }

  body.nav-drawer-open .dock-hub-band {
    pointer-events: none !important;
  }

  /* Hem — höger widget-rail (I-stone mockup) */
  .fyren-home-rail {
    @apply pointer-events-auto fixed right-0 z-[45] flex flex-col gap-0.5 rounded-l-2xl border border-r-0 py-2 pl-1 pr-1;
    top: calc(4.75rem + env(safe-area-inset-top, 0px));
    bottom: calc(3.75rem + env(safe-area-inset-bottom, 0px));
    max-height: min(72vh, 520px);
    overflow-y: auto;
    border-color: rgba(212, 175, 55, 0.35);
    background: rgba(10, 10, 10, 0.72);
    backdrop-filter: blur(14px);
    box-shadow: -8px 0 32px rgba(0, 0, 0, 0.45);
  }

  .fyren-home-rail__row {
    @apply flex cursor-pointer flex-col items-center gap-1 rounded-xl border-0 px-2 py-2.5 text-center transition-colors;
    background: transparent;
    color: var(--text);
    touch-action: manipulation;
    min-width: 4.25rem;
  }

  .fyren-home-rail__row:hover {
    background: rgba(212, 175, 55, 0.1);
  }

  .fyren-home-rail__icon {
    @apply flex h-11 w-11 items-center justify-center rounded-full text-accent;
    border: 1.5px solid rgba(212, 175, 55, 0.45);
    background: rgba(10, 10, 10, 0.65);
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.12);
  }

  .fyren-home-rail__label {
    @apply max-w-[4.5rem] text-[9px] font-medium leading-tight text-accent/90;
  }

  .home-hero-kanon__bridge {
