@import './styles/design-packs.css';

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer utilities {
  .font-display-serif {
    font-family: 'Cinzel', 'Outfit', serif;
  }
}

:root {
  /* Theme Pack I — default stone (overridden by applyTheme at runtime) */
  --bg-teal-deep: #0a1614;
  --bg-dusk: #12151f;
  --compass-disk: #0d3b3b;
  --text-gold: #d4af37;
  --text-gold-dim: #9a7b2f;
  --accent-ember: #f59e0b;

  --bg: var(--bg-teal-deep);
  --surface: #0f1a18;
  --surface-2: #142220;
  --surface-3: #1a2b28;
  --text: #f5f0e8;
  --text-muted: #c4bdb4;
  --text-dim: #a8a29e;
  --accent: var(--text-gold);
  --accent-secondary: var(--accent-ember);
  --accent-light: #e8d48a;
  --accent-glow: rgba(212, 175, 55, 0.18);
  --success: #6b8f71;
  --glass: rgba(6, 8, 8, 0.9);
  --glass-hero: rgba(4, 4, 4, 0.94);
  --border: rgba(212, 175, 55, 0.12);
  --border-strong: rgba(212, 175, 55, 0.25);
  --warning: #b45309;
  --danger: #dc2626;

  /* Utrymme under scrollbart innehåll — dock-rail + banner + safe area + marginal */
  --app-dock-clearance: calc(8.5rem + env(safe-area-inset-bottom, 0px) + 1.5rem);
}

@layer base {
  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: 'Outfit', sans-serif;
  }

  .tabular-nums {
    font-variant-numeric: tabular-nums;
  }

  /* Theme Pack E — prod default */
  html[data-theme='E-skymning-prod'] {
    --bg: #0a1614;
    --bg-dusk: #12151f;
    --compass-disk: #0d3b3b;
    --accent: #d4af37;
    --border-strong: rgba(212, 175, 55, 0.38);
  }

  /* Theme Pack I — CSS fallbacks (runtime: applyTheme + themeRegistry.ts) */
  html[data-theme='I-stone'],
  html[data-theme^='I-stone-draft'] {
    --bg: #0a0a0a;
    --accent: #d4af37;
    --border-strong: rgba(212, 175, 55, 0.45);
  }

  html[data-theme='I-stone-draft-twilight'] {
    --bg: #060a10;
    --accent: #c9a227;
    --border-strong: rgba(201, 162, 39, 0.38);
  }

  html[data-theme='I-stone-draft-bronze'] {
    --accent: #c9a66b;
    --border-strong: rgba(201, 166, 107, 0.48);
  }

  html[data-theme='I-alchemical'] {
    --bg: #050505;
    --accent: #e8c547;
    --border-strong: rgba(232, 197, 71, 0.5);
  }

  html[data-theme='I-skymning'] {
    --bg: #0a1614;
    --accent: #4fd1c5;
    --border-strong: rgba(79, 209, 197, 0.28);
  }

  html[data-theme='I-hamn'] {
    --bg: #2c2f33;
    --accent: #d4af37;
    --border-strong: rgba(212, 175, 55, 0.35);
  }

  html[data-theme='I-glass'] {
    --bg: #0a0a0a;
    --accent: #d4af37;
    --glass: rgba(8, 6, 4, 0.9);
    --border-strong: rgba(212, 175, 55, 0.55);
  }
}

@layer components {
  .ambient-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: radial-gradient(ellipse 120% 80% at 50% -20%, var(--bg-dusk) 0%, var(--bg-teal-deep) 55%);
  }

  .ambient-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .ambient-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }

  .ambient-blob--gold {
    background: rgba(212, 175, 55, 0.12);
  }

  .ambient-blob--indigo {
    background: rgba(13, 59, 59, 0.35);
  }

  .ambient-blob--accent-secondary {
    background: color-mix(in srgb, var(--accent-secondary) 28%, transparent);
