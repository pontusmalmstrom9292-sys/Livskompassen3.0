  .fyren-header-strip__chip {
    @apply flex shrink-0 cursor-pointer items-center gap-2 rounded-full border-0 px-3 py-2 text-left transition-colors;
    border: 1px solid color-mix(in srgb, var(--accent) 32%, transparent);
    background: rgba(10, 10, 10, 0.72);
    color: var(--text);
    touch-action: manipulation;
  }

  .fyren-header-strip__chip:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--accent) 48%, transparent);
  }

  .fyren-header-strip__icon {
    @apply flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-accent;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    background: rgba(10, 10, 10, 0.65);
