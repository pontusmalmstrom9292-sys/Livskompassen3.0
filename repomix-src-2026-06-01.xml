    touch-action: manipulation;
    border-radius: 0.9rem;
    border: 1.5px solid color-mix(in srgb, var(--accent) 42%, transparent);
    background: linear-gradient(
      168deg,
      rgba(58, 48, 32, 0.99) 0%,
      rgba(26, 20, 14, 0.97) 46%,
      rgba(8, 10, 16, 0.95) 100%
    );
    box-shadow:
      0 6px 16px rgba(0, 0, 0, 0.52),
      0 0 0 1px rgba(0, 0, 0, 0.28),
      0 1px 0 rgba(255, 243, 210, 0.18) inset,
      0 -4px 11px rgba(0, 0, 0, 0.4) inset;
    transform: translateY(-2px);
    transition:
      transform 0.16s ease,
      box-shadow 0.16s ease,
      border-color 0.16s ease;
