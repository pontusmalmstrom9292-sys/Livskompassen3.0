function presetSides(presetId: LifeHubPresetId): { left: DockSideLink; right: DockSideLink } {
  switch (presetId) {
    case 'foralder_trygg':
      return {
        left: { to: '/familjen', label: 'Familjen', icon: 'users' },
        right: { to: '/hamn', label: 'Hamn', icon: 'anchor' },
      };
    case 'rehab_lag':
