  try {
    localStorage.setItem(KEY, JSON.stringify(pin));
  } catch {
    /* ignore */
  }
}

export function clearPlaneringHomePin(): void {
  try {
    localStorage.removeItem(KEY);
  } catch {
    /* ignore */
  }
}
