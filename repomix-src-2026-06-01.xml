      />
      <circle cx={cx} cy={cy} r={3.2} fill="#080808" stroke={tokens.gold} strokeWidth={1.1} />
      <circle cx={cx} cy={cy - 16} r={1.6} fill={tokens.gold} opacity={0.92} />
    </svg>
