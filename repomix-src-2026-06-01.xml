export const MAX_CORE_VALUES = 5;

export const ACT_VALUES = [
  { id: 'narmhet', label: 'Närhet' },
  { id: 'omsorg', label: 'Omsorg' },
  { id: 'arlighet', label: 'Ärlighet' },
  { id: 'mod', label: 'Mod' },
