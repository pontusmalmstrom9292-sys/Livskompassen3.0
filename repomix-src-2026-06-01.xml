    id: 'low-breath-1',
    title: 'Andning 1 min',
    lead: '4-7-8 — låg tröskel',
    emoji: '🌬',
    category: 'akut',
    action: { type: 'breathing', variant: 'panic_rsd', minutes: 1 },
  },
