  | 'hamn_hub_hint';

export type LifeHubPreset = {
  id: LifeHubPresetId;
  label: string;
  lead: string;
  materials: Record<LifeHubMaterialKey, boolean>;
};

const ALL_TRUE: Record<LifeHubMaterialKey, boolean> = {
