  .dock-hub-fan--orbit {
    @apply relative;
    grid-template-columns: 2.35rem 3.65rem 2.35rem;
    grid-template-rows: 2.35rem 3.65rem 2.35rem;
    gap: 0.12rem;
    z-index: 1;
