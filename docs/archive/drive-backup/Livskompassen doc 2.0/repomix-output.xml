<file path="firestore.rules">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Hjälpfunktion för att verifiera ägarskap
    function isOwner(data) {
      return request.auth != null && data.ownerId == request.auth.uid;
    }

    // Grundläggande WORM (Write Once Read Many) Protokoll
    // Tillåter skapande men blockerar uppdatering och radering för alla dokument
    match /{document=**} {
      allow read: if isOwner(resource.data);
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    // Specifika regler för "Kunskapsvalvet" (Vault)
    match /vault/{docId} {
      allow read: if isOwner(resource.data);
      allow create: if request.auth != null 
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.createdAt == serverTimestamp();
      allow update, delete: if false;
    }

    // Stenhårt WORM-protokoll för "Reality Vault" (Det Digitala Pansaret)
    match /reality_vault/{docId} {
      allow read: if isOwner(resource.data);
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
