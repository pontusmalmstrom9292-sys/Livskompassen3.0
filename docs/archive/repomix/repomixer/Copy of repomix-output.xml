<file path="livskompassen-trasig-1/src/components/VaultEntities.tsx">
import React, { useState } from 'react';
import { motion } from 'motion/react';
import { Plus, Trash2, Edit3, User, Box, MapPin, Tag, ChevronDown, ChevronUp } from 'lucide-react';
import { useSystemMemory, MemoryEntity } from '../contexts/SystemMemoryContext';

export function VaultEntities() {
  const { entities, addEntity, removeEntity } = useSystemMemory();
  const [isAdding, setIsAdding] = useState(false);
  const [expandedId, setExpandedId] = useState<string | null>(null);

  const [formData, setFormData] = useState({
    name: '',
    type: 'PERSON' as MemoryEntity['type'],
    patterns: '',
    subcategories: ''
  });

  const handleAdd = async () => {
    if (!formData.name) return;
    await addEntity({
      name: formData.name,
      type: formData.type,
      patterns: formData.patterns,
      subcategories: formData.subcategories.split(',').map(s => s.trim()).filter(Boolean)
    });
    setFormData({ name: '', type: 'PERSON', patterns: '', subcategories: '' });
    setIsAdding(false);
  };

  const getIcon = (type: string) => {
    switch(type) {
      case 'PERSON': return <User className="w-5 h-5 text-indigo-400" />;
      case 'OBJECT': return <Box className="w-5 h-5 text-teal-400" />;
      case 'PLACE': return <MapPin className="w-5 h-5 text-blue-400" />;
      default: return <Tag className="w-5 h-5 text-slate-400" />;
    }
  };

  return (
    <div className="space-y-8 animate-in fade-in duration-500">
      <div className="flex justify-between items-end border-b border-white/5 pb-4">
        <div>
          <h2 className="text-2xl font-outfit text-slate-100">Målpersoner & Objekt</h2>
          <p className="text-sm text-slate-500 max-w-lg mt-1">
            Här har du full kontroll över Systemminnet. Definiera de personer och objekt som AI:n ska bevaka. 
            När du laddar upp bevis i framtiden kommer de automatiskt att kategoriseras under dessa rubriker.
          </p>
        </div>
        <button 
          onClick={() => setIsAdding(!isAdding)}
          className="flex items-center gap-2 px-4 py-2 bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-300 rounded-full text-xs font-bold uppercase tracking-widest transition-all border border-indigo-500/30"
        >
          <Plus className="w-4 h-4" /> Ny Entitet
        </button>
      </div>

      {isAdding && (
        <motion.div 
          initial={{ opacity: 0, y: -10 }} 
          animate={{ opacity: 1, y: 0 }}
          className="bg-[#0a0a12]/80 border border-indigo-500/30 rounded-3xl p-6 shadow-2xl backdrop-blur-md"
        >
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div>
              <label className="text-[10px] uppercase font-bold tracking-widest text-slate-500 mb-2 block">Namn / Benämning</label>
              <input 
                type="text" 
                value={formData.name}
                onChange={e => setFormData({...formData, name: e.target.value})}
                placeholder="T.ex. Mamma, Ex-fru, Gosedjuret Björnen" 
                className="w-full bg-[#05050a] border border-white/10 rounded-xl p-3 text-sm text-slate-200 outline-none focus:border-indigo-500/50"
              />
            </div>
            <div>
              <label className="text-[10px] uppercase font-bold tracking-widest text-slate-500 mb-2 block">Kategori</label>
              <select 
                value={formData.type}
                onChange={e => setFormData({...formData, type: e.target.value as any})}
                className="w-full bg-[#05050a] border border-white/10 rounded-xl p-3 text-sm text-slate-200 outline-none focus:border-indigo-500/50"
              >
                <option value="PERSON">Person</option>
                <option value="OBJECT">Objekt</option>
                <option value="PLACE">Plats</option>
                <option value="CONCEPT">Abstrakt Koncept</option>
              </select>
            </div>
            <div className="md:col-span-2">
              <label className="text-[10px] uppercase font-bold tracking-widest text-slate-500 mb-2 block">Underkategorier (komma-separerade)</label>
              <input 
                type="text" 
                value={formData.subcategories}
                onChange={e => setFormData({...formData, subcategories: e.target.value})}
                placeholder="T.ex. Ekonomi, Lojalitetskonflikter, Skolan" 
                className="w-full bg-[#05050a] border border-white/10 rounded-xl p-3 text-sm text-slate-200 outline-none focus:border-indigo-500/50"
              />
            </div>
            <div className="md:col-span-2">
              <label className="text-[10px] uppercase font-bold tracking-widest text-slate-500 mb-2 block">Mönster att bevaka (Valfritt)</label>
              <textarea 
                value={formData.patterns}
                onChange={e => setFormData({...formData, patterns: e.target.value})}
                placeholder="Beskriv eventuella beteendemönster du vill att systemet ska upptäcka, t.ex. 'Försöker styra via ekonomi'." 
                className="w-full bg-[#05050a] border border-white/10 rounded-xl p-3 text-sm text-slate-200 outline-none focus:border-indigo-500/50 resize-none h-20"
              />
            </div>
          </div>
          <div className="flex justify-end gap-3">
            <button onClick={() => setIsAdding(false)} className="px-4 py-2 text-xs font-bold uppercase text-slate-500 hover:text-slate-300">Avbryt</button>
            <button onClick={handleAdd} className="px-6 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-full text-xs font-bold uppercase tracking-widest">Spara Entitet</button>
          </div>
        </motion.div>
      )}

      <div className="grid gap-4">
        {entities.map(entity => (
          <div key={entity.id} className="bg-[#0a0a12]/50 hover:bg-[#0a0a12] border border-white/5 hover:border-white/10 rounded-2xl transition-all overflow-hidden group">
            <div 
              onClick={() => setExpandedId(expandedId === entity.id ? null : entity.id)}
              className="p-5 flex items-center justify-between cursor-pointer"
            >
              <div className="flex items-center gap-4">
                <div className="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center border border-white/5">
                  {getIcon(entity.type)}
                </div>
                <div>
                  <h3 className="text-lg font-outfit text-slate-200">{entity.name}</h3>
                  <div className="flex gap-2 mt-1">
                    {entity.subcategories.slice(0, 3).map((sub, i) => (
                      <span key={i} className="text-[9px] uppercase tracking-wider text-slate-400 bg-white/5 px-2 py-0.5 rounded-md border border-white/5">
                        {sub}
                      </span>
                    ))}
                    {entity.subcategories.length > 3 && <span className="text-[9px] text-slate-500">+{entity.subcategories.length - 3}</span>}
                  </div>
                </div>
              </div>
              <div className="flex items-center gap-4 text-slate-500">
                {expandedId === entity.id ? <ChevronUp className="w-5 h-5" /> : <ChevronDown className="w-5 h-5" />}
              </div>
            </div>
            
            {expandedId === entity.id && (
              <div className="px-5 pb-5 pt-2 border-t border-white/5 bg-[#05050a]/30">
                {entity.patterns && (
                  <div className="mb-4">
                    <p className="text-[10px] uppercase font-bold tracking-widest text-slate-500 mb-1">Bevakade Mönster</p>
                    <p className="text-sm text-slate-300 bg-white/5 p-3 rounded-xl border border-white/5">{entity.patterns}</p>
                  </div>
                )}
                <div className="flex justify-end mt-4">
                  <button 
                    onClick={() => removeEntity(entity.id)}
                    className="flex items-center gap-2 text-xs font-medium text-red-400 hover:text-red-300 hover:bg-red-950/30 px-3 py-1.5 rounded-lg transition-colors"
                  >
                    <Trash2 className="w-4 h-4" /> Radera
                  </button>
                </div>
              </div>
            )}
          </div>
        ))}
        {entities.length === 0 && !isAdding && (
          <div className="text-center py-20 border border-dashed border-white/10 rounded-3xl">
            <p className="text-slate-500 text-sm">Systemminnet är tomt. Lägg till en person eller ett objekt för att börja logga.</p>
          </div>
        )}
      </div>
    </div>
  );
}
</file>

<file path="livskompassen-trasig-1/src/components/VaultMap.tsx">
import React, { useEffect, useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Database, FileText, Activity, Map as MapIcon, Lock, ShieldCheck, Zap, AlertTriangle, ShieldAlert, BrainCircuit, Network } from 'lucide-react';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { radarService, RadarEvent } from '../services/radarService';
import { collection, query, where, getDocs } from 'firebase/firestore';
import { db } from '../lib/firebase';
import { cn } from '../lib/utils';
import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';
import { useLearning } from '../contexts/LearningContext';

interface VaultMapProps {
  user: any;
  onNavigate: (module: string) => void;
}

export function VaultMap({ user, onNavigate }: VaultMapProps) {
  const { entities } = useSystemMemory();
  const { startTutorial } = useLearning();
  const [totalLogs, setTotalLogs] = useState(0);
  const [events, setEvents] = useState<RadarEvent[]>([]);
  const [hoveredEntity, setHoveredEntity] = useState<string | null>(null);
  
  // Detail View State
  const [selectedEntity, setSelectedEntity] = useState<any | null>(null);
  const [isGeneratingProfile, setIsGeneratingProfile] = useState(false);
  const [actorProfile, setActorProfile] = useState<any>(null);
  const [actorEvents, setActorEvents] = useState<RadarEvent[]>([]);

  // Time Travel State
  const [timeOffset, setTimeOffset] = useState(0); // 0 = Nu, 100 = Äldsta logg

  useEffect(() => {
    if (!user) return;
    const fetchData = async () => {
      // Fetch stats
      const q = query(collection(db, 'kb_docs'), where('userId', '==', user.uid));
      const snapshot = await getDocs(q);
      setTotalLogs(snapshot.size);

      // Fetch recent radar events
      const recentEvents = await radarService.getEvents(user.uid);
      setEvents(recentEvents);
    };
    fetchData();
  }, [user]);

  const handleEntityClick = async (entity: any) => {
    setSelectedEntity(entity);
    setIsGeneratingProfile(true);
    setActorProfile(null);
    try {
      // 1. Hämta alla events för denna specifika person
      const filteredEvents = await radarService.getEvents(user.uid, entity.id);
      setActorEvents(filteredEvents);

      // 2. Generera profil via Gemini
      const profileRes = await (geminiService as any).generateActorProfile(entity, filteredEvents);
      setActorProfile(JSON.parse(profileRes));
    } catch (error) {
      console.error("Kunde inte generera aktörsprofil:", error);
    } finally {
      setIsGeneratingProfile(false);
    }
  };

  const handleExportPDF = () => {
    if (!selectedEntity || !actorProfile) return;

    const doc = new jsPDF();
    const timestamp = new Date().toLocaleString();

    // Header
    doc.setFillColor(15, 23, 42); // Slate-900
    doc.rect(0, 0, 210, 40, 'F');
    
    doc.setTextColor(255, 255, 255);
    doc.setFontSize(20);
    doc.text("VERKLIGHETSVALVET // AKTÖRSPROFIL", 15, 25);
    
    doc.setFontSize(10);
    doc.text(`Genererad: ${timestamp}`, 150, 25);

    // Actor Info
    doc.setTextColor(0, 0, 0);
    doc.setFontSize(14);
    doc.text(`Aktör: ${selectedEntity.name}`, 15, 55);
    doc.setFontSize(10);
    doc.text(`Roll: ${selectedEntity.role || selectedEntity.type}`, 15, 62);
    doc.text(`Risknivå: ${selectedEntity.riskLevel}/10`, 15, 69);

    // AI Analysis - Tactics
    doc.setFontSize(12);
    doc.text("Identifierade Taktiker & Mönster", 15, 85);
    
    const tacticsData = actorProfile.topTactics.map((t: any) => [
      t.tactic,
      t.frequency,
      t.explanation
    ]);

    (doc as any).autoTable({
      startY: 90,
      head: [['Taktik', 'Frekvens', 'Förklaring']],
      body: tacticsData,
      theme: 'grid',
      headStyles: { fillColor: [99, 102, 241] }
    });

    // Escalation & Strategy
    const finalY = (doc as any).lastAutoTable.cursor.y + 15;
    doc.setFontSize(12);
    doc.text("Eskaleringsanalys", 15, finalY);
    doc.setFontSize(10);
    const splitEscalation = doc.splitTextToSize(actorProfile.escalationAnalysis, 180);
    doc.text(splitEscalation, 15, finalY + 7);

    doc.setFontSize(12);
    doc.text("Strategiskt Råd", 15, finalY + 35);
    doc.setFontSize(10);
    doc.setFont("helvetica", "italic");
    const splitAdvice = doc.splitTextToSize(actorProfile.strategicAdvice, 180);
    doc.text(splitAdvice, 15, finalY + 42);

    // Footer
    doc.setFont("helvetica", "normal");
    doc.setFontSize(8);
    doc.setTextColor(150, 150, 150);
    doc.text("Detta dokument är genererat av LivsKompassen AI för privat bruk och juridisk dokumentation.", 15, 285);

    doc.save(`Aktörsprofil_${selectedEntity.name.replace(/\s+/g, '_')}.pdf`);
  };

  // Funktion för att räkna ut risken vid en viss tidpunkt
  const getRiskAtTime = (entity: any, offset: number) => {
    if (offset === 0 || events.length === 0) return entity.riskLevel || 5;
    
    // Hitta alla events för denna entitet, sorterade på tid (nyast först)
    const actorHistory = events
      .filter(e => e.involvedActors?.includes(entity.id) || (e as any).riskSnapshots?.some((s: any) => s.entityName === entity.name))
      .sort((a, b) => b.timestamp - a.timestamp);

    if (actorHistory.length === 0) return entity.riskLevel || 5;

    // Räkna ut vilket event som motsvarar offsetten
    const eventIndex = Math.floor((offset / 100) * (actorHistory.length - 1));
    const historicEvent = actorHistory[eventIndex];

    // Kolla om det finns en snapshot i det eventet
    const snapshot = (historicEvent as any).riskSnapshots?.find((s: any) => s.entityName === entity.name);
    return snapshot ? snapshot.riskLevel : entity.riskLevel || 5;
  };

  // Funktion för att placera ut entiteter i en cirkel baserat på ID (för stabilitet) och risk
  const getEntityPosition = (index: number, total: number, riskLevel: number = 5) => {
    const angle = (index / total) * 2 * Math.PI;
    const radius = 180 - (riskLevel * 12); // Högre risk = närmare mitten
    return {
      x: Math.cos(angle) * radius,
      y: Math.sin(angle) * radius,
      angle
    };
  };

  return (
    <div className="space-y-10 animate-in fade-in duration-700">
