import { AnalysisPanel } from '../components/terminal/AnalysisPanel';

import { collection, query, where, onSnapshot, addDoc, serverTimestamp, orderBy, getDocs, limit } from 'firebase/firestore';
import { db } from '../lib/firebase';

interface TerminalPageProps {
  user: any;
}

export function TerminalPage({ user }: TerminalPageProps) {
  const [logs, setLogs] = useState<string[]>([]);
  const [activeTab, setActiveTab] = useState<'CONSOLE' | 'SYNAPSES' | 'AGENTS' | 'SCANS'>('CONSOLE');
  const [isScanning, setIsScanning] = useState(false);
  const [synapses, setSynapses] = useState<SystemSynapse[]>([]);

  useEffect(() => {
    if (!user) return;

    const q = query(
      collection(db, 'synapses'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribe = onSnapshot(q, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      } as SystemSynapse));
      
      // If no synapses in DB, we could show the INITIAL_SYNAPSES as placeholders or seed them
      setSynapses(docs.length > 0 ? docs : INITIAL_SYNAPSES.map(s => ({ ...s, userId: user.uid })));
    }, (error) => {
      console.error("Synapses listen error", error);
    });

    return unsubscribe;
  }, [user]);

  const agents = [
    { 
      name: 'Gräns-Arkitekten', 
      role: 'Kommunikations-Vakt', 
      icon: Layers, 
      mission: 'Förvandlar manipulatörers input till neutral data. Implementerar BIFF-skölden och förhindrar JADE. Din främsta vakt mot emotionella krokar.',
      color: 'text-emerald-400',
      bg: 'bg-emerald-400/10'
    },
    { 
      name: 'Skydds-Agenten', 
      role: 'Våldsprevention', 
      icon: ShieldCheck, 
      mission: 'Identifierar mönster av narcissistiskt våld i realtid. Skyddar Kasper och Arvid genom att flagga för lojalitetskonflikter och "Crazymaking".',
      color: 'text-red-400',
      bg: 'bg-red-400/10'
    },
    { 
      name: 'Livs-Arkivarien', 
      role: 'Sanningens Ankare', 
      icon: Database, 
      mission: 'Objektör för användarens biografi. Förhindrar gaslighting genom att korskörda inkommande data mot låsta bevis (Immutable Snapshots).',
      color: 'text-sand',
      bg: 'bg-sand/10'
    },
    { 
      name: 'Analys-Agenten', 
      role: 'Säkerhets-DNA', 
      icon: Activity, 
      mission: 'Övervakar Zero Footprint. Garanterar att Verklighetsvalvet förblir osynligt och att "Kill Switch" fungerar vid fysiska hot.',
      color: 'text-lavender',
      bg: 'bg-lavender/10'
    },
    { 
      name: 'Kod-Agenten', 
      role: 'Logik-Determinist', 
      icon: Cpu, 
      mission: 'Bygger systemets deterministiska filter. Ser till att inga AI-hallucinationer äventyrar användarens trygghet eller data-integritet.',
      color: 'text-blue-400',
      bg: 'bg-blue-400/10'
    },
    { 
      name: 'Nätverksvisir', 
      role: 'Social Architect', 
      icon: BrainCircuit, 
      mission: 'Kartlägger och analyserar det sociala nätverket kring familjen. Identifierar allierade, Flying Monkeys och myndighetskontakter för att säkra kärnan.',
      color: 'text-orange-400',
      bg: 'bg-orange-400/10'
    }
  ];
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    setLogs([
      `[${new Date().toLocaleTimeString()}] Initializing LivsKompassen Kernel 3.1...`,
      `[${new Date().toLocaleTimeString()}] Handshake: Ekonomi-Motorn ... OK`,
      `[${new Date().toLocaleTimeString()}] Handshake: Wellness-Motorn ... OK`,
      `[${new Date().toLocaleTimeString()}] Handshake: Valv-Motorn ... OK`,
      `[${new Date().toLocaleTimeString()}] Systemmedvetenhet: AKTIVERAD`,
      `[${new Date().toLocaleTimeString()}] Deep Agent "Livs-Arkivarien": CONNECTED`,
      `[${new Date().toLocaleTimeString()}] Protection Protocol "Skydds-Agenten": ACTIVE`,
    ]);
  }, []);

  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
  }, [logs]);

  const runAnalysis = async () => {
    if (!user) return;
    setIsScanning(true);
    const time = new Date().toLocaleTimeString();
    setLogs(prev => [...prev, `[${time}] Kärn-initiering: Initierar Djup-Analys (Grounding)...`]);
    
    try {
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] Livs-Arkivarien: Samlar in dataflöden från Kärnan...`]);
      
      const [checkinsSnap, projectsSnap, txSnap] = await Promise.all([
        getDocs(query(collection(db, 'checkins'), where('userId', '==', user.uid), orderBy('createdAt', 'desc'), limit(5))),
        getDocs(query(collection(db, 'projects'), where('userId', '==', user.uid), orderBy('createdAt', 'desc'), limit(5))),
        getDocs(query(collection(db, 'transactions'), where('userId', '==', user.uid), orderBy('createdAt', 'desc'), limit(5)))
      ]);

      const contextItems = [
        ...checkinsSnap.docs.map(d => `Check-in: ${d.data().questionText} -> ${d.data().optionSelected}`),
        ...projectsSnap.docs.map(d => `Projekt: ${d.data().title} (${d.data().status})`),
        ...txSnap.docs.map(d => `Transaktion: ${d.data().description} ${d.data().amount}kr`)
      ];

      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] Analys-Agenten: Bearbetar ${contextItems.length} noder av kontext...`]);
      
      const result = await geminiService.intenseAnalysis(
        contextItems.join('\n'), 
        "System-DNA: ADHD/GAD skyddslager. Inga regressioner tillåtna."
      );
      
      await new Promise(r => setTimeout(r, 800));
      
      if (result) {
        setLogs(prev => [
          ...prev, 
          `[${new Date().toLocaleTimeString()}] ✅ Analys klar: Grounding Score: ${result.groundingScore}%`,
          `[${new Date().toLocaleTimeString()}] Sammanfattning: ${result.summary}`,
          ...result.contradictions.map((c: string) => `[${new Date().toLocaleTimeString()}] ⚠️ Varning: ${c}`)
        ]);

        await addDoc(collection(db, 'synapses'), {
          userId: user.uid,
          title: result.title,
          category: 'SECURITY',
          analysis: result.summary,
          groundingPoints: result.contradictions.length > 0 ? result.contradictions : ['Deterministisk synk OK'],
          hallucinationRisk: 'LOW',
          lastScannedAt: serverTimestamp(),
          createdAt: serverTimestamp(),
        });
      }

    } catch (e) {
      console.error(e);
      setLogs(prev => [...prev, `[${new Date().toLocaleTimeString()}] ❌ ALLVARLIGT FEL: Kärn-kollaps vid analys.`]);
    } finally {
      setIsScanning(false);
    }
  };

  return (
    <div className="space-y-6">
      {/* System Tabs */}
      <div className="flex p-1 bg-black/40 backdrop-blur-xl rounded-2xl border border-gold/10 overflow-x-auto no-scrollbar">
        {[
          { id: 'CONSOLE', label: 'Konsoll', icon: TerminalIcon },
          { id: 'SYNAPSES', label: 'Synapser', icon: BrainCircuit },
          { id: 'AGENTS', label: 'Agenter', icon: Database },
          { id: 'SCANS', label: 'Analyser', icon: Layers },
        ].map((tab) => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as any)}
            className={cn(
              "flex-1 flex items-center justify-center gap-2 py-2.5 px-4 rounded-xl text-[10px] uppercase font-bold tracking-widest transition-all min-w-fit whitespace-nowrap",
              activeTab === tab.id ? "bg-gold/20 text-gold" : "text-gold/40 hover:text-gold/60"
            )}
          >
            <tab.icon className="w-3.5 h-3.5" />
            {tab.label}
          </button>
        ))}
      </div>

      <AnimatePresence mode="wait">
        {activeTab === 'CONSOLE' && (
          <motion.div
            key="console"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="space-y-4"
          >
            <BentoCard className="bg-black/60 border-gold/10 p-0 overflow-hidden h-64 flex flex-col">
              <div className="flex items-center justify-between px-4 py-2 bg-gold/5 border-b border-gold/10">
                <span className="text-[10px] uppercase tracking-widest font-bold text-gold/30">Livs-Arkivarien Shell</span>
                <div className="flex gap-1.5 font-mono text-[8px] text-gold/30">
                  <span>CPU: 1.2%</span>
                  <span>MEM: 256MB</span>
                </div>
              </div>
              <div 
                ref={scrollRef}
                className="p-4 flex-1 overflow-y-auto font-mono text-[10px] leading-relaxed space-y-1"
              >
                {logs.map((log, i) => (
                  <div key={i} className="flex gap-2">
                    <span className="text-gold/50">›</span>
                    <span className="text-gold/70">{log}</span>
                  </div>
                ))}
              </div>
            </BentoCard>

            <button
              onClick={runAnalysis}
              disabled={isScanning}
              className="w-full h-14 rounded-2xl bg-gold/10 border border-gold/20 flex items-center justify-center gap-3 transition-all active:scale-95 disabled:opacity-50"
            >
              <RefreshCw className={cn("w-5 h-5 text-gold", isScanning && "animate-spin")} />
              <span className="text-xs font-bold uppercase tracking-widest text-gold">Kör Djup-Analys (Grounding)</span>
            </button>
          </motion.div>
        )}

        {activeTab === 'AGENTS' && (
          <motion.div
            key="agents"
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            className="grid gap-4"
          >
            {agents.map((agent) => (
              <BentoCard key={agent.name} className="relative overflow-hidden">
                <div className="flex items-center gap-4">
                  <div className={cn("w-12 h-12 rounded-2xl flex items-center justify-center", agent.bg)}>
                    <agent.icon className={cn("w-6 h-6", agent.color)} />
                  </div>
                  <div className="flex-1">
                    <div className="flex items-center justify-between">
                      <h4 className="text-sm font-bold">{agent.name}</h4>
                      <span className="text-[9px] uppercase font-bold tracking-widest text-emerald-400 bg-emerald-400/10 px-2 py-1 rounded-lg">Aktiv</span>
                    </div>
                    <p className="text-[10px] opacity-40 uppercase tracking-tighter mb-2 italic">{agent.role}</p>
                    <p className="text-[11px] opacity-60 leading-relaxed pr-8">{agent.mission}</p>
                  </div>
                </div>
              </BentoCard>
            ))}
          </motion.div>
        )}

        {activeTab === 'SYNAPSES' && (
          <motion.div
            key="synapses"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-4"
          >
            {synapses.length === 0 && (
              <div className="p-12 text-center opacity-20 italic text-sm">
                Inga synapser hittades. Kör en djup-analys för att kartlägga systemet.
              </div>
            )}
            {synapses.map((synapse) => (
              <BentoCard key={synapse.id} className="bg-white/5 border-white/10">
                <div className="flex items-center gap-3 mb-3">
                  <div className={cn(
                    "p-2 rounded-xl",
                    synapse.category === 'INTEGRITY' ? "bg-red-500/10 text-red-400" : "bg-blue-500/10 text-blue-400"
                  )}>
                    <Database className="w-4 h-4" />
                  </div>
                  <div>
                    <h3 className="text-sm font-bold">{synapse.title}</h3>
                    <p className="text-[10px] opacity-40 uppercase tracking-tighter">{synapse.category}</p>
                  </div>
                </div>
                <p className="text-xs opacity-70 leading-relaxed mb-4">
                  {synapse.analysis}
                </p>
                <div className="flex flex-wrap gap-2">
                  {synapse.groundingPoints.map((point, idx) => (
                    <span key={idx} className="px-2 py-1 bg-white/5 rounded-lg text-[9px] uppercase font-bold opacity-40">
                      • {point}
                    </span>
                  ))}
                </div>
              </BentoCard>
            ))}
          </motion.div>
        )}

        {activeTab === 'SCANS' && (
          <motion.div
            key="scans"
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -20 }}
            className="space-y-6"
          >
            <AnalysisPanel />

            <BentoCard highlightColor="lavender" className="bg-lavender/5">
              <div className="flex items-center gap-4">
                <ShieldCheck className="w-10 h-10 text-lavender opacity-60" />
                <div>
                  <h3 className="text-sm font-bold uppercase tracking-widest">Säkerhetsövervakare</h3>
                  <p className="text-xs opacity-50">Inga regressioner upptäckta. Verklighetsvalvet är intakt.</p>
                </div>
              </div>
            </BentoCard>

            <BentoCard className="bg-white/5 border-white/5">
              <h3 className="text-[10px] uppercase font-bold opacity-30 mb-4 tracking-[0.2em]">Senaste Analyser</h3>
              <div className="space-y-3">
                {[
                  { label: 'Kognitiv Belastning (AI Scan)', val: 'Låg', color: 'text-emerald-400' },
                  { label: 'Hallucinations-kontroll', val: '0 Incidenter', color: 'text-emerald-400' },
                  { label: 'Arkiv-Integritet', val: 'Stabil', color: 'text-blue-400' },
                ].map((stat, i) => (
                  <div key={i} className="flex justify-between items-center p-3 bg-black/20 rounded-xl border border-white/5">
                    <span className="text-[10px] uppercase font-bold opacity-40">{stat.label}</span>
                    <span className={cn("text-[10px] font-bold uppercase", stat.color)}>{stat.val}</span>
                  </div>
                ))}
              </div>
            </BentoCard>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
</file>

<file path="livskompassen-trasig/src/pages/VaultPage.tsx">
import { useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Shield, Lock, X, Eye, EyeOff, Save, ShieldAlert, Zap, Anchor, Users, AlertTriangle, CheckCircle2, Terminal, BookOpen, FileText } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, query, where, orderBy, onSnapshot } from 'firebase/firestore';
import { VAULT_CATEGORIES } from '../constants';
import { VaultLog, NetworkMember } from '../types';
import { cn } from '../lib/utils';

// Sub-Pages
import { NetworkPage } from './NetworkPage';
import { KnowledgePage } from './KnowledgePage';
import { TerminalPage } from './TerminalPage';
import { Silo3View } from '../components/Silo3View';

interface VaultPageProps {
  user: any;
}

type VaultModule = 'LOGS' | 'NETWORK' | 'KNOWLEDGE' | 'SYSTEM';

export function VaultPage({ user }: VaultPageProps) {
  const [isUnlocked, setIsUnlocked] = useState(false);
  const [pin, setPin] = useState('');
  const [showPinModal, setShowPinModal] = useState(false);
  const [activeModule, setActiveModule] = useState<VaultModule>('LOGS');
  const [logs, setLogs] = useState<VaultLog[]>([]);
  const [importantPeople, setImportantPeople] = useState<NetworkMember[]>([]);
  
  // Form State
  const [category, setCategory] = useState(VAULT_CATEGORIES[0]);
  const [action, setAction] = useState('');
  const [truth, setTruth] = useState('');
  const [childrenImpact, setChildrenImpact] = useState('');
  const [isSaving, setIsSaving] = useState(false);

  // Hidden trigger state
  const pressTimer = useRef<NodeJS.Timeout | null>(null);
  const [isPressing, setIsPressing] = useState(false);

  useEffect(() => {
    if (!user || !isUnlocked) return;
    if (activeModule !== 'LOGS') return;

    // Load Vault Logs
    const qLogs = query(
      collection(db, 'vault'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribeLogs = onSnapshot(qLogs, (snapshot) => {
      setLogs(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as VaultLog)));
    });

    // Load Important Network Members for the quick view
    const qNetwork = query(
      collection(db, 'network'),
      where('userId', '==', user.uid),
      where('importance', '==', 'HIGH')
    );

    const unsubscribeNetwork = onSnapshot(qNetwork, (snapshot) => {
      setImportantPeople(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as NetworkMember)));
    });

    return () => {
      unsubscribeLogs();
      unsubscribeNetwork();
    };
  }, [user, isUnlocked, activeModule]);

  const handleStartPress = () => {
    setIsPressing(true);
    pressTimer.current = setTimeout(() => {
      setShowPinModal(true);
      setIsPressing(false);
    }, 3000);
  };

  const handleEndPress = () => {
    if (pressTimer.current) {
      clearTimeout(pressTimer.current);
      setIsPressing(false);
    }
  };

  const handlePinSubmit = () => {
    if (pin === '6469') { // Original PIN återställd
      setIsUnlocked(true);
      setShowPinModal(false);
      setPin('');
    } else {
      setPin('');
      alert('Fel kod');
    }
  };

  const handleSave = async () => {
    if (!action || !truth) return;
    setIsSaving(true);
    try {
      await addDoc(collection(db, 'vault'), {
        userId: user.uid,
        category,
        action,
        truth,
        childrenImpact,
        biffUsed: action.toLowerCase().includes('biff'),
        createdAt: serverTimestamp()
      });
      setAction('');
      setTruth('');
      setChildrenImpact('');
    } catch (e) {
      console.error("Vault save error", e);
    } finally {
      setIsSaving(false);
    }
  };

  if (!isUnlocked) {
    return (
      <div className="flex flex-col items-center justify-center py-20 px-6">
        <motion.button
          onMouseDown={handleStartPress}
          onMouseUp={handleEndPress}
          onMouseLeave={handleEndPress}
          onTouchStart={handleStartPress}
          onTouchEnd={handleEndPress}
          animate={{ scale: isPressing ? 0.9 : 1 }}
          className="w-32 h-32 rounded-[3rem] glass-card flex items-center justify-center relative overflow-hidden group"
        >
          <Anchor className="w-12 h-12 text-gold opacity-20 group-hover:opacity-40 transition-opacity" />
          {isPressing && (
            <motion.div
              initial={{ height: 0 }}
              animate={{ height: '100%' }}
              transition={{ duration: 3, ease: 'linear' }}
              className="absolute bottom-0 left-0 right-0 bg-gold/10 -z-10"
            />
          )}
        </motion.button>
        
        <p className="mt-8 text-xs uppercase tracking-[0.2em] font-bold opacity-20 text-center">
          Identifiering krävs för tillträde
        </p>

        <AnimatePresence>
          {showPinModal && (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="fixed inset-0 bg-deep-midnight/80 backdrop-blur-xl z-[100] flex items-center justify-center p-6"
            >
            <div className="w-full max-w-xs card-mystic p-8 rounded-[2.5rem] flex flex-col items-center">
                <Lock className="w-8 h-8 text-gold mb-6" />
                <h3 className="text-lg mb-8 text-gold font-display">Ange PIN-kod</h3>
                
                <div className="flex gap-4 mb-8">
                  {[...Array(4)].map((_, i) => (
                    <div key={i} className={`w-3 h-3 rounded-full ${pin.length > i ? 'bg-gold' : 'bg-gold/20'}`} />
                  ))}
                </div>

                <div className="grid grid-cols-3 gap-4 w-full">
                  {[1,2,3,4,5,6,7,8,9, 'X', 0, 'OK'].map((val) => (
                    <button
                      key={val.toString()}
                      onClick={() => {
                        if (val === 'X') setPin(pin.slice(0, -1));
                        else if (val === 'OK') handlePinSubmit();
                        else if (pin.length < 4) setPin(pin + val);
                      }}
                      className="h-14 rounded-2xl bg-white/5 hover:bg-white/10 active:scale-90 transition-all flex items-center justify-center text-lg font-medium"
                    >
                      {val}
                    </button>
                  ))}
                </div>

                <button onClick={() => setShowPinModal(false)} className="mt-8 text-xs uppercase tracking-widest opacity-40">Avbryt</button>
              </div>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    );
  }

  return (
    <div className="space-y-6 pb-20">
      {/* Vault Header - The Gateway */}
      <header className="flex justify-between items-center bg-gold/5 p-4 rounded-3xl border border-gold/10">
        <div className="flex items-center gap-3">
          <ShieldAlert className="w-5 h-5 text-gold" />
          <div>
            <span className="text-sm font-bold uppercase tracking-widest text-gold block leading-tight">Verklighetsvalvet</span>
            <span className="text-[10px] text-gold/40 uppercase tracking-tighter">Skyddad sanning</span>
          </div>
        </div>
        <div className="flex gap-2">
          <button onClick={() => setIsUnlocked(false)} className="p-2 rounded-xl bg-white/5 hover:bg-red-400/20 text-red-400 transition-colors">
            <Lock className="w-4 h-4" />
          </button>
        </div>
      </header>

      {/* Main Bento Dashboard */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        {/* Silo 1: Jaget & Hälsan */}
        <BentoCard className="bg-deep-green-mid/40 border-gold/10 p-6">
          <h3 className="text-sm font-bold text-gold uppercase tracking-widest mb-4">Jaget & Hälsan</h3>
          <div className="space-y-2">
            <Button variant="ghost" onClick={() => setActiveModule('SYSTEM')} className="w-full justify-start text-xs text-gold/60">Vagusnerv-stimulering</Button>
            <Button variant="ghost" className="w-full justify-start text-xs text-gold/60">Ekonomi-översikt</Button>
          </div>
        </BentoCard>

        {/* Silo 2: Barnens Värld */}
        <BentoCard className="bg-deep-green-mid/40 border-gold/10 p-6">
          <h3 className="text-sm font-bold text-gold uppercase tracking-widest mb-4">Barnens Värld</h3>
          <div className="space-y-2">
            <Button variant="ghost" className="w-full justify-start text-xs text-gold/60">KASPER (Scen: Syndabock)</Button>
            <Button variant="ghost" className="w-full justify-start text-xs text-gold/60">ARVID (Scen: Regression)</Button>
          </div>
        </BentoCard>

        {/* Silo 3: Ex-fruns Sfär */}
        <BentoCard className="bg-red-900/10 border-red-900/30 p-6 md:col-span-2">
          <h3 className="text-sm font-bold text-red-400 uppercase tracking-widest mb-4">Ex-fruns Sfär (Bevislogg)</h3>
          <Button onClick={() => setActiveModule('LOGS')} className="w-full bg-red-900/20 hover:bg-red-900/40 text-red-400 border border-red-900/50">
            Öppna Jurisdiktionsfilerna
          </Button>
        </BentoCard>
      </div>

      {/* Vault Sub-navigation */}
      <div className="flex bg-white/5 p-1 rounded-2xl border border-white/5">
        {[
          { id: 'LOGS', label: 'Bevis', icon: FileText },
          { id: 'NETWORK', label: 'Nätverk', icon: Users },
          { id: 'KNOWLEDGE', label: 'Banken', icon: BookOpen },
          { id: 'SYSTEM', label: 'System', icon: Terminal },
        ].map((mod) => (
          <button
            key={mod.id}
            onClick={() => setActiveModule(mod.id as any)}
            className={cn(
              "flex-1 flex flex-col items-center py-3 rounded-xl transition-all relative overflow-hidden",
              activeModule === mod.id ? "bg-gold text-deep-green-dark" : "text-gold/40 hover:text-gold/60"
            )}
          >
            <mod.icon className={cn("w-5 h-5 mb-1", activeModule === mod.id ? "text-deep-green-dark" : "text-gold/40")} />
            <span className="text-[9px] font-bold uppercase tracking-tighter">{mod.label}</span>
          </button>
        ))}
      </div>
      
      {/* Central Action */}
      {activeModule === 'LOGS' && <Silo3View user={user} />}
      {activeModule === 'NETWORK' && <NetworkPage user={user} />}
      {activeModule === 'KNOWLEDGE' && <KnowledgePage user={user} />}
      {activeModule === 'SYSTEM' && <TerminalPage user={user} />}
    </div>
  );
}
</file>

<file path="livskompassen-trasig/src/pages/WellnessPage.tsx">
import { BentoCard } from '../components/ui/BentoCard';
import { Sprout, Wind, Brain, Droplets, Battery, Activity, Shield, RefreshCw, Zap, Save, Calendar, MessageCircle, Star, BrainCircuit } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { DIARY_CATEGORIES } from '../constants';
import { DiaryEntry } from '../types';
import { Button } from '../components/ui/button';
import { geminiService } from '../services/geminiService';
import { cn } from '../lib/utils';

interface WellnessPageProps {
  user: any;
}

type WellnessTab = 'PULS' | 'REFLEKTION';

export function WellnessPage({ user }: WellnessPageProps) {
  const [activeTab, setActiveTab] = useState<WellnessTab>('PULS');
  
  // Diary State
  const [entries, setEntries] = useState<DiaryEntry[]>([]);
  const [text, setText] = useState('');
  const [energy, setEnergy] = useState(3);
  const [category, setCategory] = useState(DIARY_CATEGORIES[0]);
  const [isSaving, setIsSaving] = useState(false);

  // Reflection State
  const [reflectionQuestion, setReflectionQuestion] = useState<{ agentName: string; question: string; category: string } | null>(null);
  const [reflectionAnswer, setReflectionAnswer] = useState('');
  const [reflections, setReflections] = useState<any[]>([]);
  const [isReflecting, setIsReflecting] = useState(false);

  useEffect(() => {
    if (!user) return;

    // Pulse (Diary) entries
    const qPulse = query(
      collection(db, 'diary'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribePulse = onSnapshot(qPulse, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data(),
        date: doc.data().createdAt?.toDate().toLocaleDateString('sv-SE', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) || 'Sparar...'
      } as DiaryEntry));
      setEntries(docs);
    });

    // Reflection entries
    const qReflection = query(
      collection(db, 'reflections'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribeReflection = onSnapshot(qReflection, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data(),
        date: doc.data().createdAt?.toDate().toLocaleDateString('sv-SE', { month: 'short', day: 'numeric' }) || '...'
      }));
      setReflections(docs);
    });

    return () => {
      unsubscribePulse();
      unsubscribeReflection();
    };
  }, [user]);

  useEffect(() => {
    if (activeTab === 'REFLEKTION' && !reflectionQuestion) {
      loadNewQuestion();
    }
  }, [activeTab]);

  const loadNewQuestion = async () => {
    const context = entries.map(e => e.text).join('\n').slice(0, 1000);
    const result = await geminiService.generateReflectionQuestion(context);
    setReflectionQuestion(result);
  };

  const handleSaveDiary = async () => {
    if (!text) return;
    setIsSaving(true);
    try {
      await addDoc(collection(db, 'diary'), {
        userId: user.uid,
        text,
        energy,
        category,
        createdAt: serverTimestamp()
      });
      setText('');
      setEnergy(3);
    } catch (e) {
      console.error("Diary save error", e);
    } finally {
      setIsSaving(false);
    }
  };

  const handleSaveReflection = async () => {
    if (!reflectionAnswer || !reflectionQuestion) return;
    setIsReflecting(true);
    try {
      await addDoc(collection(db, 'reflections'), {
        userId: user.uid,
        agentName: reflectionQuestion.agentName,
        question: reflectionQuestion.question,
        category: reflectionQuestion.category,
        answer: reflectionAnswer,
        createdAt: serverTimestamp()
      });
      setReflectionAnswer('');
      loadNewQuestion();
    } catch (e) {
      console.error("Reflection save error", e);
    } finally {
      setIsReflecting(false);
    }
  };

  return (
    <div className="space-y-6 pb-20">
      {/* Sub-nav Tabs */}
      <div className="flex p-1 bg-black/40 backdrop-blur-xl rounded-[2rem] border border-white/5 mx-auto max-w-xs">
        {[
          { id: 'PULS', label: 'Puls', icon: Activity },
          { id: 'REFLEKTION', label: 'Spegling', icon: BrainCircuit },
        ].map((tab) => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as WellnessTab)}
            className={cn(
              "flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-[1.8rem] text-[10px] uppercase font-bold tracking-widest transition-all",
              activeTab === tab.id ? "bg-turquoise text-white shadow-lg shadow-turquoise/20" : "text-white/40 hover:text-white/60"
            )}
          >
            <tab.icon className="w-4 h-4" />
            {tab.label}
          </button>
        ))}
      </div>

      <AnimatePresence mode="wait">
        {activeTab === 'PULS' ? (
          <motion.div
            key="puls"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="space-y-6"
          >
            {/* Mental Pulse Header */}
            <BentoCard highlightColor="turquoise" className="bg-deep-green-mid/80 border-gold/30">
              <div className="flex justify-between items-center mb-6 relative z-10">
                <div className="w-12 h-12 rounded-2xl bg-gold/20 flex items-center justify-center shadow-lg shadow-gold/10">
                  <Activity className="w-6 h-6 text-gold" />
                </div>
                <div className="text-right">
                  <p className="text-[10px] font-bold uppercase tracking-tighter text-gold opacity-60">Energinivå</p>
                  <p className="text-sm font-medium text-gold">{entries[0]?.energy || 0} / 5</p>
                </div>
              </div>

              <div className="relative h-24 flex items-center justify-center z-10">
                <div className="flex gap-1 items-end h-12">
                  {[30, 60, 45, 80, 50, 40, 90, 30, 55].map((h, i) => (
                    <motion.div 
                      key={i}
                      initial={{ height: 0 }}
                      animate={{ height: h }}
                      transition={{ delay: i * 0.05, duration: 0.5, repeat: Infinity, repeatType: 'mirror' }}
                      className="w-2 bg-gold/40 rounded-full"
                    />
                  ))}
                </div>
              </div>
            </BentoCard>

            {/* New Entry */}
            <BentoCard className="bg-deep-green-mid/80 border-gold/30">
              <h3 className="text-sm font-bold uppercase tracking-widest text-gold mb-4">Livsarkivet</h3>
              <div className="space-y-4">
                <textarea
                  placeholder="Hur mår du egentligen? Släpp ut tankarna här..."
                  value={text}
                  onChange={(e) => setText(e.target.value)}
                  className="w-full h-32 rounded-2xl bg-deep-green-dark/40 border border-gold/20 p-4 text-sm text-gold outline-none focus:border-gold/50 resize-none transition-colors placeholder:text-gold/20"
                />
                
                <div className="flex items-center justify-between">
                  <div className="flex gap-2">
                    {[1, 2, 3, 4, 5].map((num) => (
                      <button
                        key={num}
                        onClick={() => setEnergy(num)}
                        className={cn(
                          "w-10 h-10 rounded-xl transition-all",
                          energy === num ? 'bg-gold text-deep-green-dark shadow-lg shadow-gold/20' : 'bg-deep-green-dark/40 text-gold/40 hover:text-gold'
                        )}
                      >
                        {num}
                      </button>
                    ))}
                  </div>
                  <select 
                    value={category} 
                    onChange={(e) => setCategory(e.target.value)}
                    className="h-10 rounded-xl bg-deep-green-dark/40 border border-gold/20 px-3 text-xs text-gold outline-none"
                  >
                    {DIARY_CATEGORIES.map(c => <option key={c} value={c}>{c}</option>)}
                  </select>
                </div>

                <Button disabled={isSaving || !text} onClick={handleSaveDiary} className="w-full bg-gold text-deep-green-dark hover:bg-gold/90">
                  {isSaving ? 'Sparar...' : 'Spara i Arkivet'}
                </Button>
              </div>
            </BentoCard>

            {/* Toolbox Quick Actions */}
            <div className="grid grid-cols-2 gap-4">
              <BentoCard delay={0.1} className="flex flex-col items-center justify-center py-6 hover:bg-gold/5 transition-colors cursor-pointer bg-deep-green-mid/80 border-gold/30">
                <Wind className="w-6 h-6 text-gold mb-2" />
                <p className="text-sm text-gold">Andas</p>
                <p className="text-[10px] text-gold/40">4-7-8 metod</p>
              </BentoCard>

              <BentoCard delay={0.2} className="flex flex-col items-center justify-center py-6 hover:bg-gold/5 transition-colors cursor-pointer bg-deep-green-mid/80 border-gold/30">
                <Battery className="w-6 h-6 text-gold mb-2" />
                <p className="text-sm text-gold">Vila</p>
                <p className="text-[10px] text-gold/40">Kravlös tid</p>
              </BentoCard>
            </div>

            {/* History */}
            <div className="space-y-4">
              <div className="flex items-center gap-2 opacity-30 px-2 text-gold">
                <Calendar className="w-4 h-4" />
                <span className="text-[10px] font-bold uppercase tracking-widest">Historik</span>
              </div>
              {entries.map((entry) => (
                <BentoCard key={entry.id} className="bg-deep-green-mid/60 border-gold/10 group">
                  <div className="flex justify-between items-center mb-2">
                    <span className="text-[10px] font-bold text-gold/60">{entry.category}</span>
                    <span className="text-[10px] text-gold/40">{entry.date}</span>
                  </div>
                  <p className="text-sm leading-relaxed text-gold/80 group-hover:text-gold transition-opacity">{entry.text}</p>
                  <div className="mt-3 flex gap-1">
                    {[...Array(entry.energy)].map((_, i) => (
                      <div key={i} className="w-1.5 h-1.5 rounded-full bg-gold" />
                    ))}
                  </div>
                </BentoCard>
              ))}
            </div>
          </motion.div>
        ) : (
          <motion.div
            key="reflection"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-6"
          >
            {/* System Reflection Question (The "Quiz") */}
            <BentoCard highlightColor="turquoise" className="bg-deep-green-mid/80 border-gold/30">
              <div className="flex items-center gap-4 mb-6">
                <div className="w-12 h-12 rounded-2xl bg-gold/10 flex items-center justify-center shadow-lg shadow-gold/10">
                  <Star className="w-6 h-6 text-gold animate-pulse" />
                </div>
                <div>
                  <h3 className="text-sm font-bold uppercase tracking-widest text-gold/60">Speglings-Agenten</h3>
                  <p className="text-[10px] text-gold/40">System-lärande pågår</p>
                </div>
              </div>

              <AnimatePresence mode="wait">
                {reflectionQuestion ? (
                  <motion.div
                    initial={{ opacity: 0, y: 10 }}
                    animate={{ opacity: 1, y: 0 }}
                    key={reflectionQuestion.question}
                    className="space-y-6"
                  >
                    <div className="bg-deep-green-dark/40 p-6 rounded-3xl border border-gold/40">
                      <p className="text-base font-display leading-relaxed text-gold">
                        "{reflectionQuestion.question}"
                      </p>
                      <div className="mt-3 inline-block px-2 py-0.5 bg-gold/10 text-gold text-[8px] font-black uppercase rounded">
                        Kategori: {reflectionQuestion.category}
                      </div>
                    </div>

                    <div className="space-y-4">
                      <textarea
                        placeholder="Ditt svar här..."
                        value={reflectionAnswer}
                        onChange={(e) => setReflectionAnswer(e.target.value)}
                        className="w-full h-32 rounded-2xl bg-deep-green-dark/40 border border-gold/20 p-4 text-sm text-gold outline-none focus:border-gold/50 resize-none transition-colors placeholder:text-gold/20"
                      />
                      <div className="flex gap-3">
                        <Button 
                          disabled={isReflecting || !reflectionAnswer} 
                          onClick={handleSaveReflection}
                          className="flex-1 bg-gold text-deep-green-dark"
                        >
                          Svara {reflectionQuestion.agentName}
                        </Button>
                        <button 
                          onClick={() => { setReflectionQuestion(null); loadNewQuestion(); }}
                          className="w-12 h-12 rounded-2xl bg-gold/10 flex items-center justify-center hover:bg-gold/20 transition-all"
                        >
                          <RefreshCw className="w-5 h-5 text-gold/40" />
                        </button>
                      </div>
                    </div>
                  </motion.div>
                ) : (
                  <div className="h-40 flex items-center justify-center">
                    <RefreshCw className="w-6 h-6 text-gold animate-spin opacity-20" />
                  </div>
                )}
              </AnimatePresence>
            </BentoCard>

            {/* Past Reflections / Insights */}
            <div className="space-y-4">
              <div className="flex items-center gap-2 opacity-30 px-2 text-gold">
                <Brain className="w-4 h-4" />
                <span className="text-[10px] font-bold uppercase tracking-widest">Insiktsvalvet</span>
              </div>
              
              {reflections.length === 0 && (
                <div className="p-8 text-center text-gold/20 italic text-xs">
                  Här sparas dina svar så att systemet kan lära känna dig bättre.
                </div>
              )}

              {reflections.map((ref) => (
                <BentoCard key={ref.id} className="bg-deep-green-mid/60 border-gold/5 space-y-3">
                  <div className="flex justify-between items-center text-[10px] font-bold text-gold/60">
                    <span>Av: {ref.agentName}</span>
                    <span className="opacity-40">{ref.date}</span>
                  </div>
                  <div className="space-y-2">
                    <p className="text-[11px] text-gold/40 italic">Q: {ref.question}</p>
                    <p className="text-sm font-medium text-gold/80 border-l-2 border-gold/20 pl-3 py-1">
                      {ref.answer}
                    </p>
                  </div>
                </BentoCard>
              ))}
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
</file>

