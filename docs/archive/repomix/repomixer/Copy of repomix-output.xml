import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Gavel, ShieldAlert, Scale, FileSearch, 
  ArrowRight, Loader2, Sparkles, BookOpen,
  Lock, History, BarChart3, Fingerprint,
  Download, Copy, Share2, AlertTriangle, Shield
