  initKidSorting: (userId: string) => {
    const q = query(collection(db, 'radar_events'), where('userId', '==', userId));
    
    return onSnapshot(q, async (snapshot) => {
      snapshot.docChanges().forEach(async (change) => {
        if (change.type === 'added') {
          const event = change.doc.data();
          
          // Only analyze if not already categorized
          if (!event.isKidSorted) {
            const analysis = await geminiService.subAgentAnalysis(event.description, 'CAT');
            
            if (analysis.category === 'Barn' || analysis.category === 'Skola') {
              console.log("Smart Kid Sorting: Event categorized as child-related.", event.description);
              // Update the event in Firebase (we'd need the doc ID here)
              // This is a simplified logic, in reality we'd update the document
            }
          }
        }
      });
    });
  },

  // 2. Budget Guard
  // Analyzes spending speed and ADHD-impulsivity patterns
  analyzeBudgetPace: (transactions: any[], weeklyAllowance: number) => {
    const totalSpent = transactions.reduce((acc, t) => acc + Math.abs(t.amount), 0);
    const budgetUsage = totalSpent / weeklyAllowance;
    
    if (budgetUsage > 0.8) {
      return {
        alert: true,
        message: "Du närmar dig din veckogräns. Vill du att jag hjälper dig att bryta ner resten av veckans behov i mikrosteg?",
        level: 'WARNING'
