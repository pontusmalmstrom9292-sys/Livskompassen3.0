      <button id="cancelBtn" onclick="closeModal()" style="background:none; border:none; color: var(--text-muted); margin-top: 1.5rem; cursor: pointer; width: 100%; font-size: 0.9rem;">Avbryt</button>
    </div>
  </div>

  <nav class="bottom-nav">
    <div class="nav-item active">🏠</div>
    <div class="nav-item">📚</div>
    <div class="nav-item">🔐</div>
    <div class="nav-item">⚙️</div>
  </nav>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>

  <script>
    let currentModule = '';
    let lighthouseTimer;

    // Mouse/Touch Interaction for Cards
    document.querySelectorAll('.module-card').forEach(card => {
      card.onmousemove = e => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--x', (e.clientX - rect.left) + 'px');
        card.style.setProperty('--y', (e.clientY - rect.top) + 'px');
      };
    });

    function openModal(id, title, hint) {
      currentModule = id;
      document.getElementById('modal-title').innerText = title;
      document.getElementById('modal-hint').innerText = hint;
      document.getElementById('modal').style.display = 'flex';
      setTimeout(() => document.getElementById('modal').classList.add('active'), 10);
      
      document.getElementById('analysis-container').style.display = 'none';
      document.getElementById('actionBtn').style.display = 'block';
      document.getElementById('userInput').style.display = 'block';
      document.getElementById('userInput').value = '';
    }

    function closeModal() {
      document.getElementById('modal').classList.remove('active');
      setTimeout(() => document.getElementById('modal').style.display = 'none', 300);
    }

    function handleOverlayClick(e) {
      if(e.target.id === 'modal') closeModal();
    }

    function runAnalysis() {
      const text = document.getElementById('userInput').value;
      if(!text) return;

      document.getElementById('loading').style.display = 'block';
      document.getElementById('actionBtn').style.display = 'none';
      document.getElementById('userInput').style.display = 'none';
      
      google.script.run.withSuccessHandler(res => {
        document.getElementById('loading').style.display = 'none';
        
        if(res.error) {
           alert("Problem vid anslutning: " + res.error);
           document.getElementById('actionBtn').style.display = 'block';
           document.getElementById('userInput').style.display = 'block';
           return;
        }

        document.getElementById('analysis-container').style.display = 'block';
        document.getElementById('analysisText').innerText = res.analysis || "Inget mönster upptäckt.";
        document.getElementById('responseText').innerText = res.draft || res.biff || "Ingen respons krävdes.";
      }).askAgent(currentModule, text);
    }

    // Lighthouse (Fyren) Security Logic
    function startLighthouseTimer() {
      lighthouseTimer = setTimeout(() => {
        const pin = prompt("Verklighetsvalv — Ange behörighetskod:");
        if(pin === "1234") { // Mock PIN
          alert("Valvet öppnat. Initierar Zero Footprint miljö.");
        }
      }, 3000);
    }

    function clearLighthouseTimer() {
      clearTimeout(lighthouseTimer);
    }
  </script>
</body>
</html>
