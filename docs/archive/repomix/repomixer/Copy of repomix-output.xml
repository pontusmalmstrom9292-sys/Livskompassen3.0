        console.error("AI Strength msg failed:", err);
        // Fallback-meddelanden om AI:n sviker
        if (actionOrMsg === 'VAULT_SAVE') finalMsg = "Sanningen är låst och din integritet är bevarad.";
        if (actionOrMsg === 'IMPULSE_AVOIDED') finalMsg = "Du prioriterade din framtida trygghet över stundens impuls.";
      }
    }

    setActiveStrengthMessage(finalMsg);
    setTimeout(() => setActiveStrengthMessage(null), 6000);
  };

  return (
    <LearningContext.Provider value={{ 
      snippets, activeSnippet, setActiveSnippet, 
      activeStrengthMessage, triggerStrengthMessage,
      isLearningMode, toggleLearningMode 
    }}>
      {children}
    </LearningContext.Provider>
  );
};

export const useLearning = () => {
  const context = useContext(LearningContext);
  if (!context) throw new Error('useLearning must be used within a LearningProvider');
  return context;
};
