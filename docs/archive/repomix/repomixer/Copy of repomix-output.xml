import React from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { X, Lightbulb, Shield, Zap, Brain, Info } from 'lucide-react';
import { useLearning } from '../contexts/LearningContext';

const ICON_MAP = {
  'INFO': Info,
  'SHIELD': Shield,
  'ZAP': Zap,
  'LIGHTBULB': Lightbulb,
  'BRAIN': Brain
};

const CATEGORY_COLORS = {
  'STRATEGY': 'text-amber-400 border-amber-500/20 bg-amber-500/5',
  'GUIDE': 'text-teal-400 border-teal-500/20 bg-teal-500/5',
  'SAFETY': 'text-indigo-400 border-indigo-500/20 bg-indigo-500/5',
  'GROWTH': 'text-emerald-400 border-emerald-500/20 bg-emerald-500/5'
};

export const LearningManual: React.FC = () => {
  const { activeSnippet, setActiveSnippet } = useLearning();

  if (!activeSnippet) return null;

  const Icon = ICON_MAP[activeSnippet.iconType] || Info;
  const colorClasses = CATEGORY_COLORS[activeSnippet.category] || CATEGORY_COLORS['STRATEGY'];

  return (
    <AnimatePresence>
      <motion.div 
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        className="fixed inset-0 z-[100] flex items-center justify-center p-6 backdrop-blur-md bg-black/60"
        onClick={() => setActiveSnippet(null)}
