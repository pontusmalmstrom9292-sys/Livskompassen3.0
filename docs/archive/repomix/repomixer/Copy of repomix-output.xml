interface ActorDeepDiveProps {
  actor: any;
  onClose: () => void;
}

export const ActorDeepDive: React.FC<ActorDeepDiveProps> = ({ actor, onClose }) => {
  const [profile, setProfile] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [events, setEvents] = useState<any[]>([]);

  useEffect(() => {
    const loadProfile = async () => {
      try {
        const fetchedEvents = await radarService.getEvents("", actor.id);
        setEvents(fetchedEvents);
        
        const res = await geminiService.generateActorProfile(actor, fetchedEvents);
        const data = JSON.parse(res.replace(/```json/g, '').replace(/```/g, '').trim());
        setProfile(data);
      } catch (error) {
        console.error("Failed to load deep dive:", error);
      } finally {
        setLoading(false);
      }
    };
    loadProfile();
