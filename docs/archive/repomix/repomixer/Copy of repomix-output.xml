<file path="livskompassen-trasig-1/src/pages/VaultPage.tsx">
import { useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { ShieldAlert, Lock, Lighthouse, Map, Database, FileText, BrainCircuit } from 'lucide-react';
import { cn } from '../lib/utils';

// Sub-Pages for Vault
import { VaultMap } from '../components/VaultMap';
import { VaultArchive } from '../components/VaultArchive';
import { KnowledgePage } from './KnowledgePage';
import { VaultEntities } from '../components/VaultEntities';
import { VaultDocumentation } from '../components/VaultDocumentation';

interface VaultPageProps {
  user: any;
}

type VaultModule = 'DOC' | 'MAP' | 'ARCHIVE' | 'CASES' | 'ENTITIES';

export function VaultPage({ user }: VaultPageProps) {
  const [isUnlocked, setIsUnlocked] = useState(false);
  const [pin, setPin] = useState('');
  const [showPinModal, setShowPinModal] = useState(false);
  const [activeModule, setActiveModule] = useState<VaultModule>('DOC');

  // Hidden trigger state
  const pressTimer = useRef<NodeJS.Timeout | null>(null);
  const [isPressing, setIsPressing] = useState(false);

  // Shake to hide (Panik-stängning)
  useEffect(() => {
    if (!isUnlocked) return;
    
    const handleMotion = (event: DeviceMotionEvent) => {
      if (event.acceleration) {
        const { x, y, z } = event.acceleration;
        const acceleration = Math.sqrt((x || 0) ** 2 + (y || 0) ** 2 + (z || 0) ** 2);
        if (acceleration > 15) {
          setIsUnlocked(false);
          setActiveModule('MAP');
        }
      }
    };

    window.addEventListener('devicemotion', handleMotion);
    return () => window.removeEventListener('devicemotion', handleMotion);
  }, [isUnlocked]);

  const handleStartPress = () => {
    setIsPressing(true);
    pressTimer.current = setTimeout(() => {
      setShowPinModal(true);
      setIsPressing(false);
    }, 3000);
  };

  const handleEndPress = () => {
    if (pressTimer.current) {
      clearTimeout(pressTimer.current);
      setIsPressing(false);
    }
  };

  const handlePinSubmit = () => {
    if (pin === '6469') {
      setIsUnlocked(true);
      setShowPinModal(false);
      setPin('');
    } else {
      setPin('');
      alert('Fel kod');
    }
  };

  if (!isUnlocked) {
    return (
      <div className="min-h-screen bg-obsidian flex flex-col items-center justify-center p-6 relative overflow-hidden">
        {/* Security Glows */}
        <div className="absolute inset-0 pointer-events-none overflow-hidden">
          <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-rose-500/5 blur-[150px] rounded-full" />
        </div>

        <motion.button
          onMouseDown={handleStartPress}
          onMouseUp={handleEndPress}
          onMouseLeave={handleEndPress}
          onTouchStart={handleStartPress}
          onTouchEnd={handleEndPress}
          animate={{ scale: isPressing ? 0.9 : 1 }}
          className="w-40 h-40 rounded-[4rem] glass-card flex items-center justify-center relative overflow-hidden group shadow-2xl shadow-rose-900/20"
        >
          <Lighthouse className="w-16 h-16 text-rose-400 opacity-20 group-hover:opacity-40 transition-opacity" />
          {isPressing && (
            <motion.div
              initial={{ height: 0 }}
              animate={{ height: '100%' }}
              transition={{ duration: 3, ease: 'linear' }}
              className="absolute bottom-0 left-0 right-0 bg-rose-500/10 -z-10"
            />
          )}
        </motion.button>
        
        <p className="mt-12 text-[10px] uppercase tracking-[0.5em] font-black text-rose-500/40 text-center">
          Identifiering krävs • Håll in Fyren
        </p>

        <AnimatePresence>
          {showPinModal && (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="fixed inset-0 bg-obsidian/90 backdrop-blur-3xl z-[100] flex items-center justify-center p-6"
            >
              <div className="w-full max-w-xs glass-card p-10 rounded-[3rem] flex flex-col items-center border-rose-500/10">
                <Lock className="w-8 h-8 text-rose-400 mb-8" />
                <h3 className="text-lg mb-10 text-white font-outfit font-light tracking-tight">Ange Säkerhetskod</h3>
                
                <div className="flex gap-4 mb-10">
                  {[...Array(4)].map((_, i) => (
                    <motion.div 
                      key={i} 
                      animate={pin.length > i ? { scale: [1, 1.2, 1] } : {}}
                      className={`w-4 h-4 rounded-full border ${pin.length > i ? 'bg-rose-500 border-rose-400' : 'bg-white/5 border-white/10'}`} 
                    />
                  ))}
                </div>

                <div className="grid grid-cols-3 gap-5 w-full">
                  {[1,2,3,4,5,6,7,8,9, 'X', 0, 'OK'].map((val) => (
                    <button
                      key={val.toString()}
                      onClick={() => {
                        if (val === 'X') setPin(pin.slice(0, -1));
                        else if (val === 'OK') handlePinSubmit();
                        else if (pin.length < 4) setPin(pin + val);
                      }}
                      className="h-16 rounded-[2rem] bg-white/5 hover:bg-white/10 active:scale-90 transition-all flex items-center justify-center text-xl font-outfit font-bold text-slate-300"
                    >
                      {val}
                    </button>
                  ))}
                </div>

                <button onClick={() => setShowPinModal(false)} className="mt-10 text-[10px] font-black uppercase tracking-widest text-slate-600 hover:text-slate-400 transition-colors">Avbryt Session</button>
              </div>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-obsidian text-slate-200 font-inter pb-20">
      
      {/* Top Header */}
      <header className="sticky top-0 z-40 bg-obsidian/40 backdrop-blur-3xl border-b border-white/5 px-6 py-5 flex justify-between items-center">
        <div className="flex items-center gap-4">
          <div className="w-10 h-10 rounded-2xl bg-rose-500/10 flex items-center justify-center border border-rose-500/20">
            <Lighthouse className="w-5 h-5 text-rose-400" />
          </div>
          <div>
            <h1 className="text-sm font-black uppercase tracking-widest text-white leading-tight">Verklighetsvalvet</h1>
            <p className="text-[10px] text-rose-500 font-black uppercase tracking-tighter opacity-60">System Integrity Active</p>
          </div>
        </div>
        <button onClick={() => setIsUnlocked(false)} className="h-11 px-6 bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2 border border-rose-500/20 active:scale-95">
          <Lock className="w-3.5 h-3.5" /> Lås Valvet
        </button>
      </header>

      <main className="max-w-6xl mx-auto px-6 pt-8 space-y-10">
        
        {/* Navigation Tabs */}
        <div className="flex bg-black/40 backdrop-blur-2xl p-1.5 rounded-[2rem] border border-white/5 shadow-2xl overflow-x-auto no-scrollbar">
          {[
            { id: 'DOC', label: 'Dokumentera', icon: FileText, color: '#FB7185' },
            { id: 'MAP', label: 'Karta', icon: Map, color: '#818CF8' },
            { id: 'ARCHIVE', label: 'Arkiv', icon: Database, color: '#A78BFA' },
            { id: 'CASES', label: 'Akter', icon: FileText, color: '#2DD4BF' },
            { id: 'ENTITIES', label: 'Personer', icon: BrainCircuit, color: '#FDE68A' },
          ].map((mod) => (
            <button
              key={mod.id}
              onClick={() => setActiveModule(mod.id as any)}
              className={cn(
                "flex-1 min-w-[120px] flex items-center justify-center gap-2.5 py-4 px-4 rounded-2xl transition-all duration-500",
                activeModule === mod.id 
                  ? "bg-white/8 text-white shadow-inner border border-white/10" 
                  : "text-slate-500 hover:text-slate-300"
              )}
            >
              <mod.icon 
                className="w-4 h-4 transition-all" 
                style={{ color: activeModule === mod.id ? mod.color : undefined }}
              />
              <span className="text-[9px] font-black uppercase tracking-widest">{mod.label}</span>
            </button>
          ))}
        </div>

        {/* Content Area */}
        <div className="min-h-[500px]">
          {activeModule === 'DOC' && (
            <VaultDocumentation 
              onPanic={() => {
                setIsUnlocked(false);
                // We need to trigger navigation to HOME in App.tsx
                // For now, we'll just relock, but ideally we'd pass onNavigate
                window.location.hash = 'HOME'; // Hacky way if no state passed
              }} 
            />
          )}
          {activeModule === 'MAP' && <VaultMap user={user} onNavigate={setActiveModule} />}
          {activeModule === 'ARCHIVE' && (
            <div className="-mx-6 lg:-mx-12 -mt-8">
              <VaultArchive userId={user.uid} />
            </div>
          )}
          {activeModule === 'CASES' && (
             <div className="-mx-6 lg:-mx-12 -mt-8">
               <KnowledgePage user={user} />
             </div>
          )}
          {activeModule === 'ENTITIES' && <VaultEntities />}
        </div>

      </main>
    </div>
  );
}
</file>

