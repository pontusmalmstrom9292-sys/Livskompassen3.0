                        <div>
                          <p className={cn(
                            "text-base font-outfit tracking-tight",
                            task.completed ? "text-slate-500 line-through" : "text-white"
                          )}>{task.title}</p>
                          <div className="flex items-center gap-4 mt-1">
                             <span className="text-[10px] text-slate-500 font-bold uppercase tracking-widest flex items-center gap-1">
                                <Clock className="w-3 h-3" /> {task.time}
                             </span>
                             <span className={cn(
                               "text-[8px] px-2 py-0.5 rounded uppercase font-black tracking-tighter",
                               task.priority === 'HÖG' ? "bg-rose-500/10 text-rose-400" : "bg-indigo-500/10 text-indigo-400"
                             )}>{task.priority}</span>
                          </div>
                        </div>
                      </div>
                      
                      {!task.completed && (
                        <div className="flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
                           <div className="text-right">
                              <p className="text-[8px] text-slate-500 uppercase font-black">Mental Last</p>
                              <p className="text-xs text-indigo-400 font-bold">{task.brainEnergy} CP</p>
                           </div>
                           <ChevronRight className="w-5 h-5 text-slate-700" />
                        </div>
                      )}
                    </motion.div>
                  ))}
               </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/Silo3View.tsx">
import React, { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { ShieldAlert, BookOpen, Lock } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { geminiService } from '../services/geminiService';

export function Silo3View({ user }: { user: any }) {
  const [logs, setLogs] = useState<any[]>([]);
  const [action, setAction] = useState('');
  const [truth, setTruth] = useState('');
  const [isSaving, setIsSaving] = useState(false);
  const [mirroring, setMirroring] = useState<{feedback: string, groundingPoint: string} | null>(null);

  useEffect(() => {
    if (!user) return;
    const q = query(
      collection(db, 'vault'),
      where('userId', '==', user.uid),
      // where('folderId', '==', 'ARKIV'), // Borttagen för tillfället då Arkiv kanske inte följer med
      orderBy('createdAt', 'desc')
    );
    return onSnapshot(q, (snapshot) => {
      setLogs(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
    });
  }, [user]);

  const handleSave = async () => {
    if (!action || !truth) return;
    setIsSaving(true);
    
    // 1. Lås in sanningen
    await addDoc(collection(db, 'vault'), {
      userId: user.uid,
      category: 'JURIDIK',
      action,
      truth,
      isLocked: true,
      createdAt: serverTimestamp()
    });

    // 2. Kör speglingsanalys
    const result = await geminiService.mirroringAnalysis(action, truth);
    setMirroring(result);
    
    setAction('');
    setTruth('');
    setIsSaving(false);
  };

  return (
    <div className="space-y-6">
      <BentoCard icon="⚖️" title="Jurisdiktionsarkivet (Silo 3)">
        <p className="text-xs text-gold/60 mb-6">Oföränderlig loggning av manipulation och gaslighting.</p>
        <div className="space-y-4">
          <textarea
            placeholder="Vad skedde? (Handlingen)"
            value={action}
            onChange={(e) => setAction(e.target.value)}
            className="w-full h-20 rounded-2xl bg-deep-green-dark/40 border border-red-900/30 p-4 text-sm text-red-100 outline-none"
          />
          <textarea
            placeholder="Objektiv Sanning (Det som inte kan ändras)"
            value={truth}
            onChange={(e) => setTruth(e.target.value)}
            className="w-full h-24 rounded-2xl bg-deep-green-dark/40 border border-gold/30 p-4 text-sm text-gold outline-none"
          />
          <Button onClick={handleSave} disabled={isSaving} className="w-full bg-red-900/50 text-red-100 border border-red-900/50">
            {isSaving ? 'Låser...' : 'Kryptografera & Lås In'}
          </Button>
        </div>
      </BentoCard>

      {/* Mirroring feedback */}
      {mirroring && (
          <BentoCard title="Speglings-Agentens analys" icon="🧠">
              <p className="text-xs text-gold/80 mb-2">{mirroring.feedback}</p>
              <div className="bg-gold/10 p-3 rounded-lg border border-gold/20">
                  <p className="text-[10px] text-gold uppercase underline">Grundningspunkt:</p>
                  <p className="text-sm font-bold text-gold">{mirroring.groundingPoint}</p>
              </div>
          </BentoCard>
      )}

      <div className="space-y-4">
        {logs.map(log => (
          <div key={log.id} className="p-4 bg-deep-green-dark/40 rounded-2xl border border-gold/10">
            <div className="flex justify-between text-[9px] text-gold/40 uppercase mb-2">
              <span>{log.createdAt?.toDate().toLocaleDateString()}</span>
              <span>LÅST</span>
            </div>
            <p className="text-xs text-gold/80 mb-2">{log.action}</p>
            <p className="text-xs italic text-gold">{log.truth}</p>
          </div>
        ))}
      </div>
    </div>
  );
}
</file>

<file path="livskompassen-trasig-1/src/components/StrategicBriefing.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { geminiService } from '../services/geminiService';
import { radarService } from '../services/radarService';
import { db } from '../lib/firebase';
import { collection, query, where, orderBy, limit, onSnapshot, doc, addDoc, serverTimestamp } from 'firebase/firestore';
import { Sparkles, ShieldCheck, ArrowRight, Loader2, Zap, Brain, ShieldAlert, RefreshCw, Anchor } from 'lucide-react';
import { cn } from '../lib/utils';
import { getDocs } from 'firebase/firestore';
import { shieldApi, AnalysisResponse } from '../services/apiService';

export const StrategicBriefing = ({ userId }: { userId: string }) => {
  const [brief, setBrief] = useState<any>(null);
  const [shieldAnalysis, setShieldAnalysis] = useState<AnalysisResponse | null>(null);
  const [loading, setLoading] = useState(true);
  const [isGenerating, setIsGenerating] = useState(false);

  // Data State
  const [events, setEvents] = useState<any[]>([]);
  const [diary, setDiary] = useState<any[]>([]);
  const [vibe, setVibe] = useState<any>(null);
  const [coreValues, setCoreValues] = useState<string[]>([]);
  const [chronos, setChronos] = useState<any>(null);

  useEffect(() => {
    if (!userId) return;

    // 1. Fetch Radar Events
    const qRadar = query(collection(db, 'events'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(5));
    const unsubRadar = onSnapshot(qRadar, (snap) => setEvents(snap.docs.map(d => d.data())));

    // 2. Fetch Diary Entries
    const qDiary = query(collection(db, 'diary_entries'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(3));
    const unsubDiary = onSnapshot(qDiary, (snap) => setDiary(snap.docs.map(d => d.data())));

    // 3. Fetch Daily Vibe
    const unsubVibe = onSnapshot(doc(db, 'daily_vibes', userId), (snap) => setVibe(snap.data()));

    // 4. Fetch Core Values
    const qValues = query(collection(db, 'core_values'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(1));
    const unsubValues = onSnapshot(qValues, (snap) => {
      if (!snap.empty) setCoreValues(snap.docs[0].data().values);
    });

    // 5. Fetch Latest Chronos Analysis (to feed into briefing)
    const runQuickChronos = async () => {
      const q = query(collection(db, 'events'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(30));
      const snap = await getDocs(q);
      const events = snap.docs.map(d => d.data());
      if (events.length >= 3) {
        const patterns = await (geminiService as any).analyzeChronosPatterns(events);
        setChronos(patterns);
      }
    };
    runQuickChronos();

    return () => {
      unsubRadar();
      unsubDiary();
      unsubVibe();
      unsubValues();
    };
  }, [userId]);

  const generateBrief = async () => {
    setIsGenerating(true);
    try {
      // 1. Synthesize general insight using client-side Gemini
      const result = await geminiService.generateStrategicInsight(events, diary, vibe, coreValues, chronos);
      setBrief(result);
      
      // 2. Perform Deep Grounded Analysis using Python Backend (Sanningens Sköld)
      const aggregatedContent = `
        Senaste händelser: ${events.map(e => e.title).join(', ')}.
        Reflektioner: ${diary.map(d => d.content).join('. ')}.
        Mående: Stress ${vibe?.stressLevel}, Energi ${vibe?.energyLevel}.
      `;
      
      try {
        const groundedRes = await shieldApi.analyze({
          content: aggregatedContent,
          mode: 'PATTERN'
        });
        setShieldAnalysis(groundedRes);
      } catch (shieldError) {
        console.warn("Shield Analysis skipped or failed:", shieldError);
      }

      // Save to Firestore
      await addDoc(collection(db, 'strategic_briefings'), {
        userId,
        ...result,
        shieldAnalysis: groundedRes,
        timestamp: serverTimestamp()
      });
    } catch (error) {
      console.error("Briefing failed:", error);
    } finally {
      setIsGenerating(false);
      setLoading(false);
    }
  };

  // Autogenerera vid start om vi har data
  useEffect(() => {
    if (events.length > 0 && !brief && !isGenerating) {
      generateBrief();
    }
  }, [events, diary, vibe, chronos]);

  if (loading && !brief) {
    return (
      <div className="h-64 flex items-center justify-center bg-[#020617]/40 border border-white/5 rounded-[2.5rem] animate-pulse">
        <Loader2 className="w-8 h-8 text-indigo-500 animate-spin" />
      </div>
    );
  }

  return (
    <div className="relative group">
      {/* Background Glow */}
      <div className="absolute -inset-1 bg-gradient-to-r from-indigo-500/10 via-teal-500/10 to-purple-500/20 rounded-[2.5rem] blur-xl opacity-50 group-hover:opacity-100 transition-all duration-1000" />
      
      <div className="relative bg-[#020617]/80 border border-white/10 rounded-[2.5rem] p-8 backdrop-blur-2xl shadow-2xl overflow-hidden">
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
          <div className="flex items-center gap-4">
            <div className="p-3 bg-indigo-500/10 rounded-2xl border border-indigo-500/20">
              <Sparkles className="w-6 h-6 text-indigo-400" />
            </div>
            <div>
              <h3 className="text-xl text-white font-outfit">Strategisk Briefing</h3>
              <p className="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Över-Arkivariens Rapport</p>
            </div>
          </div>

          <div className="flex items-center gap-3">
            {brief?.weatherForecast && (
              <div className={cn(
                "px-4 py-2 rounded-xl border flex items-center gap-2",
                brief.weatherForecast.status === 'STORM' ? "bg-rose-500/10 border-rose-500/20 text-rose-400" :
                brief.weatherForecast.status === 'MOLNIGT' ? "bg-amber-500/10 border-amber-500/20 text-amber-400" :
                "bg-teal-500/10 border-teal-500/20 text-teal-400"
              )}>
                <Zap className="w-3.5 h-3.5" />
                <div className="flex flex-col">
                  <span className="text-[8px] font-black uppercase tracking-tighter">Psykologisk Prognos</span>
                  <span className="text-[10px] font-bold leading-tight">{brief.weatherForecast.warning || brief.weatherForecast.status}</span>
                </div>
              </div>
            )}
            <button 
              onClick={generateBrief}
              disabled={isGenerating}
              className="p-3 bg-white/5 hover:bg-white/10 rounded-xl border border-white/10 transition-all active:scale-95"
            >
              {isGenerating ? <Loader2 className="w-4 h-4 animate-spin text-indigo-400" /> : <RefreshCw className="w-4 h-4 text-indigo-400" />}
            </button>
          </div>
        </div>

        {brief && (
          <div className="space-y-8 animate-in fade-in duration-700">
            {/* Master Brief */}
            <p className="text-lg text-slate-200 font-inter font-light italic leading-relaxed border-l-2 border-indigo-500/30 pl-6">
              "{brief.masterBrief}"
            </p>

            {/* Strategic Moves */}
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              {brief.strategicMoves.map((move: any, i: number) => (
                <div key={i} className="p-6 bg-white/[0.02] border border-white/5 rounded-[2rem] hover:bg-white/[0.04] transition-all group/move">
                  <div className="w-10 h-10 rounded-2xl bg-indigo-500/10 flex items-center justify-center mb-4 group-hover/move:bg-indigo-500/20 transition-colors">
                    <span className="text-[11px] font-black text-indigo-400">{i + 1}</span>
                  </div>
                  <h4 className="text-xs font-bold text-white uppercase tracking-widest mb-2 leading-tight">{move.title}</h4>
                  <p className="text-[11px] text-slate-400 leading-relaxed mb-4">{move.action}</p>
                  <div className="pt-4 border-t border-white/5">
                    <p className="text-[10px] text-slate-600 italic font-inter">{move.why}</p>
                  </div>
                </div>
              ))}
            </div>

            {/* Grounding Anchor (Kärnvärden) */}
            {brief.anchorPhrase && (
              <div className="p-6 bg-teal-500/5 border border-teal-500/10 rounded-[2rem] flex items-center gap-4">
                <div className="w-10 h-10 rounded-full bg-teal-500/10 flex items-center justify-center border border-teal-500/20">
                  <Anchor className="w-5 h-5 text-teal-400" />
                </div>
                <p className="text-sm text-teal-100 font-inter italic">
                  "{brief.anchorPhrase}"
                </p>
              </div>
            )}

            {/* Grounded Strategic Insight (From Shield API) */}
            <AnimatePresence>
              {shieldAnalysis && (
                <motion.div 
