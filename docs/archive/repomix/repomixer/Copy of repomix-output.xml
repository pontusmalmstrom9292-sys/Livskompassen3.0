                </div>
              </BentoCard>
            );
          })}
        </div>
      </div>

      {/* Recent Activity */}
      <BentoCard delay={0.3} className="bg-deep-green-mid/80 border-gold/30">
        <div className="flex justify-between items-center mb-6">
           <div className="flex items-center gap-2 text-gold opacity-40">
             <PieChart className="w-4 h-4" />
             <h3 className="text-[10px] font-bold uppercase tracking-widest">Kärn-Logg</h3>
           </div>
           <button className="text-[8px] font-black uppercase text-gold/20 border border-gold/10 px-2 py-0.5 rounded">Realtid</button>
        </div>
        <div className="space-y-2">
          {transactions.length === 0 && (
            <p className="text-center py-8 text-gold/20 text-xs italic">Inga transaktioner loggade än.</p>
          )}
          {transactions.slice(0, 10).map((tx) => (
            <div key={tx.id} className="flex items-center justify-between p-3 bg-deep-green-dark/20 rounded-2xl border border-gold/5 hover:bg-deep-green-dark/40 transition-colors">
              <div className="flex items-center gap-3 text-gold">
                <div className={cn("w-1 h-6 rounded-full", tx.amount < 0 ? 'bg-expense' : 'bg-income')} />
                <div className="flex flex-col">
                   <span className="text-sm font-medium">{tx.description}</span>
                   <span className="text-[8px] opacity-40 uppercase tracking-widest">{tx.category}</span>
                </div>
              </div>
              <span className={cn("text-sm font-display", tx.amount < 0 ? 'text-expense' : 'text-income')}>
                {tx.amount > 0 ? '+' : ''}{tx.amount.toLocaleString()} kr
              </span>
            </div>
          ))}
        </div>
      </BentoCard>
    </div>
  );
}
</file>

<file path="livskompassen-trasig/src/pages/KnowledgePage.tsx">
import { BentoCard } from '../components/ui/BentoCard';
import { Folder, FileText, Search, Plus, ExternalLink, HardDrive, RefreshCw, ChevronLeft, Download, Shield, BrainCircuit, Zap } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { KBDocument } from '../types';
import { geminiService } from '../services/geminiService';
import { Button } from '../components/ui/button';
import { cn } from '../lib/utils';
import Markdown from 'react-markdown';

interface KnowledgePageProps {
  user: any;
}

export function KnowledgePage({ user }: KnowledgePageProps) {
  const [searchQuery, setSearchQuery] = useState('');
  const [documents, setDocuments] = useState<KBDocument[]>([]);
  const [selectedDoc, setSelectedDoc] = useState<KBDocument | null>(null);
  const [isCreating, setIsCreating] = useState(false);
  const [isGenerating, setIsGenerating] = useState(false);
  const [isAnalysingIntense, setIsAnalysingIntense] = useState(false);
  const [analysisResult, setAnalysisResult] = useState<any | null>(null);
  const [newDoc, setNewDoc] = useState({ title: '', content: '', folderId: 'arkiv' });

  useEffect(() => {
    if (!user) return;

    const q = query(
      collection(db, 'kb_docs'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribe = onSnapshot(q, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      } as KBDocument));
      setDocuments(docs);
    }, (error) => {
      console.error("Knowledge docs listen error", error);
    });

    return unsubscribe;
  }, [user]);

  const handleSaveDoc = async () => {
    if (!newDoc.title || !newDoc.content || !user) return;
    try {
      // Intelligens-Agenten klassificerar automatiskt
      const { folderId, importance, tags } = await geminiService.classifyDocument(newDoc.content);
      
      await addDoc(collection(db, 'kb_docs'), {
        ...newDoc,
        folderId,
        importance,
        tags,
        userId: user.uid,
        createdAt: serverTimestamp()
      });
      setIsCreating(false);
      setNewDoc({ title: '', content: '', folderId: 'ARKIV' });
    } catch (e) {
      console.error("Error saving doc", e);
    }
  };

  const generateDossier = async (agentName: string) => {
    setIsGenerating(true);
    try {
      const dossier = await geminiService.generateTechnicalDossier(agentName, "Systemkontext: LivsKompassen V3.1. Fokus på strategiskt försvar.");
      setNewDoc({
        title: `Teknisk Analys: ${agentName}`,
        content: dossier,
        folderId: 'arkiv'
      });
      setIsCreating(true);
    } catch (e) {
      console.error("Dossier generation failed", e);
    } finally {
      setIsGenerating(false);
    }
  };

  const handleIntenseAnalysis = async () => {
    if (!newDoc.content) return;
    setIsAnalysingIntense(true);
    setAnalysisResult(null);
    try {
      const context = documents.map(d => d.title).join(', ');
      const result = await geminiService.intenseAnalysis(newDoc.content, context);
      setAnalysisResult(result);
    } catch (e) {
      console.error("Intense analysis failed", e);
    } finally {
      setIsAnalysingIntense(false);
    }
  };

  return (
    <div className="space-y-6">
      <AnimatePresence mode="wait">
        {selectedDoc ? (
          <motion.div
            key="reader"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-4"
          >
            <button 
              onClick={() => setSelectedDoc(null)}
              className="flex items-center gap-2 text-xs font-bold uppercase opacity-40 hover:opacity-100 transition-all"
            >
              <ChevronLeft className="w-4 h-4" /> Tillbaka till Arkivet
            </button>

            <BentoCard className="bg-deep-green-mid/80 min-h-[60vh] p-8 overflow-y-auto border-gold/30">
              <div className="flex justify-between items-start mb-8 border-b border-gold/20 pb-6">
                <div>
                  <h2 className="text-xl font-display text-gold mb-2">{selectedDoc.title}</h2>
                  <p className="text-[10px] uppercase font-bold tracking-widest text-gold/40">Editorial Technical Dossier</p>
                </div>
                <button onClick={() => window.print()} className="p-2 rounded-xl bg-gold/10 text-gold hover:bg-gold/20 transition-all">
                  <Download className="w-5 h-5" />
                </button>
              </div>
              <div className="prose prose-invert prose-sm max-w-none text-gold/80 leading-relaxed dossier-body">
                <Markdown>{selectedDoc.content}</Markdown>
              </div>
            </BentoCard>
          </motion.div>
        ) : isCreating ? (
          <motion.div
            key="editor"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="space-y-4"
          >
            <BentoCard className="bg-deep-green-mid/80 border-gold/30">
              <h3 className="text-sm font-bold uppercase tracking-widest text-gold/40 mb-6">Arkivera Analys</h3>
              <div className="space-y-4">
                <input 
                  type="text" 
                  placeholder="Titel (t.ex. Analys från NotebookLM)"
                  value={newDoc.title}
                  onChange={(e) => setNewDoc(prev => ({ ...prev, title: e.target.value }))}
                  className="w-full h-12 bg-deep-green-dark/40 border border-gold/20 rounded-2xl px-4 text-sm text-gold outline-none focus:border-gold/50 placeholder:text-gold/20"
                />
                <textarea 
                  placeholder="Klistra in eller ladda upp text här för att arkivera – eller välj 'Intensiv Analys' för att granska mot systemet..."
                  value={newDoc.content}
                  onChange={(e) => setNewDoc(prev => ({ ...prev, content: e.target.value }))}
                  className="w-full h-64 bg-deep-green-dark/40 border border-gold/20 rounded-2xl p-4 text-sm text-gold outline-none focus:border-gold/50 resize-none font-mono text-xs placeholder:text-gold/20"
                />

                <AnimatePresence>
                  {analysisResult && (
                    <motion.div
                      initial={{ opacity: 0, y: 10 }}
                      animate={{ opacity: 1, y: 0 }}
                      className="p-4 bg-gold/5 rounded-2xl border border-gold/20 space-y-3"
                    >
                      <div className="flex justify-between items-center">
                        <h4 className="text-[10px] font-bold uppercase tracking-widest text-gold">Resultat: Intensiv Analys</h4>
                        <div className="px-2 py-0.5 bg-gold/20 text-gold text-[8px] rounded font-black">
                          Grounding: {analysisResult.groundingScore}%
                        </div>
                      </div>
                      
                      <p className="text-xs text-gold/60">{analysisResult.summary}</p>
                      
                      {analysisResult.contradictions?.length > 0 && (
                        <div className="space-y-1">
                          <p className="text-[9px] font-bold text-red-400 uppercase">⚠️ Motsägelser Identifierade:</p>
                          {analysisResult.contradictions.map((c: string, idx: number) => (
                            <p key={idx} className="text-[10px] text-red-500/80 leading-tight">• {c}</p>
                          ))}
                        </div>
                      )}

                      {analysisResult.suggestDeepScan && (
                        <div className="p-3 bg-amber-400/5 border border-amber-400/20 rounded-xl">
                          <p className="text-[9px] font-bold text-amber-500 uppercase flex items-center gap-2">
                            <Zap className="w-3 h-3" /> Systemförslag: Deep Scan Session rekommenderas
                          </p>
                          <p className="text-[10px] opacity-60 mt-1 italic">{analysisResult.deepScanInstruction}</p>
                        </div>
                      )}
                    </motion.div>
                  )}
                </AnimatePresence>

                <div className="flex gap-3">
                  <Button onClick={handleSaveDoc} className="flex-1 bg-gold text-deep-green-dark">Spara i Arkivet</Button>
                  <Button 
                    disabled={isAnalysingIntense || !newDoc.content} 
                    onClick={handleIntenseAnalysis}
                    variant="secondary"
                    className="flex-1 gap-2"
                  >
                    {isAnalysingIntense ? <RefreshCw className="w-4 h-4 animate-spin" /> : <BrainCircuit className="w-4 h-4 text-gold" />}
                    <span className="text-gold">Intensiv Analys</span>
                  </Button>
                  <Button variant="ghost" onClick={() => { setIsCreating(false); setAnalysisResult(null); }}>Avbryt</Button>
                </div>
              </div>
            </BentoCard>
          </motion.div>
        ) : (
          <motion.div
            key="list"
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="space-y-6"
          >
            {/* Search & Action Bar */}
            <div className="flex gap-3">
              <div className="flex-1 relative">
                <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 opacity-30" />
                <input 
                  type="text" 
                  placeholder="Sök i arkivet..."
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  className="w-full h-12 bg-white/5 border border-white/10 rounded-2xl pl-12 pr-4 text-sm focus:outline-none focus:border-sand/50 transition-colors"
                />
              </div>
              <button 
                onClick={() => setIsCreating(true)}
                className="w-12 h-12 rounded-2xl bg-sand text-deep-midnight flex items-center justify-center shadow-lg shadow-sand/10 active:scale-95 transition-all"
              >
                <Plus className="w-5 h-5" />
              </button>
            </div>

            {/* AI Generator Hub */}
            <BentoCard highlightColor="turquoise" className="bg-turquoise/5 border-turquoise/10 py-6">
              <div className="flex items-center gap-4 mb-4">
                <div className="w-10 h-10 rounded-xl bg-turquoise/10 flex items-center justify-center">
                  <Shield className="w-5 h-5 text-turquoise" />
                </div>
                <div>
                  <h3 className="text-sm font-bold uppercase tracking-widest leading-none">Dossier-Generator</h3>
                  <p className="text-[10px] opacity-40 uppercase tracking-tighter mt-1">Producera tekniska analyser inifrån kärnan</p>
                </div>
              </div>
              <div className="grid grid-cols-2 gap-2">
                {['Gräns-Arkitekten', 'Skydds-Agenten'].map(agent => (
                  <button
                    key={agent}
                    disabled={isGenerating}
                    onClick={() => generateDossier(agent)}
                    className="h-10 rounded-xl bg-white/5 border border-white/10 text-[9px] uppercase font-bold tracking-widest hover:bg-white/10 transition-all flex items-center justify-center gap-2 group"
                  >
                    {isGenerating ? <RefreshCw className="w-3 h-3 animate-spin opacity-20" /> : <Plus className="w-3 h-3 opacity-0 group-hover:opacity-100 transition-all" />}
                    {agent}
                  </button>
                ))}
              </div>
            </BentoCard>

            {/* Drive Sync Status */}
            <BentoCard className="bg-gold/5 border-gold/10">
              <div className="flex items-center justify-between">
                <div className="flex items-center gap-3">
                  <div className="w-10 h-10 rounded-xl bg-gold/10 flex items-center justify-center">
                    <HardDrive className="w-5 h-5 text-gold" />
                  </div>
                  <div>
                    <h3 className="text-sm font-bold leading-none text-gold">Google Drive Synk</h3>
                    <p className="text-[10px] text-gold/40 uppercase tracking-widest mt-1">Läs in dokument via Cloud Connect</p>
                  </div>
                </div>
                <ExternalLink className="w-4 h-4 text-gold/30" />
              </div>
            </BentoCard>

            {/* Document List */}
            <div className="space-y-2">
              {documents.length === 0 && (
                <div className="p-12 text-center text-gold/20 italic text-sm">
                  Ditt bevisarkiv är tomt. Börja bygga din sanning här.
                </div>
              )}
              {documents
                .filter(f => f.title.toLowerCase().includes(searchQuery.toLowerCase()))
                .map((doc, i) => (
                <motion.div
                  key={doc.id}
                  initial={{ opacity: 0, x: -10 }}
                  animate={{ opacity: 1, x: 0 }}
                  transition={{ delay: i * 0.05 }}
                  onClick={() => setSelectedDoc(doc)}
                  className="group flex items-center justify-between p-4 bg-deep-green-mid/40 hover:bg-deep-green-mid/60 rounded-2xl border border-gold/5 transition-all cursor-pointer"
                >
                  <div className="flex items-center gap-4">
                    <div className="w-10 h-10 rounded-xl flex items-center justify-center bg-gold/10">
                      <FileText className="w-5 h-5 text-gold" />
                    </div>
                    <div>
                      <h4 className="text-sm font-medium text-gold/90">{doc.title}</h4>
                      <p className="text-[10px] text-gold/40 uppercase font-bold tracking-tighter">Editorial Technical Dossier</p>
                    </div>
                  </div>
                  <div className="opacity-0 group-hover:opacity-40 transition-opacity text-gold">
                    <ExternalLink className="w-4 h-4" />
                  </div>
                </motion.div>
              ))}
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <style>{`
        @media print {
          body * { visibility: hidden; }
          .dossier-body, .dossier-body * { visibility: visible; }
          .dossier-body { position: absolute; left: 0; top: 0; width: 100%; padding: 2cm; background: white; color: black; }
        }
      `}</style>
    </div>
  );
}
