          ))}
        </div>
      </BentoCard>

      {/* Systemets Grundregler */}
      <BentoCard delay={0.3} className="bg-deep-green-mid/80 border-gold/30">
        <div className="flex items-center gap-2 mb-4">
          <Clock className="w-4 h-4 text-gold/60" />
          <h3 className="font-display text-lg text-gold">Systemets Grundregler</h3>
        </div>
        <ul className="space-y-3">
          {rules.map((rule, i) => (
            <li key={i} className="flex items-center gap-3 p-3 bg-deep-green-dark/40 rounded-2xl border border-gold/10 text-sm text-gold/80">
              <div className="w-1.5 h-1.5 rounded-full bg-gold shadow-[0_0_8px_rgba(253,230,138,0.5)]" />
              {rule}
            </li>
          ))}
        </ul>
      </BentoCard>
    </div>
  );
}
