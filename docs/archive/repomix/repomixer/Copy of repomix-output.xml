<file path="livskompassen-trasig-1/src/components/ChronosAnalysis.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Clock, TrendingUp, AlertTriangle, Anchor, Loader2, RefreshCw } from 'lucide-react';
import { geminiService } from '../services/geminiService';
import { db } from '../lib/firebase';
import { collection, query, where, orderBy, limit, getDocs } from 'firebase/firestore';
import { cn } from '../lib/utils';

export const ChronosAnalysis = ({ userId }: { userId: string }) => {
  const [analysis, setAnalysis] = useState<any>(null);
  const [isLoading, setIsLoading] = useState(false);

  const runAnalysis = async () => {
    if (!userId) return;
    setIsLoading(true);
    try {
      // Hämta de senaste 30 händelserna för att se mönster
      const q = query(
        collection(db, 'events'), 
        where('userId', '==', userId), 
        orderBy('timestamp', 'desc'), 
        limit(30)
      );
      const snap = await getDocs(q);
      const events = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));

      if (events.length < 3) {
        setAnalysis({ error: "Behöver minst 3 händelser för att identifiera mönster." });
        return;
      }

      const data = await (geminiService as any).analyzeChronosPatterns(events);
      setAnalysis(data);
    } catch (error) {
      console.error("Chronos analysis failed:", error);
    } finally {
      setIsLoading(false);
    }
  };

  useEffect(() => {
    runAnalysis();
  }, [userId]);

  return (
    <div className="bg-[#0f172a]/40 backdrop-blur-xl border border-white/5 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden">
      <div className="absolute top-0 right-0 w-64 h-64 bg-amber-500/5 rounded-full blur-[80px]" />
      
      <div className="flex items-center justify-between mb-8 relative z-10">
        <div className="flex items-center gap-4">
          <div className="w-12 h-12 bg-amber-500/10 rounded-2xl border border-amber-500/20 flex items-center justify-center">
            <Clock className="w-6 h-6 text-amber-400" />
          </div>
          <div>
            <h3 className="text-xl text-slate-100 font-outfit font-light tracking-wide">Chronos Mönsteranalys</h3>
            <p className="text-[10px] text-amber-400 uppercase tracking-widest font-bold">Långsiktig Beteende-motor</p>
          </div>
        </div>
        <button 
          onClick={runAnalysis}
          disabled={isLoading}
          className="p-2 hover:bg-white/5 rounded-full transition-all"
        >
          <RefreshCw className={cn("w-4 h-4 text-slate-500", isLoading && "animate-spin")} />
        </button>
      </div>

      <AnimatePresence mode="wait">
        {isLoading ? (
          <motion.div key="loading" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="h-48 flex flex-col items-center justify-center gap-4">
            <Loader2 className="w-8 h-8 text-amber-500 animate-spin" />
            <p className="text-xs text-slate-500 italic">Analyserar tidslinjen efter cykliska triggers...</p>
          </motion.div>
        ) : analysis?.error ? (
          <motion.div key="error" className="h-48 flex items-center justify-center text-center">
            <p className="text-sm text-slate-500 italic px-10">{analysis.error}</p>
          </motion.div>
        ) : analysis ? (
          <motion.div key="result" initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className="space-y-8 relative z-10">
            {/* Title & Observations */}
            <div>
              <h4 className="text-lg text-amber-100 font-outfit mb-4">{analysis.patternTitle}</h4>
              <div className="space-y-3">
                {analysis.observations.map((obs: any, i: number) => (
                  <div key={i} className="p-4 bg-white/[0.02] border border-white/5 rounded-2xl">
                    <div className="flex justify-between items-start mb-2">
                      <p className="text-sm text-slate-300 font-medium">{obs.trend}</p>
                      <span className={cn(
                        "text-[8px] font-black px-2 py-0.5 rounded uppercase tracking-tighter",
                        obs.intensity === 'HÖG' ? "bg-red-500/20 text-red-400 border border-red-500/30" : "bg-amber-500/20 text-amber-400 border border-amber-500/30"
                      )}>
                        {obs.intensity}
                      </span>
                    </div>
                    <div className="flex gap-2">
                      {obs.evidenceDates.map((date: string, dIdx: number) => (
                        <span key={dIdx} className="text-[9px] font-mono text-slate-600">{date}</span>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>

            {/* Cyclical Triggers */}
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div className="p-6 bg-indigo-500/5 border border-indigo-500/20 rounded-[2rem] space-y-4">
                <div className="flex items-center gap-2 text-indigo-400">
                  <RefreshCw className="w-4 h-4" />
                  <p className="text-[10px] font-bold uppercase tracking-widest">Cykliska Triggers</p>
                </div>
                <div className="space-y-4">
                  {analysis.cyclicalTriggers.map((trig: any, i: number) => (
                    <div key={i} className="space-y-1">
                      <div className="flex justify-between items-center">
                        <p className="text-xs text-slate-200 font-bold">{trig.trigger}</p>
                        <p className="text-[10px] text-indigo-400">{trig.probability * 100}% sannolikhet</p>
                      </div>
                      <p className="text-[11px] text-slate-500 italic">{trig.consequence}</p>
                    </div>
                  ))}
                </div>
              </div>

              {/* Escalation Report */}
              <div className="p-6 bg-rose-500/5 border border-rose-500/20 rounded-[2rem] space-y-4">
                <div className="flex items-center gap-2 text-rose-400">
                  <TrendingUp className="w-4 h-4" />
                  <p className="text-[10px] font-bold uppercase tracking-widest">Eskalerings-status</p>
                </div>
                <div className="text-center py-2">
                  <span className={cn(
                    "text-xl font-outfit font-bold tracking-widest uppercase",
                    analysis.escalationReport.status === 'ESKALERANDE' ? "text-red-500" : "text-teal-500"
                  )}>
                    {analysis.escalationReport.status}
                  </span>
                  <p className="text-[11px] text-slate-400 mt-2 px-2 leading-relaxed">
                    {analysis.escalationReport.reasoning}
                  </p>
                </div>
              </div>
            </div>

            {/* Strategic Anchor */}
            <div className="p-6 bg-teal-500/10 border border-teal-500/20 rounded-[2rem] flex items-start gap-4">
              <Anchor className="w-6 h-6 text-teal-400 shrink-0 mt-1" />
              <div>
                <p className="text-[10px] text-teal-400 uppercase font-bold tracking-widest mb-1">Strategiskt Ankare</p>
                <p className="text-sm text-teal-50 font-inter italic leading-relaxed">
                  "{analysis.strategicAnchor}"
                </p>
              </div>
            </div>
          </motion.div>
        ) : null}
      </AnimatePresence>
    </div>
  );
};
</file>

