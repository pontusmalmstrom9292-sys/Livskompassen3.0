import React, { useState } from 'react';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { Shield, UserPlus, FileText, Trash2 } from 'lucide-react';

export default function DossierProfileManager() {
  const { entities: actors, addEntity: addActor, removeEntity: removeActor } = useSystemMemory();
  const [name, setName] = useState('');
  const [role, setRole] = useState('');
