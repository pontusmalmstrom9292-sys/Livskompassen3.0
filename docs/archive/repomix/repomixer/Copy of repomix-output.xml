Uppdrag:
  Orkestrerar ALLA andra agenter och sammanfogar resultaten till ett
  strukturerat BBIC-kompatibelt rapport-utkast.
  Kräver explicit Human-in-the-Loop-godkännande innan export.

Triggers:
  - Manuellt via "Generera Rapport"-knappen
  - Sekventiell pipeline: anropar EscalationAgent → NetworkAgent → EconomicAgent

Output:
  {
    "reportId": str,
    "reportType": "BBIC|LEGAL|CRISIS|COMPREHENSIVE",
    "generatedAt": str,
    "sections": {
      "executiveSummary": str,
      "childWellbeing": {...},
      "patternAnalysis": {...},
      "economicAnalysis": {...},
      "networkAnalysis": {...},
      "escalationStatus": {...},
      "recommendations": [...],
      "evidenceInventory": [...]
    },
    "legalCompliance": {"isCompliant": bool, "notes": []},
    "requiresApproval": true,  # ALLTID true - Human-in-the-Loop
    "groundingPoints": [...]
  }
"""
import json
from typing import Dict, Any, List, Optional
from datetime import datetime
from .base_agent import BaseAgent
from .escalation_agent import EscalationAgent
from .crisis_agent import CrisisAgent
from .economic_agent import EconomicAgent
from .network_agent import NetworkAgent


class ReportAgent(BaseAgent):
    AGENT_NAME = "Rapport-Generatorn"
    AGENT_ROLE = "Orkestrerar alla agenter och producerar BBIC-kompatibla rapport-utkast"

    def __init__(self):
        super().__init__()
        # Orkestrerar alla andra agenter
        self.escalation_agent = EscalationAgent()
        self.economic_agent = EconomicAgent()
        self.network_agent = NetworkAgent()

    async def analyze(self, data: Dict[str, Any]) -> Dict:
        report_type = data.get("reportType", "COMPREHENSIVE")
        events = data.get("events", [])
        actors = data.get("actors", [])
        network_members = data.get("networkMembers", [])
        transactions = data.get("transactions", [])
        diary_entries = data.get("diaryEntries", [])
        child_observations = data.get("childObservations", [])
        user_statement = data.get("userStatement", "")

        # 1. Kör alla sub-agenter parallellt (data context engineering)
        escalation_data = None
        economic_data = None
        network_data = None

        if events:
            escalation_data = await self.escalation_agent.analyze({
                "newEvent": events[-1].get("description", "") if events else "",
                "historicalEvents": events[:-1],
                "actorProfiles": actors,
            })

        if transactions:
            economic_data = await self.economic_agent.analyze({
                "transactions": transactions,
                "timePeriod": "90 dagar",
            })

        if actors or network_members:
            network_data = await self.network_agent.analyze({
                "actors": actors,
                "networkMembers": network_members,
                "recentEvents": events[-10:],
            })

        # 2. Jordar mot BBIC och juridisk dokumentationspraxis
        grounding = await self._ground_with_vertex_search(
            "BBIC barns behov i centrum rapport socialtjänst dokumentation"
        )
        context_block = self._build_context_block(grounding)

        # 3. Bygg fullständigt kontextblock för Master Report-agenten
        events_block = "\n".join([
            f"  [{e.get('timestamp', '')}] ({e.get('type', '')}): {e.get('description', '')}"
            for e in events[-20:]
        ])
        diary_block = "\n".join([
            f"  [{d.get('timestamp', '')}]: {d.get('content', '')[:200]}"
            for d in diary_entries[-10:]
        ])
        child_block = "\n".join([
            f"  - {o.get('observation', '')} [{o.get('date', '')}]"
            for o in child_observations[:10]
        ])

        escalation_summary = json.dumps(escalation_data, ensure_ascii=False) if escalation_data else "Ej tillgänglig"
        economic_summary = json.dumps(economic_data, ensure_ascii=False) if economic_data else "Ej tillgänglig"
        network_summary = json.dumps(network_data, ensure_ascii=False) if network_data else "Ej tillgänglig"

        prompt = f"""
Du är "Rapport-Generatorn" – en Master Orchestration Agent som sammanfogar analyser
från specialiserade sub-agenter till ett BBIC-kompatibelt rapport-utkast.

VIKTIGT: Detta är ett UTKAST som ALLTID kräver mänskligt godkännande innan det används.

BBIC-REFERENSFAKTA:
{context_block}

SUB-AGENT RESULTAT:
ESKALERINGS-ANALYS:
{escalation_summary[:800]}

EKONOMISK ANALYS:
{economic_summary[:800]}

NÄTVERKS-ANALYS:
{network_summary[:800]}

RÅDATA:
HÄNDELSELOGG (senaste 20):
{events_block if events_block else "Inga händelser"}

DAGBOK (senaste 10):
{diary_block if diary_block else "Inga dagboksinlägg"}

BARNOBSERVATIONER:
{child_block if child_block else "Inga barnobservationer"}

ANVÄNDARENS EGET UTLÅTANDE:
{user_statement if user_statement else "Inget utlåtande"}

UPPGIFT:
Skapa ett rapport-utkast av typen "{report_type}" som:
1. Är objektivt och faktabaserat (BBIC-standard)
2. Sätter barnets perspektiv i centrum
3. Är lämpligt att lämna till socialtjänst/domstol
4. Innehåller tydliga evidensreferenser

Svara STRIKT i JSON:
{{
  "reportType": "{report_type}",
  "generatedAt": "{datetime.now().isoformat()}",
  "requiresApproval": true,
  "sections": {{
    "executiveSummary": "<Neutral 3-5 meningar sammanfattning av hela situationen>",
    "childWellbeing": {{
      "overallAssessment": "KRITISK|VARNING|STABIL|BRA",
      "observations": ["<objektiv observation>"],
      "riskFactors": ["<riskfaktor>"],
      "protectiveFactors": ["<skyddsfaktor>"]
    }},
    "patternAnalysis": {{
      "dominantPattern": "<huvudsakligt mönster>",
      "duration": "<hur länge>",
      "severity": "HÖG|MEDEL|LÅG",
      "specificInstances": ["<konkret händelse med datum>"]
    }},
    "recommendedInterventions": [
      {{"intervention": "<åtgärd>", "urgency": "OMEDELBAR|HÖG|MEDEL", "responsible": "<vem>"}}
    ],
    "evidenceInventory": [
      {{"type": "HÄNDELSE|DAGBOK|EKONOMI|KOMMUNIKATION", "description": "<beskrivning>", "date": "<datum>", "relevance": "<relevans>"}}
    ]
  }},
  "legalCompliance": {{
    "isCompliant": true,
    "framework": "BBIC",
    "notes": ["<notering om juridisk relevans>"]
  }},
  "groundingPoints": ["<fakta från BBIC-manualen>"]
}}
"""
        result = self._call_model(prompt)

        # Lägg till sub-agent data för fullständig rapport
        result["subAgentResults"] = {
            "escalation": escalation_data,
            "economic": economic_data,
            "network": network_data,
        }

        return result
