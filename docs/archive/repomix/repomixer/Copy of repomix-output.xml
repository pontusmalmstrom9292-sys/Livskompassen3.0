  { id: 'MIRRORING', label: 'Rutiner', icon: CheckCircle2 },
  { id: 'WELLNESS', label: 'MåBra', icon: Sprout },
  { id: 'DIARY', label: 'Dagbok', icon: Book },
];

interface BottomNavProps {
  currentView: View;
  onNavigate: (view: View) => void;
}

export function BottomNav({ currentView, onNavigate }: BottomNavProps) {
  return (
