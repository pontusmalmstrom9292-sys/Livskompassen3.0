import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Home, Wallet, Sprout, Book, Lock, X, ShieldCheck } from 'lucide-react';
import { cn } from '../../lib/utils';
import { View } from '../../types';
import { useLongPress } from '../../hooks/useLongPress';

interface NavItem {
  id: View;
  label: string;
  icon: any;
  color: string;
  glow: string;
}

const NAV_ITEMS: NavItem[] = [
  { id: 'HOME', label: 'Kompass', icon: Home, color: 'text-[#FDE68A]', glow: 'bg-[#FDE68A]' },
  { id: 'WELLNESS', label: 'Må Bra', icon: Sprout, color: 'text-[#2DD4BF]', glow: 'bg-[#2DD4BF]' },
  { id: 'DIARY', label: 'Dagbok', icon: Book, color: 'text-[#818CF8]', glow: 'bg-[#818CF8]' },
  { id: 'FINANCE', label: 'Ekonomi', icon: Wallet, color: 'text-[#FB923C]', glow: 'bg-[#FB923C]' },
];

interface FloatingDockProps {
  currentView: View;
  onNavigate: (view: View) => void;
}

export function FloatingDock({ currentView, onNavigate }: FloatingDockProps) {
  const [showPin, setShowPin] = useState(false);
  const [pin, setPin] = useState('');
  const [isError, setIsError] = useState(false);

  const handleLongPress = () => {
    setShowPin(true);
  };

  const handleNavigate = (view: View) => {
    onNavigate(view);
  };

  const longPressProps = useLongPress(handleLongPress, () => handleNavigate('DIARY'));

  const handlePinSubmit = (e?: React.FormEvent) => {
    e?.preventDefault();
    if (pin === '1234') { // Mock PIN
      onNavigate('VAULT');
      setShowPin(false);
      setPin('');
      setIsError(false);
    } else {
      setIsError(true);
      setPin('');
      setTimeout(() => setIsError(false), 500);
    }
  };

  const handlePinChange = (val: string) => {
    setPin(val);
    if (val.length === 4) {
      // Auto-submit when 4 digits are entered
      setTimeout(() => {
        if (val === '1234') {
          onNavigate('VAULT');
          setShowPin(false);
          setPin('');
        } else {
          setIsError(true);
          setPin('');
          setTimeout(() => setIsError(false), 500);
        }
      }, 300);
    }
  };

  return (
    <>
      <div className="fixed bottom-10 left-1/2 -translate-x-1/2 z-50 flex items-center gap-4 px-4 w-full max-w-lg">
        <motion.nav 
          initial={{ y: 50, opacity: 0 }}
          animate={{ y: 0, opacity: 1 }}
          className="flex items-center justify-between w-full p-2 rounded-[2.5rem] bg-slate-950/80 backdrop-blur-3xl border border-white/10 shadow-[0_32px_64px_-16px_rgba(0,0,0,0.6)]"
        >
          {NAV_ITEMS.map((item) => {
            const isActive = currentView === item.id;
            const Icon = item.icon;
            
            return (
              <button
                key={item.id}
                {...(item.id === 'DIARY' ? longPressProps : { onClick: () => handleNavigate(item.id) })}
                className={cn(
                  "relative group flex items-center justify-center w-14 h-14 rounded-3xl transition-all duration-500",
                  isActive ? "bg-white/5 scale-110 shadow-inner" : "hover:bg-white/5 active:scale-90"
                )}
              >
                <Icon 
                  className={cn(
                    "w-5 h-5 transition-all duration-500",
                    isActive ? item.color : "text-slate-500 group-hover:text-slate-300"
                  )} 
                />
                
                {isActive && (
                  <motion.div
                    layoutId="nav-glow"
                    className={cn(
                      "absolute inset-0 rounded-3xl blur-xl opacity-20 -z-10",
                      item.glow
                    )}
                  />
                )}

                {/* Label Tooltip */}
                <div className="absolute -top-14 left-1/2 -translate-x-1/2 pointer-events-none opacity-0 group-hover:opacity-100 transition-all duration-300 translate-y-2 group-hover:translate-y-0">
                  <div className="bg-slate-900 border border-white/10 px-3 py-1.5 rounded-xl shadow-2xl">
                    <span className="text-[10px] font-black uppercase tracking-[0.2em] text-white whitespace-nowrap font-outfit">
                      {item.label}
                    </span>
                  </div>
                  <div className="w-2 h-2 bg-slate-900 border-r border-b border-white/10 rotate-45 mx-auto -mt-1" />
                </div>
              </button>
            );
          })}
        </motion.nav>
      </div>

      {/* PIN Overlay */}
      <AnimatePresence>
        {showPin && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-[100] bg-obsidian/95 backdrop-blur-3xl flex items-center justify-center p-6"
          >
            <motion.div 
              initial={{ scale: 0.9, y: 20 }}
              animate={{ 
                scale: 1, 
                y: 0,
                x: isError ? [0, -10, 10, -10, 10, 0] : 0
              }}
              transition={{ duration: isError ? 0.4 : 0.6 }}
              className="w-full max-w-xs space-y-8 text-center"
            >
              <div className="space-y-4">
                <div className={cn(
                  "w-20 h-20 rounded-[2.5rem] bg-white/5 border flex items-center justify-center mx-auto mb-6 transition-colors duration-500",
                  isError ? "border-rose-500/50" : "border-white/10"
                )}>
                  {isError ? <X className="w-8 h-8 text-rose-500" /> : <Lock className="w-8 h-8 text-white/40" />}
                </div>
                <h2 className="text-2xl font-outfit font-light text-white tracking-tight">System Integrity</h2>
                <p className="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-bold">Ange din personliga kod</p>
              </div>

              <div className="space-y-6">
                <div className="flex justify-center gap-4">
                  {[0, 1, 2, 3].map((i) => (
                    <div 
                      key={i}
                      className={cn(
                        "w-4 h-4 rounded-full border-2 transition-all duration-300",
                        pin.length > i ? "bg-white border-white scale-125 shadow-[0_0_15px_white]" : "border-white/20"
                      )}
                    />
                  ))}
                </div>
                
                <input 
                  type="password" 
                  value={pin}
                  onChange={(e) => handlePinChange(e.target.value)}
                  autoFocus
                  maxLength={4}
                  className="absolute opacity-0 pointer-events-none"
                />
                
                <p className={cn(
                  "text-[9px] uppercase font-bold tracking-widest transition-opacity duration-300",
                  isError ? "text-rose-500 opacity-100" : "opacity-0"
                )}>
                  Felaktig kod. Försök igen.
                </p>

                <button 
                  onClick={() => setShowPin(false)}
                  className="w-full py-4 rounded-2xl bg-white/5 border border-white/5 text-slate-500 font-bold text-[10px] uppercase tracking-widest hover:bg-white/10 transition-all font-outfit"
                >
                  Avbryt
                </button>
