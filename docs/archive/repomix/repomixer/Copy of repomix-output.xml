                  <div className="flex flex-wrap items-center gap-10">
                     <div className="flex items-center gap-6 bg-white/5 px-8 py-6 rounded-[2.5rem] border border-white/5 backdrop-blur-md">
                       <WeatherIcon status={weather} />
                       <div className="space-y-0.5">
                         <p className="text-[9px] text-slate-500 uppercase font-black tracking-widest">Atmosfär</p>
                         <span className={cn(
