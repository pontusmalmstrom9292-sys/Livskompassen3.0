import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp } from 'firebase/firestore';
import { Check, ShieldCheck, ArrowRight } from 'lucide-react';

const GAD7_QUESTIONS = [
  "Känt dig nervös, orolig eller på helspänn?",
  "Inte kunnat låta bli att ängslas eller oroa dig?",
  "Oroat dig för mycket över olika saker?",
  "Haft svårt att koppla av?",
  "Varit så rastlös att det varit svårt att sitta still?",
  "Varit lättretlig eller lätt irriterad?",
  "Känt dig rädd, som att något hemskt skulle kunna hända?"
];

const OPTIONS = [
  { value: 0, label: "Inte alls" },
  { value: 1, label: "Flera dagar" },
  { value: 2, label: "Mer än hälften av dagarna" },
  { value: 3, label: "Nästan varje dag" }
];

interface GAD7Props {
  userId: string;
  onComplete?: () => void;
}

export const GAD7Questionnaire = ({ userId, onComplete }: GAD7Props) => {
  const [answers, setAnswers] = useState<number[]>(Array(7).fill(-1));
  const [currentStep, setCurrentStep] = useState(0);
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [success, setSuccess] = useState(false);

  const handleSelect = (value: number) => {
    const newAnswers = [...answers];
    newAnswers[currentStep] = value;
    setAnswers(newAnswers);

    // Progressive disclosure: gå till nästa fråga efter kort fördröjning
    if (currentStep < 6) {
      setTimeout(() => setCurrentStep(prev => prev + 1), 350);
    }
  };

  const isAllAnswered = answers.every(a => a !== -1);
  const totalScore = answers.reduce((sum, val) => sum + (val === -1 ? 0 : val), 0);

  const handleSubmit = async () => {
    if (!isAllAnswered || isSubmitting) return;
    setIsSubmitting(true);

    try {
      await addDoc(collection(db, "health_assessments"), {
        userId,
        type: "GAD-7",
        score: totalScore,
        createdAt: serverTimestamp(),
      });
      
      // Omedelbar rensning av minnet (Zero Footprint)
      setAnswers(Array(7).fill(-1));
      setCurrentStep(0);
      setSuccess(true);
      
      if (onComplete) {
        setTimeout(onComplete, 2500);
      }
    } catch (error) {
      console.error("Fel vid sparande", error);
      setIsSubmitting(false);
    }
  };

  if (success) {
    return (
      <motion.div 
        initial={{ opacity: 0, scale: 0.95 }}
        animate={{ opacity: 1, scale: 1 }}
        className="bg-[#0b3d2e] border border-[#d4af37]/20 rounded-[2rem] p-8 flex flex-col items-center justify-center text-center shadow-xl min-h-[350px] max-w-lg mx-auto"
      >
        <div className="w-16 h-16 rounded-full bg-[#d4af37]/10 flex items-center justify-center mb-6">
          <ShieldCheck className="w-8 h-8 text-[#d4af37]" />
        </div>
        <h3 className="text-2xl text-[#d4af37] font-serif mb-3">Säkrat & Rensat</h3>
        <p className="text-[#F4F4F4]/70 text-sm font-light max-w-xs leading-relaxed">
          Din skattning har skickats krypterat till servern. Minnet är nu rensat och inga spår finns kvar på enheten.
        </p>
      </motion.div>
    );
  }

  return (
    <div className="bg-[#0b3d2e] border border-[#d4af37]/20 rounded-[2rem] p-6 md:p-8 relative overflow-hidden shadow-xl max-w-lg mx-auto w-full">
      <div className="flex justify-between items-center mb-8">
        <div>
          <h3 className="text-xl text-[#d4af37] font-serif tracking-wide">Inre Skattning</h3>
          <p className="text-[10px] text-[#F4F4F4]/40 uppercase tracking-widest mt-1">GAD-7 Protokoll</p>
        </div>
        <span className="text-xs text-[#d4af37]/60 font-bold tracking-widest uppercase bg-[#d4af37]/10 px-3 py-1 rounded-full">
          {currentStep + 1} / 7
        </span>
      </div>

      <p className="text-xs text-[#F4F4F4]/60 font-medium mb-4 uppercase tracking-wider">
        Under de senaste 2 veckorna...
      </p>

      <div className="min-h-[100px] mb-8">
        <AnimatePresence mode="wait">
          <motion.h4 
            key={currentStep}
            initial={{ opacity: 0, x: 15 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -15 }}
            transition={{ duration: 0.3 }}
            className="text-xl text-[#F4F4F4] font-serif leading-relaxed"
          >
            Hur ofta har du {GAD7_QUESTIONS[currentStep].toLowerCase()}
          </motion.h4>
        </AnimatePresence>
      </div>

      <div className="space-y-3 mb-8">
        {OPTIONS.map((opt) => {
          const isSelected = answers[currentStep] === opt.value;
          return (
            <button
              key={opt.value}
              onClick={() => handleSelect(opt.value)}
              className={`w-full py-4 px-5 rounded-2xl border text-left transition-all duration-300 flex items-center justify-between ${
                isSelected 
                  ? 'bg-[#d4af37]/15 border-[#d4af37]/50 text-[#d4af37] shadow-[0_0_15px_rgba(212,175,55,0.1)]' 
                  : 'bg-[#082a20] border-[#d4af37]/10 text-[#F4F4F4]/80 hover:bg-[#d4af37]/5 hover:border-[#d4af37]/30'
              }`}
            >
              <span className="text-sm font-medium">{opt.label}</span>
              {isSelected && <Check className="w-4 h-4 text-[#d4af37]" />}
            </button>
          );
        })}
      </div>

      <div className="flex items-center justify-between mt-8 pt-6 border-t border-[#d4af37]/10">
        <button
          onClick={() => setCurrentStep(prev => Math.max(0, prev - 1))}
          disabled={currentStep === 0}
          className="text-xs text-[#d4af37]/60 hover:text-[#d4af37] disabled:opacity-20 transition-colors uppercase tracking-wider font-bold"
        >
          Tillbaka
        </button>
        
        {currentStep === 6 && isAllAnswered ? (
          <button
            onClick={handleSubmit}
            disabled={isSubmitting}
            className="py-3 px-6 rounded-full bg-gradient-to-r from-[#d4af37] to-[#e6c96a] text-[#0b3d2e] font-bold text-sm hover:opacity-90 transition-opacity flex items-center gap-2 shadow-lg"
          >
            {isSubmitting ? 'Säkrar data...' : 'Spara skattning'}
          </button>
        ) : (
          <button
            onClick={() => setCurrentStep(prev => Math.min(6, prev + 1))}
            disabled={answers[currentStep] === -1}
            className="py-3 px-6 rounded-full bg-[#082a20] border border-[#d4af37]/30 text-[#d4af37] font-bold text-xs uppercase tracking-wider hover:bg-[#d4af37]/10 disabled:opacity-30 disabled:hover:bg-[#082a20] transition-all flex items-center gap-2"
          >
            Nästa <ArrowRight className="w-4 h-4" />
          </button>
        )}
      </div>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/GlobalErrorBoundary.tsx">
import React, { Component, ErrorInfo, ReactNode } from 'react';
import { ShieldAlert, RefreshCcw, Home } from 'lucide-react';

interface Props {
  children: ReactNode;
}

interface State {
  hasError: boolean;
  error: Error | null;
}

export class GlobalErrorBoundary extends Component<Props, State> {
  public state: State = {
    hasError: false,
    error: null
  };

  public static getDerivedStateFromError(error: Error): State {
    return { hasError: true, error };
  }

  public componentDidCatch(error: Error, errorInfo: ErrorInfo) {
    console.error('Uncaught error:', error, errorInfo);
    // Here we could also log to Firebase if desired
  }

  public render() {
    if (this.state.hasError) {
      return (
        <div className="min-h-screen bg-[#020617] flex items-center justify-center p-6 font-inter">
          <div className="max-w-md w-full bg-white/[0.02] backdrop-blur-3xl border border-white/5 rounded-[3rem] p-12 text-center space-y-8 shadow-2xl">
            <div className="mx-auto w-20 h-20 bg-rose-500/10 rounded-[2rem] border border-rose-500/20 flex items-center justify-center">
              <ShieldAlert className="w-10 h-10 text-rose-400" />
            </div>
            
            <div className="space-y-4">
              <h1 className="text-2xl text-white font-outfit font-light tracking-tight">Ett oväntat fel uppstod</h1>
              <p className="text-sm text-slate-500 leading-relaxed italic">
                Systemet har stött på en kritisk flaskhals, men din data i valvet är säker och oförändrad.
              </p>
            </div>

            <div className="p-4 bg-black/40 rounded-2xl border border-white/5 text-left">
              <p className="text-[10px] text-rose-400/50 uppercase font-black tracking-widest mb-2">Feldetaljer</p>
              <p className="text-[10px] text-slate-600 font-mono break-all">{this.state.error?.message || 'Okänt systemfel'}</p>
            </div>

            <div className="flex flex-col gap-3">
              <button
                onClick={() => window.location.reload()}
                className="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl font-bold text-xs uppercase tracking-widest transition-all flex items-center justify-center gap-3"
              >
                <RefreshCcw className="w-4 h-4" />
                Ladda om systemet
              </button>
              <button
                onClick={() => window.location.href = '/'}
                className="w-full py-4 bg-white/5 hover:bg-white/10 text-slate-400 rounded-2xl font-bold text-xs uppercase tracking-widest transition-all flex items-center justify-center gap-3"
              >
                <Home className="w-4 h-4" />
                Tillbaka till start
              </button>
            </div>
          </div>
        </div>
      );
    }

    return this.children;
  }
}
</file>

<file path="livskompassen-trasig-1/src/components/GreyRockTrainer.tsx">
import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { geminiService } from '../services/geminiService';
import { Shield, MessageSquare, AlertTriangle, CheckCircle2, ChevronRight, Info, Loader2, Sparkles, X } from 'lucide-react';
import { cn } from '../lib/utils';

export const GreyRockTrainer: React.FC = () => {
  const [step, setStep] = useState<'INCOMING' | 'DRAFT' | 'ANALYSIS'>('INCOMING');
  const [incoming, setIncoming] = useState('');
  const [draft, setDraft] = useState('');
  const [analysis, setAnalysis] = useState<any>(null);
  const [loading, setLoading] = useState(false);

  const handleAnalyze = async () => {
    setLoading(true);
    try {
      const res = await geminiService.greyRockAnalysis(incoming, draft);
      const data = JSON.parse(res.replace(/```json/g, '').replace(/```/g, '').trim());
      setAnalysis(data);
      setStep('ANALYSIS');
    } catch (error) {
      console.error("Grey Rock Analysis failed:", error);
    } finally {
      setLoading(false);
    }
  };

  const reset = () => {
    setStep('INCOMING');
    setIncoming('');
    setDraft('');
    setAnalysis(null);
  };

  return (
    <div className="w-full max-w-2xl mx-auto bg-[#0f172a]/60 backdrop-blur-2xl border border-white/5 rounded-[3rem] p-8 md:p-12 shadow-2xl relative overflow-hidden">
      {/* Background Aura */}
      <div className="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-slate-500/20 to-transparent" />
      
      <header className="mb-10 flex justify-between items-center relative z-10">
        <div className="flex items-center gap-4">
          <div className="w-12 h-12 bg-slate-800 rounded-2xl flex items-center justify-center border border-white/10 shadow-inner">
            <Shield className="w-6 h-6 text-slate-400" />
          </div>
          <div>
            <h3 className="text-2xl font-outfit font-light text-slate-100 tracking-wide">Grey Rock-Tränaren</h3>
            <p className="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-bold">Emotionellt Brandskydd</p>
          </div>
        </div>
        {step !== 'INCOMING' && (
          <button onClick={reset} className="text-slate-500 hover:text-slate-300 transition-colors">
            <X className="w-5 h-5" />
          </button>
        )}
      </header>

      <AnimatePresence mode="wait">
        {step === 'INCOMING' && (
          <motion.div
            key="incoming"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-8 relative z-10"
          >
            <div className="space-y-3">
              <h4 className="text-lg text-slate-200 font-outfit">Vad har du tagit emot?</h4>
              <p className="text-sm text-slate-500 leading-relaxed">Klistra in det provocerande meddelandet här. Vi ska titta på det objektivt.</p>
            </div>
            
            <textarea
              autoFocus
              value={incoming}
              onChange={(e) => setIncoming(e.target.value)}
              placeholder="Ex: 'Du är alltid så egoistisk, du tänker aldrig på barnen...'"
              className="w-full h-40 bg-black/40 border border-white/5 rounded-[2rem] p-6 text-slate-200 text-sm focus:outline-none focus:border-slate-500/30 transition-all placeholder:text-slate-800 resize-none font-inter"
            />

            <button
              disabled={!incoming.trim()}
              onClick={() => setStep('DRAFT')}
              className="w-full h-16 bg-white/5 border border-white/10 hover:bg-white/10 text-slate-200 rounded-full font-bold flex items-center justify-center gap-3 transition-all disabled:opacity-20"
            >
              Nästa: Formulera ditt svar <ChevronRight className="w-4 h-4" />
            </button>
          </motion.div>
        )}

        {step === 'DRAFT' && (
          <motion.div
            key="draft"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-8 relative z-10"
          >
            <div className="space-y-3">
              <h4 className="text-lg text-slate-200 font-outfit">Ditt tänkta svar</h4>
              <p className="text-sm text-slate-500 leading-relaxed">Skriv hur du vill svara. Var ärlig mot dig själv – vi ska rensa bort "bränslet" i nästa steg.</p>
            </div>
            
            <div className="p-4 bg-white/5 rounded-2xl border border-white/5 mb-4">
              <p className="text-[10px] uppercase font-bold text-slate-600 mb-2">Inkommande provokation:</p>
              <p className="text-xs text-slate-500 italic line-clamp-2">"{incoming}"</p>
            </div>

            <textarea
              autoFocus
              value={draft}
              onChange={(e) => setDraft(e.target.value)}
              placeholder="Skriv ditt svar här..."
              className="w-full h-40 bg-black/40 border border-white/5 rounded-[2rem] p-6 text-slate-200 text-sm focus:outline-none focus:border-slate-500/30 transition-all placeholder:text-slate-800 resize-none font-inter"
            />

            <button
              disabled={loading || !draft.trim()}
              onClick={handleAnalyze}
              className="w-full h-16 bg-slate-100 text-[#0f172a] rounded-full font-bold flex items-center justify-center gap-3 transition-all shadow-xl shadow-white/5"
            >
              {loading ? <Loader2 className="w-5 h-5 animate-spin" /> : <><Sparkles className="w-5 h-5" /> Analysera mot JADE</>}
            </button>
          </motion.div>
        )}

        {step === 'ANALYSIS' && analysis && (
          <motion.div
            key="analysis"
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            className="space-y-8 relative z-10"
          >
            {/* JADE Scorecard */}
            <div className="grid grid-cols-4 gap-3">
              {['justify', 'argue', 'defend', 'explain'].map((key) => (
                <div 
                  key={key} 
                  className={cn(
                    "p-3 rounded-2xl border text-center transition-all",
                    analysis.jadeDetected[key] 
                      ? "bg-red-500/10 border-red-500/30 text-red-400" 
                      : "bg-teal-500/5 border-teal-500/20 text-teal-500/40"
                  )}
                >
                  <p className="text-[8px] uppercase font-bold tracking-widest">{key}</p>
                  <p className="text-[10px] mt-1">{analysis.jadeDetected[key] ? 'DETEKTERAD' : 'GRÖN'}</p>
                </div>
              ))}
            </div>

            {/* AI Feedback */}
            <div className="bg-white/5 border border-white/5 rounded-[2rem] p-6 space-y-4">
              <div className="flex items-center gap-3 text-[#FDE68A]">
                <Info className="w-5 h-5" />
                <h4 className="text-sm font-bold uppercase tracking-widest">Tränarens Insikt</h4>
              </div>
              <p className="text-sm text-slate-300 leading-relaxed font-inter italic">"{analysis.feedback}"</p>
            </div>

            {/* Grey Rock Suggestion */}
            <div className="space-y-4">
              <div className="flex items-center justify-between px-1">
                <span className="text-[10px] uppercase font-bold text-slate-500 tracking-widest flex items-center gap-2">
                  <CheckCircle2 className="w-3 h-3 text-teal-400" /> Stensäkert Svarsförslag
                </span>
                <span className="text-[10px] text-slate-600">Säkerhetsindex: {analysis.safetyRating}/10</span>
              </div>
              <div className="bg-teal-500/10 border border-teal-500/20 rounded-[2rem] p-6 relative group">
                <p className="text-lg text-teal-100 font-outfit text-center leading-relaxed">
                  {analysis.greyRockSuggestion}
                </p>
                <button 
                  onClick={() => { navigator.clipboard.writeText(analysis.greyRockSuggestion); alert("Kopierat!"); }}
                  className="absolute bottom-4 right-4 text-[9px] uppercase font-bold text-teal-500/50 hover:text-teal-400 transition-colors"
                >
                  Kopiera svar
                </button>
              </div>
            </div>

            {/* Triggers Detected */}
            <div className="space-y-3">
              <p className="text-[10px] uppercase font-bold text-slate-600 tracking-widest ml-1">Provokationer vi skalat bort:</p>
              <div className="flex flex-wrap gap-2">
                {analysis.incomingTriggers.map((trigger: string, i: number) => (
                  <span key={i} className="px-3 py-1 bg-red-500/5 border border-red-500/10 rounded-full text-[9px] text-red-400/60 italic">
                    {trigger}
                  </span>
                ))}
              </div>
            </div>

            <div className="flex gap-4 pt-4">
              <button
                onClick={() => setStep('DRAFT')}
                className="flex-1 h-14 bg-white/5 border border-white/10 text-slate-400 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-white/10 transition-all"
              >
                Förfina mitt svar
              </button>
              <button
                onClick={reset}
                className="flex-1 h-14 bg-slate-800 text-slate-200 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-slate-700 transition-all"
              >
                Ny träning
              </button>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <footer className="mt-10 pt-8 border-t border-white/5 flex items-center justify-center gap-8 text-slate-600">
        <div className="flex items-center gap-2">
          <div className="w-1.5 h-1.5 rounded-full bg-red-400 opacity-50" />
          <span className="text-[9px] uppercase tracking-tighter">JADE-Analys aktiv</span>
        </div>
        <div className="flex items-center gap-2">
          <div className="w-1.5 h-1.5 rounded-full bg-teal-400 opacity-50" />
          <span className="text-[9px] uppercase tracking-tighter">Emotionell neutralisering</span>
        </div>
      </footer>
    </div>
  );
};
</file>

