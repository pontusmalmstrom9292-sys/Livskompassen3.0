                <div className={cn("p-12 rounded-[3rem] border border-white/10 relative overflow-hidden", `bg-gradient-to-br from-${selectedCase.color}-900/20 to-transparent`)}>
                  <div className="flex justify-between items-start relative z-10">
                    <div className="space-y-4">
                       <h2 className="text-4xl text-white font-outfit tracking-tighter">{selectedCase.title}</h2>
                       <p className="text-sm text-slate-400 max-w-xl leading-relaxed italic">
                         "Denna akt sammanställer bevis för {selectedCase.alert.toLowerCase()}. AI-motorn har identifierat systematiska avvikelser i kommunikation."
                       </p>
                    </div>
                    <button className="px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-[10px] font-black uppercase tracking-widest text-slate-300 transition-all flex items-center gap-2">
                       <Download className="w-4 h-4" /> Exportera Akt-Rapport
                    </button>
                  </div>
                </div>

                {/* AI Pattern Timeline */}
                <div className="space-y-10">
                   <div className="flex items-center gap-4">
                      <History className="w-5 h-5 text-indigo-400" />
                      <h3 className="text-xs font-black uppercase tracking-[0.3em] text-slate-500">AI Pattern Timeline</h3>
                   </div>

                   <div className="pl-8 border-l border-white/5 space-y-16">
                      {[1, 2, 3].map((_, i) => (
