import { collection, addDoc, serverTimestamp, query, where, getDocs, orderBy, limit, doc, getDoc, updateDoc, setDoc } from 'firebase/firestore';
import { db } from '../lib/firebase';
import { shieldApi } from './apiService';

export const synapseService = {
  /**
   * Broar händelser mellan moduler för att skapa kognitiv samverkan.
   */
  async processEventSynapses(userId: string, event: any, currentVibe?: any) {
    const insights = [];

    // 1. Säkerhetssynaps: Vid hög hotnivå (Röda flaggor)
    if (event.aiAnalysis?.redFlags?.length > 2 || event.severity === 'HÖG') {
      try {
        const legalAnalysis = await shieldApi.analyze({
          content: event.description || event.content,
          mode: 'LEGAL',
          context: { userId, eventId: event.id }
        });
        
        insights.push({
          type: 'SECURITY_INSIGHT',
          title: 'Skyddsprotokoll Aktiverat',
          message: legalAnalysis.masterInsight || 'Flera manipulationstaktiker detekterade. Systemet rekommenderar BIFF-metoden för nästa svar.',
          severity: 'HIGH',
          action: 'BIFF'
        });
      } catch (e) {
        console.error("Synapse analysis failed:", e);
      }
    }

    // 2. Barnfokus-synaps: Vid händelser rörande umgänge/skola
    if (['Umgänge', 'Skola', 'Orosanmälan'].includes(event.type)) {
      insights.push({
        type: 'CHILD_PERSPECTIVE',
        title: 'Barnets Perspektiv',
        message: 'Denna händelse påverkar barnens stabilitet. AI-agenten rekommenderar en BBIC-sammanfattning.',
        severity: 'MEDIUM'
      });
    }

    // 3. Vibe-synaps: Koppla händelse till stressnivå
    if (currentVibe && currentVibe.stressLevel > 7) {
      insights.push({
        type: 'STRESS_MITIGATION',
        title: 'Kognitiv Avlastning',
        message: 'Din stressnivå är hög. Impulsbromsen har stärkts för att skydda din ekonomi.',
        severity: 'URGENT'
      });
    }

    return insights;
  }
};
