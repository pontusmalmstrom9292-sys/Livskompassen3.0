                    placeholder="Viktig information om personens inverkan..."
                    className="w-full h-24 bg-deep-green-dark/40 border border-gold/20 rounded-2xl p-4 text-sm text-gold focus:outline-none focus:border-gold/50 resize-none placeholder:text-gold/20"
