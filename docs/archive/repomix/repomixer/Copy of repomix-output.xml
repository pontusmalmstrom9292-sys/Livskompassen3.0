            <CheckCircle className="w-4 h-4 text-gold/60" />
            <h3 className="font-display text-lg text-gold">Dagens Rutiner</h3>
          </div>
          <p className="text-[8px] font-black uppercase text-gold/20 tracking-widest">Kognitiv avlastning</p>
        </div>
        <div className="grid gap-2">
          {routines.map(r => (
            <button 
              key={r.id}
              onClick={() => handleToggleRoutine(r)}
              className={cn(
                "flex items-center justify-between p-3 rounded-2xl border transition-all text-left",
                r.completed 
                  ? "bg-gold/10 border-gold/40 text-gold" 
                  : "bg-deep-green-dark/40 border-gold/10 text-gold/40 hover:border-gold/30"
              )}
            >
              <span className={cn("text-xs font-bold", r.completed && "line-through opacity-50")}>{r.text}</span>
              <div className={cn(
                "w-5 h-5 rounded-lg border-2 flex items-center justify-center transition-colors",
                r.completed ? "bg-gold border-gold" : "border-gold/20"
              )}>
                {r.completed && <CheckCircle className="w-3 h-3 text-deep-green-dark" />}
              </div>
            </button>
          ))}
        </div>
      </BentoCard>

      {/* Systemets Grundregler */}
      <BentoCard delay={0.3} className="bg-deep-green-mid/80 border-gold/30">
        <div className="flex items-center gap-2 mb-4">
          <Clock className="w-4 h-4 text-gold/60" />
