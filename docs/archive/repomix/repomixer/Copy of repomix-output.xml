<file path="livskompassen-trasig-1/src/hooks/useIntelligenceAutomation.ts">
import { useEffect } from 'react';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { SmartAutomationService } from '../services/SmartAutomationService';
import { db } from '../lib/firebase';
import { collection, query, where, onSnapshot, orderBy, limit } from 'firebase/firestore';

export const useIntelligenceAutomation = (userId: string | undefined) => {
  const { postToIntelligenceFeed, dailyVibe } = useSystemMemory();

  useEffect(() => {
    if (!userId) return;

    // 1. Init Kid Sorting (Auto-analysis of new events)
    const unsubKidSorting = SmartAutomationService.initKidSorting(userId);

    // 2. Monitor Transactions for Budget Guard
    const transQ = query(
      collection(db, 'transactions'),
      where('userId', '==', userId),
      orderBy('date', 'desc'),
      limit(20)
    );

    const unsubBudget = onSnapshot(transQ, (snapshot) => {
      const transactions = snapshot.docs.map(doc => doc.data());
      // Assume a default weekly allowance if not found elsewhere
      const result = SmartAutomationService.analyzeBudgetPace(transactions, 2500); 
      
      if (result.alert) {
        postToIntelligenceFeed({
          agent: 'Ekonomi-Vaktposten',
          type: 'BUDGET',
          message: result.message,
          priority: 'HIGH',
          metadata: { budgetUsage: 0.85 }
        });
      }
    });

    // 3. Monitor High Stress for Proactive Anchoring
    if (dailyVibe && dailyVibe.stressLevel > 7) {
      postToIntelligenceFeed({
        agent: 'Trygghets-Arkivarien',
        type: 'SAFETY',
        message: "Jag ser att din stressnivå är hög. Kom ihåg att systemet har dämpat notifikationer. Fokusera på ett mikrosteg i taget.",
        priority: 'HIGH'
      });
    }

    return () => {
      unsubKidSorting();
      unsubBudget();
    };
  }, [userId, dailyVibe?.stressLevel]);
};
</file>

<file path="livskompassen-trasig-1/src/hooks/useLongPress.ts">
import { useCallback, useRef, useState } from 'react';

export const useLongPress = (
  onLongPress: () => void,
  onClick: () => void,
  { delay = 3000 } = {}
) => {
  const [isPressing, setIsPressing] = useState(false);
  const timerRef = useRef<NodeJS.Timeout | null>(null);

  const start = useCallback((e: any) => {
    e.preventDefault();
    setIsPressing(true);
    timerRef.current = setTimeout(() => {
      onLongPress();
      setIsPressing(false);
    }, delay);
  }, [onLongPress, delay]);

  const stop = useCallback((e: any) => {
    e.preventDefault();
    if (timerRef.current) {
      clearTimeout(timerRef.current);
      if (isPressing) {
        onClick();
      }
    }
    setIsPressing(false);
  }, [onClick, isPressing]);

  return {
    onMouseDown: start,
    onMouseUp: stop,
    onMouseLeave: stop,
    onTouchStart: start,
    onTouchEnd: stop,
  };
};
</file>

<file path="livskompassen-trasig-1/src/hooks/useVertexAnalysis.ts">
import { useState, useCallback, useEffect } from 'react';
import { shieldApi, AnalysisResponse, ChronosAnalysisResult, BIFFScript, SystemStatus } from '../services/apiService';

type AnalysisMode = 'DEFAULT' | 'PATTERN' | 'LEGAL' | 'BBIC' | 'BIFF';

interface UseVertexAnalysisReturn {
  // State
  isLoading: boolean;
  error: string | null;
  systemStatus: SystemStatus | null;
  isOnline: boolean;
  
  // Core Analysis
  analyze: (content: string, mode?: AnalysisMode, context?: Record<string, any>) => Promise<AnalysisResponse | null>;
  lastAnalysis: AnalysisResponse | null;
  
  // Chronos
  analyzeChronos: (events: any[], userId: string) => Promise<ChronosAnalysisResult | null>;
  lastChronos: ChronosAnalysisResult | null;
  
  // BIFF Script
  generateBIFF: (message: string, context?: Record<string, any>) => Promise<BIFFScript | null>;
  lastBIFF: BIFFScript | null;
  
  // BBIC Report
  generateBBIC: (events: any[], childName: string, context: Record<string, any>, userId: string) => Promise<any | null>;
  lastBBIC: any | null;
  
  // Utils
  clearError: () => void;
  reset: () => void;
}

/**
 * useVertexAnalysis
 * 
 * React hook som exponerar alla Vertex AI-drivna analysendpoints.
 * Hanterar loading state, errors och caching av senaste resultat.
 * 
 * @example
 * const { analyze, isLoading, lastAnalysis } = useVertexAnalysis();
 * 
 * // Analysera ett meddelande
 * const result = await analyze("Texten att analysera", "BIFF");
 */
export function useVertexAnalysis(): UseVertexAnalysisReturn {
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [systemStatus, setSystemStatus] = useState<SystemStatus | null>(null);
  const [isOnline, setIsOnline] = useState(false);
  
  const [lastAnalysis, setLastAnalysis] = useState<AnalysisResponse | null>(null);
  const [lastChronos, setLastChronos] = useState<ChronosAnalysisResult | null>(null);
  const [lastBIFF, setLastBIFF] = useState<BIFFScript | null>(null);
  const [lastBBIC, setLastBBIC] = useState<any | null>(null);

  // Kontrollera systemstatus vid mount
  useEffect(() => {
    const checkStatus = async () => {
      const status = await shieldApi.checkHealth();
      setSystemStatus(status);
      setIsOnline(status.status === 'ACTIVE');
    };
    checkStatus();
    
    // Kontrollera var 2:e minut
    const interval = setInterval(checkStatus, 120000);
    return () => clearInterval(interval);
  }, []);

  const analyze = useCallback(async (
    content: string,
    mode: AnalysisMode = 'DEFAULT',
    context?: Record<string, any>
  ): Promise<AnalysisResponse | null> => {
    setIsLoading(true);
    setError(null);
    
    try {
      const result = await shieldApi.analyze({ content, mode, context });
      setLastAnalysis(result);
      return result;
    } catch (err: any) {
      const message = err?.response?.data?.detail || err?.message || 'Analys misslyckades';
      setError(`Shield API: ${message}`);
      console.error('Vertex Analysis Error:', err);
      return null;
    } finally {
      setIsLoading(false);
    }
  }, []);

  const analyzeChronos = useCallback(async (
    events: any[],
    userId: string
  ): Promise<ChronosAnalysisResult | null> => {
    if (events.length < 2) {
      setError('Chronos kräver minst 2 händelser för mönsteranalys.');
      return null;
    }
    
    setIsLoading(true);
    setError(null);
    
    try {
      const result = await shieldApi.analyzeChronos(events, userId);
      const chronosResult = result.analysis;
      setLastChronos(chronosResult);
      return chronosResult;
    } catch (err: any) {
      const message = err?.response?.data?.detail || err?.message || 'Chronos-analys misslyckades';
      setError(`Chronos: ${message}`);
      return null;
    } finally {
      setIsLoading(false);
    }
  }, []);

  const generateBIFF = useCallback(async (
    message: string,
    context?: Record<string, any>
  ): Promise<BIFFScript | null> => {
    setIsLoading(true);
    setError(null);
    
    try {
      const result = await shieldApi.generateBIFFScript(message, context);
      setLastBIFF(result);
      return result;
    } catch (err: any) {
      const message = err?.response?.data?.detail || err?.message || 'BIFF-generering misslyckades';
      setError(`BIFF: ${message}`);
      return null;
    } finally {
      setIsLoading(false);
    }
  }, []);

  const generateBBIC = useCallback(async (
    events: any[],
    childName: string,
    context: Record<string, any>,
    userId: string
  ): Promise<any | null> => {
    setIsLoading(true);
    setError(null);
    
    try {
      const result = await shieldApi.generateBBICReport(events, childName, context, userId);
      setLastBBIC(result.report);
      return result.report;
    } catch (err: any) {
      const message = err?.response?.data?.detail || err?.message || 'BBIC-rapport misslyckades';
      setError(`BBIC: ${message}`);
      return null;
    } finally {
      setIsLoading(false);
    }
  }, []);

  const clearError = useCallback(() => setError(null), []);
  
  const reset = useCallback(() => {
    setError(null);
    setLastAnalysis(null);
    setLastChronos(null);
    setLastBIFF(null);
    setLastBBIC(null);
  }, []);

  return {
    isLoading,
    error,
    systemStatus,
    isOnline,
    analyze,
    lastAnalysis,
    analyzeChronos,
    lastChronos,
    generateBIFF,
    lastBIFF,
    generateBBIC,
    lastBBIC,
    clearError,
    reset
  };
}
</file>

