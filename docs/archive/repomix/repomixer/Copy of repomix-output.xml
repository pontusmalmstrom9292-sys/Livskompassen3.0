                <div className="h-64 flex items-end gap-4 mb-10 relative">
                   {history.slice().reverse().map((item, i) => (
                     <div key={i} className="flex-1 flex flex-col items-center gap-6 group/bar">
                        <div className="relative w-full h-full flex items-end">
                           <motion.div 
                             initial={{ height: 0 }}
                             animate={{ height: `${item.groundingScore || 60}%` }}
                             className={cn(
                               "w-full rounded-2xl transition-all duration-700 shadow-2xl",
                               (item.groundingScore || 0) > 75 ? "bg-gradient-to-t from-teal-600 to-teal-400 shadow-teal-500/20" : "bg-gradient-to-t from-indigo-600 to-indigo-400 shadow-indigo-500/20"
                             )}
                           />
                           <div className="absolute -top-16 left-1/2 -translate-x-1/2 opacity-0 group-hover/bar:opacity-100 transition-all pointer-events-none translate-y-4 group-hover/bar:translate-y-0 z-50">
                              <div className="bg-slate-900 border border-white/10 p-4 rounded-2xl shadow-2xl text-center min-w-[140px]">
                                 <p className="text-[10px] text-slate-500 uppercase font-black tracking-widest mb-1">{item.timestamp?.toDate().toLocaleDateString()}</p>
                                 <p className="text-xl font-outfit font-light text-white">{item.groundingScore || 60}%</p>
                              </div>
                           </div>
                        </div>
                     </div>
                   ))}
                </div>
                
                <div className="flex justify-between items-center px-4 pt-6 border-t border-white/5">
                   <div className="flex items-center gap-3 text-slate-600">
                      <Shield className="w-4 h-4" />
                      <span className="text-[10px] font-black uppercase tracking-widest">Objektivitets-Vakt aktiverad</span>
                   </div>
                   <div className="px-6 py-2 bg-teal-500/10 border border-teal-500/20 rounded-full">
                      <span className="text-[10px] font-bold text-teal-400 uppercase tracking-widest">Styrka: Optimal</span>
                   </div>
                </div>
             </div>
          </div>
        </div>
      </div>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/Reframing.tsx">
import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Heart, Sparkles, Loader2, ArrowRight, ShieldCheck } from 'lucide-react';
import { geminiService } from '../services/geminiService';

export const Reframing = () => {
  const [criticalThought, setCriticalThought] = useState('');
  const [reframedThought, setReframedThought] = useState('');
  const [isAnalyzing, setIsAnalyzing] = useState(false);

  const handleReframe = async () => {
    if (!criticalThought.trim()) return;
    setIsAnalyzing(true);
    try {
      const res = await (geminiService as any).generateStrengthMessage(
        'REFRAMING',
        `Användaren är självkritisk och tänker: "${criticalThought}". Omformulera denna tanke till objektiv självmedkänsla. Ta hänsyn till att användaren lever med ADHD och GAD under extrem stress. Gör det extremt varmt, stärkande och validerande. Byt "Jag är ett misslyckande" till "Det är förståeligt att..." osv. Max 2-3 meningar.`
      );
      setReframedThought(res);
    } catch (e) {
      console.error(e);
      setReframedThought("Idag var tufft. Du gör ditt allra bästa under omständigheter som skulle knäcka de flesta. Var snäll mot dig själv.");
    } finally {
      setIsAnalyzing(false);
    }
  };

  const handleReset = () => {
    setCriticalThought('');
    setReframedThought('');
  };

  return (
    <div className="bg-[#0f172a]/60 backdrop-blur-xl border border-rose-500/20 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden">
      <div className="absolute top-0 right-0 w-64 h-64 bg-rose-500/5 rounded-full blur-[80px]" />
      
      <div className="flex items-center gap-4 mb-6 relative z-10">
        <div className="w-12 h-12 bg-rose-500/10 rounded-2xl border border-rose-500/20 flex items-center justify-center">
          <Heart className="w-6 h-6 text-rose-400" />
        </div>
        <div>
          <h3 className="text-xl text-slate-100 font-outfit font-light tracking-wide">Självmedkänsla</h3>
          <p className="text-[10px] text-rose-400 uppercase tracking-widest font-bold">Omformulera den inre kritikern</p>
        </div>
      </div>

      <div className="relative z-10 space-y-6">
        <p className="text-sm text-slate-400 italic">
          Vilken dömande eller hård tanke ekar i huvudet just nu?
        </p>
        
        <textarea
          value={criticalThought}
          onChange={(e) => setCriticalThought(e.target.value)}
          disabled={isAnalyzing || !!reframedThought}
          placeholder="T.ex. 'Jag är en dålig pappa för att jag tappade tålamodet...'"
          className="w-full h-24 bg-black/40 border border-white/5 rounded-2xl p-4 text-sm text-slate-200 placeholder:text-slate-600 focus:outline-none focus:border-rose-500/30 resize-none disabled:opacity-50"
        />

        <AnimatePresence mode="wait">
          {!reframedThought ? (
            <motion.div key="action" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <button
                onClick={handleReframe}
                disabled={!criticalThought.trim() || isAnalyzing}
                className="w-full py-4 bg-rose-600/20 hover:bg-rose-600/30 text-rose-300 border border-rose-500/30 rounded-2xl font-bold text-sm tracking-widest uppercase transition-all disabled:opacity-30 flex items-center justify-center gap-2"
              >
                {isAnalyzing ? <Loader2 className="w-5 h-5 animate-spin" /> : <><Sparkles className="w-4 h-4" /> Byt Perspektiv</>}
              </button>
            </motion.div>
          ) : (
            <motion.div key="result" initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} className="space-y-4">
              <div className="flex justify-center my-2">
                <ArrowRight className="w-5 h-5 text-slate-500 rotate-90" />
              </div>
              <div className="p-6 bg-teal-950/30 border border-teal-500/30 rounded-2xl relative">
                <ShieldCheck className="absolute top-4 right-4 w-4 h-4 text-teal-500/50" />
                <p className="text-sm text-teal-100 leading-relaxed font-inter">{reframedThought}</p>
              </div>
              <button
                onClick={handleReset}
                className="w-full py-3 bg-white/5 hover:bg-white/10 text-slate-300 border border-white/10 rounded-xl font-bold text-xs tracking-widest uppercase transition-all"
              >
                Släpp en tanke till
              </button>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
};
</file>

