<file path="src/pages/DossierGeneratorPage.tsx">
import { useState, useEffect } from 'react';
import { motion } from 'motion/react';
import { FileText, Shield, Database, Download } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { db } from '../lib/firebase';
import { collection, query, where, onSnapshot, orderBy } from 'firebase/firestore';
import { VaultLog, SystemSynapse } from '../types';
import { cn } from '../lib/utils';

interface DossierPageProps {
  user: any;
}

export function DossierGeneratorPage({ user }: DossierPageProps) {
  const [logs, setLogs] = useState<VaultLog[]>([]);
  const [synapses, setSynapses] = useState<SystemSynapse[]>([]);
  const [selectedLogs, setSelectedLogs] = useState<Set<string>>(new Set());
  const [selectedSynapses, setSelectedSynapses] = useState<Set<string>>(new Set());

  useEffect(() => {
    if (!user) return;

    const unsubscribeLogs = onSnapshot(query(collection(db, 'vault'), where('userId', '==', user.uid), orderBy('createdAt', 'desc')), (snap) => {
      setLogs(snap.docs.map(doc => ({ id: doc.id, ...doc.data() } as VaultLog)));
    });

    const unsubscribeSynapses = onSnapshot(query(collection(db, 'synapses'), where('userId', '==', user.uid), orderBy('createdAt', 'desc')), (snap) => {
      setSynapses(snap.docs.map(doc => ({ id: doc.id, ...doc.data() } as SystemSynapse)));
    });

    return () => {
      unsubscribeLogs();
      unsubscribeSynapses();
    };
  }, [user]);

  const toggleLog = (id: string) => {
    const next = new Set(selectedLogs);
    if (next.has(id)) next.delete(id); else next.add(id);
    setSelectedLogs(next);
  };

  const toggleSynapse = (id: string) => {
    const next = new Set(selectedSynapses);
    if (next.has(id)) next.delete(id); else next.add(id);
    setSelectedSynapses(next);
  };

  return (
    <div className="space-y-6 pb-20">
      <header className="flex justify-between items-center bg-gold/5 p-4 rounded-3xl border border-gold/10">
        <div className="flex items-center gap-3">
          <FileText className="w-5 h-5 text-gold" />
          <div>
            <span className="text-sm font-bold uppercase tracking-widest text-gold block leading-tight">Dossier-Generator</span>
            <span className="text-[10px] text-gold/40 uppercase tracking-tighter">Sanningens sammanställning</span>
          </div>
        </div>
      </header>

      <BentoCard className="bg-sand/5 border-sand/10">
        <h3 className="text-xs font-bold uppercase tracking-widest text-sand mb-4">Välj underlag för rapport</h3>
        <p className="text-[10px] opacity-40 mb-6">Markera logs och synapser för att skapa en oföränderlig dossier.</p>
        
        <div className="space-y-6">
          <div>
            <h4 className="text-[10px] uppercase font-bold text-gold/30 mb-2">Bevis (Vault)</h4>
            <div className="space-y-2">
              {logs.map(log => (
                <div key={log.id} onClick={() => toggleLog(log.id)} className={cn("p-3 rounded-xl border cursor-pointer transition-all", selectedLogs.has(log.id) ? "bg-gold/10 border-gold" : "bg-white/5 border-white/5")}>
                  <p className="text-xs font-bold">{log.action}</p>
                </div>
              ))}
            </div>
          </div>
          
          <div>
            <h4 className="text-[10px] uppercase font-bold text-gold/30 mb-2">Synapser (Insikter)</h4>
            <div className="space-y-2">
              {synapses.map(s => (
                <div key={s.id} onClick={() => toggleSynapse(s.id)} className={cn("p-3 rounded-xl border cursor-pointer transition-all", selectedSynapses.has(s.id) ? "bg-blue-400/10 border-blue-400" : "bg-white/5 border-white/5")}>
                  <p className="text-xs font-bold">{s.title}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <Button className="w-full mt-8 bg-gold text-deep-green-dark hover:bg-gold/90" disabled={selectedLogs.size === 0 && selectedSynapses.size === 0}>
          <Download className="w-4 h-4 mr-2" />
          Generera Teknisk Dossier
        </Button>
      </BentoCard>
    </div>
  );
}
</file>

<file path="src/pages/EconomyPage.tsx">
import { BentoCard } from '../components/ui/BentoCard';
import { Wallet, TrendingUp, ArrowDownRight, CreditCard, Plus, Target, PieChart, RefreshCw } from 'lucide-react';

import { collection, query, where, onSnapshot, orderBy, addDoc, serverTimestamp, doc, updateDoc } from 'firebase/firestore';
import { db } from '../lib/firebase';
import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Transaction, SavingsGoal } from '../types';
import { Button } from '../components/ui/button';
import { cn } from '../lib/utils';

interface EconomyPageProps {
  user: any;
}

export function EconomyPage({ user }: EconomyPageProps) {
  const [transactions, setTransactions] = useState<Transaction[]>([]);
  const [savings, setSavings] = useState<SavingsGoal[]>([]);
  const [showAddTx, setShowAddTx] = useState(false);
  const [showAddSavings, setShowAddSavings] = useState(false);

  // Form states
  const [amount, setAmount] = useState('');
  const [desc, setDesc] = useState('');
  const [category, setCategory] = useState('ÖVRIGT');
  const [goalTitle, setGoalTitle] = useState('');
  const [goalTarget, setGoalTarget] = useState('');

  useEffect(() => {
    if (!user) return;

    const qTx = query(
      collection(db, 'transactions'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubTx = onSnapshot(qTx, (snapshot) => {
      setTransactions(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as Transaction)));
    });

    const qSavings = query(
      collection(db, 'budget_savings'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubSavings = onSnapshot(qSavings, (snapshot) => {
      setSavings(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as SavingsGoal)));
    });

    return () => {
      unsubTx();
      unsubSavings();
    };
  }, [user]);

  const totalBalance = transactions.reduce((acc, curr) => acc + curr.amount, 0);

  const handleAddTx = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!amount || !desc || !user) return;
    
    try {
      await addDoc(collection(db, 'transactions'), {
        userId: user.uid,
        amount: parseFloat(amount),
        description: desc,
        category,
        createdAt: serverTimestamp()
      });
      setAmount(''); setDesc(''); setShowAddTx(false);
    } catch (err) {
      console.error("Error adding transaction", err);
    }
  };

  const handleAddSavings = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!goalTitle || !goalTarget || !user) return;

    try {
      await addDoc(collection(db, 'budget_savings'), {
        userId: user.uid,
        title: goalTitle,
        targetAmount: parseFloat(goalTarget),
        currentAmount: 0,
        createdAt: serverTimestamp()
      });
      setGoalTitle(''); setGoalTarget(''); setShowAddSavings(false);
    } catch (err) {
      console.error("Error adding savings goal", err);
    }
  };

  const handleUpdateSaving = async (goalId: string, current: number, increment: number) => {
    const newAmount = current + increment;
    await updateDoc(doc(db, 'budget_savings', goalId), {
      currentAmount: newAmount
    });
  };

  return (
    <div className="space-y-6 pb-20">
      {/* Wallet Overview */}
      <BentoCard highlightColor="warm-orange" className="bg-deep-green-mid/80 relative overflow-hidden border-gold/30">
        <div className="flex justify-between items-start mb-8 relative z-10">
          <div>
            <p className="text-xs font-semibold uppercase tracking-widest text-gold mb-1 opacity-60">Global Likviditet</p>
            <h2 className="text-4xl font-display text-gold">{totalBalance.toLocaleString('sv-SE')} kr</h2>
          </div>
          <button 
            onClick={() => setShowAddTx(!showAddTx)}
            className="w-12 h-12 rounded-2xl bg-gold text-deep-green-dark flex items-center justify-center shadow-lg shadow-gold/20 hover:scale-105 transition-transform"
          >
            <Plus className={cn("w-6 h-6 transition-transform", showAddTx && "rotate-45")} />
          </button>
        </div>
        
        <div className="flex gap-6 relative z-10">
          <div className="flex items-center gap-2">
            <div className="p-1.5 rounded-lg bg-income/10 border border-income/20">
              <TrendingUp className="w-3 h-3 text-income" />
            </div>
            <span className="text-[10px] font-bold uppercase text-gold/60">Flöde In</span>
          </div>
          <div className="flex items-center gap-2">
            <div className="p-1.5 rounded-lg bg-expense/10 border border-expense/20">
              <ArrowDownRight className="w-3 h-3 text-expense" />
            </div>
            <span className="text-[10px] font-bold uppercase text-gold/60">Flöde Ut</span>
          </div>
        </div>
        {/* Decorative mask */}
        <div className="absolute top-0 right-0 w-32 h-32 bg-gold/5 rounded-full blur-3xl -mr-16 -mt-16" />
      </BentoCard>

      {/* Add Transaction Overlay */}
      <AnimatePresence>
        {showAddTx && (
          <BentoCard className="bg-deep-green-mid border-gold/40 shadow-2xl">
            <form onSubmit={handleAddTx} className="space-y-4">
              <h3 className="text-xs font-bold uppercase tracking-widest text-gold/60">Ny Transaktion</h3>
              <div className="grid grid-cols-2 gap-3">
                <input 
                  type="number" step="0.01" placeholder="Belopp (negativt för utgift)" 
                  value={amount} onChange={e => setAmount(e.target.value)}
                  className="bg-deep-green-dark border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none focus:border-gold/50"
                  required
                />
                <select 
                  value={category} onChange={e => setCategory(e.target.value)}
                  className="bg-deep-green-dark border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none focus:border-gold/50"
                >
                  <option value="INKOMST">Inkomst</option>
                  <option value="MAT">Mat</option>
                  <option value="BOENDE">Boende</option>
                  <option value="NÖJE">Nöje</option>
                  <option value="SPARANDE">Sparande</option>
                  <option value="ÖVRIGT">Övrigt</option>
                </select>
              </div>
              <input 
                type="text" placeholder="Beskrivning" 
                value={desc} onChange={e => setDesc(e.target.value)}
                className="w-full bg-deep-green-dark border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none focus:border-gold/50"
                required
              />
              <Button type="submit" className="w-full bg-gold text-deep-green-dark font-bold">Bokför i Kärnan</Button>
            </form>
          </BentoCard>
        )}
      </AnimatePresence>

      {/* Quick Stats Grid */}
      <div className="grid grid-cols-2 gap-4">
        <BentoCard delay={0.1} className="flex flex-col items-center justify-center py-6 bg-deep-green-mid/80 border-gold/30">
           <CreditCard className="w-6 h-6 text-gold/40 mb-2" />
           <p className="text-sm font-medium text-gold">Fasta utgifter</p>
           <div className="mt-2 text-[10px] font-black uppercase text-gold/20 tracking-tighter">Automatisering aktiv</div>
        </BentoCard>

        <BentoCard delay={0.2} className="flex flex-col items-center justify-center py-6 bg-deep-green-mid/80 border-gold/30">
           <div className="w-8 h-8 rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center mb-2">
              <span className="text-[10px] font-bold text-gold">VP</span>
           </div>
           <p className="text-sm font-medium text-gold">Veckopeng</p>
           <button className="mt-2 px-3 py-1 bg-gold/10 text-gold text-[8px] font-bold uppercase rounded border border-gold/20">Utbetala</button>
        </BentoCard>
      </div>

      {/* Savings Goals */}
      <div className="space-y-4">
        <div className="flex justify-between items-center px-2">
          <div className="flex items-center gap-2 text-gold opacity-40">
            <Target className="w-4 h-4" />
            <h3 className="text-[10px] font-bold uppercase tracking-widest">Dynamiska Sparmål</h3>
          </div>
          <button 
            onClick={() => setShowAddSavings(!showAddSavings)}
            className="text-[10px] uppercase font-bold text-gold border-b border-gold/20 hover:border-gold transition-colors"
          >
            {showAddSavings ? 'Avbryt' : 'Nytt Mål'}
          </button>
        </div>

        {showAddSavings && (
          <BentoCard className="bg-deep-green-mid/90 border-gold/20">
            <form onSubmit={handleAddSavings} className="space-y-3">
              <input 
                type="text" placeholder="Mål (t.ex. Buffert)" 
                value={goalTitle} onChange={e => setGoalTitle(e.target.value)}
                className="w-full bg-deep-green-dark border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none"
              />
              <input 
                type="number" placeholder="Målbelopp" 
                value={goalTarget} onChange={e => setGoalTarget(e.target.value)}
                className="w-full bg-deep-green-dark border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none"
              />
              <Button type="submit" className="w-full bg-gold/10 text-gold border border-gold/40">Skapa Sparmål</Button>
            </form>
          </BentoCard>
        )}

        <div className="grid gap-3">
          {savings.map((goal) => {
            const progress = (goal.currentAmount / goal.targetAmount) * 100;
            return (
              <BentoCard key={goal.id} className="bg-deep-green-mid/40 border-gold/5 group">
                <div className="flex items-center justify-between mb-3">
                  <div>
                    <h4 className="text-sm font-bold text-gold">{goal.title}</h4>
                    <p className="text-[10px] text-gold/40">{goal.currentAmount.toLocaleString()} / {goal.targetAmount.toLocaleString()} kr</p>
                  </div>
                  <div className="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                    <button 
                      onClick={() => handleUpdateSaving(goal.id, goal.currentAmount, 500)}
                      className="w-6 h-6 rounded bg-gold/10 text-gold text-[10px] font-bold"
                    >
                      +
                    </button>
                  </div>
                </div>
                <div className="h-1.5 w-full bg-deep-green-dark rounded-full overflow-hidden">
                  <motion.div 
                    initial={{ width: 0 }}
                    animate={{ width: `${Math.min(progress, 100)}%` }}
                    className="h-full bg-gold shadow-[0_0_10px_rgba(253,230,138,0.5)]"
                  />
                </div>
              </BentoCard>
            );
          })}
        </div>
      </div>

      {/* Recent Activity */}
      <BentoCard delay={0.3} className="bg-deep-green-mid/80 border-gold/30">
        <div className="flex justify-between items-center mb-6">
           <div className="flex items-center gap-2 text-gold opacity-40">
             <PieChart className="w-4 h-4" />
             <h3 className="text-[10px] font-bold uppercase tracking-widest">Kärn-Logg</h3>
           </div>
           <button className="text-[8px] font-black uppercase text-gold/20 border border-gold/10 px-2 py-0.5 rounded">Realtid</button>
        </div>
        <div className="space-y-2">
          {transactions.length === 0 && (
            <p className="text-center py-8 text-gold/20 text-xs italic">Inga transaktioner loggade än.</p>
          )}
          {transactions.slice(0, 10).map((tx) => (
            <div key={tx.id} className="flex items-center justify-between p-3 bg-deep-green-dark/20 rounded-2xl border border-gold/5 hover:bg-deep-green-dark/40 transition-colors">
              <div className="flex items-center gap-3 text-gold">
                <div className={cn("w-1 h-6 rounded-full", tx.amount < 0 ? 'bg-expense' : 'bg-income')} />
                <div className="flex flex-col">
                   <span className="text-sm font-medium">{tx.description}</span>
                   <span className="text-[8px] opacity-40 uppercase tracking-widest">{tx.category}</span>
                </div>
              </div>
              <span className={cn("text-sm font-display", tx.amount < 0 ? 'text-expense' : 'text-income')}>
                {tx.amount > 0 ? '+' : ''}{tx.amount.toLocaleString()} kr
              </span>
            </div>
          ))}
        </div>
      </BentoCard>
    </div>
  );
}
</file>

<file path="src/pages/NetworkPage.tsx">
import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Users, UserPlus, Shield, Heart, Briefcase, GraduationCap, Info, MessageSquare, BrainCircuit, Search, Star, MoreVertical } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { db } from '../lib/firebase';
import { collection, query, where, onSnapshot, addDoc, serverTimestamp } from 'firebase/firestore';
import { NetworkMember } from '../types';
import { cn } from '../lib/utils';
import { geminiService } from '../services/geminiService';

export function NetworkPage({ user }: { user: any }) {
  const [members, setMembers] = useState<NetworkMember[]>([]);
  const [loading, setLoading] = useState(true);
  const [showAdd, setShowAdd] = useState(false);
  const [agentAnalysis, setAgentAnalysis] = useState<{ question: string; insight: string } | null>(null);

  // New Member Form State
  const [newName, setNewName] = useState('');
  const [newRole, setNewRole] = useState('');
  const [newCategory, setNewCategory] = useState<NetworkMember['category']>('VÄNNER');
  const [newImportance, setNewImportance] = useState<NetworkMember['importance']>('LOW');
  const [newNotes, setNewNotes] = useState('');
  const [newIsAlly, setNewIsAlly] = useState(true);

  useEffect(() => {
    const q = query(collection(db, 'network'), where('userId', '==', user.uid));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as NetworkMember));
      setMembers(data);
      setLoading(false);
      
      // Trigger Agent Analysis when members change or on load
      runAgentAnalysis(data);
    });
    return unsubscribe;
  }, [user.uid]);

  const runAgentAnalysis = async (currentMembers: NetworkMember[]) => {
    const result = await geminiService.analyzeNetwork(currentMembers);
    setAgentAnalysis(result);
  };

  const handleAdd = async (e: React.FormEvent) => {
    e.preventDefault();
    try {
      await addDoc(collection(db, 'network'), {
        userId: user.uid,
        name: newName,
        role: newRole,
        category: newCategory,
        importance: newImportance,
        notes: newNotes,
        isAlly: newIsAlly,
        createdAt: serverTimestamp()
      });
      setShowAdd(false);
      // Reset form
      setNewName(''); setNewRole(''); setNewNotes('');
    } catch (e) {
      console.error(e);
    }
  };

  const getCategoryIcon = (cat: string) => {
    switch (cat) {
      case 'SLÄKT': return Heart;
      case 'MYNDIGHET': return Shield;
      case 'SKOLA': return GraduationCap;
      case 'VÄNNER': return Users;
      default: return Info;
    }
  };

  const categories = ['SLÄKT', 'MYNDIGHET', 'SKOLA', 'VÄNNER', 'ÖVRIGT'];

  return (
    <div className="space-y-6">
      {/* Agent Section: Nätverksvisir */}
      <BentoCard highlightColor="sand" className="bg-deep-green-mid/80 border-gold/30">
        <div className="flex items-center gap-4 mb-4">
          <div className="w-12 h-12 rounded-2xl bg-gold/10 flex items-center justify-center shadow-lg shadow-gold/10">
            <BrainCircuit className="w-6 h-6 text-gold" />
          </div>
          <div>
            <h3 className="text-xl font-display text-gold">Nätverksvisir</h3>
            <p className="text-xs text-gold/60">Social Architect Agent</p>
          </div>
        </div>
        
        <AnimatePresence mode="wait">
          {agentAnalysis ? (
            <motion.div 
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              className="space-y-4"
            >
              <div className="bg-deep-green-dark/40 rounded-2xl p-4 border border-gold/20">
                <p className="text-sm italic text-gold/90 mb-2 font-medium">"{agentAnalysis.question}"</p>
                <div className="flex gap-2">
                  <input 
                    type="text" 
                    placeholder="Svara här..."
                    className="flex-1 h-10 bg-deep-green-dark/60 border border-gold/20 rounded-xl px-4 text-sm text-gold focus:outline-none focus:border-gold/50 placeholder:text-gold/20"
                  />
                  <Button size="sm" className="bg-gold text-deep-green-dark rounded-xl">Skicka</Button>
                </div>
              </div>
              <div className="bg-gold/5 border border-gold/10 rounded-2xl p-4">
                <div className="flex items-center gap-2 mb-2">
                  <Star className="w-3 h-3 text-gold" />
                  <span className="text-[10px] uppercase font-bold text-gold/60 tracking-widest">Insikt från Kärnan</span>
                </div>
                <p className="text-xs text-gold/70 leading-relaxed">
                  {agentAnalysis.insight}
                </p>
              </div>
            </motion.div>
          ) : (
            <div className="h-20 flex items-center justify-center opacity-20 text-gold">
              <span className="animate-pulse">Analyserar nätverk...</span>
            </div>
          )}
        </AnimatePresence>
      </BentoCard>

      <div className="flex items-center justify-between">
        <h2 className="text-2xl font-display text-gold">Ditt Nätverk</h2>
        <Button 
          onClick={() => setShowAdd(!showAdd)}
          className={cn(
            "rounded-full gap-2 transition-all",
            showAdd ? "bg-danger text-white" : "bg-gold text-deep-green-dark"
          )}
        >
          {showAdd ? 'Avbryt' : <><UserPlus className="w-4 h-4" /> Lägg till person</>}
        </Button>
      </div>

      <AnimatePresence>
        {showAdd && (
          <motion.div 
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: 'auto', opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            className="overflow-hidden"
          >
            <BentoCard className="bg-deep-green-mid/80 border-gold/30">
              <form onSubmit={handleAdd} className="space-y-4">
                <div className="grid grid-cols-2 gap-4">
                  <div className="space-y-1">
                    <label className="text-[10px] uppercase font-bold text-gold/40 ml-1">Namn</label>
                    <input 
                      required
                      value={newName} onChange={e => setNewName(e.target.value)}
                      placeholder="Elisabeth Franck" 
                      className="w-full h-12 bg-deep-green-dark/40 border border-gold/20 rounded-2xl px-4 text-sm text-gold focus:outline-none focus:border-gold/50 placeholder:text-gold/20"
                    />
                  </div>
                  <div className="space-y-1">
                    <label className="text-[10px] uppercase font-bold text-gold/40 ml-1">Roll / Titel</label>
                    <input 
                      required
                      value={newRole} onChange={e => setNewRole(e.target.value)}
                      placeholder="Barnens farmor" 
                      className="w-full h-12 bg-deep-green-dark/40 border border-gold/20 rounded-2xl px-4 text-sm text-gold focus:outline-none focus:border-gold/50 placeholder:text-gold/20"
                    />
                  </div>
                </div>

                <div className="grid grid-cols-3 gap-3">
                  {categories.map(cat => (
