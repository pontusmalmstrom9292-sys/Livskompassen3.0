            <div className="flex items-center gap-4 border-r border-white/5 pr-6">
              <div className="relative flex items-center justify-center">
                <Activity className="w-6 h-6 text-teal-400 z-10" />
                <motion.div 
                  animate={{ scale: [1, 1.2, 1] }} 
                  transition={{ repeat: Infinity, duration: 2 }}
                  className="absolute inset-0 bg-teal-400/20 rounded-full blur-md"
                />
              </div>
              <div>
                <p className="text-[10px] uppercase font-bold tracking-widest text-slate-500">System Vagus-Nerv</p>
                <p className="text-sm font-outfit text-teal-400">Reglerad & Stabil</p>
              </div>
            </div>
            <div className="flex items-center gap-4">
              <Database className="w-5 h-5 text-indigo-400 opacity-80" />
              <div>
                <p className="text-[10px] uppercase font-bold tracking-widest text-slate-500">Aktivt RAG-Minne</p>
                <p className="text-sm font-outfit text-indigo-300">1,045 Noder Låsta</p>
              </div>
            </div>
          </div>
