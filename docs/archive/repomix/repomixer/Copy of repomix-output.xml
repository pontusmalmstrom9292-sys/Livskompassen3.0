import { ReactNode, useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { BottomNav } from './BottomNav';
import { User, Lighthouse, BookOpen, LogOut, Lock, X } from 'lucide-react';
import { View } from '../../types';
import { ZenBackgroundAura } from '../ui/ZenBackgroundAura';
import { cn } from '../../lib/utils';

interface MainLayoutProps {
  children: ReactNode;
  currentView: View;
  onNavigate: (view: View) => void;
  user: any;
  onSignOut: () => void;
  onOpenManual: () => void;
}

export function MainLayout({ children, currentView, onNavigate, user, onSignOut, onOpenManual }: MainLayoutProps) {
  const [isPressing, setIsPressing] = useState(false);
  const [showPin, setShowPin] = useState(false);
  const [pin, setPin] = useState('');
  const [isError, setIsError] = useState(false);
  const timerRef = useRef<NodeJS.Timeout | null>(null);

  // ─── Accelerometer Panic Close ──────────────────────────────────────────
  useEffect(() => {
    const handleShake = (event: DeviceMotionEvent) => {
      const { x, y, z } = event.accelerationIncludingGravity || { x: 0, y: 0, z: 0 };
      const acceleration = Math.sqrt((x || 0) ** 2 + (y || 0) ** 2 + (z || 0) ** 2);
      if (acceleration > 25 && currentView === 'VAULT') {
        onNavigate('HOME');
      }
    };

    if (typeof DeviceMotionEvent !== 'undefined' && 'requestPermission' in DeviceMotionEvent) {
      // Handle iOS permission if needed
    } else {
      window.addEventListener('devicemotion', handleShake);
    }
    return () => window.removeEventListener('devicemotion', handleShake);
  }, [currentView, onNavigate]);

  const handleStartPress = () => {
    setIsPressing(true);
    timerRef.current = setTimeout(() => {
      setShowPin(true);
      setIsPressing(false);
    }, 3000);
  };

  const handleEndPress = () => {
    if (timerRef.current) {
      clearTimeout(timerRef.current);
      timerRef.current = null;
    }
    setIsPressing(false);
  };

  const handlePinChange = (val: string) => {
    if (val.length > 4) return;
    setPin(val);
    if (val.length === 4) {
      setTimeout(() => {
        if (val === '1234') { // Secure PIN should be in environment or user profile
          onNavigate('VAULT');
          setShowPin(false);
          setPin('');
        } else {
          setIsError(true);
          setPin('');
          setTimeout(() => setIsError(false), 500);
        }
      }, 300);
    }
  };

  return (
    <div className="min-h-screen relative font-inter text-slate-100 overflow-x-hidden">
      <ZenBackgroundAura />

      {/* Header */}
      <header className="fixed top-0 left-0 right-0 h-24 flex items-center justify-between px-8 z-40 bg-obsidian/40 backdrop-blur-md border-b border-white/5">
        <div className="flex items-center gap-5">
          <motion.div 
            onMouseDown={handleStartPress}
            onMouseUp={handleEndPress}
            onMouseLeave={handleEndPress}
            onTouchStart={handleStartPress}
            onTouchEnd={handleEndPress}
            animate={{ scale: isPressing ? 0.95 : 1 }}
            className="w-12 h-12 rounded-2xl glass-card flex items-center justify-center border border-white/10 cursor-pointer relative overflow-hidden group"
          >
            <Lighthouse className="w-6 h-6 text-indigo-400 group-hover:text-indigo-300 transition-colors" />
            {isPressing && (
              <motion.div 
                initial={{ height: 0 }}
                animate={{ height: '100%' }}
                transition={{ duration: 3, ease: 'linear' }}
                className="absolute bottom-0 left-0 right-0 bg-indigo-500/30 -z-10"
              />
            )}
          </motion.div>
          <div>
            <h1 className="text-base font-outfit font-bold uppercase tracking-[0.2em] text-white">LivsKompassen</h1>
            <p className="text-[9px] text-slate-500 uppercase font-black tracking-widest">Sanningens Sköld Aktiv</p>
          </div>
        </div>

        <div className="flex items-center gap-6">
          <button 
            onClick={onOpenManual}
            className="hidden md:flex items-center gap-2 px-5 py-2.5 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 transition-all group"
          >
            <BookOpen className="w-4 h-4 text-slate-400" />
            <span className="text-[10px] uppercase font-black text-slate-300 tracking-[0.2em]">Manual</span>
          </button>
          
          <div className="flex items-center gap-4">
            <div className="text-right hidden sm:block">
              <p className="text-xs font-outfit font-bold text-white">{user?.displayName}</p>
              <button 
                onClick={onSignOut} 
                className="text-[9px] uppercase font-black text-rose-500/60 hover:text-rose-400 transition-colors tracking-widest flex items-center gap-1 justify-end"
              >
                Logga ut <LogOut className="w-3 h-3" />
              </button>
            </div>
            <div className="w-12 h-12 rounded-full glass-card flex items-center justify-center border border-white/10 p-0.5 overflow-hidden">
               {user?.photoURL ? (
                 <img src={user.photoURL} alt="" className="w-full h-full rounded-full object-cover" />
               ) : (
                 <User className="w-6 h-6 opacity-30" />
               )}
            </div>
          </div>
        </div>
      </header>

      {/* Main Content */}
      <main className="pt-32 pb-40 px-6 max-w-4xl mx-auto min-h-screen">
        <AnimatePresence mode="wait">
          <motion.div
            key={currentView}
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            transition={{ duration: 0.5, ease: [0.16, 1, 0.3, 1] }}
          >
            {children}
          </motion.div>
        </AnimatePresence>
      </main>

      {/* Navigation */}
      <BottomNav currentView={currentView} onNavigate={onNavigate} />

      {/* PIN Overlay */}
      <AnimatePresence>
        {showPin && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 z-[100] bg-obsidian/95 backdrop-blur-3xl flex items-center justify-center p-6"
          >
            <motion.div 
              initial={{ scale: 0.9, y: 20 }}
              animate={{ 
                scale: 1, 
                y: 0,
                x: isError ? [0, -10, 10, -10, 10, 0] : 0
              }}
              transition={{ duration: isError ? 0.4 : 0.6 }}
              className="w-full max-w-xs space-y-8 text-center"
            >
              <div className="space-y-4">
                <div className={cn(
                  "w-20 h-20 rounded-[2.5rem] bg-white/5 border flex items-center justify-center mx-auto mb-6 transition-colors duration-500",
                  isError ? "border-rose-500/50" : "border-white/10"
                )}>
                  {isError ? <X className="w-8 h-8 text-rose-500" /> : <Lock className="w-8 h-8 text-white/40" />}
                </div>
                <h2 className="text-2xl font-outfit font-light text-white tracking-tight">System Integrity</h2>
                <p className="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-bold">Ange din personliga kod</p>
              </div>

              <div className="space-y-6">
                <div className="flex justify-center gap-4">
                  {[0, 1, 2, 3].map((i) => (
                    <div 
                      key={i}
                      className={cn(
                        "w-4 h-4 rounded-full border-2 transition-all duration-300",
                        pin.length > i ? "bg-white border-white scale-125 shadow-[0_0_15px_white]" : "border-white/20"
                      )}
                    />
                  ))}
                </div>
                
                <input 
                  type="password" 
                  value={pin}
                  onChange={(e) => handlePinChange(e.target.value)}
                  autoFocus
                  maxLength={4}
                  className="absolute opacity-0 pointer-events-none"
                />
                
                <p className={cn(
                  "text-[9px] uppercase font-bold tracking-widest transition-opacity duration-300",
                  isError ? "text-rose-500 opacity-100" : "opacity-0"
                )}>
                  Felaktig kod. Försök igen.
                </p>

                <button 
                  onClick={() => setShowPin(false)}
                  className="w-full py-4 rounded-2xl bg-white/5 border border-white/5 text-slate-500 font-bold text-[10px] uppercase tracking-widest hover:bg-white/10 transition-all font-outfit"
                >
                  Avbryt
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
