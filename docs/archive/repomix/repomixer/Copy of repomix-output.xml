              className={`w-full bg-slate-900/40 border border-white/5 rounded-2xl px-5 py-4 text-slate-200 placeholder-slate-700 focus:outline-none focus:border-[#FDE68A]/30 transition-all text-sm font-inter ${
                isSaved ? 'opacity-50 cursor-default' : 'hover:bg-slate-900/60'
              }`}
            />
          </div>
        ))}
      </div>

      <button
        onClick={handleSave}
        disabled={isSaved || !hasAnyIntention || isAnalyzing}
        className={`w-full py-5 rounded-3xl font-bold transition-all duration-500 flex items-center justify-center gap-3 font-outfit shadow-2xl ${
          isSaved 
            ? 'bg-teal-500/10 text-teal-400 border border-teal-500/20'
            : !hasAnyIntention || isAnalyzing
              ? 'bg-slate-800/50 text-slate-600 border border-white/5 cursor-not-allowed opacity-50'
              : 'bg-slate-800 text-[#FDE68A] border border-[#FDE68A]/20 hover:bg-slate-700 hover:shadow-[#FDE68A]/10 active:scale-95 cursor-pointer'
