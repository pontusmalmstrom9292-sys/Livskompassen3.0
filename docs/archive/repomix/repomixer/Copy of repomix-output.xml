<file path="livskompassen-trasig-1/src/components/EveningCompass.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Moon, Check, ArrowRight, Loader2, Sparkles, ShieldCheck } from 'lucide-react';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, doc, onSnapshot } from 'firebase/firestore';
import { geminiService } from '../services/geminiService';
import { cn } from '../lib/utils';
import { useLearning } from '../contexts/LearningContext';

type ViewState = 'IDLE' | 'KASAM' | 'ANALYZING' | 'RESULT' | 'CHORE_INPUT' | 'CHORE_BREAKDOWN' | 'MICROSTEPPING' | 'DONE';

const KASAM_QUESTIONS = [
  { id: 'comprehensibility', title: 'Begriplighet', text: 'Vad kändes logiskt eller ologiskt idag?' },
  { id: 'manageability', title: 'Hanterbarhet', text: 'Hur hanterade du dagens tyngsta stund?' },
  { id: 'meaningfulness', title: 'Meningsfullhet', text: 'Vad gav dig en gnutta energi eller mening?' }
];

export const EveningCompass = ({ userId }: { userId: string }) => {
  const [view, setView] = useState<ViewState>('IDLE');
  
  // KASAM State
  const [kasamIndex, setKasamIndex] = useState(0);
  const [answers, setAnswers] = useState(['', '', '']);
  const [analysisResult, setAnalysisResult] = useState<any>(null);
  
  // Daily Vibe
  const [dailyVibe, setDailyVibe] = useState<any>(null);

  // Chores State
  const [choreText, setChoreText] = useState('');
  const [choreSteps, setChoreSteps] = useState<any[]>([]);
  const [choreIndex, setChoreIndex] = useState(0);
  const [encouragement, setEncouragement] = useState('');

  const { triggerStrengthMessage } = useLearning();

  useEffect(() => {
    if (!userId) return;
    const unsub = onSnapshot(doc(db, 'daily_vibes', userId), (docSnap) => {
      if (docSnap.exists()) setDailyVibe(docSnap.data());
    });
    return unsub;
  }, [userId]);

  const handleKasamNext = async () => {
    if (kasamIndex < 2) {
      setKasamIndex(prev => prev + 1);
    } else {
      // Finished KASAM
      setView('ANALYZING');
      try {
        const fullReflection = `Begriplighet: ${answers[0]}\nHanterbarhet: ${answers[1]}\nMeningsfullhet: ${answers[2]}`;
        
        // Spara tyst till dagboken
        await addDoc(collection(db, 'diary_entries'), {
          userId,
          content: `KASAM-Reflektion:\n${fullReflection}`,
          vibe: 'NEUTRAL',
          category: 'KASAM',
          timestamp: serverTimestamp()
        });
        
        triggerStrengthMessage('COMPASS_COMPLETE', 'Kvällsreflektion');

        const result = await geminiService.analyzeEveningCompass(fullReflection, dailyVibe);
        setAnalysisResult(result);
        setView('RESULT');
      } catch (error) {
        console.error("KASAM analysis failed:", error);
        setView('CHORE_INPUT'); // Fallback
      }
    }
  };

  const handleChoreSubmit = async () => {
    if (!choreText.trim()) {
      setView('DONE');
      return;
    }
    setView('CHORE_BREAKDOWN');
    try {
      const result = await geminiService.breakDownTask(choreText);
      setChoreSteps(result.steps);
      setEncouragement(result.encouragement);
      setView('MICROSTEPPING');
    } catch (error) {
      console.error("Task breakdown failed:", error);
      setView('DONE'); // Fallback
    }
  };

  const handleStepDone = () => {
    if (choreIndex < choreSteps.length - 1) {
      setChoreIndex(prev => prev + 1);
    } else {
      setView('DONE');
    }
  };

  const renderContent = () => {
    switch (view) {
      case 'IDLE':
        return (
          <motion.div 
            key="idle"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="flex flex-col h-full justify-between"
          >
            <div>
              <div className="flex items-center gap-4 mb-6">
                <div className="p-3 bg-[#FDE68A]/10 rounded-2xl border border-[#FDE68A]/20">
                  <Moon className="w-5 h-5 text-[#FDE68A]" />
                </div>
                <div>
                  <h3 className="text-xl text-slate-100 font-outfit font-light tracking-wide">Kvällskompassen</h3>
                  <p className="text-[10px] text-slate-500 uppercase tracking-widest font-bold">KASAM & Reflektion</p>
                </div>
              </div>
              <p className="text-sm text-slate-400 mb-8 font-inter leading-relaxed italic">
                Vägledd reflektion för att filtrera bort bruset och hitta din inre trygghet och sammanhang.
              </p>
            </div>
            <button 
              onClick={() => setView('KASAM')}
              className="w-full py-5 rounded-[1.5rem] border border-[#FDE68A]/30 text-[#FDE68A] text-[10px] font-bold uppercase tracking-widest hover:bg-[#FDE68A]/10 transition-all flex items-center justify-center gap-2"
            >
              Starta Reflektion <ArrowRight className="w-3 h-3" />
            </button>
          </motion.div>
        );

      case 'KASAM':
        return (
          <motion.div 
            key={`kasam-${kasamIndex}`}
            initial={{ opacity: 0, x: 20 }} animate={{ opacity: 1, x: 0 }} exit={{ opacity: 0, x: -20 }}
            className="flex flex-col h-full"
          >
            <div className="mb-6 flex justify-between items-center">
              <span className="text-[10px] font-bold text-[#FDE68A] uppercase tracking-widest">
                {KASAM_QUESTIONS[kasamIndex].title}
              </span>
              <span className="text-[10px] font-bold text-slate-600">
                {kasamIndex + 1} / 3
              </span>
            </div>
            <h4 className="text-lg text-slate-200 font-outfit mb-6">
              {KASAM_QUESTIONS[kasamIndex].text}
            </h4>
            <textarea
              value={answers[kasamIndex]}
              onChange={(e) => {
                const newAnswers = [...answers];
                newAnswers[kasamIndex] = e.target.value;
                setAnswers(newAnswers);
              }}
              placeholder="Skriv dina tankar..."
              className="flex-1 w-full bg-black/20 border border-white/5 rounded-2xl p-4 text-sm text-slate-300 focus:outline-none focus:border-[#FDE68A]/30 transition-colors resize-none mb-4"
            />
            <button 
              onClick={handleKasamNext}
              disabled={!answers[kasamIndex].trim()}
              className="w-full py-4 rounded-xl bg-[#FDE68A]/10 text-[#FDE68A] text-xs font-bold uppercase hover:bg-[#FDE68A]/20 transition-all disabled:opacity-30 disabled:cursor-not-allowed"
            >
              {kasamIndex === 2 ? 'Lås In Dagen' : 'Nästa'}
            </button>
          </motion.div>
        );

      case 'ANALYZING':
        return (
          <motion.div 
            key="analyzing"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="flex flex-col h-full items-center justify-center text-center space-y-4 py-10"
          >
            <Loader2 className="w-8 h-8 text-[#FDE68A] animate-spin mb-2" />
            <p className="text-xs text-[#FDE68A] font-bold uppercase tracking-widest">Väver samman trådarna</p>
            <p className="text-sm text-slate-400 italic">Söker den objektiva sanningen i dagens brus...</p>
          </motion.div>
        );

      case 'RESULT':
        return (
          <motion.div 
            key="result"
            initial={{ opacity: 0, y: 10 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0 }}
            className="flex flex-col h-full"
          >
            <div className="flex items-center gap-3 mb-6 shrink-0">
              <Sparkles className="w-5 h-5 text-[#FDE68A]" />
              <h3 className="text-lg text-slate-200 font-outfit">Din Inre Trygghet</h3>
            </div>
            
            <div className="flex-1 space-y-4 overflow-y-auto pr-2 pb-4 scrollbar-thin scrollbar-thumb-white/10">
              <div className="p-4 bg-white/[0.02] border border-white/5 rounded-2xl">
                <p className="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Begriplighet</p>
                <p className="text-sm text-slate-300">{analysisResult?.comprehensibility}</p>
              </div>
              <div className="p-4 bg-white/[0.02] border border-white/5 rounded-2xl">
                <p className="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Styrka</p>
                <p className="text-sm text-slate-300">{analysisResult?.manageability}</p>
              </div>
              <div className="p-4 bg-white/[0.02] border border-white/5 rounded-2xl">
                <p className="text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2">Mening</p>
                <p className="text-sm text-slate-300">{analysisResult?.meaningfulness}</p>
              </div>
              <p className="text-sm text-[#FDE68A] italic text-center pt-4 px-2 shrink-0">"{analysisResult?.closingThought}"</p>
            </div>

            <button 
              onClick={() => setView('CHORE_INPUT')}
              className="w-full mt-4 py-4 shrink-0 rounded-xl bg-teal-500/10 text-teal-400 border border-teal-500/20 text-xs font-bold uppercase hover:bg-teal-500/20 transition-all flex items-center justify-center gap-2"
            >
              Nästa: Morgondagens Sköld <ArrowRight className="w-3 h-3" />
            </button>
          </motion.div>
        );

      case 'CHORE_INPUT':
        return (
          <motion.div 
            key="chore_input"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="flex flex-col h-full justify-center space-y-6 py-6"
          >
            <div className="text-center space-y-2">
              <ShieldCheck className="w-8 h-8 text-teal-400 mx-auto mb-4" />
              <h3 className="text-lg text-slate-200 font-outfit">Skydda din morgonenergi</h3>
              <p className="text-sm text-slate-400">Vad behöver göras ikväll för att morgondagen ska bli lugn?</p>
            </div>
            
            <input
              type="text"
              value={choreText}
              onChange={(e) => setChoreText(e.target.value)}
              placeholder="T.ex. Packa barnens väskor..."
              className="w-full bg-black/20 border border-white/5 rounded-2xl p-4 text-center text-sm text-slate-200 focus:outline-none focus:border-teal-500/30"
            />

            <div className="flex gap-3">
              <button 
                onClick={() => setView('DONE')}
                className="flex-1 py-4 rounded-xl bg-white/5 text-slate-400 text-xs font-bold uppercase hover:bg-white/10 transition-colors"
              >
                Hoppa över
              </button>
              <button 
                onClick={handleChoreSubmit}
                disabled={!choreText.trim()}
                className="flex-1 py-4 rounded-xl bg-teal-500/10 text-teal-400 text-xs font-bold uppercase hover:bg-teal-500/20 disabled:opacity-30 transition-colors"
              >
                Bryt Ner Det
              </button>
            </div>
          </motion.div>
        );

      case 'CHORE_BREAKDOWN':
        return (
          <motion.div 
            key="chore_breakdown"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}
            className="flex flex-col h-full items-center justify-center text-center space-y-4 py-10"
          >
            <Loader2 className="w-8 h-8 text-teal-400 animate-spin mb-2" />
            <p className="text-xs text-teal-400 font-bold uppercase tracking-widest">Processar Uppgift</p>
            <p className="text-sm text-slate-400 italic">Skapar mikrosteg för att undvika bandbreddsskatt...</p>
          </motion.div>
        );

      case 'MICROSTEPPING':
        return (
          <motion.div 
            key={`step-${choreIndex}`}
            initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} exit={{ opacity: 0, scale: 1.05 }}
            className="flex flex-col h-full items-center justify-center text-center py-6"
          >
            <span className="text-[10px] font-bold text-teal-500/50 uppercase tracking-widest mb-6">
              Steg {choreIndex + 1} av {choreSteps.length}
            </span>
            
            <h2 className="text-2xl text-white font-outfit mb-12 max-w-[250px] leading-tight">
              {choreSteps[choreIndex]?.text}
            </h2>

            <button 
              onClick={handleStepDone}
              className="w-32 h-32 rounded-full bg-teal-500/10 border-2 border-teal-500/30 text-teal-400 hover:bg-teal-500 hover:text-white transition-all duration-300 flex flex-col items-center justify-center gap-2 group shadow-[0_0_30px_rgba(45,212,191,0.1)] hover:shadow-[0_0_50px_rgba(45,212,191,0.3)] active:scale-90"
            >
              <Check className="w-10 h-10 group-hover:scale-110 transition-transform" />
              <span className="text-[10px] font-bold uppercase tracking-widest">Klar</span>
            </button>
          </motion.div>
        );

      case 'DONE':
        return (
          <motion.div 
            key="done"
            initial={{ opacity: 0 }} animate={{ opacity: 1 }}
            className="flex flex-col h-full items-center justify-center text-center space-y-6 py-6"
          >
            <div className="relative">
              <div className="absolute inset-0 bg-[#FDE68A]/20 rounded-full blur-2xl" />
              <Moon className="w-16 h-16 text-[#FDE68A] relative z-10" />
            </div>
            <div className="space-y-2">
              <h3 className="text-xl text-slate-200 font-outfit">Din morgondag är skyddad</h3>
              <p className="text-sm text-slate-400 italic">Verklighetsvalvet vakar. Sov gott.</p>
            </div>
            {encouragement && (
              <p className="text-xs text-teal-400 font-medium px-4 py-2 bg-teal-500/10 rounded-lg">
                "{encouragement}"
              </p>
            )}
            <button 
              onClick={() => {
                setView('IDLE');
                setAnswers(['', '', '']);
                setKasamIndex(0);
                setChoreText('');
                setChoreIndex(0);
              }}
              className="text-[10px] text-slate-500 uppercase font-bold hover:text-slate-300 transition-colors mt-8"
            >
              Återställ
            </button>
          </motion.div>
        );
    }
  };

  return (
    <div className="bg-gradient-to-b from-[#0f172a]/80 to-[#020617]/90 backdrop-blur-xl border border-white/5 rounded-[2.5rem] p-8 shadow-2xl h-[450px] relative overflow-hidden">
      {/* ProgressBar (thin line at bottom) */}
      {view !== 'IDLE' && view !== 'DONE' && (
        <div className="absolute bottom-0 left-0 h-1 bg-white/5 w-full">
          <motion.div 
            className={cn("h-full", view.startsWith('CHORE') || view === 'MICROSTEPPING' ? 'bg-teal-500/50' : 'bg-[#FDE68A]/50')}
            initial={{ width: 0 }}
            animate={{ 
              width: view === 'KASAM' ? `${((kasamIndex + 1) / 4) * 100}%` :
                     view === 'RESULT' ? '40%' :
                     view === 'CHORE_INPUT' ? '50%' :
                     view === 'MICROSTEPPING' ? `${50 + ((choreIndex + 1) / choreSteps.length) * 50}%` : '100%'
            }}
            transition={{ duration: 0.5 }}
          />
        </div>
      )}

      <AnimatePresence mode="wait">
        {renderContent()}
      </AnimatePresence>
    </div>
  );
};
</file>

