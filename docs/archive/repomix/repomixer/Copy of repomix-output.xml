import { MorningCompass } from './MorningCompass';
import { EveningCompass } from './EveningCompass';
import { RoutineFlow } from './flow/RoutineFlow';
import { MoodJournal } from './flow/MoodJournal';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Moon, Zap, Book, PenLine, Camera, Mic, 
  Smile, ShieldCheck, Heart, CloudRain, Frown, 
  ShieldAlert, Loader2, Compass, Lock, Calendar, Wallet
} from 'lucide-react';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, query, where, orderBy, limit, onSnapshot } from 'firebase/firestore';
import { cn } from '../lib/utils';
import { RadarEvent } from '../types';
import { useLearning } from '../contexts/LearningContext';

type Vibe = 'CALM' | 'ANXIOUS' | 'ANGRY' | 'SAD' | 'STRONG' | 'NEUTRAL';

const VIBES: { type: Vibe, icon: any, label: string, color: string, bg: string }[] = [
  { type: 'STRONG', icon: Zap, label: 'Stark', color: 'text-amber-400', bg: 'bg-amber-500/10' },
  { type: 'CALM', icon: ShieldCheck, label: 'Lugn', color: 'text-teal-400', bg: 'bg-teal-500/10' },
  { type: 'NEUTRAL', icon: Smile, label: 'Neutral', color: 'text-slate-400', bg: 'bg-slate-500/10' },
  { type: 'ANXIOUS', icon: Heart, label: 'Orolig', color: 'text-indigo-400', bg: 'bg-indigo-500/10' },
  { type: 'SAD', icon: CloudRain, label: 'Ledsen', color: 'text-blue-400', bg: 'bg-blue-500/10' },
  { type: 'ANGRY', icon: Frown, label: 'Arg', color: 'text-rose-400', bg: 'bg-rose-500/10' },
];

// ─── Synaps 1: Dagboken skickar "Strength Message" vid Lås In ───────────────
const QuickDiary = ({ userId }: { userId: string }) => {
  const [content, setContent] = useState('');
  const [selectedVibe, setSelectedVibe] = useState<Vibe>('NEUTRAL');
  const [isSaving, setIsSaving] = useState(false);
  const [strategicPrompt, setStrategicPrompt] = useState<string | null>(null);
  const { triggerStrengthMessage } = useLearning();

  useEffect(() => {
    if (!userId) return;
    const q = query(
      collection(db, 'strategic_briefings'), 
      where('userId', '==', userId), 
      orderBy('timestamp', 'desc'), 
      limit(1)
    );
    return onSnapshot(q, (snap) => {
      if (!snap.empty) {
        const brief = snap.docs[0].data();
        setStrategicPrompt(brief.anchorPhrase || brief.masterBrief);
      }
    });
  }, [userId]);

  const handleSave = async () => {
    if (!content.trim()) return;
    setIsSaving(true);
    try {
      await addDoc(collection(db, 'diary_entries'), {
        userId,
        content,
        vibe: selectedVibe,
        timestamp: serverTimestamp(),
      });
      // Synaps: Dagbok → LearningContext → Strength Message
      triggerStrengthMessage('VAULT_SAVE', content);
      setContent('');
      setSelectedVibe('NEUTRAL');
    } catch (error) {
      console.error("Save failed:", error);
    } finally {
      setIsSaving(false);
    }
  };

  return (
    <div className="bg-[#020617]/60 backdrop-blur-2xl border border-white/5 rounded-[3rem] p-8 lg:p-10 relative overflow-hidden shadow-2xl group transition-all duration-700 hover:border-rose-500/20">
      <div className="absolute -top-24 -right-24 w-64 h-64 bg-rose-500/5 rounded-full blur-[100px] group-hover:bg-rose-500/10 transition-colors" />
      
      <div className="relative space-y-8">
        <div className="flex items-center gap-4">
          <div className="p-3 bg-rose-500/10 rounded-2xl border border-rose-500/20">
            <Book className="w-5 h-5 text-rose-400" />
          </div>
          <div>
            <h3 className="text-xl text-slate-100 font-outfit font-light tracking-wide">Snabb-Dagbok</h3>
            <p className="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Hur känns ditt hjärta?</p>
          </div>
        </div>

        {strategicPrompt && (
          <motion.div 
            initial={{ opacity: 0, y: 5 }}
            animate={{ opacity: 1, y: 0 }}
            className="p-5 bg-indigo-500/5 border border-indigo-500/10 rounded-2xl relative overflow-hidden group/prompt"
          >
            <div className="absolute top-0 right-0 p-3 opacity-10 group-hover/prompt:opacity-20 transition-opacity">
              <Sparkles className="w-8 h-8 text-indigo-400" />
            </div>
            <p className="text-[10px] text-indigo-400 uppercase font-black tracking-widest mb-1">Strategisk Reflektion</p>
            <p className="text-xs text-slate-300 italic font-inter leading-relaxed relative">
              "{strategicPrompt}"
            </p>
          </motion.div>
        )}

        <div className="flex flex-wrap gap-3 justify-center md:justify-start">
          {VIBES.map((v) => (
            <button
              key={v.type}
              onClick={() => setSelectedVibe(v.type)}
              className={cn(
                "p-3 rounded-2xl transition-all border",
                selectedVibe === v.type ? v.bg + " border-white/20 scale-105" : "bg-white/[0.02] border-transparent hover:bg-white/5"
              )}
            >
              <v.icon className={cn("w-4 h-4", selectedVibe === v.type ? v.color : "text-slate-500")} />
            </button>
          ))}
        </div>
        
        <div className="space-y-4">
          <textarea 
            value={content}
            onChange={(e) => setContent(e.target.value)}
            placeholder="Skriv, prata eller ta en bild..." 
            className="w-full bg-black/40 border border-white/5 rounded-[2rem] px-6 py-5 text-slate-200 text-sm focus:outline-none focus:border-rose-500/20 transition-all placeholder:text-slate-700 resize-none h-28"
          />
          
          <div className="flex gap-3">
