import { useLearning } from '../contexts/LearningContext';
import { useVertexAnalysis } from '../hooks/useVertexAnalysis';
import { shieldApi } from '../services/apiService';

export const LegalStrategyVault = ({ userId }: { userId: string }) => {
  const { isLoading: isVertexLoading } = useVertexAnalysis() as any;
  const [loading, setLoading] = useState(true);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [analysis, setAnalysis] = useState<any>(null);
  const [events, setEvents] = useState<any[]>([]);
  const [score, setScore] = useState<any>(null);
  const [legalBrief, setLegalBrief] = useState<any>(null);
  const [isGeneratingBrief, setIsGeneratingBrief] = useState(false);
  const { triggerStrengthMessage } = useLearning();

  useEffect(() => {
    if (!userId) return;
    const q = query(
      collection(db, 'events'), 
      where('userId', '==', userId), 
      orderBy('timestamp', 'desc'), 
      limit(50)
    );
    const unsub = onSnapshot(q, (snap) => setEvents(snap.docs.map(d => d.data())));
    return unsub;
  }, [userId]);

  const runAnalysis = async () => {
    if (events.length === 0) return;
    setIsAnalyzing(true);
    try {
      // Use the grounded Vertex AI agents
      const [res, scoreRes] = await Promise.all([
        shieldApi.analyze({
          content: "Analysera tecken på coercive control och taktiskt beteende.",
          mode: "PATTERN",
          context: { events }
        }),
        shieldApi.analyzeEscalation({
          newEvent: events[0]?.description || "",
          historicalEvents: events.slice(1, 20),
          actorProfiles: []
        })
      ]);
      
      setAnalysis(res);
      setScore({
        grade: scoreRes.escalationLevel === 'CRITICAL' ? 'A' : 'B',
        legalViability: scoreRes.escalationScore,
        gaslightingExposure: 100 - scoreRes.escalationScore,
        gaps: scoreRes.immediateWarnings,
        priorityNext: scoreRes.timelineInsight
      });
      
      triggerStrengthMessage('PATTERN_DETECTED');
    } catch (error) {
      console.error("Legal analysis failed:", error);
    } finally {
      setIsAnalyzing(false);
      setLoading(false);
    }
  };

  const generateBrief = async () => {
    if (events.length < 3) return;
    setIsGeneratingBrief(true);
    try {
      const res = await shieldApi.analyze({
        content: "Generera en juridisk brief för ombud.",
        mode: "LEGAL",
        context: { events }
      });
      setLegalBrief(res);
      triggerStrengthMessage('VAULT_SAVE', 'Juridisk brief har genererats.');
    } catch (error) {
      console.error("Legal brief failed:", error);
    } finally {
      setIsGeneratingBrief(false);
    }
  };

  useEffect(() => {
    if (events.length >= 3 && !analysis) {
      runAnalysis();
    } else if (events.length === 0) {
      setLoading(false);
    }
  }, [events]);

  if (loading && !analysis) return (
    <div className="py-24 flex flex-col items-center justify-center gap-6">
      <div className="p-6 bg-indigo-500/10 rounded-full border border-indigo-500/20">
        <Loader2 className="w-12 h-12 text-indigo-500/40 animate-spin" />
      </div>
      <p className="text-[10px] uppercase tracking-[0.4em] text-slate-500 font-bold">Sammanställer juridisk bevisstyrka...</p>
    </div>
  );

  return (
    <div className="space-y-12 animate-in fade-in duration-700 max-w-6xl mx-auto">
      {/* Strategy Header */}
      <div className="bg-[#0f172a]/80 border border-white/5 rounded-[3.5rem] p-12 md:p-16 relative overflow-hidden shadow-2xl">
        <div className="absolute inset-0 bg-gradient-to-br from-indigo-500/10 to-transparent" />
        
        <div className="relative flex flex-col md:flex-row justify-between items-start md:items-center gap-10">
          <div className="flex items-center gap-8">
            <div className="p-6 bg-indigo-500/10 rounded-[2.5rem] border border-indigo-500/20 shadow-2xl shadow-indigo-900/20">
              <Gavel className="w-12 h-12 text-indigo-400" />
            </div>
            <div>
              <h3 className="text-4xl text-white font-outfit font-light tracking-tighter">Juridisk Strategi-Hub</h3>
              <div className="flex items-center gap-3 mt-2">
                <div className="w-2 h-2 rounded-full bg-teal-500 animate-pulse" />
                <p className="text-[10px] text-slate-500 uppercase tracking-[0.4em] font-black">Eftervåld & Coercive Control</p>
              </div>
            </div>
          </div>
          
          <div className="flex items-center gap-6">
            {score && (
              <div className="px-8 py-4 bg-white/5 rounded-3xl border border-white/5 flex flex-col items-center shadow-inner">
                <span className="text-[9px] text-slate-500 font-black uppercase tracking-widest mb-1">Bevis-Betyg</span>
                <span className={cn(
                  "text-3xl font-outfit font-bold",
                  score.grade === 'A' ? 'text-teal-400' : 
                  score.grade === 'B' ? 'text-indigo-400' : 'text-amber-400'
                )}>{score.grade}</span>
              </div>
            )}
            <button 
              onClick={runAnalysis} 
              disabled={isAnalyzing || isVertexLoading}
              className="p-6 bg-indigo-600 hover:bg-indigo-500 rounded-3xl transition-all shadow-2xl shadow-indigo-900/40 active:scale-95"
            >
              {isAnalyzing || isVertexLoading ? <Loader2 className="w-6 h-6 text-white animate-spin" /> : <Sparkles className="w-6 h-6 text-white" />}
            </button>
