      </div>

      {loading ? (
        <div className="h-64 flex flex-col items-center justify-center border border-white/5 rounded-[3rem] bg-[#020617]/40 space-y-4">
          <Loader2 className="w-10 h-10 text-indigo-500 animate-spin" />
          <p className="text-[10px] text-slate-600 uppercase tracking-widest font-black">Genomsöker arkivet via Synapse-bussen...</p>
