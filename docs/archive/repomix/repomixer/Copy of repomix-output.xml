<file path="livskompassen-trasig-1/src/components/MorningCompass.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Compass, CheckCircle2, Zap, Brain, Info, Loader2, Shield, Sparkles, BookOpen, Book, ArrowRight } from 'lucide-react';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { useLearning } from '../contexts/LearningContext';
import { shieldApi } from '../services/apiService';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, query, where, orderBy, limit, getDocs, onSnapshot, doc } from 'firebase/firestore';
import { cn } from '../lib/utils';

export const MorningCompass: React.FC<{ userId?: string }> = ({ userId }) => {
  const { updateDailyVibe } = useSystemMemory();
  const { triggerStrengthMessage, snippets, setActiveSnippet } = useLearning();
  const [intentions, setIntentions] = useState<string[]>(['', '', '']);
  const [stressLevel, setStressLevel] = useState(3);
  const [energyLevel, setEnergyLevel] = useState(7);
  const [isSaved, setIsSaved] = useState(false);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [guidance, setGuidance] = useState<any>(null);
  const [suggestedIntentions, setSuggestedIntentions] = useState<string[]>([]);
  const [chronosWarning, setChronosWarning] = useState<string | null>(null);
  
  const [isBreakingDown, setIsBreakingDown] = useState(false);
  const [breakdownSteps, setBreakdownSteps] = useState<any[]>([]);
  const [coreValueAnchors, setCoreValueAnchors] = useState<string[]>([]);
  const [identityGrounding, setIdentityGrounding] = useState<string | null>(null);

  useEffect(() => {
    if (!userId) return;
    
    const loadStrategicContext = async () => {
      // 1. Fetch Radar Events for Chronos
      const q = query(collection(db, 'events'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(30));
      const snap = await getDocs(q);
      const events = snap.docs.map(d => d.data());
      
      if (events.length >= 2) {
        try {
          const res = await shieldApi.analyzeChronos(events, userId);
          const patterns = res.analysis;
          if (patterns.escalationTrend === 'ESKALERANDE') {
            setChronosWarning("Varning: Systemet ser en eskalerande trend. Prioritera skydd idag.");
          }
          
          // 2. Fetch Strategic Moves & Values
          const diaryQ = query(collection(db, 'diary_entries'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(3));
          const diarySnap = await getDocs(diaryQ);
          const diaryEntries = diarySnap.docs.map(d => d.data());
          
          const valuesQ = query(collection(db, 'core_values'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(1));
          const valuesSnap = await getDocs(valuesQ);
          const values = valuesSnap.empty ? [] : valuesSnap.docs[0].data().values;
          setCoreValueAnchors(values);

          // 3. Identity Grounding
          const identQ = query(collection(db, 'identity_analysis'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(1));
          const identSnap = await getDocs(identQ);
          if (!identSnap.empty) {
            setIdentityGrounding(identSnap.docs[0].data().identityBrief);
          }

          const brief = await shieldApi.analyze({
            content: "Skapa en strategisk morgon-brief.",
            mode: "DEFAULT",
            context: { events, diaryEntries, stressLevel, energyLevel, values }
          });
          
          setSuggestedIntentions(brief.nextSteps || []);
        } catch (e) {
          console.warn("Could not load strategic context for Morning Compass", e);
        }
      }
    };
    
    loadStrategicContext();
  }, [userId, stressLevel, energyLevel]);

  const adoptIntention = (text: string) => {
    const emptyIdx = intentions.findIndex(i => !i.trim());
    if (emptyIdx !== -1) {
      const newIntentions = [...intentions];
      newIntentions[emptyIdx] = text;
      setIntentions(newIntentions);
    }
  };

  const handleIntentionChange = (index: number, value: string) => {
    if (isSaved) return;
    const newIntentions = [...intentions];
    newIntentions[index] = value;
    setIntentions(newIntentions);
  };

  const handleLearn = (e: React.MouseEvent) => {
    e.stopPropagation();
    const snippet = snippets.find(s => s.id === 'morning-compass');
    if (snippet) setActiveSnippet(snippet);
  };

  const handleSave = async () => {
    setIsAnalyzing(true);
    try {
      // 1. Spara grunddata
      await updateDailyVibe({
        stressLevel,
        energyLevel
      });

      // 2. Generera AI-vägledning
      const res = await shieldApi.analyze({
        content: `INTENTIONER: ${intentions.filter(i => i.trim()).join(', ')}`,
        mode: "DEFAULT",
        context: { stressLevel, energyLevel, type: 'MORNING_COMPASS' }
      });
      
      const guidanceData = {
        vibeCheck: res.masterInsight,
        anchoringAdvice: res.strategicAdvice.rationale,
        recommendedProtocol: res.strategicAdvice.action === 'BIFF' ? 'VIVIR' : 'NORMAL',
        diaryDraft: res.strategicAdvice.script,
        complexTaskIndex: 0
      };
      
      setGuidance(guidanceData);

      // 3. Spara dagboks-utkast
      if (userId && guidanceData.diaryDraft) {
        await addDoc(collection(db, 'diary_entries'), {
          userId,
          content: guidanceData.diaryDraft,
          vibe: 'NEUTRAL',
          type: 'MORNING_DRAFT',
          timestamp: serverTimestamp(),
          isDraft: true
        });
      }

      setIsSaved(true);
      triggerStrengthMessage('COMPASS_COMPLETE', guidanceData.vibeCheck);
    } catch (error) {
      console.error("Compass analysis failed:", error);
      setIsSaved(true);
    } finally {
      setIsAnalyzing(false);
    }
  };

  const handleBreakdown = async () => {
    if (guidance?.complexTaskIndex === null) return;
    const task = intentions[guidance.complexTaskIndex];
    setIsBreakingDown(true);
    try {
      const res = await shieldApi.analyze({
        content: `Bryt ner denna uppgift i mikrosteg: ${task}`,
        mode: "DEFAULT"
      });
      
      setBreakdownSteps(res.nextSteps.map(step => ({ text: step, why: "Minskar kognitiv last" })));
      triggerStrengthMessage('COMPASS_COMPLETE', "Uppgiften är nu nedbruten i mikrosteg.");
    } catch (error) {
      console.error("Breakdown failed:", error);
    } finally {
      setIsBreakingDown(false);
    }
  };

  const hasAnyIntention = intentions.some(i => i.trim() !== '');

  return (
    <div className="w-full max-w-md mx-auto bg-[#0f172a]/60 backdrop-blur-xl border border-white/5 rounded-[2.5rem] p-6 sm:p-10 shadow-2xl relative overflow-hidden animate-in fade-in zoom-in duration-700">
      {/* Soft top gradient for Den Trygga Hamnen */}
      <div className="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#FDE68A]/40 to-transparent"></div>
      
      <div className="flex items-center justify-between mb-8">
        <div className="flex items-center gap-5">
          <div className="p-4 bg-[#FDE68A]/10 rounded-[1.5rem] border border-[#FDE68A]/10 shadow-inner relative group">
            <div className="absolute inset-0 bg-[#FDE68A]/20 rounded-[1.5rem] blur-xl opacity-0 group-hover:opacity-100 transition-opacity animate-pulse" />
            <Compass className="w-7 h-7 text-[#FDE68A] relative z-10" strokeWidth={1.5} />
          </div>
          <div>
            <h2 className="text-2xl font-light text-slate-100 tracking-wide font-outfit">
              Morgonkompassen
            </h2>
            <p className="text-[10px] uppercase tracking-[0.2em] text-slate-500 mt-1 font-bold">
              Riktning & Inre Väder
            </p>
          </div>
        </div>
        <button 
          onClick={handleLearn}
          className="p-3 hover:bg-white/5 rounded-2xl transition-all"
        >
          <Info className="w-5 h-5 text-[#FDE68A]/40" />
        </button>
      </div>

      {identityGrounding && !isSaved && (
        <motion.div 
          initial={{ opacity: 0, y: -10 }}
          animate={{ opacity: 1, y: 0 }}
          className="mb-10 p-6 bg-indigo-500/5 border border-indigo-500/10 rounded-[2rem] relative group"
        >
          <div className="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
            <Shield className="w-12 h-12 text-white" />
          </div>
          <p className="text-[10px] uppercase font-bold text-indigo-400 tracking-widest mb-2 flex items-center gap-2">
            <Sparkles className="w-3 h-3" /> Identitets-Förankring
          </p>
          <p className="text-sm text-slate-300 font-inter leading-relaxed italic">
            "{identityGrounding}"
          </p>
        </motion.div>
      )}

      {/* Dagsform / Vibe Check */}
      <div className="space-y-8 mb-10">
        <div className="space-y-4">
          <div className="flex justify-between items-center px-1">
            <span className="text-[10px] uppercase font-bold text-slate-500 tracking-widest flex items-center gap-2">
              <Brain className="w-3 h-3" /> Stress-nivå
            </span>
            <span className={`text-xs font-bold ${stressLevel > 7 ? 'text-red-400' : 'text-[#FDE68A]'}`}>{stressLevel}/10</span>
          </div>
          <input 
            type="range" min="1" max="10" 
            value={stressLevel} onChange={(e) => setStressLevel(parseInt(e.target.value))}
            disabled={isSaved}
            className="w-full h-1.5 bg-slate-800 rounded-full appearance-none cursor-pointer accent-[#FDE68A]"
          />
        </div>

        <div className="space-y-4">
          <div className="flex justify-between items-center px-1">
            <span className="text-[10px] uppercase font-bold text-slate-500 tracking-widest flex items-center gap-2">
              <Zap className="w-3 h-3" /> Energinivå
            </span>
            <span className="text-xs font-bold text-teal-400">{energyLevel}/10</span>
          </div>
          <input 
            type="range" min="1" max="10" 
            value={energyLevel} onChange={(e) => setEnergyLevel(parseInt(e.target.value))}
            disabled={isSaved}
            className="w-full h-1.5 bg-slate-800 rounded-full appearance-none cursor-pointer accent-teal-400"
          />
        </div>
      </div>

      {chronosWarning && (
        <motion.div 
          initial={{ opacity: 0, scale: 0.95 }}
          animate={{ opacity: 1, scale: 1 }}
          className="mb-8 p-4 bg-rose-500/10 border border-rose-500/20 rounded-2xl flex items-center gap-4 animate-pulse"
        >
          <Shield className="w-5 h-5 text-rose-500" />
          <p className="text-[10px] font-bold text-rose-400 uppercase tracking-widest">{chronosWarning}</p>
        </motion.div>
      )}

      {/* Strategic Suggestions & Value Anchors */}
      {!isSaved && (
        <div className="mb-10 space-y-6">
          {suggestedIntentions.length > 0 && (
            <div className="space-y-3">
              <p className="text-[10px] uppercase font-bold text-slate-500 tracking-widest px-1">Strategiska Fokus</p>
              <div className="flex flex-wrap gap-2">
                {suggestedIntentions.map((text, i) => (
                  <button
                    key={i}
                    onClick={() => adoptIntention(text)}
                    disabled={intentions.includes(text)}
                    className={cn(
                      "px-3 py-2 rounded-xl text-[10px] font-bold transition-all border",
                      intentions.includes(text) 
                        ? "bg-indigo-500/20 border-indigo-500/30 text-indigo-400 opacity-50" 
                        : "bg-white/5 border-white/5 text-slate-400 hover:bg-white/10 hover:border-white/20"
                    )}
                  >
                    + {text}
                  </button>
                ))}
              </div>
            </div>
          )}

          {coreValueAnchors.length > 0 && (
            <div className="space-y-3">
              <p className="text-[10px] uppercase font-bold text-slate-500 tracking-widest px-1">Värderings-Ankare</p>
              <div className="flex flex-wrap gap-2">
                {coreValueAnchors.map((val, i) => (
                  <button
                    key={i}
                    onClick={() => adoptIntention(`Agera utifrån ${val.toLowerCase()}`)}
                    className="px-3 py-2 rounded-xl text-[10px] font-bold bg-[#2DD4BF]/5 border border-[#2DD4BF]/20 text-[#2DD4BF] hover:bg-[#2DD4BF]/10 transition-all"
                  >
                    ⚓ {val}
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      <div className="space-y-4 mb-10 border-t border-white/5 pt-8">
        <p className="text-[10px] uppercase font-bold text-slate-500 tracking-widest mb-4 px-1">Dagens Intentionsankare</p>
        {intentions.map((intention, index) => (
          <div key={index} className="flex items-center gap-4">
