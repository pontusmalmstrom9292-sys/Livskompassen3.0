      </div>
    );
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex items-center gap-4">
        <div className="w-12 h-12 rounded-2xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center">
          <span className="text-xl">👤</span>
        </div>
        <div>
          <h3 className="text-xl font-outfit text-white font-light">{promotion.name}</h3>
          <p className="text-[10px] font-bold text-amber-500 uppercase tracking-widest">
            Har dykt upp {promotion.count} gånger i dina loggar
          </p>
        </div>
      </div>

      {analysis && (
        <div className="p-5 bg-white/[0.03] border border-white/5 rounded-2xl space-y-3">
          <div className="flex items-center gap-2 mb-2">
            <Sparkles className="w-3.5 h-3.5 text-indigo-400" />
            <span className="text-[10px] uppercase font-bold text-indigo-400 tracking-widest">AI-Analys</span>
          </div>
          <p className="text-[11px] text-slate-400 italic font-bold uppercase tracking-widest">Föreslagen Roll</p>
          <p className="text-sm text-slate-200">{analysis.suggestedRole}</p>
          <p className="text-[11px] text-slate-400 italic font-bold uppercase tracking-widest mt-3">Sammanfattning</p>
          <p className="text-xs text-slate-300 leading-relaxed">{analysis.suggestedBio}</p>
        </div>
      )}

      {/* Trust Level Picker */}
      <div className="space-y-2">
        <p className="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Bekräfta förtroende-nivå</p>
        <div className="grid grid-cols-3 gap-2">
          {TRUST_OPTIONS.map(opt => (
            <button
              key={opt.value}
              onClick={() => setTrust(opt.value)}
              className={cn(
                "py-3 px-2 rounded-2xl border text-xs font-bold transition-all text-center",
                trust === opt.value ? opt.bg + ' ' + opt.color + ' scale-105' : 'bg-white/[0.02] border-white/5 text-slate-500'
              )}
            >
              {opt.label}
            </button>
          ))}
        </div>
      </div>

      {/* Actions */}
      <div className="flex gap-3">
        <button
          onClick={handleMute}
          className="p-3 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl transition-all"
          title="Tysta – fråga inte igen"
        >
          <UserX className="w-5 h-5 text-slate-500" />
        </button>
        <button
          onClick={handlePromote}
          disabled={isPromoting}
          className="flex-1 py-3 bg-indigo-500/20 hover:bg-indigo-500/30 text-indigo-300 border border-indigo-500/30 rounded-xl font-outfit font-bold text-sm tracking-widest uppercase transition-all flex items-center justify-center gap-2"
        >
          {isPromoting 
            ? <Loader2 className="w-4 h-4 animate-spin" /> 
            : <><UserPlus className="w-4 h-4" /> Skapa Profil</>
          }
        </button>
      </div>
      <p className="text-[9px] text-slate-600 text-center">
        All historik med denna person kopplas automatiskt till profilen.
      </p>
    </div>
  );
};

export const ActorPromotionAlert: React.FC<ActorPromotionAlertProps> = ({ promotions, userId, onDismiss }) => {
  const [currentIdx, setCurrentIdx] = useState(0);

  const handleNext = () => {
    if (currentIdx < promotions.length - 1) {
      setCurrentIdx(prev => prev + 1);
    } else {
      onDismiss();
    }
  };

  if (promotions.length === 0) return null;
  const current = promotions[currentIdx];

  return (
    <AnimatePresence>
      <motion.div
        initial={{ opacity: 0 }}
        animate={{ opacity: 1 }}
        exit={{ opacity: 0 }}
        className="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-black/80 backdrop-blur-md"
        onClick={(e) => e.target === e.currentTarget && onDismiss()}
      >
        <motion.div
          initial={{ scale: 0.9, opacity: 0, y: 20 }}
          animate={{ scale: 1, opacity: 1, y: 0 }}
          exit={{ scale: 0.95, opacity: 0 }}
          className="w-full max-w-md bg-[#0a0f1e] border border-indigo-500/30 rounded-[3rem] p-8 shadow-[0_30px_80px_rgba(0,0,0,0.8)] relative overflow-hidden"
        >
          {/* Ambient glow */}
          <div className="absolute -top-20 -right-20 w-64 h-64 bg-indigo-500/10 rounded-full blur-[80px]" />

          {/* Header badge */}
          <div className="flex items-center justify-between mb-8 relative">
            <div className="flex items-center gap-2 px-3 py-1.5 bg-amber-500/10 border border-amber-500/20 rounded-full">
              <ShieldAlert className="w-3.5 h-3.5 text-amber-500" />
              <span className="text-[10px] font-bold text-amber-500 uppercase tracking-widest">
                Ny Aktör Detekterad
              </span>
              {promotions.length > 1 && (
                <span className="ml-1 text-[9px] text-amber-500/60">({currentIdx + 1}/{promotions.length})</span>
              )}
            </div>
            <button onClick={onDismiss} className="p-2 hover:bg-white/5 rounded-full transition-all">
              <X className="w-4 h-4 text-slate-500" />
            </button>
          </div>

          <SinglePromotion
            key={current.name}
            promotion={current}
            userId={userId}
            onDone={handleNext}
            onSkip={handleNext}
          />
        </motion.div>
      </motion.div>
    </AnimatePresence>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/AIAssistantModal.tsx">
import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  X, Sparkles, ShieldCheck, Send, Loader2, Check, 
  TrendingUp, Activity, Wallet, Network, FileText,
  AlertTriangle, ArrowRight, ShieldAlert, Zap, Heart, Scale, Database, Calendar
} from 'lucide-react';
import { shieldApi } from '../services/apiService';
import { cn } from '../lib/utils';

type AgentMode = 'FEELINGS' | 'SAFETY' | 'ESCALATION' | 'ECONOMIC' | 'NETWORK' | 'REPORT' | 'CRISIS' | 'LEGAL' | 'ARCHIVE' | 'SCHEDULE' | 'BUDGET';

interface AIAssistantModalProps {
  isOpen: boolean;
  onClose: () => void;
  mode: AgentMode;
  userId: string;
}

export const AIAssistantModal = ({ isOpen, onClose, mode, userId }: AIAssistantModalProps) => {
  const [input, setInput] = useState('');
  const [isLoading, setIsLoading] = useState(false);
  const [result, setResult] = useState<any>(null);
  const [isApproved, setIsApproved] = useState(false);

  const handleAnalyze = async () => {
    setIsLoading(true);
    try {
      let response;
      switch (mode) {
        case 'LEGAL':
          response = await shieldApi.analyzeLegal({ content: input, events: [] });
          break;
        case 'ARCHIVE':
          response = await shieldApi.analyzeArchive({ content: input });
          break;
        case 'SCHEDULE':
          response = await shieldApi.analyzeSchedule({ scheduleText: input, existingCalendar: [] });
          break;
        case 'BUDGET':
          response = await shieldApi.analyzeBudget({ transactions: [], budgetGoals: [] });
          break;
        case 'ESCALATION':
          response = await shieldApi.analyzeEscalation({ 
            newEvent: input, 
            historicalEvents: [], // TODO: Hämta från Firestore
            actorProfiles: [] 
          });
          break;
        case 'CRISIS':
          response = await shieldApi.analyzeCrisis({ diaryText: input });
          break;
        case 'ECONOMIC':
          response = await shieldApi.analyzeEconomic({ transactions: [], contextNotes: input });
          break;
        case 'NETWORK':
          response = await shieldApi.analyzeNetwork({ actors: [], networkMembers: [], recentEvents: [], userDescription: input });
          break;
        case 'REPORT':
          response = await shieldApi.generateComprehensiveReport({ events: [], actors: [], networkMembers: [], transactions: [], diaryEntries: [] });
          break;
        default:
          response = await shieldApi.analyze({
            content: input,
            mode: mode === 'SAFETY' ? 'BIFF' : 'PATTERN',
          });
      }
      setResult(response);
    } catch (error) {
      console.error("Analysis failed:", error);
    } finally {
      setIsLoading(false);
    }
  };

  const getAgentTheme = () => {
    switch (mode) {
      case 'LEGAL': return { icon: Scale, title: 'Juridisk Strateg', color: 'text-amber-500', bg: 'bg-amber-500/10' };
      case 'ARCHIVE': return { icon: Database, title: 'Arkiv-Väktaren', color: 'text-purple-400', bg: 'bg-purple-500/10' };
      case 'ESCALATION': return { icon: TrendingUp, title: 'Eskalerings-Detektorn', color: 'text-rose-400', bg: 'bg-rose-500/10' };
      case 'CRISIS': return { icon: Zap, title: 'Kris-Stabilisatorn', color: 'text-amber-400', bg: 'bg-amber-500/10' };
      case 'ECONOMIC': return { icon: Wallet, title: 'Ekonomisk Analys', color: 'text-orange-400', bg: 'bg-orange-500/10' };
      case 'NETWORK': return { icon: Network, title: 'Nätverks-Kartläggaren', color: 'text-indigo-400', bg: 'bg-indigo-500/10' };
      case 'REPORT': return { icon: FileText, title: 'Rapport-Generatorn', color: 'text-teal-400', bg: 'bg-teal-500/10' };
      case 'SCHEDULE': return { icon: Calendar, title: 'Schema-Harmonisator', color: 'text-amber-300', bg: 'bg-amber-400/10' };
      case 'BUDGET': return { icon: Wallet, title: 'Budget-Väktaren', color: 'text-emerald-400', bg: 'bg-emerald-500/10' };
      default: return { icon: Sparkles, title: 'AI-Assistenten', color: 'text-indigo-400', bg: 'bg-indigo-500/10' };
    }
  };

  const theme = getAgentTheme();

  if (!isOpen) return null;

  return (
    <AnimatePresence>
      <div className="fixed inset-0 z-[100] flex items-center justify-center p-4">
        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          exit={{ opacity: 0 }}
          onClick={onClose}
          className="absolute inset-0 bg-black/80 backdrop-blur-xl"
        />
        
        <motion.div
          initial={{ opacity: 0, scale: 0.9, y: 20 }}
          animate={{ opacity: 1, scale: 1, y: 0 }}
          exit={{ opacity: 0, scale: 0.9, y: 20 }}
          className="relative w-full max-w-2xl glass-card rounded-[3rem] overflow-hidden flex flex-col max-h-[90vh] border border-white/10"
        >
          {/* Header */}
          <div className="p-8 border-b border-white/5 flex items-center justify-between bg-white/[0.02]">
            <div className="flex items-center gap-5">
              <div className={cn("p-4 rounded-2xl", theme.bg, "border border-white/5 shadow-inner")}>
                <theme.icon className={cn("w-6 h-6", theme.color)} />
              </div>
              <div>
                <h2 className="text-2xl font-outfit font-light text-white">{theme.title}</h2>
                <p className="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-black">Multi-Agent Intelligence System</p>
              </div>
            </div>
            <button onClick={onClose} className="p-2.5 hover:bg-white/5 rounded-2xl transition-colors border border-transparent hover:border-white/5">
              <X className="w-5 h-5 text-slate-500" />
            </button>
          </div>

          <div className="flex-1 overflow-y-auto p-8 space-y-8 no-scrollbar">
            {!result ? (
              <div className="space-y-6">
                <div className="p-6 bg-indigo-500/5 rounded-3xl border border-indigo-500/10">
                  <p className="text-xs text-indigo-300/80 leading-relaxed italic">
                    "Jag analyserar data i realtid mot dina jordade manualer för att ge ett objektivt utlåtande."
                  </p>
                </div>
                <textarea
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  placeholder="Beskriv situationen eller klistra in text här..."
                  className="w-full h-48 bg-black/40 border border-white/5 rounded-3xl p-8 text-slate-200 text-sm focus:outline-none focus:border-indigo-500/30 transition-all resize-none shadow-inner"
                />
                <button
                  onClick={handleAnalyze}
                  disabled={isLoading || (!input.trim() && mode !== 'REPORT')}
                  className="w-full py-5 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white rounded-[1.5rem] font-outfit font-bold transition-all flex items-center justify-center gap-3 shadow-2xl shadow-indigo-500/20 active:scale-95"
                >
                  {isLoading ? <Loader2 className="w-5 h-5 animate-spin" /> : <><Sparkles className="w-5 h-5" /> Kör Analys</>}
                </button>
              </div>
            ) : (
              <motion.div 
                initial={{ opacity: 0, y: 10 }}
                animate={{ opacity: 1, y: 0 }}
                className="space-y-8"
              >
                {/* ─── Standard Result Rendering ──────────────────────────────── */}
                <div className="p-8 bg-white/[0.02] border border-white/5 rounded-[2.5rem] space-y-6">
                  <div className="flex items-center gap-3 text-[10px] font-black uppercase tracking-[0.2em] text-indigo-400">
                    <Zap className="w-4 h-4" /> Systemets Slutsats
                  </div>
                  <p className="text-xl text-white font-outfit font-light leading-relaxed">
                    {result.masterInsight || result.sections?.executiveSummary || "Analys slutförd."}
                  </p>
                </div>

                {/* ─── Agent-Specific UI ─────────────────────────────────────── */}
                
                {/* 0. LEGAL STRATEGY */}
                {mode === 'LEGAL' && (
                  <div className="space-y-6">
                    <div className="p-8 bg-amber-500/5 border border-amber-500/10 rounded-[2.5rem] space-y-4">
                      <div className="flex items-center gap-3">
                        <Scale className="w-5 h-5 text-amber-500" />
                        <h3 className="text-lg font-outfit text-white">Juridisk Bedömning</h3>
                      </div>
                      <p className="text-2xl font-outfit text-white leading-tight">{result.legalClassification}</p>
                      <div className="flex items-center gap-4 pt-4">
                        <div className="flex-1 h-2 bg-white/5 rounded-full overflow-hidden">
                          <motion.div 
                            initial={{ width: 0 }} 
                            animate={{ width: `${result.evidenceStrength}%` }} 
                            className="h-full bg-amber-500"
                          />
                        </div>
                        <span className="text-xs font-bold text-amber-500">{result.evidenceStrength}% Bevisstyrka</span>
                      </div>
                    </div>
                    <div className="p-6 bg-white/[0.02] border border-white/5 rounded-3xl">
                      <p className="text-[9px] uppercase font-black tracking-widest text-slate-500 mb-3">Strategiskt Råd</p>
                      <p className="text-sm text-slate-200 leading-relaxed italic">"{result.strategicAdvice}"</p>
                    </div>
                  </div>
                )}

                {/* 0. ARCHIVE MEMORY */}
                {mode === 'ARCHIVE' && (
                  <div className="space-y-6">
                    <div className="p-8 bg-purple-500/5 border border-purple-500/10 rounded-[2.5rem] space-y-4">
                      <div className="flex items-center gap-3">
                        <Database className="w-5 h-5 text-purple-400" />
                        <h3 className="text-lg font-outfit text-white">Systematik-Analys</h3>
                      </div>
                      <div className="p-4 bg-white/5 rounded-2xl border border-white/5">
                        <p className="text-sm text-purple-200 font-bold mb-2">{result.patternDescription}</p>
                        <p className="text-xs text-slate-400">{result.strategicInsight}</p>
                      </div>
                    </div>
                    <div className="space-y-3">
                      <p className="text-[9px] uppercase font-black tracking-widest text-slate-500 ml-2">Historiska Träffar</p>
                      {result.similarHistoricalIncidents?.map((inc: string, i: number) => (
                        <div key={i} className="p-4 bg-white/5 border border-white/5 rounded-2xl flex items-center gap-3">
