<file path="livskompassen-trasig-1/src/components/CommunicationLog.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import {
  MessageSquare, Plus, Trash2, CheckCircle2, AlertTriangle,
  Loader2, Sparkles, ChevronDown, ChevronUp, Calendar,
  User, Phone, Mail, FileText, Scale, Clock, ArrowRight
} from 'lucide-react';
import { db } from '../lib/firebase';
import {
  collection, query, where, orderBy, addDoc,
  deleteDoc, doc, onSnapshot, serverTimestamp
} from 'firebase/firestore';
import { geminiService } from '../services/geminiService';
import { cn } from '../lib/utils';

type Channel = 'TELEFON' | 'MEJL' | 'MÖTE' | 'BREV' | 'SMS' | 'ÖVRIGT';
type Outcome = 'POSITIV' | 'NEGATIV' | 'NEUTRAL' | 'AVVAKTAR';

interface CommEntry {
  id?: string;
  date: string;
  party: string;
  channel: Channel;
  summary: string;
  outcome?: Outcome;
  notes?: string;
  userId: string;
}

const CHANNEL_ICONS: Record<Channel, React.ReactNode> = {
  TELEFON: <Phone className="w-3.5 h-3.5" />,
  MEJL: <Mail className="w-3.5 h-3.5" />,
  MÖTE: <User className="w-3.5 h-3.5" />,
  BREV: <FileText className="w-3.5 h-3.5" />,
  SMS: <MessageSquare className="w-3.5 h-3.5" />,
  ÖVRIGT: <Scale className="w-3.5 h-3.5" />,
};

const OUTCOME_COLORS: Record<Outcome, string> = {
  POSITIV: 'bg-teal-500/10 text-teal-400 border-teal-500/20',
  NEGATIV: 'bg-rose-500/10 text-rose-400 border-rose-500/20',
  NEUTRAL: 'bg-slate-500/10 text-slate-400 border-slate-500/20',
  AVVAKTAR: 'bg-amber-500/10 text-amber-400 border-amber-500/20',
};

export const CommunicationLog = ({ userId }: { userId: string }) => {
  const [entries, setEntries] = useState<CommEntry[]>([]);
  const [isAdding, setIsAdding] = useState(false);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [analysis, setAnalysis] = useState<any>(null);
  const [expanded, setExpanded] = useState<string | null>(null);

  const [form, setForm] = useState<Partial<CommEntry>>({
    date: new Date().toISOString().split('T')[0],
    channel: 'MEJL',
    outcome: 'AVVAKTAR',
  });

  useEffect(() => {
    if (!userId) return;
    const q = query(
      collection(db, 'communication_log'),
      where('userId', '==', userId),
      orderBy('date', 'desc')
    );
    const unsub = onSnapshot(q, (snap) => {
      setEntries(snap.docs.map(d => ({ id: d.id, ...d.data() } as CommEntry)));
    });
    return unsub;
  }, [userId]);

  const handleSave = async () => {
    if (!form.party || !form.summary || !form.date) return;
    try {
      await addDoc(collection(db, 'communication_log'), {
        ...form,
        userId,
        createdAt: serverTimestamp(),
      });
      setForm({ date: new Date().toISOString().split('T')[0], channel: 'MEJL', outcome: 'AVVAKTAR' });
      setIsAdding(false);
    } catch (err) {
      console.error('Failed to save comm entry:', err);
    }
  };

  const handleDelete = async (id: string) => {
    await deleteDoc(doc(db, 'communication_log', id));
  };

  const runAnalysis = async () => {
    if (entries.length < 2) return;
    setIsAnalyzing(true);
    try {
      const res = await geminiService.analyzeCommunicationLog(entries);
      setAnalysis(res);
    } catch (err) {
      console.error('Comm analysis failed:', err);
    } finally {
      setIsAnalyzing(false);
    }
  };

  return (
    <div className="space-y-8 animate-in fade-in duration-700">
      {/* Header */}
      <div className="bg-gradient-to-br from-slate-900/80 to-indigo-950/30 border border-indigo-500/10 rounded-[3rem] p-10 relative overflow-hidden">
        <div className="absolute top-0 right-0 p-10 opacity-5">
          <MessageSquare className="w-32 h-32 text-white" />
        </div>

        <div className="relative flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
          <div className="space-y-3">
            <div className="flex items-center gap-4">
              <div className="p-3 bg-indigo-500/10 rounded-2xl border border-indigo-500/20">
                <MessageSquare className="w-6 h-6 text-indigo-400" />
              </div>
              <div>
                <h3 className="text-2xl text-white font-outfit font-light">Kommunikations-Loggen</h3>
                <p className="text-[10px] text-indigo-400 uppercase font-bold tracking-widest">Spåra kontakter med myndigheter & parter</p>
              </div>
            </div>
            <p className="text-xs text-slate-500 max-w-lg leading-relaxed">
              Logga varje samtal, mejl och möte med socialtjänst, advokat, skola eller motpart. Systemet analyserar automatiskt om du fått motstridiga besked eller om myndigheter drar ut på tiden.
            </p>
          </div>

          <div className="flex items-center gap-3">
            {entries.length >= 2 && (
              <button
                onClick={runAnalysis}
                disabled={isAnalyzing}
                className="flex items-center gap-2 px-6 py-4 bg-indigo-500/10 text-indigo-300 border border-indigo-500/20 rounded-[1.5rem] text-[10px] font-black uppercase tracking-widest hover:bg-indigo-500/20 transition-all"
              >
                {isAnalyzing ? <Loader2 className="w-4 h-4 animate-spin" /> : <Sparkles className="w-4 h-4" />}
                Analysera Mönster
              </button>
            )}
            <button
              onClick={() => setIsAdding(true)}
              className="flex items-center gap-2 px-8 py-4 bg-indigo-600 text-white rounded-[1.5rem] font-black text-[10px] uppercase tracking-widest hover:bg-indigo-500 transition-all shadow-2xl shadow-indigo-900/30"
            >
              <Plus className="w-4 h-4" />
              Ny Kontakt
            </button>
          </div>
        </div>
      </div>

      {/* Analysis Result */}
      <AnimatePresence>
        {analysis && (
          <motion.div
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0 }}
            className="space-y-6"
          >
            <div className="p-8 bg-indigo-500/5 border border-indigo-500/10 rounded-[2.5rem] space-y-6">
              <div className="flex items-center gap-2">
                <Sparkles className="w-4 h-4 text-indigo-400" />
                <span className="text-[10px] font-black uppercase tracking-widest text-indigo-400">Kommunikations-Analys</span>
              </div>
              <p className="text-lg text-slate-200 font-outfit font-light leading-relaxed italic">
                "{analysis.summary}"
              </p>
              {analysis.recommendedAction && (
                <div className="flex items-center gap-4 pt-4 border-t border-indigo-500/10">
                  <ArrowRight className="w-4 h-4 text-indigo-400 shrink-0" />
                  <p className="text-sm text-indigo-200 font-medium">{analysis.recommendedAction}</p>
                </div>
              )}
            </div>

            {/* Inconsistencies */}
            {analysis.inconsistencies?.length > 0 && (
              <div className="space-y-3">
                <p className="text-[10px] uppercase font-black text-amber-400 tracking-widest px-2">⚠ Motstridiga Besked</p>
                {analysis.inconsistencies.map((inc: any, i: number) => (
                  <div key={i} className="p-6 bg-amber-500/5 border border-amber-500/10 rounded-2xl space-y-3">
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div className="space-y-1">
                        <p className="text-[9px] text-slate-500 font-bold uppercase">{inc.date1}</p>
                        <p className="text-xs text-slate-300">"{inc.claim1}"</p>
                      </div>
                      <div className="space-y-1">
                        <p className="text-[9px] text-slate-500 font-bold uppercase">{inc.date2}</p>
                        <p className="text-xs text-slate-300">"{inc.claim2}"</p>
                      </div>
                    </div>
                    <div className={cn("px-3 py-1 rounded-full text-[9px] font-black inline-block uppercase border", OUTCOME_COLORS[inc.severity === 'HÖG' ? 'NEGATIV' : 'NEUTRAL'])}>
                      Allvar: {inc.severity}
                    </div>
                  </div>
                ))}
              </div>
            )}

            {/* Delays */}
            {analysis.delays?.length > 0 && (
              <div className="space-y-3">
                <p className="text-[10px] uppercase font-black text-rose-400 tracking-widest px-2">⏱ Dröjsmål</p>
                {analysis.delays.map((del: any, i: number) => (
                  <div key={i} className="p-4 bg-rose-500/5 border border-rose-500/10 rounded-2xl flex items-start gap-3">
                    <Clock className="w-4 h-4 text-rose-400 mt-0.5 shrink-0" />
                    <div>
                      <p className="text-[10px] text-rose-300 font-bold">{del.party}</p>
                      <p className="text-xs text-slate-400">{del.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </motion.div>
        )}
      </AnimatePresence>

      {/* Add Form */}
      <AnimatePresence>
        {isAdding && (
          <motion.div
            initial={{ opacity: 0, y: -10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            className="p-8 bg-[#0f172a]/60 border border-white/10 rounded-[2.5rem] space-y-6"
          >
            <h4 className="text-lg text-white font-outfit font-light">Logga ny kontakt</h4>
            
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div className="space-y-2">
                <label className="text-[9px] text-slate-500 uppercase font-bold tracking-widest">Part / Organisation</label>
                <input
                  type="text"
                  placeholder="t.ex. Socialtjänsten Södermalm"
                  value={form.party || ''}
                  onChange={e => setForm(p => ({ ...p, party: e.target.value }))}
                  className="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-slate-200 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-indigo-500/40 text-sm"
                />
              </div>
              <div className="space-y-2">
                <label className="text-[9px] text-slate-500 uppercase font-bold tracking-widest">Datum</label>
                <input
                  type="date"
                  value={form.date || ''}
                  onChange={e => setForm(p => ({ ...p, date: e.target.value }))}
                  className="w-full bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-slate-200 focus:outline-none focus:ring-1 focus:ring-indigo-500/40 text-sm"
                />
              </div>
            </div>

            <div className="grid grid-cols-2 md:grid-cols-3 gap-3">
              {(['TELEFON', 'MEJL', 'MÖTE', 'BREV', 'SMS', 'ÖVRIGT'] as Channel[]).map(ch => (
                <button
                  key={ch}
                  onClick={() => setForm(p => ({ ...p, channel: ch }))}
                  className={cn(
                    "flex items-center justify-center gap-2 py-3 rounded-2xl text-[10px] font-bold uppercase tracking-widest border transition-all",
                    form.channel === ch ? 'bg-indigo-500/20 border-indigo-500/40 text-indigo-300' : 'bg-white/[0.03] border-white/5 text-slate-500 hover:text-slate-300'
                  )}
                >
                  {CHANNEL_ICONS[ch]} {ch}
                </button>
              ))}
            </div>

            <div className="space-y-2">
              <label className="text-[9px] text-slate-500 uppercase font-bold tracking-widest">Sammanfattning av kontakten</label>
              <textarea
                placeholder="Vad diskuterades? Vad lovades? Vad bestämdes?"
                value={form.summary || ''}
                onChange={e => setForm(p => ({ ...p, summary: e.target.value }))}
                rows={4}
