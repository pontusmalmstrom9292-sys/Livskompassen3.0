async function callGemini(content: string, systemInstruction: string) {
  const response = await fetch("/api/gemini", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ content, systemInstruction }),
  });
  if (!response.ok) throw new Error("Kunde inte anropa Gemini API");
  return response.json();
}

export const geminiService = {
  async analyzeIntegrity(content: string, context: string = "") {
    const systemInstruction = `
      KÄRN-SIGNATUR: LIVSKOMPASSEN KERNEL 3.1 [ACTIVE]
      Du är "Livs-Arkivarien", en objektiv och säkerhetsfokuserad analytiker för en person med ADHD/GAD.
      Ditt uppdrag är att vara sanningens ankare och motverka gaslighting genom att jämföra inkommande data med användarens etablerade verklighet.
      
      VIKTIGT: Användaren är under extrem psykisk stress (ADHD/GAD).
      Svara i JSON-format med fälten: title, category, analysis, groundingPoints, hallucinationRisk (LOW|MEDIUM|HIGH).
    `;
    return await callGemini(`INKOMMANDE TEXT FÖR ANALYS: ${content}`, systemInstruction);
  },

  async analyzeNetwork(members: any[]) {
    const systemInstruction = `
      Du är "Nätverksvisir". Kartlägg användarens nätverk för att identifiera allierade och riskpersoner.
      Svara i JSON: { question: string, insight: string }.
    `;
    return await callGemini("Generera nätverks-analys baserat på data.", systemInstruction);
  },

  async runSystemGrounding() {
    return { status: 'COMPLETED', findings: ['Systemminne förankrat.', 'Integritetssköld aktiv.'] };
  },

  async generateReflectionQuestion(userContext: string) {
    const systemInstruction = `
      Du är "Speglings-Agenten". Ställ frågor som hjälper användaren att reflektera ÖVER systemet och sin situation.
      Svara i JSON: { agentName: string, question: string, category: string }.
    `;
    return await callGemini(`KONTEXT: ${userContext}`, systemInstruction);
  },

  async intenseAnalysis(content: string, systemContext: string) {
    const systemInstruction = `
      Du är "System-Analytikern" med fokus på kross-referering och sanning.
      Svara i JSON: { title, summary, contradictions, suggestDeepScan, deepScanInstruction, groundingScore }.
    `;
    return await callGemini(content, systemInstruction);
  },

  async classifyDocument(content: string) {
    const systemInstruction = `
      Du är "Knowledge Architect". Analysera innehåll.
      Svara i JSON: { folderId, importance, tags }.
    `;
    return await callGemini(content, systemInstruction);
  },

  async mirroringAnalysis(action: string, truth: string) {
    const systemInstruction = `
      Du är "Speglings-Agenten". Analysera händelse och fakta för grundning.
      Svara i JSON: { feedback, groundingPoint }.
    `;
    return await callGemini(`HÄNDELSE: ${action}\n fakta: ${truth}`, systemInstruction);
  }
};
