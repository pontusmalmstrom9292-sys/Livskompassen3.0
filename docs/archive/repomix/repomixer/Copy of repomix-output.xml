  bgColor: string;
  onClick: () => void;
  pulse?: boolean;
}

const QuickAction: React.FC<QuickActionProps> = ({ icon: Icon, label, color, bgColor, onClick, pulse }) => (
  <motion.button
    whileHover={{ scale: 1.05, y: -2 }}
    whileTap={{ scale: 0.95 }}
    onClick={onClick}
