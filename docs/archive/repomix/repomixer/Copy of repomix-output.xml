  const toggleLearningMode = () => setIsLearningMode(!isLearningMode);

  const triggerStrengthMessage = async (actionOrMsg: string, context?: string) => {
    let finalMsg = actionOrMsg;
    
    // Om det är en fördefinierad aktion, låt AI:n generera meddelandet
    if (['VAULT_SAVE', 'IMPULSE_AVOIDED', 'COMPASS_COMPLETE', 'PATTERN_DETECTED'].includes(actionOrMsg)) {
