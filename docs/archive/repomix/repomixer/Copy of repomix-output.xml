<file path="livskompassen-trasig-1/src/components/RadarEventForm.tsx">
import React, { useState, useEffect } from 'react';
import { radarService } from '../services/radarService';
import { geminiService } from '../services/geminiService';
import { Actor, RadarEvent, ACTOR_CATEGORIES } from '../types';
import { ShieldAlert, Users, MessageSquare, Save, Loader2, Info, TriangleAlert, Paperclip, X, FileText, VolumeX, Sparkles } from 'lucide-react';
import { useLearning } from '../contexts/LearningContext';
import { AnimatePresence, motion } from 'motion/react';

interface RadarEventFormProps {
  userId: string;
  onSuccess?: () => void;
}

export const RadarEventForm = ({ userId, onSuccess }: RadarEventFormProps) => {
  const { triggerStrengthMessage } = useLearning();
  const [actors, setActors] = useState<Actor[]>([]);
  const [loading, setLoading] = useState(false);
  const [analyzing, setAnalyzing] = useState(false);
  
  // Form State
  const [type, setType] = useState('Kommunikation');
  const [description, setDescription] = useState('');
  const [originalText, setOriginalText] = useState('');
  const [selectedActors, setSelectedActors] = useState<string[]>([]);
  const [aiAnalysis, setAiAnalysis] = useState<RadarEvent['aiAnalysis'] | null>(null);
  const [unidentifiedActors, setUnidentifiedActors] = useState<string[]>([]);
  const [evidenceUrls, setEvidenceUrls] = useState<string[]>([]);
  const [uploadingFile, setUploadingFile] = useState(false);
  const [patternAlert, setPatternAlert] = useState<{name: string, count: number} | null>(null);
  const [promoting, setPromoting] = useState(false);
  const [promotionCandidate, setPromotionCandidate] = useState<{
    name: string,
    suggestedRole: string,
    suggestedBio: string,
    suggestedTrustLevel: 'Neutral' | 'Fientlig' | 'Allierad',
    suggestedCategory: Actor['category'],
    suggestedColorCode: string
  } | null>(null);
  const [analyzingPromotion, setAnalyzingPromotion] = useState(false);

  // Ladda aktörer för koppling
  useEffect(() => {
    const unsubscribe = radarService.subscribeToActors(userId, (data) => {
      setActors(data);
    });
    return unsubscribe;
  }, [userId]);

  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    
    setUploadingFile(true);
    try {
      const url = await radarService.uploadFile(userId, file);
      setEvidenceUrls(prev => [...prev, url]);
    } catch (error) {
      console.error("Upload failed:", error);
      alert("Kunde inte ladda upp filen.");
    } finally {
      setUploadingFile(false);
    }
  };

  const handleAnalyze = async () => {
    if (!originalText.trim()) return;
    setAnalyzing(true);
    try {
      const patternRes = await geminiService.subAgentAnalysis(originalText, 'PATTERN');
      const biffRes = await geminiService.subAgentAnalysis(originalText, 'BIFF');
      const actorIdRes = await geminiService.subAgentAnalysis(originalText, 'ACTOR_ID', actors);
      
      const pattern = JSON.parse(patternRes.replace(/```json/g, '').replace(/```/g, '').trim());
      const biff = JSON.parse(biffRes.replace(/```json/g, '').replace(/```/g, '').trim());
      const actorId = JSON.parse(actorIdRes.replace(/```json/g, '').replace(/```/g, '').trim());

      setAiAnalysis({
        redFlags: pattern.redFlags || [],
        biffResponse: biff.biffResponse,
        unidentifiedActors: actorId.unidentified || []
      });
      
      setUnidentifiedActors(actorId.unidentified || []);
      
      if (actorId.involvedActors && actorId.involvedActors.length > 0) {
        setSelectedActors(prev => {
          const combined = [...new Set([...prev, ...actorId.involvedActors])];
          return combined;
        });
      }

      if (pattern.summary && !description) {
        setDescription(pattern.summary);
      }
    } catch (error) {
      console.error("Analysis failed:", error);
    } finally {
      setAnalyzing(false);
    }
  };

  const handleSave = async (e: React.FormEvent) => {
    e.preventDefault();
    setLoading(true);
    try {
      await radarService.saveEvent(userId, {
        type,
        description,
        originalText,
        involvedActors: selectedActors,
        aiAnalysis: aiAnalysis || { redFlags: [], unidentifiedActors: [] },
        evidenceUrls
      });

      // Uppdatera räknare för okända aktörer och få eventuella notiser (vid 5, 10, 15...)
      const notifications = await radarService.processUnidentifiedActors(userId, unidentifiedActors);
      if (notifications.length > 0) {
        setPatternAlert(notifications[0]); // Vi visar den första som triggade
      }
      
      // Reset form
      setDescription('');
      setOriginalText('');
      setSelectedActors([]);
      setAiAnalysis(null);
      setUnidentifiedActors([]);
      setEvidenceUrls([]);
      if (onSuccess && !patternAlert) onSuccess(); 
      if (!patternAlert) triggerStrengthMessage('VAULT_SAVE', description);
    } catch (error) {
      console.error("Save failed:", error);
      alert("Kunde inte spara händelsen.");
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="w-full bg-[#0f172a]/80 border border-white/5 rounded-[2.5rem] p-8 backdrop-blur-xl shadow-2xl animate-in fade-in slide-in-from-bottom-4">
      <div className="flex items-center gap-3 mb-8">
        <div className="w-10 h-10 rounded-2xl bg-indigo-500/20 flex items-center justify-center border border-indigo-500/20">
          <ShieldAlert className="w-5 h-5 text-indigo-400" />
        </div>
        <div>
          <h3 className="text-lg font-outfit text-slate-100 tracking-wide">Logga ny Händelse</h3>
          <p className="text-[10px] uppercase tracking-widest text-slate-500">Radar-System v2.0</p>
        </div>
      </div>

      {/* Mönster-Alert (Magic 5) - Zen Edition */}
      {patternAlert && (
        <div className="mb-10 relative group animate-in fade-in zoom-in slide-in-from-top-4 duration-700">
          {/* Glow Effect */}
          <div className="absolute -inset-1 bg-gradient-to-r from-indigo-500/20 to-teal-500/20 rounded-[3rem] blur-xl opacity-50 group-hover:opacity-75 transition duration-1000"></div>
          
          <div className="relative bg-[#020617]/60 border border-white/10 rounded-[3rem] p-10 backdrop-blur-2xl shadow-2xl overflow-hidden">
            {/* Decorative Orbs */}
            <div className="absolute -top-24 -right-24 w-48 h-48 bg-indigo-500/10 rounded-full blur-3xl"></div>
            <div className="absolute -bottom-24 -left-24 w-48 h-48 bg-teal-500/10 rounded-full blur-3xl"></div>

            <div className="flex flex-col md:flex-row items-center md:items-start gap-8 relative z-10">
              <div className="w-20 h-20 rounded-[2.5rem] bg-gradient-to-br from-indigo-500 to-indigo-600 flex items-center justify-center shadow-2xl shadow-indigo-500/40 transform -rotate-6">
                <Users className="w-10 h-10 text-white" />
              </div>
              
              <div className="flex-1 text-center md:text-left">
                <div className="inline-block px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full mb-3">
                  <span className="text-[10px] font-bold uppercase tracking-[0.2em] text-indigo-400">Sanningens Ankare Aktiverat</span>
                </div>
                <h4 className="text-3xl font-outfit text-white mb-3">Ett mönster manifesteras</h4>
                <p className="text-lg font-inter text-slate-400 leading-relaxed max-w-lg">
                  Systemet har observerat att <span className="text-white font-medium italic">"{patternAlert.name}"</span> nu har framträtt 5 gånger. 
                  Låt oss ge detta mönster en fast form för att underlätta din kognitiva avlastning.
                </p>
                
                <div className="mt-8 flex flex-wrap justify-center md:justify-start gap-4">
                  <button 
                    disabled={analyzingPromotion}
                    onClick={async () => {
                      setAnalyzingPromotion(true);
                      try {
                        const events = await radarService.getEventsByUnidentifiedName(userId, patternAlert.name);
                        const analysis = await geminiService.generateActorPromotionAnalysis(patternAlert.name, events);
                        setPromotionCandidate({
                          name: patternAlert.name,
                          suggestedRole: analysis.suggestedRole || 'Okänd',
                          suggestedBio: analysis.suggestedBio || '',
                          suggestedTrustLevel: analysis.suggestedTrustLevel || 'Neutral',
                          // Standardvärden som användaren kan justera
                          suggestedCategory: 'Privat' as Actor['category'],
                          suggestedColorCode: '#f97316'
                        });
                      } catch (error) {
                        console.error("Promotion analysis failed:", error);
                        alert("Kunde inte analysera mönstret just nu.");
                      } finally {
                        setAnalyzingPromotion(false);
                      }
                    }}
                    className="px-8 py-4 bg-white text-indigo-950 rounded-2xl font-outfit font-bold text-sm hover:scale-105 active:scale-95 transition-all shadow-xl shadow-white/10 disabled:opacity-50 flex items-center gap-2"
                  >
                    {analyzingPromotion ? <Loader2 className="w-4 h-4 animate-spin" /> : <Users className="w-4 h-4" />}
                    Analysera & Skapa Profil
                  </button>
                  <button 
                    onClick={async () => {
                      await radarService.muteUnidentifiedActor(userId, patternAlert.name);
                      setPatternAlert(null);
                      if (onSuccess) onSuccess();
                    }}
                    className="px-8 py-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-2xl font-outfit font-bold text-sm hover:bg-red-500/20 transition-all flex items-center gap-2"
                  >
                    <VolumeX className="w-4 h-4" />
                    Tysta helt
                  </button>
                  <button 
                    onClick={() => {
                      setPatternAlert(null);
                      if (onSuccess) onSuccess();
                    }}
                    className="px-8 py-4 bg-white/5 border border-white/10 text-slate-300 rounded-2xl font-outfit font-bold text-sm hover:bg-white/10 transition-all"
                  >
                    Låt det vara
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Promotion Modal - Zen Edition */}
      {promotionCandidate && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-[#020617]/90 backdrop-blur-md animate-in fade-in duration-500">
          <div className="w-full max-w-2xl bg-[#0f172a] border border-white/10 rounded-[3rem] overflow-hidden shadow-2xl animate-in zoom-in slide-in-from-bottom-8 duration-500">
            <div className="p-10 relative">
              {/* Decorative Orbs */}
              <div className="absolute top-0 right-0 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
              
              <div className="flex items-center gap-4 mb-8">
                <div className="w-12 h-12 rounded-2xl bg-indigo-500/20 flex items-center justify-center border border-indigo-500/20">
                  <Users className="w-6 h-6 text-indigo-400" />
                </div>
                <div>
                  <h3 className="text-2xl font-outfit text-white">Verifiera Profil: {promotionCandidate.name}</h3>
                  <p className="text-[10px] uppercase tracking-[0.2em] text-indigo-400 font-bold">AI-Genererad Karaktärsanalys</p>
                </div>
              </div>

              <div className="space-y-6">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div className="space-y-2">
                    <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Namn</label>
                    <input 
                      value={promotionCandidate.name}
                      onChange={(e) => setPromotionCandidate({...promotionCandidate, name: e.target.value})}
                      className="w-full h-14 bg-black/30 border border-white/5 rounded-2xl px-4 text-sm text-slate-100 focus:outline-none focus:border-indigo-500/50"
                    />
                  </div>
                  <div className="space-y-2">
                    <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Föreslagen Roll</label>
                    <input 
                      value={promotionCandidate.suggestedRole}
                      onChange={(e) => setPromotionCandidate({...promotionCandidate, suggestedRole: e.target.value})}
                      className="w-full h-14 bg-black/30 border border-white/5 rounded-2xl px-4 text-sm text-slate-100 focus:outline-none focus:border-indigo-500/50"
                    />
                  </div>
                </div>

                <div className="space-y-2">
                  <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Beteendeanalys (Bio)</label>
                  <textarea 
                    value={promotionCandidate.suggestedBio}
                    onChange={(e) => setPromotionCandidate({...promotionCandidate, suggestedBio: e.target.value})}
                    className="w-full h-32 bg-black/30 border border-white/5 rounded-2xl p-4 text-sm text-slate-300 focus:outline-none focus:border-indigo-500/50 resize-none leading-relaxed"
                  />
                  <p className="text-[9px] text-slate-500 italic">
                    AI-notering: Denna bio är baserad på de 5 senaste observerade händelserna.
                  </p>
                </div>

                <div className="space-y-2">
                  <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Tillitsnivå</label>
                  <div className="flex gap-2">
                    {(['Neutral', 'Fientlig', 'Allierad'] as const).map(level => (
                      <button
                        key={level}
                        type="button"
                        onClick={() => setPromotionCandidate({...promotionCandidate, suggestedTrustLevel: level})}
                        className={`flex-1 py-3 rounded-xl text-[10px] font-bold uppercase transition-all border ${
                          promotionCandidate.suggestedTrustLevel === level
                            ? level === 'Fientlig' ? 'bg-red-500/20 border-red-500 text-red-300' : 
                              level === 'Allierad' ? 'bg-teal-500/20 border-teal-500 text-teal-300' :
                              'bg-indigo-500/20 border-indigo-500 text-indigo-300'
                            : 'bg-white/5 border-white/5 text-slate-500 hover:border-white/10'
                        }`}
                      >
                        {level}
                      </button>
                    ))}
                  </div>
                </div>

                {/* Kategori-väljare */}
                <div className="space-y-2">
                  <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Kategori</label>
                  <div className="grid grid-cols-2 gap-2">
                    {(Object.entries(ACTOR_CATEGORIES) as [Actor['category'], typeof ACTOR_CATEGORIES[keyof typeof ACTOR_CATEGORIES]][]).map(([key, val]) => (
                      <button
                        key={key}
                        type="button"
                        onClick={() => setPromotionCandidate({...promotionCandidate!, suggestedCategory: key, suggestedColorCode: val.color})}
                        className={`py-3 px-4 rounded-xl text-[10px] font-bold uppercase transition-all border flex items-center gap-2 ${
                          promotionCandidate!.suggestedCategory === key
                            ? `${val.bg} ${val.border} text-white`
                            : 'bg-white/5 border-white/5 text-slate-500 hover:border-white/10'
                        }`}
                      >
                        <span className="w-2 h-2 rounded-full flex-shrink-0" style={{ backgroundColor: val.color }} />
                        {val.label}
                      </button>
                    ))}
                  </div>
                </div>
              </div>

              <div className="mt-10 flex gap-4">
                <button 
                  onClick={() => setPromotionCandidate(null)}
                  className="flex-1 py-4 bg-white/5 border border-white/10 text-slate-300 rounded-2xl font-outfit font-bold text-sm hover:bg-white/10 transition-all"
                >
                  Avbryt
                </button>
                <button 
                  disabled={promoting}
                  onClick={async () => {
                    setPromoting(true);
                    try {
                      await radarService.promoteToActor(
                        userId, 
                        promotionCandidate.name, 
                        promotionCandidate.suggestedRole,
                        promotionCandidate.suggestedTrustLevel,
                        promotionCandidate.suggestedBio,
                        promotionCandidate.suggestedCategory,
                        promotionCandidate.suggestedColorCode
                      );
                      setPromotionCandidate(null);
                      setPatternAlert(null);
                      triggerStrengthMessage('PATTERN_DETECTED', `Befordrade ${promotionCandidate.name} till ${promotionCandidate.suggestedRole}`);
                      if (onSuccess) onSuccess();
                    } catch (error) {
                      alert("Kunde inte spara profilen.");
                    } finally {
                      setPromoting(false);
                    }
                  }}
                  className="flex-[2] py-4 bg-indigo-600 text-white rounded-2xl font-outfit font-bold text-sm hover:bg-indigo-500 transition-all shadow-xl shadow-indigo-900/20 flex items-center justify-center gap-2"
                >
                  {promoting ? <Loader2 className="w-4 h-4 animate-spin" /> : <Save className="w-4 h-4" />}
                  Färdigställ Profil
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      <form onSubmit={handleSave} className="space-y-6">
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* Typ av händelse */}
          <div className="space-y-2">
            <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Kategori</label>
            <select 
              value={type}
              onChange={(e) => setType(e.target.value)}
              className="w-full h-14 bg-black/30 border border-white/5 rounded-2xl px-4 text-sm text-slate-300 focus:outline-none focus:border-indigo-500/50 appearance-none"
            >
              <option value="Kommunikation">SMS / Kommunikation</option>
              <option value="Umgänge">Umgänge / Överlämning</option>
              <option value="Orosanmälan">Orosanmälan / Myndighet</option>
              <option value="Ekonomi">Ekonomisk Händelse</option>
              <option value="Övrigt">Övrigt</option>
            </select>
          </div>

          {/* Inblandade Aktörer */}
          <div className="space-y-2">
            <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Inblandade i Radarn</label>
            <div className="flex flex-wrap gap-2">
              {actors.map(actor => (
                <button
                  key={actor.id}
                  type="button"
                  onClick={() => {
                    if (selectedActors.includes(actor.id!)) {
                      setSelectedActors(selectedActors.filter(id => id !== actor.id));
                    } else {
                      setSelectedActors([...selectedActors, actor.id!]);
                    }
                  }}
                  className={`px-4 py-2 rounded-xl text-[10px] font-bold uppercase transition-all border ${
                    selectedActors.includes(actor.id!) 
                      ? 'bg-indigo-500/20 border-indigo-500 text-indigo-300' 
                      : 'bg-white/5 border-white/5 text-slate-500 hover:border-white/10'
                  }`}
                >
                  <Users className="w-3 h-3 inline mr-2" />
                  {actor.name}
                </button>
              ))}
              {actors.length === 0 && <p className="text-[10px] text-slate-600 italic">Inga aktörer hittades. Lägg till dem i Radarn först.</p>}
            </div>
          </div>
        </div>

        {/* Råtext / Bevis */}
        <div className="space-y-2">
          <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Originaltext (Bevis-rådata)</label>
          <div className="relative">
            <textarea 
              value={originalText}
              onChange={(e) => setOriginalText(e.target.value)}
              placeholder="Klistra in SMS, mejl eller anteckning här..."
              className="w-full h-32 bg-black/30 border border-white/5 rounded-2xl p-4 text-sm text-slate-300 placeholder:text-slate-700 focus:outline-none focus:border-indigo-500/50 resize-none font-inter"
            />
            <div className="absolute bottom-4 right-4 flex gap-2">
              <label className="cursor-pointer px-4 py-2 bg-white/5 hover:bg-white/10 text-slate-400 border border-white/10 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all flex items-center gap-2">
                {uploadingFile ? <Loader2 className="w-3 h-3 animate-spin" /> : <Paperclip className="w-3 h-3" />}
                Bifoga fil
                <input type="file" className="hidden" onChange={handleFileUpload} disabled={uploadingFile} />
              </label>
              <button
                type="button"
                onClick={handleAnalyze}
                disabled={analyzing || !originalText.trim()}
                className="px-4 py-2 bg-indigo-500/10 hover:bg-indigo-500/30 text-indigo-400 border border-indigo-500/30 rounded-xl text-[10px] font-bold uppercase tracking-widest transition-all disabled:opacity-30"
              >
                {analyzing ? <Loader2 className="w-3 h-3 animate-spin" /> : "Snabbanalys"}
              </button>
            </div>
          </div>
        </div>

        {/* Bilagor (Filer) */}
        {evidenceUrls.length > 0 && (
          <div className="flex flex-wrap gap-3">
            {evidenceUrls.map((url, i) => {
              const fileName = url.split('/').pop()?.split('?')[0] || `Fil_${i+1}`;
              return (
                <div key={i} className="flex items-center gap-3 px-3 py-2 bg-white/5 rounded-xl border border-white/5 group">
                  <FileText className="w-3 h-3 text-indigo-400" />
                  <span className="text-[10px] text-slate-400 max-w-[100px] truncate">{fileName}</span>
                  <button 
                    type="button" 
                    onClick={() => setEvidenceUrls(prev => prev.filter((_, idx) => idx !== i))}
                    className="text-slate-600 hover:text-red-400"
                  >
                    <X className="w-3 h-3" />
                  </button>
                </div>
              );
            })}
          </div>
        )}

        {/* AI-insikter innan spara */}
        {aiAnalysis && (
          <div className="grid grid-cols-1 md:grid-cols-2 gap-4 animate-in fade-in zoom-in duration-300">
            <div className="bg-red-500/5 border border-red-500/20 rounded-2xl p-4">
              <p className="text-[10px] uppercase font-bold text-red-400 mb-2 flex items-center gap-2">
                <TriangleAlert className="w-3 h-3" /> Röda Flaggor
              </p>
              <ul className="space-y-1">
                {aiAnalysis.redFlags.map((flag, i) => (
                  <li key={i} className="text-[11px] text-red-200/70 shrink-0 flex items-start gap-2">
                    <span className="text-red-500">•</span> {flag}
                  </li>
                ))}
              </ul>
            </div>
            <div className="bg-teal-500/5 border border-teal-500/20 rounded-2xl p-4">
              <p className="text-[10px] uppercase font-bold text-teal-400 mb-2 flex items-center gap-2">
                <MessageSquare className="w-3 h-3" /> BIFF-Svarsförslag
              </p>
              <p className="text-[11px] text-teal-200/70 italic leading-relaxed">
                "{aiAnalysis.biffResponse || 'Inget specifikt svar föreslaget.'}"
              </p>
            </div>
            
            {/* Okända aktörer hittade */}
            {unidentifiedActors.length > 0 && (
              <div className="md:col-span-2 bg-indigo-500/5 border border-indigo-500/20 rounded-2xl p-4 mt-2">
                <p className="text-[10px] uppercase font-bold text-indigo-400 mb-2 flex items-center gap-2">
                  <Users className="w-3 h-3" /> Okända Entiteter Identifierade
                </p>
                <div className="flex flex-wrap gap-2">
                  {unidentifiedActors.map((name, i) => (
                    <span key={i} className="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-lg text-[10px] text-indigo-200">
                      {name}
                    </span>
                  ))}
                </div>
                <p className="text-[9px] text-slate-500 mt-2 italic">
                  Dessa namn kommer att loggas och räknas för att upptäcka mönster över tid.
                </p>
              </div>
            )}
          </div>
        )}

        {/* Objektiv Sammanfattning */}
        <div className="space-y-2">
          <label className="text-[10px] uppercase font-bold text-slate-500 ml-1 tracking-widest">Objektiv Sammanfattning</label>
          <input 
            value={description}
            onChange={(e) => setDescription(e.target.value)}
            placeholder="Kort beskrivning för din tidslinje..."
            className="w-full h-14 bg-black/30 border border-white/5 rounded-2xl px-4 text-sm text-slate-300 focus:outline-none focus:border-indigo-500/50"
          />
        </div>

        <div className="pt-4 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
          <div className="flex items-center gap-2 text-slate-600">
            <Info className="w-3 h-3" />
            <span className="text-[9px] uppercase tracking-tighter">Server-tidsstämpel appliceras vid lagring</span>
          </div>
          <button 
            type="submit"
            disabled={loading || !description.trim()}
            className="w-full md:w-auto h-14 px-12 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl font-outfit font-bold shadow-xl shadow-indigo-900/20 transition-all flex items-center justify-center gap-3 disabled:opacity-50"
          >
            {loading ? <Loader2 className="w-5 h-5 animate-spin" /> : <><Save className="w-5 h-5" /> Spara i Radarn</>}
          </button>
        </div>
      </form>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/RadarTimeline.tsx">
import React, { useState, useEffect } from 'react';
import { radarService } from '../services/radarService';
import { RadarEvent, Actor } from '../types';
import { motion, AnimatePresence } from 'motion/react';
import { Clock, ShieldAlert, MessageSquare, ChevronDown, ChevronUp, User, FileText } from 'lucide-react';

interface RadarTimelineProps {
  userId: string;
}

export const RadarTimeline = ({ userId }: RadarTimelineProps) => {
  const [events, setEvents] = useState<RadarEvent[]>([]);
  const [actors, setActors] = useState<Actor[]>([]);
  const [expandedEvent, setExpandedEvent] = useState<string | null>(null);

  useEffect(() => {
    const unsubEvents = radarService.subscribeToEvents(userId, setEvents);
    const unsubActors = radarService.subscribeToActors(userId, setActors);
    return () => {
      unsubEvents();
      unsubActors();
    };
  }, [userId]);

  const getActorName = (id: string) => {
    return actors.find(a => a.id === id)?.name || "Okänd aktör";
  };

  return (
    <div className="space-y-6 mt-12">
      <div className="flex items-center gap-3 mb-8">
        <Clock className="w-5 h-5 text-slate-500" />
        <h3 className="text-xs uppercase font-outfit tracking-[0.2em] text-slate-500">Objektiv Tidslinje (Radar-logg)</h3>
      </div>

      <div className="relative pl-8 space-y-8 before:absolute before:left-[11px] before:top-2 before:bottom-2 before:w-[2px] before:bg-white/5">
        {events.map((event) => (
          <div key={event.id} className="relative">
            {/* Timeline Dot */}
            <div className="absolute -left-[31px] top-1 w-5 h-5 bg-[#020617] border-2 border-indigo-500 rounded-full flex items-center justify-center z-10 shadow-[0_0_10px_rgba(99,102,241,0.3)]" />
            
            <div className="bg-[#0f172a]/40 border border-white/5 rounded-3xl p-6 hover:border-white/10 transition-all group">
              <div className="flex justify-between items-start mb-4">
                <div>
                  <div className="flex items-center gap-3 mb-1">
                    <span className="text-[10px] font-bold uppercase tracking-widest text-indigo-400 bg-indigo-500/10 px-2 py-0.5 rounded">
                      {event.type}
                    </span>
                    <span className="text-[10px] text-slate-500 uppercase tracking-tighter">
                      {event.timestamp?.seconds ? new Date(event.timestamp.seconds * 1000).toLocaleString() : 'Bearbetar...'}
                    </span>
                  </div>
                  <h4 className="text-slate-200 font-medium">{event.description}</h4>
                </div>
                <button 
                  onClick={() => setExpandedEvent(expandedEvent === event.id ? null : event.id!)}
                  className="p-2 text-slate-600 hover:text-slate-400 transition-colors"
                >
                  {expandedEvent === event.id ? <ChevronUp className="w-4 h-4" /> : <ChevronDown className="w-4 h-4" />}
                </button>
              </div>

              {/* Inblandade aktörer */}
              <div className="flex flex-wrap gap-2 mb-4">
                {event.involvedActors.map(id => (
                  <span key={id} className="flex items-center gap-1.5 px-2 py-1 bg-white/5 rounded-lg text-[9px] text-slate-400 uppercase font-bold tracking-widest">
                    <User className="w-3 h-3 opacity-50" />
                    {getActorName(id)}
                  </span>
                ))}
              </div>

              <AnimatePresence>
                {expandedEvent === event.id && (
                  <motion.div
                    initial={{ opacity: 0, height: 0 }}
                    animate={{ opacity: 1, height: 'auto' }}
                    exit={{ opacity: 0, height: 0 }}
                    className="overflow-hidden space-y-4"
                  >
                    {/* Originaltext */}
                    <div className="p-4 bg-black/40 rounded-2xl border border-white/5">
                      <p className="text-[10px] uppercase font-bold text-slate-600 mb-2">Originalbevis</p>
                      <p className="text-xs text-slate-400 leading-relaxed italic">"{event.originalText}"</p>
                    </div>

                    {/* AI Analys */}
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                      {event.aiAnalysis.redFlags.length > 0 && (
                        <div className="p-4 bg-red-500/5 border border-red-500/20 rounded-2xl">
                          <p className="text-[9px] uppercase font-bold text-red-400 mb-2 flex items-center gap-2">
                            <ShieldAlert className="w-3 h-3" /> Röda Flaggor
                          </p>
                          <ul className="space-y-1">
                            {event.aiAnalysis.redFlags.map((flag, i) => (
                              <li key={i} className="text-[10px] text-red-200/60 leading-tight">• {flag}</li>
                            ))}
                          </ul>
                        </div>
                      )}
                      {event.aiAnalysis.biffResponse && (
                        <div className="p-4 bg-teal-500/5 border border-teal-500/20 rounded-2xl">
                          <p className="text-[9px] uppercase font-bold text-teal-400 mb-2 flex items-center gap-2">
                            <MessageSquare className="w-3 h-3" /> BIFF-Svar
                          </p>
                          <p className="text-[10px] text-teal-200/60 leading-relaxed italic">"{event.aiAnalysis.biffResponse}"</p>
                        </div>
                      )}
                    </div>

                    {/* Multimedia-bevis */}
                    {event.evidenceUrls && event.evidenceUrls.length > 0 && (
                      <div className="space-y-2">
                        <p className="text-[10px] uppercase font-bold text-slate-600">Bilagor</p>
                        <div className="flex flex-wrap gap-4">
                          {event.evidenceUrls.map((url, i) => {
                            const isImage = url.includes('.jpg') || url.includes('.png') || url.includes('.webp') || url.includes('.jpeg');
                            return (
                              <a 
                                key={i} 
                                href={url} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                className="relative group overflow-hidden rounded-xl border border-white/5 bg-white/5 hover:border-indigo-500/30 transition-all"
                              >
                                {isImage ? (
                                  <img src={url} alt="Bevis" className="w-24 h-24 object-cover opacity-60 group-hover:opacity-100 transition-opacity" />
                                ) : (
                                  <div className="w-24 h-24 flex flex-col items-center justify-center gap-2">
                                    <FileText className="w-6 h-6 text-indigo-400/50" />
                                    <span className="text-[8px] text-slate-500 uppercase tracking-tighter">Dokument</span>
                                  </div>
                                )}
                              </a>
                            );
                          })}
                        </div>
                      </div>
                    )}
                  </motion.div>
                )}
              </AnimatePresence>
            </div>
          </div>
        ))}

        {events.length === 0 && (
          <div className="text-center py-12 text-slate-600 text-sm italic">
            Inga händelser loggade i tidslinjen ännu.
          </div>
        )}
      </div>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/RealityMirror.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  Zap, ShieldCheck, Heart, Database, 
  ArrowRight, Loader2, Sparkles, AlertCircle,
  Eye, Scale, Fingerprint, BarChart3, History, 
  TrendingUp, ChevronDown, Shield
} from 'lucide-react';
import { db } from '../lib/firebase';
import { collection, query, where, orderBy, limit, onSnapshot, addDoc, serverTimestamp } from 'firebase/firestore';
import { cn } from '../lib/utils';
import { useVertexAnalysis } from '../hooks/useVertexAnalysis';
import { shieldApi } from '../services/apiService';

export const RealityMirror = ({ userId }: { userId: string }) => {
  const { isLoading: isVertexLoading } = useVertexAnalysis() as any;
  const [loading, setLoading] = useState(true);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [comparison, setComparison] = useState<any>(null);
  const [history, setHistory] = useState<any[]>([]);
  const [showHistory, setShowHistory] = useState(false);

  // Data State
  const [events, setEvents] = useState<any[]>([]);
  const [diary, setDiary] = useState<any[]>([]);

  useEffect(() => {
    if (!userId) return;

    const qRadar = query(collection(db, 'events'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(15));
    const unsubRadar = onSnapshot(qRadar, (snap) => setEvents(snap.docs.map(d => d.data())));

    const qDiary = query(collection(db, 'diary_entries'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(5));
    const unsubDiary = onSnapshot(qDiary, (snap) => setDiary(snap.docs.map(d => d.data())));

    const qHistory = query(collection(db, 'mirror_history'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(15));
    const unsubHistory = onSnapshot(qHistory, (snap) => setHistory(snap.docs.map(d => ({ id: d.id, ...d.data() }))));

    return () => {
      unsubRadar();
      unsubDiary();
      unsubHistory();
    };
  }, [userId]);

  const runAnalysis = async () => {
    if (!userId || events.length === 0) return;
    setIsAnalyzing(true);
    try {
      // Use the grounded Vertex AI agent via the mode pattern
      const res = await shieldApi.analyze({
        content: "Spegla min verklighet baserat på händelser och dagbok.",
        mode: "PATTERN",
        context: {
          recentEvents: events,
          recentDiary: diary
        }
      });
      
      setComparison(res);
      
      // Spara till historik för trend-visning
      await addDoc(collection(db, 'mirror_history'), {
        userId,
        ...res,
        timestamp: serverTimestamp()
      });
    } catch (error) {
      console.error("Mirroring failed:", error);
    } finally {
      setIsAnalyzing(false);
      setLoading(false);
    }
  };

  useEffect(() => {
    if (events.length > 0 && diary.length > 0 && !comparison) {
      runAnalysis();
    } else if (events.length === 0) {
      setLoading(false);
    }
  }, [events, diary]);

  if (loading) {
    return (
      <div className="h-96 flex flex-col items-center justify-center space-y-6 bg-slate-950/20 border border-white/5 rounded-[3.5rem] animate-pulse">
        <div className="p-6 bg-indigo-500/10 rounded-full border border-indigo-500/20">
          <Loader2 className="w-12 h-12 text-indigo-500/40 animate-spin" />
        </div>
        <p className="text-[10px] font-black uppercase tracking-[0.4em] text-slate-700">Kalibrerar Sanningens Spegel...</p>
      </div>
    );
  }

  return (
    <div className="relative group perspective-1000 space-y-10">
      {/* Animated Background Aura */}
      <div className="absolute -inset-10 bg-gradient-to-br from-indigo-600/10 via-transparent to-teal-600/10 rounded-[5rem] blur-3xl opacity-50 group-hover:opacity-80 transition-all duration-1000" />
      
      <div className="relative bg-slate-950/60 backdrop-blur-3xl border border-white/10 rounded-[3.5rem] p-10 md:p-16 overflow-hidden shadow-[0_32px_120px_-20px_rgba(0,0,0,0.8)]">
        {/* Glass Reflection Effect */}
        <div className="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-white/5 to-transparent pointer-events-none" />
        
        <div className="relative z-10 space-y-16">
          {/* Header */}
          <div className="flex flex-col md:flex-row items-start md:items-center justify-between gap-10">
            <div className="flex items-center gap-8">
              <div className="relative">
                <div className="absolute inset-0 bg-indigo-500 blur-2xl opacity-20 animate-pulse" />
                <div className="relative p-6 bg-indigo-500/20 rounded-[2.2rem] border border-indigo-500/30">
                  <Eye className="w-10 h-10 text-indigo-400" />
                </div>
              </div>
              <div>
                <h3 className="text-4xl md:text-5xl font-outfit font-light text-white tracking-tighter">Verklighetsspegeln</h3>
                <div className="flex items-center gap-3 mt-2">
                  <div className="w-2.5 h-2.5 rounded-full bg-teal-500 animate-glow shadow-[0_0_10px_rgba(45,212,191,0.5)]" />
                  <p className="text-[10px] text-slate-500 uppercase tracking-[0.4em] font-black">Powered by Vertex AI Sub-Agents</p>
                </div>
              </div>
            </div>
            
            <button 
              onClick={runAnalysis}
              disabled={isAnalyzing || isVertexLoading}
              className="group/btn relative px-10 py-6 bg-white/5 hover:bg-white/10 rounded-[2.2rem] border border-white/10 transition-all active:scale-95 flex items-center gap-5 overflow-hidden"
            >
              <div className="absolute inset-0 bg-gradient-to-r from-indigo-500/10 to-teal-500/10 translate-y-full group-hover/btn:translate-y-0 transition-transform duration-700" />
              {isAnalyzing || isVertexLoading ? (
                <Loader2 className="w-6 h-6 animate-spin text-indigo-400" />
              ) : (
                <Sparkles className="w-6 h-6 text-indigo-400 group-hover/btn:rotate-12 transition-transform" />
              )}
              <span className="text-xs font-bold text-slate-200 uppercase tracking-widest relative z-10">Uppdatera Spegelbild</span>
            </button>
          </div>

          <AnimatePresence mode="wait">
            {comparison ? (
              <motion.div 
                key="comparison-active"
                initial={{ opacity: 0, scale: 0.98, y: 30 }}
                animate={{ opacity: 1, scale: 1, y: 0 }}
                exit={{ opacity: 0, scale: 0.98 }}
                className="space-y-16"
              >
                {/* Master Reflection */}
                <div className="relative p-1.5 bg-gradient-to-br from-indigo-500/20 via-white/5 to-teal-500/20 rounded-[3.5rem]">
                  <div className="bg-slate-950/80 backdrop-blur-2xl rounded-[3.4rem] p-12 md:p-20 relative overflow-hidden group/master">
                    <div className="absolute top-0 right-0 p-16 opacity-[0.03] group-hover/master:opacity-[0.05] transition-opacity">
                      <Fingerprint className="w-64 h-64 text-indigo-400" />
                    </div>
                    <div className="max-w-4xl relative z-10">
                      <p className="text-3xl md:text-4xl text-slate-100 font-outfit font-light leading-snug italic">
                        "{comparison.reflection || comparison.masterInsight}"
                      </p>
                    </div>
                  </div>
                </div>

                <div className="grid grid-cols-1 lg:grid-cols-2 gap-12">
                  {/* Internal State */}
                  <div className="p-10 bg-slate-900/40 border border-white/5 rounded-[3rem] space-y-6 hover:border-rose-500/20 transition-all group">
                    <div className="flex items-center gap-4 text-rose-400">
                      <Heart className="w-6 h-6" />
                      <span className="text-[11px] font-black uppercase tracking-[0.4em]">Din Upplevelse</span>
                    </div>
                    <p className="text-xl text-slate-300 font-outfit font-light leading-relaxed">
                      {comparison.internalState || "Systemet analyserar dina inre signaler..."}
                    </p>
                  </div>

                  {/* External Facts */}
                  <div className="p-10 bg-slate-900/40 border border-white/5 rounded-[3rem] space-y-6 hover:border-teal-500/20 transition-all group">
                    <div className="flex items-center gap-4 text-teal-400">
                      <Database className="w-6 h-6" />
                      <span className="text-[11px] font-black uppercase tracking-[0.4em]">Arkiverad Sanning</span>
                    </div>
                    <p className="text-xl text-slate-300 font-outfit font-light leading-relaxed">
                      {comparison.externalFacts || "Korsrefererar loggade händelser..."}
                    </p>
                  </div>
                </div>

                {/* Identity & Resiliens */}
                <div className="bg-indigo-500/5 border border-indigo-500/10 rounded-[3.5rem] p-12 relative overflow-hidden group/identity">
                   <div className="absolute -right-20 -top-20 w-80 h-80 bg-indigo-500/10 blur-[100px] pointer-events-none" />
                   <div className="relative z-10 flex flex-col md:flex-row gap-12 items-center text-center md:text-left">
                      <div className="p-8 bg-indigo-500/10 rounded-[2.5rem] border border-indigo-500/20 shrink-0">
                         <Fingerprint className="w-12 h-12 text-indigo-400" />
                      </div>
                      <div className="space-y-4 flex-1">
                         <h4 className="text-[11px] font-black text-indigo-400 uppercase tracking-[0.5em]">Identitets-Styrka</h4>
                         <p className="text-2xl text-slate-200 font-outfit font-light leading-relaxed italic">
                           {comparison.identityImpact || "Dina val och handlingar i loggen vittnar om en växande integritet och motståndskraft."}
                         </p>
                      </div>
                      <div className="md:w-px h-24 bg-white/10 hidden md:block" />
                      <div className="space-y-2 text-center shrink-0">
                         <p className="text-[10px] uppercase font-black text-slate-500 tracking-widest">Grundnings-Score</p>
                         <p className="text-6xl font-outfit font-light text-white">{comparison.groundingScore || 85}<span className="text-xl text-slate-700">%</span></p>
                      </div>
                   </div>
                </div>

                {/* Cognitive Distortions */}
                {comparison.detectedDistortions?.length > 0 && (
                  <div className="space-y-8">
                    <div className="flex items-center gap-4 px-6">
                      <AlertCircle className="w-5 h-5 text-amber-500" />
                      <h4 className="text-[11px] font-black text-slate-500 uppercase tracking-[0.3em]">Kognitiva Filter (Stress-respons)</h4>
                    </div>
                    <div className="flex flex-wrap gap-4">
                      {comparison.detectedDistortions.map((d: string, i: number) => (
                        <div key={i} className="px-8 py-5 bg-amber-500/5 border border-amber-500/10 rounded-[2rem] flex items-center gap-4 hover:bg-amber-500/10 transition-all">
                          <div className="w-2 h-2 rounded-full bg-amber-500 shadow-[0_0_10px_rgba(245,158,11,0.5)]" />
                          <span className="text-xs font-bold text-amber-200 uppercase tracking-widest">{d}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </motion.div>
            ) : (
              <div className="py-32 text-center space-y-8">
                <div className="w-32 h-32 bg-white/5 rounded-full flex items-center justify-center mx-auto border border-white/5 relative">
                   <div className="absolute inset-0 bg-indigo-500/10 rounded-full animate-ping opacity-20" />
                   <Sparkles className="w-12 h-12 text-slate-700" />
                </div>
                <div className="space-y-2">
                   <p className="text-2xl text-slate-500 font-outfit font-light italic">Väntar på att få spegla sanningen...</p>
