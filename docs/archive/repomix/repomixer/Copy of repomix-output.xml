                Initiera Nedbrytning
              </button>
            </div>
          )}

          {breakdownSteps.length > 0 && (
            <div className="p-6 bg-white/[0.03] border border-white/5 rounded-[2.5rem] space-y-6">
              <p className="text-[10px] uppercase font-bold text-teal-400 tracking-widest px-2">Dina Mikrosteg</p>
              <div className="space-y-4">
                {breakdownSteps.map((step: any, idx: number) => (
                  <motion.div 
                    initial={{ opacity: 0, x: -10 }}
                    animate={{ opacity: 1, x: 0 }}
                    transition={{ delay: idx * 0.1 }}
                    key={idx} 
                    className="flex gap-4 p-4 bg-white/5 rounded-2xl border border-white/5"
                  >
                    <div className="w-6 h-6 rounded-full bg-teal-500/10 flex items-center justify-center shrink-0">
                      <span className="text-[10px] font-bold text-teal-500">{idx + 1}</span>
                    </div>
                    <div>
                      <p className="text-sm text-slate-200 font-medium mb-1">{step.text}</p>
                      <p className="text-[10px] text-slate-500 italic">{step.why}</p>
                    </div>
                  </motion.div>
                ))}
              </div>
            </div>
          )}

          {guidance.recommendedProtocol !== 'NORMAL' && (
            <div className="p-4 bg-amber-500/10 border border-amber-500/20 rounded-2xl flex items-center gap-4">
              <Shield className="w-5 h-5 text-amber-500" />
              <div>
                <p className="text-[10px] uppercase font-bold text-amber-500 tracking-widest">Rekommenderat Protokoll</p>
