import { motion } from 'motion/react';
import { Home, Wallet, Sprout, Shield, BookOpen, Terminal, Users, Briefcase, FileText } from 'lucide-react';
import { cn } from '../../lib/utils';
import { View } from '../../types';

interface NavItem {
  id: View;
  label: string;
  icon: any;
  color: string;
  glow: string;
}

const NAV_ITEMS: NavItem[] = [
  { id: 'HOME', label: 'Hem', icon: Home, color: 'text-gold', glow: 'bg-gold' },
  { id: 'FINANCE', label: 'Ekonomi', icon: Wallet, color: 'text-gold', glow: 'bg-gold' },
  { id: 'WELLNESS', label: 'Må bra', icon: Sprout, color: 'text-gold', glow: 'bg-gold' },
  { id: 'PROJECTS', label: 'Projekt', icon: Briefcase, color: 'text-gold', glow: 'bg-gold' },
  { id: 'NETWORK', label: 'Nätverk', icon: Users, color: 'text-gold', glow: 'bg-gold' },
  { id: 'KNOWLEDGE', label: 'Arkiv', icon: BookOpen, color: 'text-gold', glow: 'bg-gold' },
  { id: 'VAULT', label: 'Valvet', icon: Shield, color: 'text-gold', glow: 'bg-gold' },
  { id: 'DOSSIER', label: 'Dossier', icon: FileText, color: 'text-gold', glow: 'bg-gold' },
];

interface FloatingDockProps {
  currentView: View;
  onNavigate: (view: View) => void;
}

export function FloatingDock({ currentView, onNavigate }: FloatingDockProps) {
  return (
    <div className="fixed bottom-10 left-1/2 -translate-x-1/2 z-50">
      <motion.nav 
        initial={{ y: 50, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        className="flex items-center gap-1 p-1.5 rounded-3xl bg-black/60 backdrop-blur-3xl border border-gold/10 shadow-[0_20px_60px_rgba(0,0,0,0.8)]"
      >
        {NAV_ITEMS.map((item) => {
          const isActive = currentView === item.id;
          const Icon = item.icon;
          
          return (
            <button
              key={item.id}
              onClick={() => onNavigate(item.id)}
              className={cn(
                "relative group flex items-center justify-center w-10 h-10 rounded-2xl transition-all duration-300",
                isActive ? "bg-gold/10" : "hover:bg-gold/5"
              )}
            >
              <Icon 
                className={cn(
                  "w-4 h-4 transition-all duration-300",
                  isActive ? "text-gold" : "text-gold/30 group-hover:text-gold/60"
                )} 
              />
              
              {isActive && (
                <motion.div
                  layoutId="nav-glow"
                  className={cn(
                    "absolute inset-0 rounded-full blur-md opacity-20 -z-10",
                    item.glow
                  )}
                />
              )}

              {/* Tooltip */}
              <span className="absolute -top-12 left-1/2 -translate-x-1/2 px-3 py-1 rounded-lg bg-black text-[10px] font-bold uppercase tracking-widest text-white opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                {item.label}
              </span>
            </button>
          );
        })}
      </motion.nav>
    </div>
  );
}
