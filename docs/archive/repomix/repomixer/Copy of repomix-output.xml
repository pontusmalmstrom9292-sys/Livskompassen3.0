                  {item.analysis?.detectedTactics?.map((t: any, idx: number) => (
                    <span key={idx} className="text-[8px] bg-rose-500/10 text-rose-400 border border-rose-500/10 px-2.5 py-1 rounded-lg uppercase font-black tracking-tighter">
                      {t.name || t}
