                  </div>
                ))}
              </div>
            </div>
          </div>

          <div className="flex justify-center pt-10">
             <button 
               onClick={resetAudit}
               className="px-12 py-6 text-[11px] uppercase font-black text-slate-700 tracking-[0.5em] hover:text-orange-500 transition-all border border-white/5 rounded-full hover:bg-white/5"
             >
               Arkivera & Nollställ Analys
             </button>
          </div>
        </motion.div>
      )}

      <footer className="mt-16 pt-12 border-t border-white/5 flex flex-wrap items-center justify-center gap-16 text-slate-600 relative z-10">
        <div className="flex items-center gap-4">
