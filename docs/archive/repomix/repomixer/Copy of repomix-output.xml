import { Brain, Save, RefreshCw, MessageCircle, BrainCircuit, Heart, Flame, Shield, ArrowLeft, Send, Sparkles, Wind, Activity } from 'lucide-react';
import { BreathingGuide } from '../components/BreathingGuide';
import { GAD7Questionnaire } from '../components/GAD7Questionnaire';
import { ProcrastinationStopper } from '../components/ProcrastinationStopper';
import { GreyRockTrainer } from '../components/GreyRockTrainer';
import { ValueCompass } from '../components/ValueCompass';
import { ThoughtfulNo } from '../components/ThoughtfulNo';
import { Reframing } from '../components/Reframing';
import { motion, AnimatePresence } from 'motion/react';
import { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { Button } from '../components/ui/button';
import { geminiService } from '../services/geminiService';
import { cn } from '../lib/utils';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { DIARY_CATEGORIES } from '../constants';

interface WellnessPageProps {
  user: any;
}

type WellnessTab = 'DAGBOK' | 'KORT' | 'FOKUS' | 'IDENTITET' | 'STOPPA' | 'SKÖLD';

export function WellnessPage({ user }: WellnessPageProps) {
  const [activeTab, setActiveTab] = useState<WellnessTab>('DAGBOK');
  const { entities } = useSystemMemory();

  const systemContext = entities.map(a => `${a.name} (${a.role}): ${a.bio || ''}`).join('\n');

  // Diary State
  const [diaryText, setDiaryText] = useState('');
  const [diaryEnergy, setDiaryEnergy] = useState(3);
  const [diaryCategory, setDiaryCategory] = useState(DIARY_CATEGORIES[0] || 'Reflektion');
  const [isSavingDiary, setIsSavingDiary] = useState(false);
  const [isGettingFeedback, setIsGettingFeedback] = useState(false);
  const [journalFeedback, setJournalFeedback] = useState<string | null>(null);

  // Cards State
  const [reflectionCards, setReflectionCards] = useState<{ category: string, question: string, isFlipped: boolean, answer: string, saved: boolean }[]>([]);
  const [isLoadingCards, setIsLoadingCards] = useState(false);

  // Focus Sessions State
  const [coachingTopic, setCoachingTopic] = useState<string | null>(null);
  const [coachingMessages, setCoachingMessages] = useState<{ role: 'user' | 'coach', text: string }[]>([]);
  const [coachingInput, setCoachingInput] = useState('');
  const [isCoachingLoading, setIsCoachingLoading] = useState(false);

  // --- Diary Functions ---
  const handleSaveDiary = async () => {
    if (!diaryText) return;
    setIsSavingDiary(true);
    try {
      await addDoc(collection(db, 'diary'), {
        userId: user.uid,
        text: diaryText,
        energy: diaryEnergy,
        category: diaryCategory,
        createdAt: serverTimestamp()
      });
      setDiaryText('');
      setDiaryEnergy(3);
      setJournalFeedback(null);
    } catch (e) {
      console.error("Diary save error", e);
    } finally {
      setIsSavingDiary(false);
    }
  };

  const handleGetFeedback = async () => {
    if (!diaryText) return;
    setIsGettingFeedback(true);
    try {
      const res = await geminiService.getJournalFeedback(diaryText);
      if (res && res.feedback) {
        setJournalFeedback(res.feedback);
      }
    } catch (e) {
      console.error("Feedback error", e);
    } finally {
      setIsGettingFeedback(false);
    }
  };

  // --- Cards Functions ---
  const loadCards = async () => {
    setIsLoadingCards(true);
    try {
      const res = await geminiService.generateReflectionCards(systemContext);
      if (res && res.cards) {
        setReflectionCards(res.cards.map((c: any) => ({ ...c, isFlipped: false, answer: '', saved: false })));
      }
    } catch (e) {
      console.error("Cards load error", e);
    } finally {
      setIsLoadingCards(false);
    }
  };

  useEffect(() => {
    if (activeTab === 'KORT' && reflectionCards.length === 0) {
      loadCards();
    }
  }, [activeTab]);

  const toggleCardFlip = (index: number) => {
    setReflectionCards(prev => prev.map((c, i) => i === index ? { ...c, isFlipped: !c.isFlipped } : c));
  };

  const updateCardAnswer = (index: number, answer: string) => {
    setReflectionCards(prev => prev.map((c, i) => i === index ? { ...c, answer } : c));
  };

  const saveCardAnswer = async (index: number) => {
    const card = reflectionCards[index];
    if (!card.answer) return;
    try {
      await addDoc(collection(db, 'reflections'), {
        userId: user.uid,
        question: card.question,
        category: card.category,
        answer: card.answer,
        createdAt: serverTimestamp()
      });
      setReflectionCards(prev => prev.map((c, i) => i === index ? { ...c, saved: true } : c));
    } catch (e) {
      console.error("Card save error", e);
    }
  };

  // --- Coaching Functions ---
  const startSession = async (topic: string) => {
    setCoachingTopic(topic);
    if (topic === 'BREATHING' || topic === 'GAD7' || topic === 'VÄRDEKOMPASS') return;
    setCoachingMessages([]);
    setIsCoachingLoading(true);
    try {
      const res = await geminiService.startCoachingSession(topic, "", systemContext);
      if (res && res.message) {
        setCoachingMessages([{ role: 'coach', text: res.message }]);
      }
    } catch (e) {
      console.error("Session start error", e);
    } finally {
      setIsCoachingLoading(false);
    }
  };

  const sendSessionMessage = async () => {
    if (!coachingInput || !coachingTopic) return;
    const newMsg = coachingInput;
    setCoachingInput('');
    const newHistory: { role: 'user' | 'coach', text: string }[] = [...coachingMessages, { role: 'user', text: newMsg }];
    setCoachingMessages(newHistory);
    setIsCoachingLoading(true);
    try {
      const res = await geminiService.sendCoachingMessage(newMsg, coachingTopic, newHistory, systemContext);
      if (res && res.message) {
        setCoachingMessages([...newHistory, { role: 'coach', text: res.message }]);
      }
    } catch (e) {
      console.error("Session message error", e);
    } finally {
      setIsCoachingLoading(false);
    }
  };

  return (
    <div className="space-y-6 pb-20 max-w-2xl mx-auto">
      <div className="flex p-1 bg-black/40 backdrop-blur-xl rounded-[2rem] border border-white/5 mx-auto max-w-md">
        {[
          { id: 'DAGBOK', label: 'Dagbok', icon: Save },
          { id: 'KORT', label: 'Kort', icon: BrainCircuit },
          { id: 'FOKUS', label: 'Fokus', icon: MessageCircle },
          { id: 'IDENTITET', label: 'Jag', icon: Brain },
          { id: 'STOPPA', label: 'Sysslor', icon: Sparkles },
          { id: 'SKÖLD', label: 'Sköld', icon: Shield },
        ].map((tab) => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as WellnessTab)}
            className={cn(
              "flex-1 flex items-center justify-center gap-2 py-3 px-1 rounded-[1.8rem] text-[9px] uppercase font-bold tracking-widest transition-all",
              activeTab === tab.id ? "bg-zen-teal text-obsidian shadow-lg shadow-zen-teal/20" : "text-slate-500 hover:text-slate-300"
            )}
          >
            <tab.icon className="w-3.5 h-3.5" />
            {tab.label}
          </button>
        ))}
      </div>

      <AnimatePresence mode="wait">
        {/* 1. KOGNITIVA DAGBOKEN */}
        {activeTab === 'DAGBOK' && (
          <motion.div
            key="dagbok"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="space-y-6"
          >
            <div className="glass-card rounded-[2.5rem] p-8 relative overflow-hidden">
              <div className="relative z-10">
                <h3 className="text-lg font-outfit text-white mb-2 flex items-center gap-2">
                  <Heart className="w-5 h-5 text-zen-teal" />
                  Den Kognitiva Dagboken
                </h3>
                <p className="text-xs text-slate-500 mb-6 font-inter">En trygg plats att skriva av sig. Mörkret är ofarligt här.</p>
                
                <textarea
                  placeholder="Hur mår du egentligen? Släpp ut tankarna här..."
                  value={diaryText}
                  onChange={(e) => setDiaryText(e.target.value)}
                  className="w-full h-64 rounded-[2rem] bg-black/20 border border-white/5 p-6 text-base text-slate-200 outline-none resize-none transition-all placeholder:text-white/5 shadow-inner leading-relaxed font-inter"
                />
                
                {/* Humör (Emojis) & Kategori */}
                <div className="flex flex-col sm:flex-row items-center justify-between gap-4 mt-6">
                  {/* Energy/Mood picker */}
                  <div className="flex gap-2 w-full sm:w-auto justify-center">
                    {[{ level: 1, emoji: '😔' }, { level: 2, emoji: '😐' }, { level: 3, emoji: '🙂' }, { level: 4, emoji: '😊' }, { level: 5, emoji: '✨' }].map((mood) => (
                      <button
                        key={mood.level}
                        onClick={() => setDiaryEnergy(mood.level)}
                        className={cn(
                          "w-12 h-12 rounded-2xl flex items-center justify-center text-lg transition-all",
                          diaryEnergy === mood.level 
                            ? "bg-zen-teal/20 border border-zen-teal/50 shadow-[0_0_15px_rgba(45,212,191,0.2)]" 
                            : "bg-white/5 border border-transparent hover:bg-white/10 opacity-50"
                        )}
                      >
                        {mood.emoji}
                      </button>
                    ))}
                  </div>

                  {/* Category */}
                  <select 
                    value={diaryCategory}
                    onChange={(e) => setDiaryCategory(e.target.value)}
                    className="w-full sm:w-auto h-10 rounded-xl bg-white/5 border border-transparent focus:border-white/10 px-4 text-xs text-slate-300 outline-none appearance-none"
                  >
                    {DIARY_CATEGORIES.map(c => <option key={c} value={c} className="bg-[#0a0f1c]">{c}</option>)}
                  </select>
                </div>
                
                <AnimatePresence>
                  {journalFeedback && (
                    <motion.div 
                      initial={{ opacity: 0, height: 0, mt: 0 }}
                      animate={{ opacity: 1, height: 'auto', mt: 24 }}
                      className="bg-teal-500/10 border border-teal-500/20 rounded-[1.5rem] p-5"
                    >
                      <div className="flex items-start gap-3">
                        <Sparkles className="w-5 h-5 text-teal-400 mt-0.5 shrink-0" />
                        <p className="text-sm text-teal-50 leading-relaxed font-medium">
                          {journalFeedback}
                        </p>
                      </div>
                    </motion.div>
                  )}
                </AnimatePresence>

                <div className="flex flex-col sm:flex-row gap-3 mt-8">
                  <Button 
                    disabled={isGettingFeedback || !diaryText} 
                    onClick={handleGetFeedback} 
                    className="flex-1 h-14 bg-white/5 text-slate-300 border border-white/5 hover:bg-white/10 rounded-[1.5rem] transition-colors shadow-none font-bold uppercase tracking-widest text-[10px]"
                  >
                    {isGettingFeedback ? 'Läser...' : 'Spegla'}
                  </Button>
                  <Button 
                    disabled={isSavingDiary || !diaryText} 
                    onClick={handleSaveDiary} 
                    className="flex-1 h-14 bg-white/5 text-slate-300 border border-white/5 hover:bg-white/10 rounded-[1.5rem] transition-colors shadow-none font-bold uppercase tracking-widest text-[10px]"
                  >
                    {isSavingDiary ? 'Sparar...' : 'Spara Tyst'}
                  </Button>
                </div>
              </div>
            </div>
          </motion.div>
        )}

        {/* 2. DYNAMISKA REFLEKTIONSKORT */}
        {activeTab === 'KORT' && (
          <motion.div
            key="kort"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-6"
          >
            <div className="flex justify-between items-end px-2">
              <div>
                <h3 className="text-lg font-display text-white">Dagens Reflektionskort</h3>
                <p className="text-xs text-white/50">Genererade unikt för dig baserat på ditt systemminne.</p>
              </div>
              <button 
                onClick={loadCards}
                className="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors"
                disabled={isLoadingCards}
              >
                <RefreshCw className={cn("w-4 h-4 text-white/60", isLoadingCards && "animate-spin")} />
              </button>
            </div>

            {isLoadingCards && reflectionCards.length === 0 ? (
              <div className="h-48 flex items-center justify-center">
                <RefreshCw className="w-6 h-6 text-turquoise animate-spin opacity-50" />
              </div>
            ) : (
              <div className="grid gap-4">
                {reflectionCards.map((card, idx) => (
                  <div key={idx} className="relative h-[280px] [perspective:1000px]">
                    <motion.div 
                      className={cn(
                        "w-full h-full absolute transition-all duration-700 [transform-style:preserve-3d] cursor-pointer",
                        card.isFlipped ? "[transform:rotateY(180deg)]" : ""
                      )}
                    >
                      {/* Front of card */}
                      <BentoCard 
                        className="absolute w-full h-full [backface-visibility:hidden] bg-gradient-to-br from-[#0f172a] to-[#020617] border border-white/10 flex flex-col items-center justify-center p-6 text-center"
                        onClick={() => toggleCardFlip(idx)}
                      >
                        <Brain className="w-12 h-12 text-indigo-400 mb-4 opacity-50" />
                        <h4 className="text-indigo-300 text-xs font-bold uppercase tracking-widest mb-2">{card.category}</h4>
                        <p className="text-white/40 text-sm mt-4">Klicka för att vända kortet</p>
                      </BentoCard>

                      {/* Back of card */}
                      <BentoCard 
                        className="absolute w-full h-full [backface-visibility:hidden] [transform:rotateY(180deg)] bg-[#0f172a] border border-indigo-500/30 flex flex-col p-6"
                      >
                        <div className="flex justify-between items-start mb-4">
                          <span className="text-[10px] font-bold text-indigo-400 uppercase tracking-wider">{card.category}</span>
                          <button onClick={() => toggleCardFlip(idx)} className="text-white/30 hover:text-white">
                            <ArrowLeft className="w-4 h-4" />
                          </button>
                        </div>
                        <p className="text-sm text-white font-medium leading-relaxed mb-4">"{card.question}"</p>
                        
                        {card.saved ? (
                          <div className="flex-1 flex flex-col items-center justify-center text-turquoise/80">
                            <Save className="w-8 h-8 mb-2 opacity-50" />
                            <p className="text-xs font-bold uppercase tracking-widest">Svar Sparat</p>
                          </div>
                        ) : (
                          <div className="flex-1 flex flex-col gap-3">
                            <textarea
                              value={card.answer}
                              onChange={(e) => updateCardAnswer(idx, e.target.value)}
                              placeholder="Din reflektion..."
                              className="flex-1 rounded-xl bg-black/30 border border-white/5 p-3 text-xs text-[#FDE68A] outline-none focus:border-indigo-500/50 resize-none placeholder:text-[#FDE68A]/30"
                            />
                            <Button 
                              onClick={() => saveCardAnswer(idx)}
                              disabled={!card.answer}
                              className="w-full bg-indigo-500/20 text-indigo-300 hover:bg-indigo-500/40 rounded-xl py-2 h-auto text-xs"
                            >
                              Spara i Insiktsvalvet
                            </Button>
                          </div>
                        )}
                      </BentoCard>
                    </motion.div>
                  </div>
                ))}
              </div>
            )}
          </motion.div>
        )}

        {/* 3. INTERAKTIVA FOKUS-SESSIONER */}
        {activeTab === 'FOKUS' && (
          <motion.div
            key="fokus"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="h-[600px] flex flex-col"
          >
            {!coachingTopic ? (
              <div className="space-y-6">
                <div className="text-center mb-8 mt-4">
                  <h3 className="text-xl font-display text-white mb-2">Vad vill du fokusera på idag?</h3>
                  <p className="text-sm text-white/50">Välj ett område för en guidad session.</p>
                </div>
                
                <div className="grid gap-4">
                  {[
                    { id: 'SJÄLVKÄNSLA', title: 'Självkänsla', icon: Heart, color: 'text-rose-400', border: 'border-rose-400/20', bg: 'bg-rose-400/10' },
                    { id: 'ÅNGEST_STRESS', title: 'Ångesthantering', icon: Shield, color: 'text-indigo-400', border: 'border-indigo-400/20', bg: 'bg-indigo-400/10' },
                    { id: 'GAD7', title: 'GAD-7 Skattning', icon: Activity, color: 'text-amber-400', border: 'border-amber-400/20', bg: 'bg-amber-400/10' },
                    { id: 'BREATHING', title: '4-7-8 Andning', icon: Wind, color: 'text-teal-400', border: 'border-teal-400/20', bg: 'bg-teal-400/10' }
                  ].map((topic) => (
                    <BentoCard 
                      key={topic.id}
                      onClick={() => startSession(topic.id)}
                      className={cn(
                        "cursor-pointer transition-all hover:scale-[1.02] flex items-center gap-4 p-6",
                        "bg-[#0f172a] border", topic.border
                      )}
                    >
                      <div className={cn("w-12 h-12 rounded-2xl flex items-center justify-center", topic.bg)}>
                        <topic.icon className={cn("w-6 h-6", topic.color)} />
                      </div>
                      <div>
                        <h4 className="text-white font-bold">{topic.title}</h4>
                        <p className="text-xs text-white/40 mt-1">Starta en guidad läkande session</p>
                      </div>
                    </BentoCard>
                  ))}
                </div>
              </div>
            ) : coachingTopic === 'BREATHING' ? (
              <div className="flex flex-col h-full relative">
                <button 
                  onClick={() => setCoachingTopic(null)}
                  className="absolute top-4 left-4 z-50 w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 backdrop-blur-md"
                >
                  <ArrowLeft className="w-5 h-5 text-white/60" />
                </button>
                <BreathingGuide />
              </div>
            ) : coachingTopic === 'GAD7' ? (
              <div className="flex flex-col h-full relative">
                <button 
                  onClick={() => setCoachingTopic(null)}
                  className="absolute top-4 left-4 z-50 w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 backdrop-blur-md"
                >
                  <ArrowLeft className="w-5 h-5 text-white/60" />
                </button>
                <div className="pt-12">
                  <GAD7Questionnaire userId={user.uid} onComplete={() => setCoachingTopic(null)} />
                </div>
              </div>
            ) : coachingTopic === 'VÄRDEKOMPASS' ? (
              <div className="flex flex-col h-full relative">
                <button 
                  onClick={() => setCoachingTopic(null)}
                  className="absolute top-4 left-4 z-50 w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10 backdrop-blur-md"
                >
                  <ArrowLeft className="w-5 h-5 text-white/60" />
                </button>
                <div className="pt-12">
                  <ValueCompass userId={user.uid} onComplete={() => setCoachingTopic(null)} />
                </div>
              </div>
            ) : (
              <BentoCard className="flex-1 flex flex-col bg-[#0f172a] border-white/5 p-0 overflow-hidden">
                {/* Header */}
                <div className="p-4 border-b border-white/5 flex items-center justify-between bg-black/20">
                  <div className="flex items-center gap-3">
                    <button 
                      onClick={() => setCoachingTopic(null)}
                      className="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center hover:bg-white/10"
                    >
                      <ArrowLeft className="w-4 h-4 text-white/60" />
                    </button>
                    <div>
                      <h4 className="text-sm font-bold text-white uppercase tracking-wider">{coachingTopic.replace('_', ' ')}</h4>
                      <p className="text-[10px] text-turquoise">Coaching-Agent Aktiv</p>
                    </div>
                  </div>
                </div>

                {/* Chat Area */}
                <div className="flex-1 overflow-y-auto p-4 space-y-4">
                  {coachingMessages.map((msg, idx) => (
                    <div 
                      key={idx} 
                      className={cn(
                        "max-w-[85%] rounded-[1.5rem] p-4",
                        msg.role === 'coach' 
                          ? "bg-turquoise/10 border border-turquoise/20 text-turquoise/90 rounded-tl-sm self-start" 
                          : "bg-white/5 border border-white/10 text-white/90 rounded-tr-sm self-end ml-auto"
                      )}
                    >
                      <p className="text-sm leading-relaxed">{msg.text}</p>
                    </div>
                  ))}
                  {isCoachingLoading && (
                    <div className="max-w-[85%] rounded-[1.5rem] rounded-tl-sm p-4 bg-turquoise/5 border border-turquoise/10 self-start">
                      <RefreshCw className="w-4 h-4 text-turquoise animate-spin" />
                    </div>
                  )}
                </div>

                {/* Input Area */}
                <div className="p-4 bg-black/20 border-t border-white/5">
                  <div className="relative">
                    <textarea
                      value={coachingInput}
                      onChange={(e) => setCoachingInput(e.target.value)}
                      onKeyDown={(e) => {
                        if (e.key === 'Enter' && !e.shiftKey) {
                          e.preventDefault();
                          sendSessionMessage();
                        }
                      }}
                      placeholder="Ditt svar..."
                      className="w-full bg-black/40 border border-white/10 rounded-[1.5rem] py-3 pl-4 pr-12 text-sm text-white outline-none focus:border-turquoise/30 resize-none max-h-32"
                      rows={1}
                    />
                    <button 
                      onClick={sendSessionMessage}
                      disabled={!coachingInput || isCoachingLoading}
                      className="absolute right-2 bottom-2 w-8 h-8 rounded-full bg-turquoise text-slate-900 flex items-center justify-center disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                      <Send className="w-4 h-4 ml-0.5" />
                    </button>
                  </div>
                </div>
              </BentoCard>
            )}
          </motion.div>
        )}

        {/* 4. IDENTITET & MÖNSTERBRYTANDE */}
        {activeTab === 'IDENTITET' && (
          <motion.div
            key="identitet"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="space-y-8"
          >
            <div className="px-2">
              <h3 className="text-xl font-outfit text-white mb-2">Identitet & Gränser</h3>
              <p className="text-sm text-white/40">Verktyg för att bryta mönster av "people-pleasing" och stärka ditt sanna jag.</p>
            </div>

            <ValueCompass userId={user.uid} />
            <ThoughtfulNo />
            <Reframing />
          </motion.div>
        )}

        {/* 5. PROKRASTINERINGSSTOPPARE */}
        {activeTab === 'STOPPA' && (
          <motion.div
            key="stoppa"
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -20 }}
          >
            <ProcrastinationStopper />
          </motion.div>
        )}
        {/* 5. GREY ROCK-TRÄNAREN */}
        {activeTab === 'SKÖLD' && (
          <motion.div
            key="skold"
            initial={{ opacity: 0, scale: 0.95 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.95 }}
          >
            <GreyRockTrainer />
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
</file>

<file path="livskompassen-trasig-1/src/services/apiService.ts">
import axios from 'axios';
import axiosRetry from 'axios-retry';
import { collection, addDoc, serverTimestamp } from 'firebase/firestore';
import { db } from '../lib/firebase';

const API_BASE_URL = import.meta.env.VITE_SHIELD_BACKEND_URL || 'http://localhost:8080';

// ─── Error Reporting ──────────────────────────────────────────────────────────

const reportApiError = async (error: any, context: string) => {
  try {
    await addDoc(collection(db, 'system_logs'), {
      type: 'API_ERROR',
      context,
      message: error.message,
      status: error.response?.status,
      data: error.response?.data,
      timestamp: serverTimestamp(),
      url: error.config?.url
    });
