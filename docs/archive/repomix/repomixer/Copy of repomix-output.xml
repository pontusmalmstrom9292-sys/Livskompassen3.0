<file path="livskompassen-trasig-1/src/components/VibeStatusHeader.tsx">
import React from 'react';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { ShieldAlert, Zap, Sparkles, Brain, Info, Target, ShieldCheck, Activity, Heart, Wind } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { db } from '../lib/firebase';
import { collection, query, where, orderBy, limit, onSnapshot } from 'firebase/firestore';
import { cn } from '../lib/utils';
import { BreathingGuide } from './BreathingGuide';

export const VibeStatusHeader: React.FC = () => {
  const { dailyVibe, userId } = useSystemMemory() as any;
  const [identityBrief, setIdentityBrief] = React.useState<string | null>(null);
  const [showBreathing, setShowBreathing] = React.useState(false);
  const [metrics, setMetrics] = React.useState({
    identity: 0,
    strategy: 0,
    boundaries: 0
  });

  React.useEffect(() => {
    if (!userId) return;

    const q = query(collection(db, 'identity_analysis'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(1));
    const unsub = onSnapshot(q, (snap) => {
      if (!snap.empty) setIdentityBrief(snap.docs[0].data().identityBrief);
    });

    setMetrics({
      identity: 85,
      strategy: 70,
      boundaries: 90
    });

    return unsub;
  }, [userId]);

  if (!dailyVibe) return null;

  const isStressed = dailyVibe.stressLevel > 7;
  const isLowEnergy = dailyVibe.energyLevel < 4;

  return (
    <>
      <motion.div 
        initial={{ opacity: 0, scale: 0.98 }}
        animate={{ opacity: 1, scale: 1 }}
        className={cn(
          "w-full rounded-[3.5rem] glass-card p-10 md:p-14 mb-10 relative overflow-hidden group transition-all duration-1000",
          isStressed ? "border-rose-500/20 shadow-[0_0_50px_rgba(244,63,94,0.1)]" : "border-white/10"
        )}
      >
        {/* Vagus Nerve Pulse - Background Animation */}
        <div className="absolute inset-0 pointer-events-none overflow-hidden">
          <motion.div 
            animate={{ 
              scale: isStressed ? [1, 1.1, 1] : [1, 1.05, 1],
              opacity: isStressed ? [0.05, 0.15, 0.05] : [0.02, 0.08, 0.02]
            }}
            transition={{ 
              duration: isStressed ? 4 : 8, 
              repeat: Infinity,
              ease: "easeInOut"
            }}
            className={cn(
              "absolute -top-1/2 -right-1/4 w-full h-full rounded-full blur-[120px]",
              isStressed ? "bg-rose-500" : isLowEnergy ? "bg-amber-500" : "bg-teal-500"
            )}
          />
          <motion.div 
            animate={{ 
              scale: [1, 1.2, 1],
              opacity: [0.01, 0.05, 0.01]
            }}
            transition={{ 
              duration: 12, 
              repeat: Infinity,
              ease: "easeInOut",
              delay: 2
            }}
            className="absolute -bottom-1/2 -left-1/4 w-full h-full bg-indigo-500 rounded-full blur-[150px]"
          />
        </div>

        <div className="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          <div className="lg:col-span-8 space-y-8">
            <div className="flex flex-wrap gap-3">
              {isStressed && (
                <button 
                  onClick={() => setShowBreathing(true)}
                  className="flex items-center gap-3 px-5 py-2.5 bg-rose-500/10 border border-rose-500/20 rounded-2xl text-rose-400 text-[10px] font-black uppercase tracking-widest hover:bg-rose-500/20 transition-all shadow-lg shadow-rose-500/5"
                >
                  <Wind className="w-4 h-4 animate-pulse" /> Ta en andningspaus
                </button>
              )}
              {isStressed ? (
                <span className="flex items-center gap-2 px-4 py-2 bg-rose-500/10 border border-rose-500/20 rounded-xl text-rose-400 text-[10px] font-black uppercase tracking-widest">
                  <ShieldAlert className="w-4 h-4" /> Hög Stressnivå
                </span>
              ) : (
                <span className="flex items-center gap-2 px-4 py-2 bg-teal-500/10 border border-teal-500/20 rounded-xl text-teal-400 text-[10px] font-black uppercase tracking-widest">
                  <ShieldCheck className="w-4 h-4" /> Systemet är Lugnt
                </span>
              )}
              {isLowEnergy && (
                <span className="flex items-center gap-2 px-4 py-2 bg-amber-500/10 border border-amber-500/20 rounded-xl text-amber-400 text-[10px] font-black uppercase tracking-widest">
                  <Zap className="w-4 h-4" /> Låg Energi - Vila
                </span>
              )}
            </div>

            <div className="space-y-4">
              <h1 className="text-4xl md:text-6xl font-outfit font-light text-white tracking-tight leading-tight">
                {isStressed ? "Ditt inre väder är stormigt." : isLowEnergy ? "Tid för återhämtning." : "Välkommen till lugnet."}
                <br />
                <span className="text-indigo-400/80 font-normal">Här vinner sanningen.</span>
