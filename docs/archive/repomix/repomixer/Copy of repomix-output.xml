<file path="livskompassen-trasig/firestore.rules">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives & Helpers
    function isSignedIn() { return request.auth != null; }
    // Note: Relaxed verification check for development environment to prevent permission errors
    function isVerified() { return isSignedIn(); } 
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Entity Validations (Pillar 2)
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'createdAt']) &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt is timestamp;
    }

    function isValidDiary(data) {
      return data.keys().hasAll(['userId', 'text', 'energy', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() <= 10000 &&
             data.energy is int && data.energy >= 1 && data.energy <= 5 &&
             data.createdAt is timestamp;
    }

    function isValidVault(data) {
      return data.keys().hasAll(['userId', 'action', 'truth', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.action is string && data.action.size() <= 5000 &&
             data.truth is string && data.truth.size() <= 5000 &&
             data.createdAt is timestamp;
    }

    function isValidCheckIn(data) {
      return data.keys().hasAll(['userId', 'questionId', 'optionSelected', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.questionId is string && data.questionId.size() <= 200 &&
             data.optionSelected is string && data.optionSelected.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    function isValidNetwork(data) {
      return data.keys().hasAll(['userId', 'name', 'role', 'category', 'importance', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.role is string && data.role.size() <= 200 &&
             data.category in ['SLÄKT', 'MYNDIGHET', 'SKOLA', 'VÄNNER', 'ÖVRIGT'] &&
             data.importance in ['HIGH', 'MEDIUM', 'LOW'] &&
             data.createdAt is timestamp;
    }

    function isValidSynapse(data) {
      return data.keys().hasAll(['userId', 'title', 'category', 'analysis', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 500 &&
             data.category in ['INTEGRITY', 'GROWTH', 'SECURITY', 'BIOGRAPHY', 'COGNITIVE', 'SENSOR', 'PROTECTION'] &&
             data.createdAt is timestamp;
    }

    function isValidReflection(data) {
      return data.keys().hasAll(['userId', 'question', 'answer', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.question is string && data.question.size() <= 2000 &&
             data.answer is string && data.answer.size() <= 10000 &&
             data.createdAt is timestamp;
    }

    function isValidKBDoc(data) {
      return data.keys().hasAll(['userId', 'folderId', 'title', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 100000 &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'description', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.description is string && data.description.size() <= 500 &&
             data.createdAt is timestamp;
    }

    function isValidKidsRecord(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.type in ['ROUTINES', 'INFO', 'LOGS'] &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt is timestamp;
    }

    function isValidAIAgent(data) {
      return data.keys().hasAll(['userId', 'name', 'role', 'prompt', 'isActive', 'category', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && data.role.size() <= 200 &&
             data.prompt is string && data.prompt.size() <= 10000 &&
             data.isActive is bool &&
             data.category in ['DESIGN', 'CODE', 'ANALYSIS', 'SAFETY', 'ARCHITECT'] &&
             data.createdAt is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'title', 'status', 'priority', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['PLANNING', 'ACTIVE', 'ON_HOLD', 'COMPLETED'] &&
             data.priority in ['LOW', 'MEDIUM', 'HIGH'] &&
             data.createdAt is timestamp;
    }

    function isValidWorkLog(data) {
      return data.keys().hasAll(['userId', 'projectId', 'startTime', 'duration', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.projectId is string &&
             data.duration is int &&
             data.createdAt is timestamp;
    }

    function isValidSavings(data) {
      return data.keys().hasAll(['userId', 'title', 'target', 'current', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string &&
             data.target is number &&
             data.current is number &&
             data.createdAt is timestamp;
    }

    function isValidRoutine(data) {
      return data.keys().hasAll(['userId', 'text', 'completed', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.text is string &&
             data.completed is bool &&
             data.createdAt is timestamp;
    }

    // Phase 4: Collection Rules
    
    match /users/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming());
      allow update: if isVerified() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email']);
    }

    match /diary/{entryId} {
      allow create: if isVerified() && isValidId(entryId) && isValidDiary(incoming()) && incoming().createdAt == request.time;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidDiary(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /vault/{logId} {
      allow create: if isVerified() && isValidId(logId) && isValidVault(incoming()) && incoming().createdAt == request.time;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Immortality
    }

    match /checkins/{checkInId} {
      allow create: if isVerified() && isValidId(checkInId) && isValidCheckIn(incoming()) && incoming().createdAt == request.time;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; 
    }

    match /network/{memberId} {
      allow create: if isVerified() && isValidId(memberId) && isValidNetwork(incoming()) && incoming().createdAt == request.time;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidNetwork(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /synapses/{synapseId} {
      allow create: if isVerified() && isValidId(synapseId) && isValidSynapse(incoming()) && incoming().createdAt == request.time;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidSynapse(incoming()) &&
                    incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /scans/{scanId} {
      allow create: if isVerified() && isValidId(scanId) && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /reflections/{reflectionId} {
      allow create: if isVerified() && isValidId(reflectionId) && isValidReflection(incoming()) && incoming().createdAt == request.time;
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /system_state/{userId} {
      allow read: if isOwner(userId);
      allow write: if isVerified() && isOwner(userId);
    }

    // Knowledge Bank
    match /kb_folders/{id} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && incoming().userId == request.auth.uid;
      allow update, delete: if isVerified() && existing().userId == request.auth.uid;
    }
    match /kb_docs/{id} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(id) && isValidKBDoc(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidKBDoc(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }
    match /kb_media/{id} { 
      allow read: if isSignedIn() && (resource == null || existing().userId == request.auth.uid);
      allow create: if isVerified() && isValidId(id) && incoming().userId == request.auth.uid && incoming().createdAt == request.time;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /transactions/{txId} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(txId) && isValidTransaction(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidTransaction(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /kids_records/{recordId} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(recordId) && isValidKidsRecord(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidKidsRecord(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /ai_agents/{agentId} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(agentId) && isValidAIAgent(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidAIAgent(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /projects/{id} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(id) && isValidProject(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidProject(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /work_logs/{id} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(id) && isValidWorkLog(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidWorkLog(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /budget_savings/{id} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(id) && isValidSavings(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidSavings(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }

    match /routines/{id} { 
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isVerified() && isValidId(id) && isValidRoutine(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && existing().userId == request.auth.uid && isValidRoutine(incoming()) && incoming().userId == existing().userId;
      allow delete: if isVerified() && existing().userId == request.auth.uid;
    }
  }
}
