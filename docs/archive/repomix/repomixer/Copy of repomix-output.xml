<file path="src/components/Silo3View.tsx">
import React, { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { ShieldAlert, BookOpen, Lock } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { geminiService } from '../services/geminiService';

export function Silo3View({ user }: { user: any }) {
  const [logs, setLogs] = useState<any[]>([]);
  const [action, setAction] = useState('');
  const [truth, setTruth] = useState('');
  const [isSaving, setIsSaving] = useState(false);
  const [mirroring, setMirroring] = useState<{feedback: string, groundingPoint: string} | null>(null);

  useEffect(() => {
    if (!user) return;
    const q = query(
      collection(db, 'vault'),
      where('userId', '==', user.uid),
      // where('folderId', '==', 'ARKIV'), // Borttagen för tillfället då Arkiv kanske inte följer med
      orderBy('createdAt', 'desc')
    );
    return onSnapshot(q, (snapshot) => {
      setLogs(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() })));
    });
  }, [user]);

  const handleSave = async () => {
    if (!action || !truth) return;
    setIsSaving(true);
    
    // 1. Lås in sanningen
    await addDoc(collection(db, 'vault'), {
      userId: user.uid,
      category: 'JURIDIK',
      action,
      truth,
      isLocked: true,
      createdAt: serverTimestamp()
    });

    // 2. Kör speglingsanalys
    const result = await geminiService.mirroringAnalysis(action, truth);
    setMirroring(result);
    
    setAction('');
    setTruth('');
    setIsSaving(false);
  };

  return (
    <div className="space-y-6">
      <BentoCard icon="⚖️" title="Jurisdiktionsarkivet (Silo 3)">
        <p className="text-xs text-gold/60 mb-6">Oföränderlig loggning av manipulation och gaslighting.</p>
        <div className="space-y-4">
          <textarea
            placeholder="Vad skedde? (Handlingen)"
            value={action}
            onChange={(e) => setAction(e.target.value)}
            className="w-full h-20 rounded-2xl bg-deep-green-dark/40 border border-red-900/30 p-4 text-sm text-red-100 outline-none"
          />
          <textarea
            placeholder="Objektiv Sanning (Det som inte kan ändras)"
            value={truth}
            onChange={(e) => setTruth(e.target.value)}
            className="w-full h-24 rounded-2xl bg-deep-green-dark/40 border border-gold/30 p-4 text-sm text-gold outline-none"
          />
          <Button onClick={handleSave} disabled={isSaving} className="w-full bg-red-900/50 text-red-100 border border-red-900/50">
            {isSaving ? 'Låser...' : 'Kryptografera & Lås In'}
          </Button>
        </div>
      </BentoCard>

      {/* Mirroring feedback */}
      {mirroring && (
          <BentoCard title="Speglings-Agentens analys" icon="🧠">
              <p className="text-xs text-gold/80 mb-2">{mirroring.feedback}</p>
              <div className="bg-gold/10 p-3 rounded-lg border border-gold/20">
                  <p className="text-[10px] text-gold uppercase underline">Grundningspunkt:</p>
                  <p className="text-sm font-bold text-gold">{mirroring.groundingPoint}</p>
              </div>
          </BentoCard>
      )}

      <div className="space-y-4">
        {logs.map(log => (
          <div key={log.id} className="p-4 bg-deep-green-dark/40 rounded-2xl border border-gold/10">
            <div className="flex justify-between text-[9px] text-gold/40 uppercase mb-2">
              <span>{log.createdAt?.toDate().toLocaleDateString()}</span>
              <span>LÅST</span>
            </div>
            <p className="text-xs text-gold/80 mb-2">{log.action}</p>
            <p className="text-xs italic text-gold">{log.truth}</p>
          </div>
        ))}
      </div>
    </div>
  );
}
</file>

