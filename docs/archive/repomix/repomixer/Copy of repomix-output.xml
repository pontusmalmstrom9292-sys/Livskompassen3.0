<file path="src/pages/VaultPage.tsx">
import { useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Shield, Lock, X, Eye, EyeOff, Save, ShieldAlert, Zap, Anchor, Users, AlertTriangle, CheckCircle2, Terminal, BookOpen, FileText } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, query, where, orderBy, onSnapshot } from 'firebase/firestore';
import { VAULT_CATEGORIES } from '../constants';
import { VaultLog, NetworkMember } from '../types';
import { cn } from '../lib/utils';

// Sub-Pages
import { NetworkPage } from './NetworkPage';
import { KnowledgePage } from './KnowledgePage';
import { TerminalPage } from './TerminalPage';
import { Silo3View } from '../components/Silo3View';

interface VaultPageProps {
  user: any;
}

type VaultModule = 'LOGS' | 'NETWORK' | 'KNOWLEDGE' | 'SYSTEM';

export function VaultPage({ user }: VaultPageProps) {
  const [isUnlocked, setIsUnlocked] = useState(false);
  const [pin, setPin] = useState('');
  const [showPinModal, setShowPinModal] = useState(false);
  const [activeModule, setActiveModule] = useState<VaultModule>('LOGS');
  const [logs, setLogs] = useState<VaultLog[]>([]);
  const [importantPeople, setImportantPeople] = useState<NetworkMember[]>([]);
  
  // Form State
  const [category, setCategory] = useState(VAULT_CATEGORIES[0]);
  const [action, setAction] = useState('');
  const [truth, setTruth] = useState('');
  const [childrenImpact, setChildrenImpact] = useState('');
  const [isSaving, setIsSaving] = useState(false);

  // Hidden trigger state
  const pressTimer = useRef<NodeJS.Timeout | null>(null);
  const [isPressing, setIsPressing] = useState(false);

  useEffect(() => {
    if (!user || !isUnlocked) return;
    if (activeModule !== 'LOGS') return;

    // Load Vault Logs
    const qLogs = query(
      collection(db, 'vault'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribeLogs = onSnapshot(qLogs, (snapshot) => {
      setLogs(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as VaultLog)));
    });

    // Load Important Network Members for the quick view
    const qNetwork = query(
      collection(db, 'network'),
      where('userId', '==', user.uid),
      where('importance', '==', 'HIGH')
    );

    const unsubscribeNetwork = onSnapshot(qNetwork, (snapshot) => {
      setImportantPeople(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as NetworkMember)));
    });

    return () => {
      unsubscribeLogs();
      unsubscribeNetwork();
    };
  }, [user, isUnlocked, activeModule]);

  const handleStartPress = () => {
    setIsPressing(true);
    pressTimer.current = setTimeout(() => {
      setShowPinModal(true);
      setIsPressing(false);
    }, 3000);
  };

  const handleEndPress = () => {
    if (pressTimer.current) {
      clearTimeout(pressTimer.current);
      setIsPressing(false);
    }
  };

  const handlePinSubmit = () => {
    if (pin === '6469') { // Original PIN återställd
      setIsUnlocked(true);
      setShowPinModal(false);
      setPin('');
    } else {
      setPin('');
      alert('Fel kod');
    }
  };

  const handleSave = async () => {
    if (!action || !truth) return;
    setIsSaving(true);
    try {
      await addDoc(collection(db, 'vault'), {
        userId: user.uid,
        category,
        action,
        truth,
        childrenImpact,
        biffUsed: action.toLowerCase().includes('biff'),
        createdAt: serverTimestamp()
      });
      setAction('');
      setTruth('');
      setChildrenImpact('');
    } catch (e) {
      console.error("Vault save error", e);
    } finally {
      setIsSaving(false);
    }
  };

  if (!isUnlocked) {
    return (
      <div className="flex flex-col items-center justify-center py-20 px-6">
        <motion.button
          onMouseDown={handleStartPress}
          onMouseUp={handleEndPress}
          onMouseLeave={handleEndPress}
          onTouchStart={handleStartPress}
          onTouchEnd={handleEndPress}
          animate={{ scale: isPressing ? 0.9 : 1 }}
          className="w-32 h-32 rounded-[3rem] glass-card flex items-center justify-center relative overflow-hidden group"
        >
          <Anchor className="w-12 h-12 text-gold opacity-20 group-hover:opacity-40 transition-opacity" />
          {isPressing && (
            <motion.div
              initial={{ height: 0 }}
              animate={{ height: '100%' }}
              transition={{ duration: 3, ease: 'linear' }}
              className="absolute bottom-0 left-0 right-0 bg-gold/10 -z-10"
            />
          )}
        </motion.button>
        
        <p className="mt-8 text-xs uppercase tracking-[0.2em] font-bold opacity-20 text-center">
          Identifiering krävs för tillträde
        </p>

        <AnimatePresence>
          {showPinModal && (
            <motion.div
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
              className="fixed inset-0 bg-deep-midnight/80 backdrop-blur-xl z-[100] flex items-center justify-center p-6"
            >
            <div className="w-full max-w-xs card-mystic p-8 rounded-[2.5rem] flex flex-col items-center">
                <Lock className="w-8 h-8 text-gold mb-6" />
                <h3 className="text-lg mb-8 text-gold font-display">Ange PIN-kod</h3>
                
                <div className="flex gap-4 mb-8">
                  {[...Array(4)].map((_, i) => (
                    <div key={i} className={`w-3 h-3 rounded-full ${pin.length > i ? 'bg-gold' : 'bg-gold/20'}`} />
                  ))}
                </div>

                <div className="grid grid-cols-3 gap-4 w-full">
                  {[1,2,3,4,5,6,7,8,9, 'X', 0, 'OK'].map((val) => (
                    <button
                      key={val.toString()}
                      onClick={() => {
                        if (val === 'X') setPin(pin.slice(0, -1));
                        else if (val === 'OK') handlePinSubmit();
                        else if (pin.length < 4) setPin(pin + val);
                      }}
                      className="h-14 rounded-2xl bg-white/5 hover:bg-white/10 active:scale-90 transition-all flex items-center justify-center text-lg font-medium"
                    >
                      {val}
                    </button>
                  ))}
                </div>

                <button onClick={() => setShowPinModal(false)} className="mt-8 text-xs uppercase tracking-widest opacity-40">Avbryt</button>
              </div>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    );
  }

  return (
    <div className="space-y-6 pb-20">
      {/* Vault Header - The Gateway */}
      <header className="flex justify-between items-center bg-gold/5 p-4 rounded-3xl border border-gold/10">
        <div className="flex items-center gap-3">
          <ShieldAlert className="w-5 h-5 text-gold" />
          <div>
            <span className="text-sm font-bold uppercase tracking-widest text-gold block leading-tight">Verklighetsvalvet</span>
            <span className="text-[10px] text-gold/40 uppercase tracking-tighter">Skyddad sanning</span>
          </div>
        </div>
        <div className="flex gap-2">
          <button onClick={() => setIsUnlocked(false)} className="p-2 rounded-xl bg-white/5 hover:bg-red-400/20 text-red-400 transition-colors">
            <Lock className="w-4 h-4" />
          </button>
        </div>
      </header>

      {/* Main Bento Dashboard */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        {/* Silo 1: Jaget & Hälsan */}
        <BentoCard className="bg-deep-green-mid/40 border-gold/10 p-6">
          <h3 className="text-sm font-bold text-gold uppercase tracking-widest mb-4">Jaget & Hälsan</h3>
          <div className="space-y-2">
            <Button variant="ghost" onClick={() => setActiveModule('SYSTEM')} className="w-full justify-start text-xs text-gold/60">Vagusnerv-stimulering</Button>
            <Button variant="ghost" className="w-full justify-start text-xs text-gold/60">Ekonomi-översikt</Button>
          </div>
        </BentoCard>

        {/* Silo 2: Barnens Värld */}
        <BentoCard className="bg-deep-green-mid/40 border-gold/10 p-6">
          <h3 className="text-sm font-bold text-gold uppercase tracking-widest mb-4">Barnens Värld</h3>
          <div className="space-y-2">
            <Button variant="ghost" className="w-full justify-start text-xs text-gold/60">KASPER (Scen: Syndabock)</Button>
            <Button variant="ghost" className="w-full justify-start text-xs text-gold/60">ARVID (Scen: Regression)</Button>
          </div>
        </BentoCard>

        {/* Silo 3: Ex-fruns Sfär */}
        <BentoCard className="bg-red-900/10 border-red-900/30 p-6 md:col-span-2">
          <h3 className="text-sm font-bold text-red-400 uppercase tracking-widest mb-4">Ex-fruns Sfär (Bevislogg)</h3>
          <Button onClick={() => setActiveModule('LOGS')} className="w-full bg-red-900/20 hover:bg-red-900/40 text-red-400 border border-red-900/50">
            Öppna Jurisdiktionsfilerna
          </Button>
        </BentoCard>
      </div>

      {/* Vault Sub-navigation */}
      <div className="flex bg-white/5 p-1 rounded-2xl border border-white/5">
        {[
          { id: 'LOGS', label: 'Bevis', icon: FileText },
          { id: 'NETWORK', label: 'Nätverk', icon: Users },
          { id: 'KNOWLEDGE', label: 'Banken', icon: BookOpen },
          { id: 'SYSTEM', label: 'System', icon: Terminal },
        ].map((mod) => (
          <button
            key={mod.id}
            onClick={() => setActiveModule(mod.id as any)}
            className={cn(
              "flex-1 flex flex-col items-center py-3 rounded-xl transition-all relative overflow-hidden",
              activeModule === mod.id ? "bg-gold text-deep-green-dark" : "text-gold/40 hover:text-gold/60"
            )}
          >
            <mod.icon className={cn("w-5 h-5 mb-1", activeModule === mod.id ? "text-deep-green-dark" : "text-gold/40")} />
            <span className="text-[9px] font-bold uppercase tracking-tighter">{mod.label}</span>
          </button>
        ))}
      </div>
      
      {/* Central Action */}
      {activeModule === 'LOGS' && <Silo3View user={user} />}
      {activeModule === 'NETWORK' && <NetworkPage user={user} />}
      {activeModule === 'KNOWLEDGE' && <KnowledgePage user={user} />}
      {activeModule === 'SYSTEM' && <TerminalPage user={user} />}
    </div>
  );
}
</file>

