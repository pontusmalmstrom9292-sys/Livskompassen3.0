<file path="livskompassen-trasig-1/src/services/radarService.ts">
import { collection, addDoc, serverTimestamp, query, where, getDocs, orderBy, limit, doc, getDoc, updateDoc, setDoc, onSnapshot, increment, deleteDoc } from 'firebase/firestore';
import { db } from '../lib/firebase'; 
import { Actor, RadarEvent, UnidentifiedCounter } from '../types';

// 1. Definition av hur en Aktör ser ut
export interface Actor {
  actorId: string;
  name: string;
  role: string;
  bio?: string;
  category: 'Myndighet' | 'Privat' | 'Ombud' | 'Övrig familj';
  colorCode: string;
  trustLevel: 'Neutral' | 'Fientlig' | 'Allierad';
  createdAt: any; 
}

// 2. Definition av hur ett Bevis/Händelse ser ut
export interface RadarEvent {
  id?: string;
  userId: string;
  type: string;
  description: string;
  originalText: string;
  timestamp: any;
  aiAnalysis: {
    redFlags: string[];
    biffResponse: string;
    unidentifiedActors: string[];
  };
  involvedActors: string[];
  evidenceUrls?: string[];
  isSelfMade?: boolean;
  isAuthentic?: boolean;
}

// 3. Tjänsten som appen använder för att spara data
export const radarService = {
  async logEvent(eventData: Omit<RadarEvent, 'timestamp'>) {
    try {
      const eventsRef = collection(db, 'events');
      
      const docRef = await addDoc(eventsRef, {
        ...eventData,
        timestamp: serverTimestamp() 
      });

      return docRef.id;
    } catch (error) {
      console.error("Kunde inte låsa in beviset: ", error);
      throw error;
    }
  },

  async getEvents(userId: string, actorId?: string) {
    const eventsRef = collection(db, 'events');
    let q = query(eventsRef, orderBy('timestamp', 'desc'), limit(50));
    
    // Om vi vill filtrera på en specifik person
    if (actorId) {
      q = query(eventsRef, where('involvedActors', 'array-contains', actorId), orderBy('timestamp', 'desc'), limit(50));
    }
    
    const snapshot = await getDocs(q);
    return snapshot.docs.map(doc => ({ 
      id: doc.id, 
      ...doc.data(),
      timestamp: (doc.data() as any).timestamp?.toDate() || new Date()
    } as RadarEvent));
  },

  async handleUnidentifiedActor(userId: string, name: string) {
    try {
      // Vi använder userId + name som ID för att hålla det privat och säkert per användare
      const counterId = `${userId}_${name.replace(/\s+/g, '_').toLowerCase()}`;
      const counterRef = doc(db, 'unidentified_counters', counterId);
      
      // 1. Öka räknaren med 1 (Atomic Increment)
      await setDoc(counterRef, { 
        userId,
        name: name,
        count: increment(1),
        lastSeen: serverTimestamp()
      }, { merge: true });

      // 2. Hämta det uppdaterade värdet för att se om vi nått gränsen
      const snap = await getDoc(counterRef);
      const data = snap.data();
      
      if (snap.exists() && data?.count && !data?.isMuted) {
        return { count: data.count, name }; 
      }
      
      return { count: 0, name };
    } catch (error) {
      console.error("Kunde inte hantera okänd aktör: ", error);
      return { shouldNotify: false };
    }
  },

  async muteUnidentifiedActor(userId: string, name: string) {
    try {
      const counterId = `${userId}_${name.replace(/\s+/g, '_').toLowerCase()}`;
      const counterRef = doc(db, 'unidentified_counters', counterId);
      await updateDoc(counterRef, { isMuted: true });
    } catch (error) {
      console.error("Kunde inte tysta aktören: ", error);
    }
  },

  async processUnidentifiedActors(userId: string, names: string[]) {
    const notifications: {name: string, count: number}[] = [];
  
    for (const name of names) {
      const result = await this.handleUnidentifiedActor(userId, name);
      
      // Vi kollar om räknaren är ett jämnt femtal (5, 10, 15...)
      if (result.count > 0 && result.count % 5 === 0) {
        notifications.push({ name: result.name, count: result.count });
      }
    }
  
    return notifications;
  },

  async getEventsByUnidentifiedName(userId: string, name: string) {
    try {
      const eventsRef = collection(db, 'events');
      const q = query(eventsRef, where('userId', '==', userId));
      const snapshot = await getDocs(q);
      
      // Vi måste filtrera i kod eftersom 'aiAnalysis.unidentifiedActors' är ett nästlat fält i en array
      return snapshot.docs
        .map(doc => ({ id: doc.id, ...doc.data() } as RadarEvent))
        .filter(event => event.aiAnalysis?.unidentifiedActors?.includes(name));
    } catch (error) {
      console.error("Kunde inte hämta händelser för okänd aktör:", error);
      return [];
    }
  },

  async promoteToActor(
    userId: string,
    name: string,
    role: string = 'Okänd',
    trustLevel: 'Neutral' | 'Fientlig' | 'Allierad' = 'Neutral',
    bio: string = '',
    category: 'Myndighet' | 'Privat' | 'Ombud' | 'Övrig familj' = 'Privat',
    colorCode: string = '#f97316'
  ) {
    try {
      const actorsRef = collection(db, 'actors');
      const actorDoc = await addDoc(actorsRef, {
        userId,
        name,
        role,
        bio,
        category,
        colorCode,
        trustLevel,
        createdAt: serverTimestamp()
      });

      const newActorId = actorDoc.id;

      // 2. Retroaktiv städning: Hitta alla händelser där namnet nämnts
      const eventsRef = collection(db, 'events');
      const q = query(eventsRef, where('userId', '==', userId));
      const querySnapshot = await getDocs(q);

      const updatePromises = querySnapshot.docs
        .filter(doc => {
          const data = doc.data() as RadarEvent;
          return data.aiAnalysis?.unidentifiedActors?.includes(name);
        })
        .map(docSnapshot => {
          const data = docSnapshot.data() as RadarEvent;
          const updatedInvolved = [...new Set([...(data.involvedActors || []), newActorId])];
          const updatedUnidentified = (data.aiAnalysis.unidentifiedActors || []).filter(n => n !== name);
          
          return updateDoc(docSnapshot.ref, {
            involvedActors: updatedInvolved,
            'aiAnalysis.unidentifiedActors': updatedUnidentified
          });
        });

      await Promise.all(updatePromises);
      
      // 3. Ta bort räknaren eftersom personen nu är en känd aktör
      const counterId = `${userId}_${name.replace(/\s+/g, '_').toLowerCase()}`;
      await deleteDoc(doc(db, 'unidentified_counters', counterId));

      return newActorId;
    } catch (error) {
      console.error("Kunde inte uppgradera till aktör:", error);
      throw error;
    }
  },

  subscribeToActors(userId: string, callback: (actors: Actor[]) => void) {
    const q = query(collection(db, 'actors'), where('userId', '==', userId));
    return onSnapshot(q, (snapshot) => {
      const actors = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as Actor));
      callback(actors);
    });
  },

  async saveEvent(userId: string, eventData: Omit<RadarEvent, 'userId' | 'timestamp'>) {
    const eventsRef = collection(db, 'events');
    const docRef = await addDoc(eventsRef, {
      ...eventData,
      userId,
      timestamp: serverTimestamp()
    });
    return docRef.id;
  },

  // 4. NYHET: Självlärande Valv - Uppladdning & Intelligens-lyssnare med Forensisk Integritet
  async generateFileHash(file: File): Promise<string> {
    const arrayBuffer = await file.arrayBuffer();
    const hashBuffer = await crypto.subtle.digest('SHA-256', arrayBuffer);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
  },

  async uploadEvidence(userId: string, file: File, metadata?: any) {
    const { ref, uploadBytes, getDownloadURL } = await import('firebase/storage');
    const { storage } = await import('../lib/firebase');
    
    // Generera hash för digitalt bevisvärde (Chain of Custody)
    const fileHash = await this.generateFileHash(file);
    
    // Vi sparar filen i en mapp låst till användarens ID
    const storageRef = ref(storage, `vault/${userId}/${Date.now()}_${file.name}`);
    
    await uploadBytes(storageRef, file, {
      customMetadata: {
        'sha256': fileHash,
        'userId': userId,
        'isAuthentic': metadata?.isAuthentic?.toString() || 'false',
        'isSelfMade': metadata?.isSelfMade?.toString() || 'false'
      }
    });

    const downloadUrl = await getDownloadURL(storageRef);

    // Spara även metadata i Firestore för snabb sökning
    await addDoc(collection(db, 'vault_intelligence'), {
      userId,
      fileName: file.name,
      fileUrl: downloadUrl,
      fileHash,
      fileType: file.type,
      size: file.size,
      timestamp: serverTimestamp(),
      ...metadata
    });

    return { downloadUrl, fileHash };
  },

  subscribeToIntelligence(userId: string, callback: (intelligence: any[]) => void) {
    const q = query(
      collection(db, 'vault_intelligence'), 
      where('userId', '==', userId),
      orderBy('timestamp', 'desc'),
      limit(20)
    );
    return onSnapshot(q, (snapshot) => {
      const data = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      callback(data);
    });
  },

  async updateIntelligenceMetadata(userId: string, itemId: string, updates: { isSelfMade?: boolean; isAuthentic?: boolean }) {
    const itemRef = doc(db, 'vault_intelligence', itemId);
    await updateDoc(itemRef, {
      ...updates,
      lastUpdated: serverTimestamp()
    });
  }
};
</file>

