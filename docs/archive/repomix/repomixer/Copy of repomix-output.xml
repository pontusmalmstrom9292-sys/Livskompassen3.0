import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { geminiService } from '../services/geminiService';
import { radarService } from '../services/radarService';
import { Sparkles, Shield, TrendingUp, Heart, Loader2, Compass, Award, Quote, AlertCircle } from 'lucide-react';
import { collection, query, where, getDocs, orderBy } from 'firebase/firestore';
import { db } from '../lib/firebase';

export const MirroringView: React.FC<{ userId: string }> = ({ userId }) => {
  const [reflection, setReflection] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    const loadReflection = async () => {
      try {
        setLoading(true);
        setError(null);
        // 1. Hämta Radar Events
        const fetchedEvents = await radarService.getEvents(userId);
        
        // 2. Hämta Dagboksanteckningar
        const diaryRef = collection(db, 'diary_entries');
        const q = query(diaryRef, where('userId', '==', userId), orderBy('timestamp', 'desc'));
        const diarySnap = await getDocs(q);
        const diaryEntries = diarySnap.docs.map(doc => doc.data());

        // 3. Generera Analys
        const res = await geminiService.generateMirroringReflection(fetchedEvents, diaryEntries);
        const data = JSON.parse(res.replace(/```json/g, '').replace(/```/g, '').trim());
        setReflection(data);
      } catch (err) {
        console.error("Failed to load mirroring:", err);
        setError("Kunde inte generera spegling just nu. Har du skrivit i dagboken nyligen?");
      } finally {
        setLoading(false);
      }
    };
    loadReflection();
  }, [userId]);

  if (loading) {
    return (
      <div className="flex flex-col items-center justify-center p-20 space-y-6">
        <div className="relative">
          <Loader2 className="w-12 h-12 text-indigo-400 animate-spin opacity-20" />
          <Compass className="w-6 h-6 text-indigo-400 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 animate-pulse" />
        </div>
        <p className="text-[10px] uppercase font-bold text-slate-500 tracking-[0.3em] animate-pulse">Söker efter din inre styrka...</p>
      </div>
    );
  }

  if (error || !reflection) {
    return (
      <div className="flex flex-col items-center justify-center p-20 space-y-4 text-center">
        <AlertCircle className="w-10 h-10 text-slate-600 mb-2" />
        <p className="text-slate-400 text-sm max-w-xs leading-relaxed">{error || "Ingen data tillgänglig för analys."}</p>
        <button 
          onClick={() => window.location.reload()}
          className="text-[10px] uppercase font-bold text-indigo-400 tracking-widest mt-4 hover:text-indigo-300 transition-colors"
        >
          Försök igen
        </button>
      </div>
    );
  }

  return (
    <motion.div 
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      className="max-w-4xl mx-auto space-y-12 pb-20"
    >
      {/* Hero Section */}
      <header className="text-center space-y-4">
        <div className="inline-flex items-center gap-2 px-4 py-1.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[10px] font-bold text-indigo-400 uppercase tracking-widest">
          <Sparkles className="w-3 h-3" /> Den Objektiva Spegeln
        </div>
        <h1 className="text-4xl lg:text-5xl font-outfit text-white font-light leading-tight">
          Här är din <span className="text-indigo-400 font-medium">sanning</span>.
        </h1>
        <p className="text-slate-500 max-w-lg mx-auto text-sm italic leading-relaxed">
          När omvärlden försöker förvirra dig, låt dina samlade loggar påminna dig om vem du faktiskt är. 
          Du är mer stabil än vad du känner dig just nu.
        </p>
      </header>

      {/* Objective Truth Card */}
      <motion.div 
        initial={{ y: 20, opacity: 0 }}
        animate={{ y: 0, opacity: 1 }}
        className="relative group"
      >
        <div className="absolute inset-0 bg-indigo-500/5 rounded-[3rem] blur-3xl group-hover:bg-indigo-500/10 transition-all duration-1000" />
        <div className="relative bg-slate-900/40 border border-white/5 rounded-[3rem] p-8 lg:p-12 backdrop-blur-xl shadow-2xl overflow-hidden">
          <div className="absolute top-0 right-0 p-8 opacity-5">
            <Shield className="w-32 h-32 text-indigo-500" />
          </div>
          <div className="flex flex-col lg:flex-row gap-10 items-center relative">
