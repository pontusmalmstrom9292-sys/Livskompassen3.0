import json
import re
from typing import Dict, Any, Optional

class SafeJSONParser:
    """
    Utility to safely parse JSON from LLM responses, 
    even if they are wrapped in markdown code blocks or contain trailing garbage.
    """
    
    @staticmethod
    def parse(text: str) -> Dict[str, Any]:
        try:
            # 1. Try direct parsing
            return json.loads(text)
        except json.JSONDecodeError:
            try:
                # 2. Try extracting from markdown code block
                match = re.search(r'```(?:json)?\s*(\{.*?\})\s*```', text, re.DOTALL)
                if match:
                    return json.loads(match.group(1))
                
                # 3. Try finding the first '{' and last '}'
                start = text.find('{')
                end = text.rfind('}')
                if start != -1 and end != -1:
                    return json.loads(text[start:end+1])
                    
            except Exception as e:
                print(f"SafeJSONParser Error: {e} | Text: {text[:200]}...")
        
        # Fallback for failing to parse
        return {
            "error": "Failed to parse system response as JSON",
            "raw_text": text[:500],
            "masterInsight": "Systemet stötte på ett tekniskt fel vid tolkning av svaret.",
            "groundingPoints": ["Tekniskt fel"]
        }
