              </div>
              <div className="grid grid-cols-1 gap-6">
                {analysis.safeMoves?.map((move: string, i: number) => (
                  <div key={i} className="flex items-center gap-6 p-8 bg-black/40 border border-white/5 rounded-[2.5rem] group hover:bg-teal-500/10 transition-all">
                    <div className="p-3 bg-teal-500/10 rounded-2xl border border-teal-500/20">
