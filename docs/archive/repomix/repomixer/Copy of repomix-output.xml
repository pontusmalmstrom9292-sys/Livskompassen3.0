import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  BookOpen, Search, Sparkles, MessageSquare, 
  FileText, Gavel, Baby, Wallet, Network,
  ChevronRight, Loader2, Send, History, 
  ShieldCheck, AlertCircle, Quote, Download
} from 'lucide-react';
import { shieldApi } from '../services/apiService';
import { cn } from '../lib/utils';
import { db } from '../lib/firebase';
import { collection, query, where, orderBy, onSnapshot } from 'firebase/firestore';

interface KBDoc {
  id: string;
  title: string;
  category: 'LEGAL' | 'ECONOMIC' | 'CHILD' | 'PATTERN' | 'MANUAL';
  summary: string;
  content: string;
  masterInsight?: string;
  createdAt: any;
}

export const KnowledgeBank = ({ userId }: { userId: string }) => {
  const [activeMode, setActiveMode] = useState<'BROWSE' | 'ASK' | 'CASES'>('BROWSE');
  const [searchTerm, setSearchTerm] = useState('');
  const [question, setQuestion] = useState('');
  const [isAsking, setIsAsking] = useState(false);
  const [answer, setAnswer] = useState<any>(null);
  const [docs, setDocs] = useState<KBDoc[]>([]);
  const [loading, setLoading] = useState(true);
  const [selectedCategory, setSelectedCategory] = useState<string | null>(null);
  const [selectedCase, setSelectedCase] = useState<any | null>(null);

  const MOCK_CASES = [
    { id: 'case-1', title: 'Akt: Ex-fru 2024', count: 14, alert: 'Gaslighting-mönster', color: 'indigo' },
    { id: 'case-2', title: 'Akt: Vårdnadstvist', count: 8, alert: 'Juridisk tidslinje aktiv', color: 'teal' },
    { id: 'case-3', title: 'Akt: Företaget', count: 3, alert: 'Ekonomisk revision', color: 'amber' },
  ];

  useEffect(() => {
    if (!userId) return;
    const q = query(collection(db, 'kb_docs'), where('userId', '==', userId), orderBy('createdAt', 'desc'));
    const unsub = onSnapshot(q, (snap) => {
      setDocs(snap.docs.map(d => ({ id: d.id, ...d.data() } as KBDoc)));
      setLoading(false);
    });
    return unsub;
  }, [userId]);

  const handleAsk = async () => {
    if (!question.trim()) return;
    setIsAsking(true);
    try {
      const res = await shieldApi.ask(question);
      setAnswer(res);
      setQuestion('');
    } catch (err) {
      console.error("Failed to ask Knowledge Bank:", err);
    } finally {
      setIsAsking(false);
    }
  };

  const categories = [
    { id: 'LEGAL', label: 'Juridisk Praxis', icon: Gavel, color: 'text-indigo-400', bg: 'bg-indigo-500/10' },
    { id: 'CHILD', label: 'Barnrätt (BBIC)', icon: Baby, color: 'text-teal-400', bg: 'bg-teal-500/10' },
    { id: 'ECONOMIC', label: 'Ekonomi & Kontroll', icon: Wallet, color: 'text-amber-400', bg: 'bg-amber-500/10' },
    { id: 'PATTERN', label: 'Beteende-Mönster', icon: History, color: 'text-rose-400', bg: 'bg-rose-500/10' },
    { id: 'MANUAL', label: 'System-Manual', icon: BookOpen, color: 'text-blue-400', bg: 'bg-blue-500/10' },
  ];

  const filteredDocs = docs.filter(d => 
    (!selectedCategory || d.category === selectedCategory) &&
    (d.title.toLowerCase().includes(searchTerm.toLowerCase()) || 
     (d.summary || '').toLowerCase().includes(searchTerm.toLowerCase()))
  );

  return (
    <div className="space-y-12 pb-32">
      {/* Header with Switcher */}
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
        <div className="space-y-2">
          <h2 className="text-4xl text-white font-outfit font-light tracking-tighter flex items-center gap-4">
            <div className="p-4 bg-indigo-500/10 rounded-[2rem] border border-indigo-500/20">
              <BookOpen className="w-8 h-8 text-indigo-400" />
            </div>
            Kunskapsbanken
          </h2>
          <p className="text-lg text-slate-500 font-outfit font-light">
            Sök i arkivet, lagrum och strategiska guider via Vertex AI Search.
          </p>
        </div>

        <div className="flex p-1.5 bg-white/5 backdrop-blur-2xl rounded-[1.8rem] border border-white/5 shadow-2xl">
          <button 
            onClick={() => setActiveMode('BROWSE')}
            className={cn(
              "px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2",
              activeMode === 'BROWSE' ? "bg-indigo-500 text-white shadow-lg" : "text-slate-500 hover:text-slate-300"
            )}
          >
            <FileText className="w-4 h-4" /> Bibliotek
          </button>
          <button 
            onClick={() => setActiveMode('CASES')}
            className={cn(
              "px-6 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest transition-all flex items-center gap-2",
              activeMode === 'CASES' ? "bg-indigo-500 text-white shadow-lg" : "text-slate-500 hover:text-slate-300"
            )}
          >
            <Folder className="w-4 h-4" /> Akter
