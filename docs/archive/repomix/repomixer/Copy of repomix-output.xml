              </div>
            </div>
          )}

          <div className="text-center opacity-40">
            <p className="text-[10px] text-slate-500 italic uppercase tracking-widest font-inter">
              Sanningens ankare är satt. Du styr ditt skepp.
            </p>
          </div>
        </motion.div>
      )}
    </div>
  );
};
