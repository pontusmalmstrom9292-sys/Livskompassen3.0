import { db } from '../lib/firebase';
import { 
  collection, addDoc, serverTimestamp, 
  query, where, orderBy, onSnapshot, limit 
} from 'firebase/firestore';

export interface IntelligenceSignal {
  id?: string;
  sourceAgent: string;
  targetAgent?: string;
  type: 'PATTERN' | 'RISK' | 'ACTION' | 'INSIGHT';
  payload: any;
  timestamp?: any;
}

class MessageBus {
  private signalsCollection = collection(db, 'intelligence_signals');

  /**
   * Publish a signal to the bus
   */
  public async publish(signal: IntelligenceSignal) {
    try {
      await addDoc(this.signalsCollection, {
        ...signal,
        timestamp: serverTimestamp(),
      });
      console.log(`[MessageBus] Signal published by ${signal.sourceAgent}: ${signal.type}`);
    } catch (error) {
      console.error("[MessageBus] Publish failed:", error);
    }
  }

  /**
   * Subscribe to signals for a specific agent or type
   */
  public subscribe(
    callback: (signals: IntelligenceSignal[]) => void,
    filters: { agentId?: string; type?: string } = {}
  ) {
    let q = query(this.signalsCollection, orderBy('timestamp', 'desc'), limit(10));

    if (filters.agentId) {
      q = query(q, where('targetAgent', 'in', [filters.agentId, 'ALL']));
    }

    if (filters.type) {
      q = query(q, where('type', '==', filters.type));
    }

    return onSnapshot(q, (snapshot) => {
      const signals = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      })) as IntelligenceSignal[];
      callback(signals);
    });
  }

  /**
   * Proactive trigger for critical cross-agent workflows
   */
  public triggerCrisisMode(reason: string) {
    return this.publish({
      sourceAgent: 'SYSTEM',
      targetAgent: 'ALL',
      type: 'RISK',
      payload: { 
        level: 'CRITICAL', 
        reason,
        action: 'ACTIVATE_GROUNDING_PROTOCOLS' 
      }
    });
  }
}

export const messageBus = new MessageBus();
