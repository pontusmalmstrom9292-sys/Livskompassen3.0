  const [mood, setMood] = useState<Mood>('CALM');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [analysis, setAnalysis] = useState<AnalysisResponse | null>(null);
  const [reflection, setReflection] = useState({
    training: '',
    goals: '',
    identity: '',
    play: ''
  });

  // Dynamic Background Logic
  useEffect(() => {
    const root = document.documentElement;
    const currentMood = MOODS[mood];
    root.style.setProperty('--app-mood-color', currentMood.color);
    root.style.setProperty('--app-mood-gradient', currentMood.gradient);
  }, [mood]);

  const handleChange = (field: keyof typeof reflection, value: string) => {
    setReflection(prev => ({ ...prev, [field]: value }));
  };

  const handleShieldAnalysis = async () => {
    const entryText = Object.values(reflection).filter(v => v.trim()).join('. ');
    if (!entryText) return;

    setIsAnalyzing(true);
    try {
      const res = await shieldApi.analyze({
        content: entryText,
        mode: mood === 'STRESSED' ? 'BIFF' : 'DEFAULT'
      });
      setAnalysis(res);
    } catch (e) {
      console.error("Shield analysis failed", e);
    } finally {
      setIsAnalyzing(false);
    }
  };

  const handleSave = async () => {
    const user = auth.currentUser;
    if (!user) return;

    try {
      const entryText = Object.values(reflection).filter(v => v.trim()).join('. ');
      
      await addDoc(collection(db, 'mood_journal'), {
        userId: user.uid,
        mood,
        ...reflection,
        analysis: analysis, // Spara även analysen om den finns
        timestamp: serverTimestamp()
      });

      // Trigger The Buddy
      window.dispatchEvent(new CustomEvent('journal-saved', { 
        detail: { text: entryText || mood } 
      }));

      // Clear fields
      setReflection({ training: '', goals: '', identity: '', play: '' });
      setAnalysis(null);
      alert('Reflektion sparad i ditt inre arkiv.');
    } catch (e) {
      console.error("Failed to save mood journal", e);
    }
  };

  return (
    <div className="bg-[#0f172a]/60 backdrop-blur-2xl border border-white/5 rounded-[3rem] p-8 lg:p-10 shadow-2xl relative overflow-hidden">
      {/* Mood Selector */}
      <div className="mb-12">
        <p className="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-black mb-6 text-center">Hur är vädret i själen idag?</p>
        <div className="flex justify-between items-center max-w-sm mx-auto">
          {(Object.keys(MOODS) as Mood[]).map((m) => (
            <button
              key={m}
              onClick={() => setMood(m)}
              className={cn(
                "group relative flex flex-col items-center gap-3 transition-all duration-500",
                mood === m ? "scale-110" : "opacity-40 grayscale hover:opacity-100 hover:grayscale-0"
              )}
            >
              <div 
                className={cn(
                  "w-16 h-16 rounded-[2rem] flex items-center justify-center text-3xl border transition-all duration-500 shadow-2xl",
                  mood === m ? "bg-white/10 border-white/20 shadow-white/5" : "bg-white/5 border-transparent"
                )}
                style={{ borderColor: mood === m ? MOODS[m].color + '40' : undefined }}
              >
                {MOODS[m].emoji}
              </div>
              <span 
                className="text-[9px] uppercase tracking-widest font-black"
                style={{ color: mood === m ? MOODS[m].color : '#64748b' }}
              >
                {MOODS[m].label}
              </span>
            </button>
          ))}
        </div>
      </div>

      {/* Reflection Form */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { id: 'training', label: 'Träning & Rörelse', icon: Heart, placeholder: 'Hur rörde du dig idag?' },
          { id: 'goals', label: 'Dagens Mål', icon: Target, placeholder: 'Vad uppnådde du?' },
          { id: 'identity', label: 'Vem var du idag?', icon: User, placeholder: 'Stod du upp för dig själv?' },
          { id: 'play', label: 'Lek & Nonsens', icon: Sparkles, placeholder: 'Vad gjorde du bara för kul?' },
        ].map((field) => (
          <div key={field.id} className="space-y-3">
            <label className="flex items-center gap-2 px-2">
              <field.icon className="w-3 h-3 text-slate-500" />
              <span className="text-[10px] uppercase tracking-widest font-bold text-slate-400">{field.label}</span>
            </label>
            <textarea
              value={reflection[field.id as keyof typeof reflection]}
              onChange={(e) => handleChange(field.id as keyof typeof reflection, e.target.value)}
              placeholder={field.placeholder}
              className="w-full bg-black/40 border border-white/5 rounded-[1.5rem] px-5 py-4 text-sm text-slate-200 focus:outline-none focus:border-white/10 transition-all min-h-[100px] resize-none placeholder:text-slate-700"
            />
          </div>
        ))}
      </div>

      {/* Shield Analysis Display */}
      <AnimatePresence>
        {analysis && (
          <motion.div 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -20 }}
            className="mt-8 p-6 bg-indigo-500/5 border border-indigo-500/20 rounded-[2rem] space-y-4"
          >
            <div className="flex items-center gap-3">
              <ShieldCheck className="w-5 h-5 text-indigo-400" />
              <p className="text-[10px] uppercase tracking-[0.2em] font-black text-indigo-300">Sanningens Sköld - Strategisk Analys</p>
            </div>
            <p className="text-sm text-slate-200 italic font-light leading-relaxed">
              "{analysis.masterInsight}"
            </p>
            <div className="flex flex-wrap gap-2">
              {analysis.groundingPoints.map((p, i) => (
                <div key={i} className="px-3 py-1 bg-white/5 rounded-full text-[8px] uppercase tracking-widest text-slate-400 border border-white/5">
                   ⚓ {p}
                </div>
              ))}
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <div className="mt-10 flex flex-col md:flex-row justify-center gap-4">
        <button 
          onClick={handleShieldAnalysis}
          disabled={isAnalyzing || !Object.values(reflection).some(v => v.trim())}
          className="px-8 py-4 bg-indigo-500/10 hover:bg-indigo-500/20 border border-indigo-500/20 rounded-full text-[10px] font-black uppercase tracking-[0.3em] text-indigo-300 transition-all active:scale-95 disabled:opacity-30 flex items-center justify-center gap-3"
        >
          {isAnalyzing ? <Loader2 className="w-4 h-4 animate-spin" /> : <ShieldCheck className="w-4 h-4" />}
          Strategisk Analys
        </button>

        <button 
          onClick={handleSave}
          className="px-12 py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full text-[10px] font-black uppercase tracking-[0.4em] text-white transition-all active:scale-95"
        >
          Spara Reflektion
        </button>
      </div>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/flow/RoutineCard.tsx">
import React, { useState } from 'react';
import { motion, useMotionValue, useTransform, AnimatePresence } from 'motion/react';
import { Check, Star, Zap, ChevronRight } from 'lucide-react';
import { cn } from '../../lib/utils';

interface RoutineCardProps {
  id: string;
  title: string;
  icon: React.ElementType;
  color: string;
  reward?: number;
  onComplete: (id: string, reward: number) => void;
}

export const RoutineCard: React.FC<RoutineCardProps> = ({ 
  id, title, icon: Icon, color, reward = 0, onComplete 
}) => {
  const [isCompleted, setIsCompleted] = useState(false);
  const x = useMotionValue(0);
  
  // Transform x position to background color and opacity for the "swipe" effect
  const backgroundOpacity = useTransform(x, [0, 150], [0.02, 0.1]);
  const checkOpacity = useTransform(x, [0, 100], [0, 1]);
  const checkScale = useTransform(x, [0, 100], [0.5, 1.2]);

  const handleDragEnd = (_: any, info: any) => {
    if (info.offset.x > 100 && !isCompleted) {
      setIsCompleted(true);
      onComplete(id, reward);
    }
  };

  return (
    <div className="relative group perspective-1000">
      <AnimatePresence mode="wait">
        {!isCompleted ? (
          <motion.div
            key="active"
            drag="x"
            dragConstraints={{ left: 0, right: 150 }}
            style={{ x }}
            onDragEnd={handleDragEnd}
            initial={{ opacity: 0, x: -20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, scale: 0.95 }}
            className="relative z-10 glass-card rounded-[2.5rem] p-8 cursor-grab active:cursor-grabbing shadow-2xl transition-all duration-500 hover:border-white/10"
          >
            <div className="flex items-center gap-6">
              <motion.div 
                style={{ backgroundColor: `${color}15`, borderColor: `${color}30` }}
                className="p-5 rounded-2xl border flex items-center justify-center transition-colors group-hover:bg-white/5"
              >
                <Icon className="w-8 h-8" style={{ color }} />
              </motion.div>
              
              <div className="flex-1">
                <h3 className="text-xl font-outfit font-light text-white tracking-tight">{title}</h3>
                {reward > 0 && (
                  <div className="flex items-center gap-2 mt-1.5">
                    <div className="px-2 py-0.5 bg-amber-500/10 rounded-full border border-amber-500/20">
                      <p className="text-[9px] uppercase tracking-widest text-amber-400 font-black flex items-center gap-1">
                        <Zap className="w-2.5 h-2.5" /> +{reward} SEK
                      </p>
                    </div>
                  </div>
                )}
              </div>

              <div className="flex flex-col items-center gap-1 opacity-20 group-hover:opacity-40 transition-opacity">
                <ChevronRight className="w-5 h-5 text-white" />
                <div className="w-1.5 h-6 bg-white/20 rounded-full" />
              </div>
            </div>

            {/* Hint for swiping */}
            <motion.div 
              style={{ opacity: checkOpacity, scale: checkScale }}
              className="absolute inset-0 bg-teal-500/10 rounded-[2.5rem] pointer-events-none flex items-center justify-end px-10"
            >
              <div className="w-14 h-14 bg-teal-500 rounded-full flex items-center justify-center shadow-[0_0_20px_rgba(45,212,191,0.5)]">
                <Check className="text-white w-8 h-8" strokeWidth={3} />
              </div>
            </motion.div>
          </motion.div>
        ) : (
          <motion.div
            key="completed"
            initial={{ scale: 0.9, opacity: 0, rotateX: -20 }}
            animate={{ scale: 1, opacity: 1, rotateX: 0 }}
            className="bg-teal-500/5 border border-teal-500/20 rounded-[2.5rem] p-8 flex items-center justify-between shadow-inner"
          >
            <div className="flex items-center gap-6 opacity-40">
              <div className="p-5 rounded-2xl bg-teal-500/10 border border-teal-500/20">
                <Check className="w-8 h-8 text-teal-400" />
              </div>
              <div>
                <h3 className="text-xl font-outfit font-light text-slate-400 line-through decoration-teal-500/40">{title}</h3>
                <p className="text-[9px] uppercase tracking-[0.3em] text-teal-500 font-black">Fullföljd & Arkiverad</p>
              </div>
            </div>
            
            <motion.div
              initial={{ rotate: -180, scale: 0 }}
              animate={{ rotate: 0, scale: 1 }}
              transition={{ type: "spring", damping: 10 }}
              className="text-amber-400"
            >
              <div className="relative">
                <Star className="w-10 h-10 fill-current shadow-amber-500/50" />
                <motion.div 
                  animate={{ scale: [1, 1.5], opacity: [1, 0] }}
                  transition={{ duration: 1, repeat: 1 }}
                  className="absolute inset-0 bg-amber-400 rounded-full blur-md"
                />
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/flow/RoutineFlow.tsx">
import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { RoutineCard } from './RoutineCard';
import { Moon, Dumbbell, Coffee, Target, Sparkles, TrendingUp, Trophy } from 'lucide-react';

export const RoutineFlow: React.FC = () => {
  const [totalSavings, setTotalSavings] = useState(0);
  const [completedCount, setCompletedCount] = useState(0);
  const goal = 5000; // Dream goal: 5000 SEK

  const routines = [
    { id: 'meditation', title: 'Meditation (10 min)', icon: Moon, color: 'rgb(129, 140, 248)', reward: 50 },
    { id: 'workout', title: 'Dagens Träning', icon: Dumbbell, color: 'rgb(45, 212, 191)', reward: 100 },
    { id: 'lunchbox', title: 'Gjort Matlåda', icon: Coffee, color: 'rgb(251, 146, 60)', reward: 120 },
  ];

  const handleComplete = (_id: string, reward: number) => {
    setTotalSavings(prev => prev + reward);
    setCompletedCount(prev => prev + 1);
  };

  const progress = (totalSavings / goal) * 100;
  const isFullyComplete = completedCount === routines.length;

  return (
    <div className="space-y-8 relative">
      {/* Background Zen Aura when complete */}
      <AnimatePresence>
        {isFullyComplete && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            className="absolute -inset-10 bg-teal-500/5 blur-[100px] rounded-full pointer-events-none -z-10"
          />
        )}
      </AnimatePresence>

      {/* Savings Progress Bar */}
      <div className="glass-card rounded-[3rem] p-10 shadow-2xl relative overflow-hidden group">
        <div className="absolute top-0 right-0 p-10 opacity-5 group-hover:opacity-10 transition-opacity">
          <Trophy className="w-32 h-32 text-white" />
        </div>

        <div className="relative z-10">
          <div className="flex justify-between items-end mb-6">
            <div>
              <p className="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-black mb-2">Mål: Semester-sparande</p>
              <h2 className="text-4xl font-outfit font-light text-white flex items-center gap-4">
                {totalSavings} <span className="text-lg text-slate-500 font-light">/ {goal} SEK</span>
              </h2>
            </div>
            <div className="text-right">
              <p className="text-[10px] uppercase tracking-[0.2em] text-teal-400 font-black mb-2">Dagens Flow</p>
              <div className="flex gap-2">
                {[...Array(routines.length)].map((_, i) => (
                  <motion.div 
                    key={i} 
                    animate={i < completedCount ? { scale: [1, 1.2, 1], backgroundColor: 'rgb(45, 212, 191)' } : {}}
                    className={`w-2 h-6 rounded-full ${i < completedCount ? 'bg-teal-400' : 'bg-slate-800'}`} 
                  />
                ))}
              </div>
            </div>
          </div>
          
          <div className="relative h-6 bg-slate-900/60 rounded-full overflow-hidden border border-white/5 p-1">
            <motion.div 
              initial={{ width: 0 }}
              animate={{ width: `${progress}%` }}
              className="h-full rounded-full bg-gradient-to-r from-indigo-500 via-teal-400 to-amber-400 shadow-[0_0_20px_rgba(45,212,191,0.5)]"
            />
            {/* Moving shine */}
            <motion.div 
              animate={{ x: ['-100%', '300%'] }}
              transition={{ duration: 4, repeat: Infinity, ease: "linear" }}
              className="absolute inset-y-0 w-32 bg-white/20 skew-x-12 blur-md"
            />
          </div>
          
          <div className="mt-6 flex items-center gap-3">
            <div className="p-2 bg-teal-500/10 rounded-lg">
              <TrendingUp className="w-4 h-4 text-teal-400" />
            </div>
            <p className="text-[10px] text-slate-400 italic uppercase tracking-widest font-bold">Varje rutin är ett steg mot din ekonomiska frihet.</p>
          </div>
        </div>
      </div>

      {/* Routine Cards Grid */}
      <div className="grid gap-6">
        {routines.map((routine) => (
          <RoutineCard
            key={routine.id}
            {...routine}
            onComplete={handleComplete}
          />
        ))}
      </div>

      <AnimatePresence>
        {isFullyComplete && (
          <motion.div
            initial={{ opacity: 0, scale: 0.9, y: 20 }}
            animate={{ opacity: 1, scale: 1, y: 0 }}
            className="p-10 glass-card border-teal-500/30 rounded-[3rem] text-center space-y-4"
          >
            <div className="w-20 h-20 bg-teal-500/10 rounded-[2.5rem] flex items-center justify-center mx-auto mb-4 border border-teal-500/20">
              <Sparkles className="w-10 h-10 text-teal-400 animate-pulse" />
            </div>
            <h3 className="text-3xl font-outfit font-light text-white tracking-tight">Full pott idag!</h3>
            <p className="text-[10px] text-teal-400 uppercase tracking-[0.3em] font-black">Du har säkrat +{routines.reduce((acc, r) => acc + r.reward, 0)} SEK till din framtid.</p>
            <p className="text-sm text-slate-400 font-inter italic max-w-xs mx-auto leading-relaxed">
              Ditt system är i harmoni. Passa på att vila eller gör något du älskar.
            </p>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
};
