import os
import json
import asyncio
from typing import List, Optional, Dict, Any
from fastapi import FastAPI, HTTPException, Request, BackgroundTasks
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel, Field

# Import utils (ADK-style for user compatibility)
from utils.adk import Agent, Gemini

# Import Agents
from agents.escalation_agent import EscalationAgent
from agents.crisis_agent import CrisisAgent
from agents.economic_agent import EconomicAgent
from agents.network_agent import NetworkAgent
from agents.report_agent import ReportAgent
from agents.legal_agent import LegalAgent
from agents.archive_agent import ArchiveAgent
from agents.chronos_agent import ChronosAgent
from agents.vagus_agent import VagusAgent
from services.vertex_service import VertexSearchService
from services.synapse_service import synapse_bus, SynapseEvent

from models.responses import (
    BaseIntelligenceResponse, 
    LegalAnalysisResponse, 
    EconomicAnalysisResponse, 
    ChildWellbeingResponse, 
    ComprehensiveReportResponse,
    ScheduleAnalysisResponse,
    BudgetAnalysisResponse
)


# Init App
app = FastAPI(title="LivsKompassen — Intelligence Hub")

# CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Models
pro_model = Gemini(model_name="gemini-1.5-pro")
flash_model = Gemini(model_name="gemini-1.5-flash")

PROJECT_ID = os.environ.get("GOOGLE_CLOUD_PROJECT")
DATA_STORE_ID = os.environ.get("VERTEX_DATA_STORE_ID")

# Services
vertex_service = VertexSearchService(
    project_id=PROJECT_ID,
    location="global",
    data_store_id=DATA_STORE_ID
)

# Initialize Deep Analysis Agents
escalation_agent = EscalationAgent()
crisis_agent = CrisisAgent()
economic_agent = EconomicAgent()
network_agent = NetworkAgent()
report_agent = ReportAgent()
legal_agent = LegalAgent()
archive_agent = ArchiveAgent()
chronos_agent = ChronosAgent()
vagus_agent = VagusAgent()

# Manual registration (though base_agent handles it if AGENT_ID is present, 
# explicit is better for the orchestrator)
synapse_bus.register_agent("chronos", chronos_agent)
synapse_bus.register_agent("vagus", vagus_agent)
synapse_bus.register_agent("legal", legal_agent)
synapse_bus.register_agent("escalation", escalation_agent)

# --- UTILS ---

def sanitize_json_response(text: str) -> Dict[str, Any]:
    """Strips Markdown backticks and ensures valid JSON from LLM output."""
    try:
        # Remove markdown code blocks if present
        clean_text = text.strip()
        if clean_text.startswith("```"):
            clean_text = clean_text.split("```")[1]
            if clean_text.startswith("json"):
                clean_text = clean_text[4:]
            clean_text = clean_text.split("```")[0].strip()
        
        return json.loads(clean_text)
    except Exception as e:
        # Fallback if parsing fails
        return {
            "error": "Malformed Intelligence Response",
            "raw": text[:200],
            "status": "PARTIAL_FAIL",
            "masterInsight": "Systemet kunde inte tyda analysen fullt ut.",
            "groundingPoints": ["Tekniskt fel vid parsing"]
        }

# --- MODELS ---

class AnalysisRequest(BaseModel):
    content: str = Field(..., description="The text or data to analyze")
    mode: str = Field("DEFAULT", description="The analysis module/mode")
    context: Optional[Dict[str, Any]] = None

class LegalRequest(BaseModel):
    data: Dict[str, Any]

class BiffRequest(BaseModel):
    content: str

# Job Store (In-memory for now)
jobs = {}

# --- SMART ORCHESTRATION AGENTS ---

orchestrator = Agent(
    name="system-orchestrator",
    model=pro_model,
    instruction="""
    Du är hjärnan i LivsKompassen. Din uppgift är att:
    1. Analysera användarens input och identifiera kognitiv belastning eller affekt.
    2. Upptäcka manipulation, gaslighting eller härskartekniker i inkommande text.
    3. Koordinera svaret genom att använda fakta från kontexten (RAG).
    4. Ge ett svar som minimerar framtida konflikt och maximerar användarens lugn.
    Svara ALLTID i strikt JSON-format.
    """
)

biff_expert = Agent(
    name="biff-expert",
    model=flash_model,
    instruction="""
    Skapa ett Brief, Informative, Friendly, Firm svar baserat på BIFF-Väktaren principen. 
    Lågaffektivt bemötande är prioriterat.
    """
)

@app.get("/")
async def root():
    return {"status": "ACTIVE", "hub": "LivsKompassen Intelligence"}

@app.get("/job/{job_id}")
async def get_job(job_id: str):
    if job_id not in jobs:
        raise HTTPException(status_code=404, detail="Job not found")
    return jobs[job_id]

async def run_analysis_task(job_id: str, request: AnalysisRequest):
    try:
        content = request.content
        mode = request.mode
        
        # 1. Get RAG context
        try:
            grounding = await vertex_service.search(content if content else mode)
            grounding_text = "\n".join(grounding) if grounding else "Ingen kontext hittades."
        except Exception:
            grounding_text = "Vertex Search ej tillgänglig."
        
        prompt = f"""
        KONTEXT: {grounding_text}
        SITUATION: {content}
        MODUL: {mode}
        
        Gör en strategisk bedömning. Returnera JSON med formatet:
        {{ "masterInsight": "...", "severity": "LÅG/MEDEL/HÖG", "detectedTactics": [], "groundingPoints": [], "recommendedActions": [] }}
        """
        res = orchestrator.run(prompt)
        data = sanitize_json_response(res.text)
        
        # Validation
        try:
            validated_data = BaseIntelligenceResponse(**data).dict()
            jobs[job_id] = {"id": job_id, "status": "COMPLETED", "result": validated_data}
        except Exception:
            # Fallback to sanitized data if validation fails
            jobs[job_id] = {"id": job_id, "status": "COMPLETED", "result": data}
            
    except Exception as e:
        jobs[job_id] = {"id": job_id, "status": "FAILED", "error": str(e)}

@app.post("/analyze")
async def analyze(request: AnalysisRequest, background_tasks: BackgroundTasks):
    job_id = f"job_{os.urandom(4).hex()}"
    jobs[job_id] = {"id": job_id, "status": "PENDING", "result": None}
    background_tasks.add_task(run_analysis_task, job_id, request)
    return {"job_id": job_id, "status": "ACCEPTED"}

@app.post("/analyze/legal")
async def analyze_legal(request: LegalRequest):
    try:
