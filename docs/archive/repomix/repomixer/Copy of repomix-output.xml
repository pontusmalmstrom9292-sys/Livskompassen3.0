import React, { useMemo } from 'react';
import { motion } from 'motion/react';
import { NetworkMember } from '../types';
import { RadarEvent } from '../services/radarService';
import { Shield, AlertTriangle, Heart, Star, Users } from 'lucide-react';

interface NetworkMapProps {
  members: NetworkMember[];
  events?: RadarEvent[];
  onSelectMember: (member: NetworkMember) => void;
}

export const NetworkMap = ({ members, events = [], onSelectMember }: NetworkMapProps) => {
  const centerX = 200;
  const centerY = 200;

  // Beräkna positioner för medlemmar
  const nodes = useMemo(() => {
    return members.map((m, i) => {
      const angle = (i / members.length) * 2 * Math.PI;
      
      let radius = 140; 
      const rLevel = m.riskLevel || (m.isAlly ? 2 : 7);

      if (m.isAlly) {
        radius = 60 + (rLevel * 7); 
      } else {
        radius = 140 + (rLevel * 6);
      }

      const x = centerX + radius * Math.cos(angle);
      const y = centerY + radius * Math.sin(angle);

      return { ...m, x, y };
    });
  }, [members]);

  // Beräkna "Sentiment Strings" (relationer mellan aktörer)
  const links = useMemo(() => {
    const connections: { source: any, target: any, weight: number }[] = [];
    
    // Räkna co-occurrences i events
    const coOccurrences: Record<string, number> = {};
    
    events.forEach(event => {
      if (!event.involvedActors || event.involvedActors.length < 2) return;
      
      for (let i = 0; i < event.involvedActors.length; i++) {
        for (let j = i + 1; j < event.involvedActors.length; j++) {
          const a = event.involvedActors[i];
          const b = event.involvedActors[j];
          const key = [a, b].sort().join('-');
          coOccurrences[key] = (coOccurrences[key] || 0) + 1;
        }
      }
    });

    // Skapa länkar för de noder som finns i kartan
    Object.entries(coOccurrences).forEach(([key, weight]) => {
      const [id1, id2] = key.split('-');
      const node1 = nodes.find(n => n.id === id1);
      const node2 = nodes.find(n => n.id === id2);
      
      if (node1 && node2) {
        connections.push({ source: node1, target: node2, weight });
      }
    });

    return connections;
  }, [nodes, events]);

  return (
    <div className="relative w-full aspect-square max-w-[500px] mx-auto bg-[#020617]/50 rounded-[3rem] border border-white/5 overflow-hidden shadow-2xl backdrop-blur-xl">
      {/* Bakgrunds-radar-cirklar */}
      <svg className="absolute inset-0 w-full h-full opacity-10 pointer-events-none">
        <circle cx={centerX} cy={centerY} r="60" stroke="#d4af37" strokeWidth="1" fill="none" />
        <circle cx={centerX} cy={centerY} r="120" stroke="#d4af37" strokeWidth="0.5" fill="none" />
        <circle cx={centerX} cy={centerY} r="180" stroke="#ef4444" strokeWidth="0.5" strokeDasharray="4 4" fill="none" />
      </svg>

      {/* Centrum-nod (DU) */}
      <div 
        className="absolute w-12 h-12 bg-gradient-to-tr from-[#d4af37] to-[#fde68a] rounded-full flex items-center justify-center shadow-[0_0_30px_rgba(212,175,55,0.4)] z-20 border-2 border-[#020617]"
        style={{ left: centerX - 24, top: centerY - 24 }}
      >
        <Shield className="w-6 h-6 text-[#0b3d2e]" />
      </div>

      <svg className="absolute inset-0 w-full h-full pointer-events-none z-10">
        {/* Sentiment Strings (Relationer mellan aktörer) */}
        {links.map((link, i) => {
          // Curved path
          const midX = (link.source.x + link.target.x) / 2;
          const midY = (link.source.y + link.target.y) / 2;
          // Offset control point slightly to make a curve
          const cx = midX + (link.source.y - link.target.y) * 0.2;
          const cy = midY - (link.source.x - link.target.x) * 0.2;
          
          return (
            <motion.path
              key={`link-${i}`}
              initial={{ pathLength: 0, opacity: 0 }}
              animate={{ pathLength: 1, opacity: Math.min(0.1 + link.weight * 0.1, 0.6) }}
              d={`M ${link.source.x} ${link.source.y} Q ${cx} ${cy} ${link.target.x} ${link.target.y}`}
              stroke="#818cf8" // Indigo-400
              strokeWidth={Math.min(1 + link.weight * 0.5, 4)}
              strokeDasharray="4 4"
              fill="none"
            />
          );
        })}
      </svg>

      {/* Nätverks-noder */}
      {nodes.map((node) => (
        <React.Fragment key={node.id}>
          {/* Linje till centrum */}
          <svg className="absolute inset-0 w-full h-full pointer-events-none z-0">
            <motion.line
              initial={{ pathLength: 0, opacity: 0 }}
              animate={{ pathLength: 1, opacity: 0.2 }}
              x1={centerX}
              y1={centerY}
              x2={node.x}
              y2={node.y}
              stroke={node.isAlly ? "#d4af37" : "#ef4444"}
              strokeWidth="1"
            />
          </svg>

          {/* Själva noden */}
          <motion.button
            initial={{ scale: 0, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            whileHover={{ scale: 1.2, zIndex: 30 }}
            onClick={() => onSelectMember(node)}
            className={`absolute w-10 h-10 rounded-xl flex items-center justify-center border transition-all cursor-pointer shadow-lg z-20 ${
              node.isAlly 
                ? 'bg-[#0b3d2e] border-[#d4af37]/30 text-[#d4af37]' 
                : 'bg-red-950/40 border-red-500/30 text-red-400'
            }`}
            style={{ left: node.x - 20, top: node.y - 20 }}
          >
            {node.isAlly ? <Heart className="w-5 h-5" /> : <AlertTriangle className="w-5 h-5" />}
            
            {/* Namn-etikett (syns vid hovring eller liten text under) */}
            <div className="absolute -bottom-6 left-1/2 -translate-x-1/2 whitespace-nowrap">
              <span className="text-[8px] font-bold uppercase tracking-widest text-white/40 group-hover:text-white transition-colors">
                {node.name.split(' ')[0]}
              </span>
            </div>
          </motion.button>
        </React.Fragment>
      ))}

      {/* Legendar / Info */}
      <div className="absolute bottom-6 left-6 right-6 flex justify-between items-center pointer-events-none z-30">
        <div className="flex gap-4 flex-wrap">
          <div className="flex items-center gap-2">
            <div className="w-2 h-2 rounded-full bg-[#d4af37]" />
            <span className="text-[8px] uppercase tracking-widest text-white/30 font-bold">Allierade</span>
          </div>
          <div className="flex items-center gap-2">
            <div className="w-2 h-2 rounded-full bg-red-500" />
            <span className="text-[8px] uppercase tracking-widest text-white/30 font-bold">Risker</span>
          </div>
          <div className="flex items-center gap-2">
            <div className="w-2 h-0.5 border-t-2 border-dashed border-indigo-400/50" />
            <span className="text-[8px] uppercase tracking-widest text-white/30 font-bold">Sentiment String (Relationer)</span>
          </div>
        </div>
      </div>
    </div>
  );
};
</file>

