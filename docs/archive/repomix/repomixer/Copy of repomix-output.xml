# Använd Node 20 som bas
FROM node:20-slim

# Installera verktyg för att bygga (om det behövs)
RUN apt-get update && apt-get install -y python3 make g++ && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Kopiera beroenden
COPY package*.json ./
RUN npm install

# Kopiera resten av koden
COPY . .

# Bygg frontend
RUN npm run build

# Exponera porten (Cloud Run använder 8080 som standard)
EXPOSE 8080

# Sätt miljövariabel för produktion
ENV NODE_ENV=production

# Starta servern med tsx (eftersom vi kör server.ts direkt)
# Notera: I en skarp produktionsmiljö skulle vi kompilera till JS, 
# men för LivsKompassen fungerar tsx utmärkt och bibehåller flexibilitet.
CMD ["npx", "tsx", "server.ts"]
</file>

