import React, { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Calendar, Clock, CheckCircle2, AlertCircle, Sparkles, Brain, ListTodo, Plus, ChevronRight } from 'lucide-react';
import { cn } from '../lib/utils';

interface Task {
  id: string;
  title: string;
  time: string;
  completed: boolean;
  priority: 'HÖG' | 'MEDEL' | 'LÅG';
  brainEnergy: number; // 1-10, how much cognitive load
}

export const ScheduleAssistant = () => {
  const [tasks, setTasks] = useState<Task[]>([
    { id: '1', title: 'Hämta på förskolan', time: '15:30', completed: false, priority: 'HÖG', brainEnergy: 6 },
    { id: '2', title: 'Förbered BIFF-svar till advokat', time: '10:00', completed: true, priority: 'HÖG', brainEnergy: 9 },
    { id: '3', title: 'Vagus-stimulering (3 min)', time: '08:00', completed: false, priority: 'MEDEL', brainEnergy: 1 },
  ]);

  const totalBrainLoad = tasks.filter(t => !t.completed).reduce((acc, t) => acc + t.brainEnergy, 0);

  return (
    <div className="space-y-8 animate-in fade-in duration-700">
      <div className="bg-indigo-500/5 border border-indigo-500/10 rounded-[3rem] p-12 relative overflow-hidden">
        <div className="absolute top-0 right-0 p-16 opacity-[0.03]">
          <Calendar className="w-64 h-64 text-indigo-400" />
        </div>

        <div className="relative z-10 space-y-10">
          <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
            <div className="space-y-2">
              <h3 className="text-3xl text-white font-outfit font-light tracking-tight">Kognitivt Schema</h3>
              <p className="text-[10px] text-indigo-400 uppercase tracking-[0.4em] font-black">ADHD-Anpassad Struktur & Energihantering</p>
            </div>
            
            <div className="flex items-center gap-6 px-8 py-4 bg-black/40 border border-white/5 rounded-2xl shadow-xl">
              <div className="text-center">
                <p className="text-[8px] text-slate-500 uppercase font-black mb-1">Dagens Belastning</p>
                <p className={cn(
                  "text-xl font-bold font-outfit",
                  totalBrainLoad > 15 ? "text-rose-400" : "text-teal-400"
                )}>{totalBrainLoad}/20 CP</p>
              </div>
              <div className="w-px h-10 bg-white/10" />
              <Brain className={cn(
                "w-8 h-8",
                totalBrainLoad > 15 ? "text-rose-500 animate-pulse" : "text-teal-500"
              )} />
            </div>
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
            {/* Energy Meter */}
            <div className="lg:col-span-1 p-8 bg-black/40 border border-white/5 rounded-[2.5rem] space-y-8">
              <h4 className="text-xs font-black text-slate-500 uppercase tracking-widest flex items-center gap-3">
                <Sparkles className="w-4 h-4 text-indigo-400" />
                AI-Rekommendation
              </h4>
              
              <div className="space-y-6">
                <p className="text-sm text-slate-300 leading-relaxed italic font-inter">
                  "Din kognitiva belastning är hög idag. Jag rekommenderar att flytta 'Förbered BIFF-svar' till imorgon bitti när din dopaminnivå är stabilare."
                </p>
                <button className="w-full py-4 bg-indigo-600/20 border border-indigo-600/30 text-indigo-300 rounded-xl text-[10px] font-black uppercase tracking-widest hover:bg-indigo-600/30 transition-all">
                  Optimera Schema
                </button>
              </div>

              <div className="pt-6 border-t border-white/5 space-y-4">
                 <div className="flex justify-between items-center text-[10px] uppercase font-bold text-slate-500">
                    <span>Vagus-status</span>
                    <span className="text-teal-400">Reglerad</span>
                 </div>
                 <div className="h-1.5 w-full bg-white/5 rounded-full overflow-hidden">
                    <motion.div 
                      initial={{ width: 0 }}
                      animate={{ width: '85%' }}
                      className="h-full bg-teal-500"
                    />
                 </div>
              </div>
            </div>

            {/* Task List */}
            <div className="lg:col-span-2 space-y-4">
               <div className="flex justify-between items-center mb-4 px-4">
                  <h4 className="text-xs font-black text-slate-500 uppercase tracking-widest">Dagens Fokus</h4>
                  <button className="p-2 bg-indigo-500/10 rounded-lg border border-indigo-500/20 text-indigo-400">
                     <Plus className="w-4 h-4" />
                  </button>
               </div>

               <div className="space-y-3">
                  {tasks.map(task => (
                    <motion.div
                      key={task.id}
                      layout
                      className={cn(
                        "p-6 rounded-[2rem] border transition-all flex items-center justify-between group",
                        task.completed 
                          ? "bg-slate-900/20 border-white/5 opacity-50" 
                          : "bg-white/[0.02] border-white/10 hover:border-indigo-500/30"
                      )}
                    >
                      <div className="flex items-center gap-6">
                        <button 
                          onClick={() => setTasks(tasks.map(t => t.id === task.id ? {...t, completed: !t.completed} : t))}
                          className={cn(
                            "w-8 h-8 rounded-full border flex items-center justify-center transition-all",
                            task.completed ? "bg-teal-500 border-teal-400 text-obsidian" : "border-white/20 hover:border-indigo-400"
                          )}
                        >
                          {task.completed && <CheckCircle2 className="w-5 h-5" />}
