import os
import json
from typing import List, Dict, Any, Optional
import vertexai
from vertexai.generative_models import GenerativeModel, GenerationConfig, SafetySetting
from google.cloud import discoveryengine_v1 as discoveryengine
from utils.json_utils import SafeJSONParser
from services.synapse_service import synapse_bus, SynapseEvent


class BaseAgent:
    """
    Abstrakt bas för alla agenter.
    Hanterar Vertex AI-initiering, Vertex Search-jordning och standardiserat JSON-svar.
    """
    AGENT_NAME = "Base Agent"
    AGENT_ROLE = "Generalist"

    def __init__(self):
        project_id = os.getenv("GCP_PROJECT_ID")
        location = os.getenv("GCP_LOCATION", "us-central1")
        self.data_store_id = os.getenv("VERTEX_DATA_STORE_ID")
        self.project_id = project_id

        vertexai.init(project=project_id, location=location)
        self.model = GenerativeModel("gemini-1.5-pro")

        self.search_client = discoveryengine.SearchServiceClient()

        self.generation_config = GenerationConfig(
            response_mime_type="application/json",
            temperature=0.2,  # Låg temp = mer deterministisk, fakta-fokuserad
            max_output_tokens=2048,
        )
        self.safety_settings = [
            SafetySetting(
                category=SafetySetting.HarmCategory.HARM_CATEGORY_HARASSMENT,
                threshold=SafetySetting.HarmBlockThreshold.BLOCK_NONE,
            ),
        ]
        self.bus = synapse_bus
        # Register self to bus if AGENT_ID is defined (overridden by subclasses)
        if hasattr(self, 'AGENT_ID'):
            self.bus.register_agent(self.AGENT_ID, self)

    async def emit_synapse(self, event_type: str, payload: Dict[str, Any]) -> Any:
        """Emits an event to the global synapse bus."""
        event = SynapseEvent(sender=self.AGENT_NAME, event_type=event_type, payload=payload)
        return await self.bus.emit(event)

    async def query_agent(self, target: str, data: Dict[str, Any]) -> Optional[Dict]:
        """Directly queries another agent for collaborative analysis."""
        return await self.bus.ask_agent(target, data)

    async def handle_synapse(self, payload: Dict[str, Any]) -> Dict:
        """Handler for incoming synapse events. Should be overridden by subclasses."""
        return await self.analyze(payload)


    async def _ground_with_vertex_search(self, query: str) -> List[str]:
        """
        Hämtar jordnings-information från Vertex AI Search Data Store.
        Använder GenAI App Builder-krediter.
        """
        if not self.project_id or not self.data_store_id:
            return ["[Jordning inaktiverad - konfigurera GCP_PROJECT_ID och VERTEX_DATA_STORE_ID]"]

        try:
            serving_config = f"projects/{self.project_id}/locations/global/dataStores/{self.data_store_id}/servingConfigs/default_config"

            request = discoveryengine.SearchRequest(
                serving_config=serving_config,
                query=query,
                page_size=5,
                content_search_spec=discoveryengine.SearchRequest.ContentSearchSpec(
                    summary_spec=discoveryengine.SearchRequest.ContentSearchSpec.SummarySpec(
                        summary_result_count=5,
                        include_citations=True,
                        use_semantic_chunks=True,
                    )
                ),
            )

            response = self.search_client.search(request)
            grounding_points = []

            if response.summary and response.summary.summary_text:
                grounding_points.append(response.summary.summary_text)

            for result in response.results:
                if hasattr(result.document, "derived_struct_data"):
                    snippets = result.document.derived_struct_data.get("snippets", [])
                    for s in snippets:
                        if s.get("snippet"):
                            grounding_points.append(s["snippet"])

            return grounding_points[:5] if grounding_points else ["Inga jordningspunkter hittades."]

        except Exception as e:
            return [f"Vertex Search-fel: {str(e)}"]

    def _call_model(self, prompt: str) -> Dict:
        """Kör Vertex AI-modellen och parsar JSON-svar."""
        response = self.model.generate_content(
            prompt,
            generation_config=self.generation_config,
            safety_settings=self.safety_settings,
        )
        return SafeJSONParser.parse(response.text)

    async def analyze(self, data: Dict[str, Any]) -> Dict:
        """Överskrivs av varje specialiserad agent."""
        raise NotImplementedError("Varje agent måste implementera analyze()")

    def _build_context_block(self, grounding_points: List[str]) -> str:
        """Formaterar jordningspunkter till ett tydligt kontextblock."""
        return "\n".join([f"  [{i+1}] {p}" for i, p in enumerate(grounding_points)])
