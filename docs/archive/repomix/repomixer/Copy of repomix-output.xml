import { motion, AnimatePresence } from 'motion/react';
import { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { KBDocument } from '../types';
import { geminiService } from '../services/geminiService';
import { Button } from '../components/ui/button';
import { cn } from '../lib/utils';
import Markdown from 'react-markdown';

interface KnowledgePageProps {
  user: any;
}

export function KnowledgePage({ user }: KnowledgePageProps) {
  const [searchQuery, setSearchQuery] = useState('');
  const [documents, setDocuments] = useState<KBDocument[]>([]);
  const [selectedDoc, setSelectedDoc] = useState<KBDocument | null>(null);
  const [isCreating, setIsCreating] = useState(false);
  const [isGenerating, setIsGenerating] = useState(false);
  const [isAnalysingIntense, setIsAnalysingIntense] = useState(false);
  const [analysisResult, setAnalysisResult] = useState<any | null>(null);
  const [newDoc, setNewDoc] = useState({ title: '', content: '', folderId: 'arkiv' });

  useEffect(() => {
    if (!user) return;

    const q = query(
      collection(db, 'kb_docs'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribe = onSnapshot(q, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      } as KBDocument));
      setDocuments(docs);
    }, (error) => {
      console.error("Knowledge docs listen error", error);
    });

    return unsubscribe;
  }, [user]);

  const handleSaveDoc = async () => {
    if (!newDoc.title || !newDoc.content || !user) return;
    try {
      // Intelligens-Agenten klassificerar automatiskt
      const { folderId, importance, tags } = await geminiService.classifyDocument(newDoc.content);
      
      await addDoc(collection(db, 'kb_docs'), {
        ...newDoc,
        folderId,
        importance,
        tags,
        userId: user.uid,
        createdAt: serverTimestamp()
      });
      setIsCreating(false);
      setNewDoc({ title: '', content: '', folderId: 'ARKIV' });
    } catch (e) {
      console.error("Error saving doc", e);
    }
  };

  const generateDossier = async (agentName: string) => {
    setIsGenerating(true);
    try {
      const dossier = await geminiService.generateTechnicalDossier(agentName, "Systemkontext: LivsKompassen V3.1. Fokus på strategiskt försvar.");
      setNewDoc({
        title: `Teknisk Analys: ${agentName}`,
        content: dossier,
        folderId: 'arkiv'
      });
      setIsCreating(true);
    } catch (e) {
      console.error("Dossier generation failed", e);
    } finally {
      setIsGenerating(false);
    }
  };

  const handleIntenseAnalysis = async () => {
    if (!newDoc.content) return;
    setIsAnalysingIntense(true);
    setAnalysisResult(null);
