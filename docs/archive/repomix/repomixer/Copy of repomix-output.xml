<file path="livskompassen-trasig-1/src/components/flow/TheBuddy.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { MessageCircle, Sparkles, X, Heart, Shield, Zap, Smile, AlertTriangle, Target, Wallet } from 'lucide-react';
import { cn } from '../../lib/utils';
import { useSystemMemory, IntelligencePost } from '../../contexts/SystemMemoryContext';

export const TheBuddy: React.FC = () => {
  const { intelligenceFeed } = useSystemMemory();
  const [isOpen, setIsOpen] = useState(false);
  const [message, setMessage] = useState<string | null>(null);
  const [moodColor, setMoodColor] = useState('#818CF8');
  const [activePost, setActivePost] = useState<IntelligencePost | null>(null);

  // Listen to Intelligence Feed
  useEffect(() => {
    if (intelligenceFeed.length > 0) {
      const latest = intelligenceFeed[0];
      if (latest.priority === 'HIGH') {
        setMessage(latest.message);
        setActivePost(latest);
        setIsOpen(true);
      }
    }
  }, [intelligenceFeed]);

  // Sync with App Mood
  useEffect(() => {
    const root = document.documentElement;
    const color = getComputedStyle(root).getPropertyValue('--app-mood-color').trim();
    if (color) setMoodColor(color);

    // Observer for CSS variable changes
    const observer = new MutationObserver(() => {
      const newColor = getComputedStyle(root).getPropertyValue('--app-mood-color').trim();
      if (newColor) setMoodColor(newColor);
    });

    observer.observe(root, { attributes: true, attributeFilter: ['style'] });
    return () => observer.disconnect();
  }, []);

  const analyzeJournalEntry = (text: string) => {
    const stressKeywords = ['stress', 'tuff', 'svårt', 'jobbigt', 'ångest', 'bråk', 'skit'];
    const successKeywords = ['klar', 'fixat', 'bra', 'stolt', 'vinst', 'sparade', 'tacksam'];

    if (stressKeywords.some(word => text.toLowerCase().includes(word))) {
      return "Jag ser att du har det tufft. Ta ett djupt andetag med mig. Du är inte ensam i detta.";
    }
    if (successKeywords.some(word => text.toLowerCase().includes(word))) {
      return "Vilken fantastisk vinst! Kom ihåg den här känslan – det är du som skapar detta.";
    }
    return "Jag finns här. Behöver du landa i nuet eller bara ventilera lite?";
  };

  useEffect(() => {
    const handleJournalSave = (e: any) => {
      const msg = analyzeJournalEntry(e.detail.text);
      setMessage(msg);
      setIsOpen(true);
    };

    window.addEventListener('journal-saved', handleJournalSave);
    return () => window.removeEventListener('journal-saved', handleJournalSave);
  }, []);

  return (
    <div className="fixed bottom-32 right-8 z-50">
      <AnimatePresence>
        {isOpen && (
          <motion.div
            initial={{ opacity: 0, scale: 0.8, y: 20, x: 20 }}
            animate={{ opacity: 1, scale: 1, y: 0, x: 0 }}
            exit={{ opacity: 0, scale: 0.8, y: 20, x: 20 }}
            className="absolute bottom-24 right-0 w-80 glass-card rounded-[2.5rem] p-8 shadow-2xl border-indigo-500/20"
          >
            <div className="flex justify-between items-start mb-6">
              <div className="flex items-center gap-2" style={{ color: moodColor }}>
                <Sparkles className="w-4 h-4 animate-pulse" />
                <span className="text-[10px] uppercase font-black tracking-[0.2em]">The Buddy</span>
              </div>
              <button onClick={() => setIsOpen(false)} className="p-2 hover:bg-white/5 rounded-xl transition-colors">
                <X className="w-4 h-4 text-slate-500" />
              </button>
            </div>
            
            <p className="text-base text-slate-200 leading-relaxed font-light italic font-outfit">
              "{message || 'Hur mår du egentligen? Jag lyssnar.'}"
            </p>
            
            <div className="mt-8 pt-6 border-t border-white/5 flex gap-3">
              <button className="flex-1 py-3 rounded-2xl bg-white/5 hover:bg-white/10 text-[9px] uppercase font-black tracking-widest text-slate-400 transition-all">
                Tack, jag är ok
              </button>
              <button className="p-3 bg-white/5 hover:bg-white/10 rounded-2xl transition-all">
                <Smile className="w-4 h-4 text-slate-400" />
              </button>
            </div>
          </motion.div>
        )}
      </AnimatePresence>

      <motion.button
        animate={{ 
          scale: [1, 1.05, 1],
          boxShadow: [
            `0 0 20px ${moodColor}20`,
            `0 0 40px ${moodColor}40`,
            `0 0 20px ${moodColor}20`
          ]
        }}
        transition={{ duration: 4, repeat: Infinity, ease: "easeInOut" }}
        whileHover={{ scale: 1.1 }}
        whileTap={{ scale: 0.9 }}
        onClick={() => setIsOpen(!isOpen)}
        className="w-20 h-20 rounded-[2.5rem] flex items-center justify-center text-white shadow-2xl relative overflow-hidden group transition-colors duration-1000"
        style={{ backgroundColor: moodColor }}
      >
        <div className="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity" />
        <motion.div
          animate={isOpen ? { rotate: 180 } : { rotate: 0 }}
        >
          {isOpen ? <X className="w-8 h-8" /> : <MessageCircle className="w-8 h-8" />}
        </motion.div>
        
        {/* Breathing Ring */}
        <motion.div 
          animate={{ scale: [1, 1.5], opacity: [0.5, 0] }}
          transition={{ duration: 2, repeat: Infinity }}
          className="absolute inset-0 rounded-[2.5rem] border-4 border-white/30 pointer-events-none"
        />

        {message && !isOpen && (
          <div className="absolute top-4 right-4 w-4 h-4 bg-rose-500 border-4 border-obsidian rounded-full" />
        )}
      </motion.button>
    </div>
  );
};
</file>

<file path="livskompassen-trasig-1/src/components/layout/BottomNav.tsx">
