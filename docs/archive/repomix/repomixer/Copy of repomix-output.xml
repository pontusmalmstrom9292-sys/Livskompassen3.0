import asyncio
import time
from typing import Dict, Any, List, Optional, Callable
import logging

class SynapseEvent:
    def __init__(self, sender: str, event_type: str, payload: Dict[str, Any]):
        self.sender = sender
        self.event_type = event_type
        self.payload = payload
        self.timestamp = time.time()
        self.response = None

class SynapseBus:
    """
    Intelligence Bus (Synapse) - Facilitates inter-agent communication.
    Uses a subscription model and history-aware routing.
    """
    def __init__(self):
        self.agents = {}
        self.subscribers: Dict[str, List[Callable]] = {}
        self.history = []
        self.logger = logging.getLogger("SynapseBus")

    def register_agent(self, name: str, agent_instance: Any):
        self.agents[name.lower()] = agent_instance
        self.logger.info(f"Agent '{name}' registered to Synapse Bus.")

    def subscribe(self, event_type: str, callback: Callable):
        """Allows an agent or service to listen for specific events."""
        if event_type not in self.subscribers:
            self.subscribers[event_type] = []
        self.subscribers[event_type].append(callback)
        self.logger.info(f"New subscription for event type: {event_type}")

    async def emit(self, event: SynapseEvent) -> List[Any]:
        """Emits an event and triggers all subscribers."""
        self.history.append({
            "sender": event.sender,
            "type": event.event_type,
            "payload": event.payload,
            "timestamp": event.timestamp
        })
        
        # Keep history manageable (last 100 events)
        if len(self.history) > 100:
            self.history = self.history[-100:]
            
        responses = []
        
        # 1. Trigger explicit subscribers
        if event.event_type in self.subscribers:
            tasks = [callback(event.payload) for callback in self.subscribers[event.event_type]]
            responses = await asyncio.gather(*tasks)
            
        # 2. Handle known Synapse Mappings
        target_mapping = {
            "LEGAL_CHECK": "legal",
            "ESCALATION_CHECK": "escalation",
            "CRISIS_CHECK": "crisis",
            "VIBE_CHECK": "vagus",
            "TACTICAL_ADVICE": "tactical",
            "TIME_ANALYSIS": "chronos",
            "REALITY_CHECK": "reality_mirror"
        }
        
        if event.event_type in target_mapping:
            agent_name = target_mapping[event.event_type]
            res = await self.ask_agent(agent_name, event.payload)
            if res:
                responses.append(res)
            
        return responses

    async def ask_agent(self, target_agent: str, query_data: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        """Directly query another agent via the bus."""
        target_agent = target_agent.lower()
        if target_agent in self.agents:
            self.logger.info(f"Synapse: {target_agent} queried for data.")
            try:
                agent = self.agents[target_agent]
                # Try .analyze (BaseAgent style) first
                if hasattr(agent, 'analyze'):
                    if asyncio.iscoroutinefunction(agent.analyze):
                        return await agent.analyze(query_data)
                    else:
                        return agent.analyze(query_data)
                # Try .run (ADK Agent style) next
                elif hasattr(agent, 'run'):
                    # ADK agents expect a string prompt usually, but we try to be smart
                    prompt = f"ANALYSIS REQUEST: {query_data}"
                    res = agent.run(prompt)
                    return res.text if hasattr(res, 'text') else res
            except Exception as e:
                self.logger.error(f"Synapse Query Error ({target_agent}): {e}")
                return {"error": str(e)}
        return None

    def get_history(self, limit: int = 10) -> List[Dict]:
        """Returns the recent event history for context grounding."""
        return self.history[-limit:]

# Singleton instance
synapse_bus = SynapseBus()
