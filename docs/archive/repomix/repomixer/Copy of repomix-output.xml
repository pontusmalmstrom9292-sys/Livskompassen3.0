            <h3 className="text-[10px] font-bold uppercase tracking-widest">Dynamiska Sparmål</h3>
          </div>
          <button 
            onClick={() => setShowAddSavings(!showAddSavings)}
            className="text-[10px] uppercase font-bold text-gold border-b border-gold/20 hover:border-gold transition-colors"
          >
            {showAddSavings ? 'Avbryt' : 'Nytt Mål'}
