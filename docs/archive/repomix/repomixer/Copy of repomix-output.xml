import { shieldApi } from './apiService';

type AgentStatus = 'HEALTHY' | 'DEGRADED' | 'FAILED';

interface AgentHealth {
  id: string;
  status: AgentStatus;
  errorCount: number;
  lastErrorTime?: number;
}

class CircuitBreaker {
  private healthMap: Map<string, AgentHealth> = new Map();
  private readonly ERROR_THRESHOLD = 5;
  private readonly RECOVERY_TIME_MS = 60000; // 1 minute

  constructor() {
    this.initializeAgents();
  }

  private initializeAgents() {
    ['escalation', 'crisis', 'economic', 'network', 'report'].forEach(id => {
      this.healthMap.set(id, { id, status: 'HEALTHY', errorCount: 0 });
    });
  }

  public async execute<T>(agentId: string, action: () => Promise<T>): Promise<T> {
    const health = this.healthMap.get(agentId);
    
    if (health && health.status === 'FAILED') {
      const now = Date.now();
      if (health.lastErrorTime && now - health.lastErrorTime > this.RECOVERY_TIME_MS) {
        console.log(`[CircuitBreaker] Attempting recovery for agent: ${agentId}`);
        health.status = 'DEGRADED';
      } else {
        throw new Error(`Agent ${agentId} is currently offline for safety (Circuit Breaker active).`);
      }
    }

    try {
      const result = await action();
      this.recordSuccess(agentId);
      return result;
    } catch (error) {
      this.recordFailure(agentId);
      throw error;
    }
  }

  private recordSuccess(agentId: string) {
    const health = this.healthMap.get(agentId);
    if (health) {
      health.errorCount = 0;
      health.status = 'HEALTHY';
    }
  }

  private recordFailure(agentId: string) {
    const health = this.healthMap.get(agentId);
    if (health) {
      health.errorCount += 1;
      health.lastErrorTime = Date.now();
      
      if (health.errorCount >= this.ERROR_THRESHOLD) {
        health.status = 'FAILED';
        console.error(`[CircuitBreaker] Agent ${agentId} tripped the circuit!`);
      }
    }
  }

  public getStatusReport() {
    return Array.from(this.healthMap.values());
  }
}

export const circuitBreaker = new CircuitBreaker();
