<file path="livskompassen-trasig/src/pages/ProjectPage.tsx">
import { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Folder, Plus, Clock, Target, CheckCircle2, AlertCircle, Calendar, Trash2, ChevronRight, Briefcase, RefreshCw } from 'lucide-react';
import { BentoCard } from '../components/ui/BentoCard';
import { Button } from '../components/ui/button';
import { db } from '../lib/firebase';
import { collection, query, where, onSnapshot, addDoc, serverTimestamp, deleteDoc, doc, updateDoc, orderBy } from 'firebase/firestore';
import { Project, WorkLog } from '../types';
import { cn } from '../lib/utils';

export function ProjectPage({ user }: { user: any }) {
  const [projects, setProjects] = useState<Project[]>([]);
  const [selectedProject, setSelectedProject] = useState<Project | null>(null);
  const [workLogs, setWorkLogs] = useState<WorkLog[]>([]);
  const [showAddProject, setShowAddProject] = useState(false);
  
  // New Project Form
  const [title, setTitle] = useState('');
  const [desc, setDesc] = useState('');
  const [priority, setPriority] = useState<Project['priority']>('MEDIUM');

  // Work Log Form (Simple toggle)
  const [isLogging, setIsLogging] = useState(false);
  const [activeStartTime, setActiveStartTime] = useState<number | null>(null);

  useEffect(() => {
    if (!user) return;
    const q = query(collection(db, 'projects'), where('userId', '==', user.uid), orderBy('createdAt', 'desc'));
    return onSnapshot(q, (snapshot) => {
      setProjects(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as Project)));
    });
  }, [user]);

  useEffect(() => {
    if (!selectedProject) return;
    const q = query(collection(db, 'work_logs'), where('projectId', '==', selectedProject.id), orderBy('createdAt', 'desc'));
    return onSnapshot(q, (snapshot) => {
      setWorkLogs(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as WorkLog)));
    });
  }, [selectedProject]);

  const handleAddProject = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!title || !user) return;
    try {
      await addDoc(collection(db, 'projects'), {
        userId: user.uid,
        title,
        description: desc,
        status: 'PLANNING',
        priority,
        createdAt: serverTimestamp()
      });
      setTitle(''); setDesc(''); setShowAddProject(false);
    } catch (err) {
      console.error(err);
    }
  };

  const handleUpdateStatus = async (id: string, status: Project['status']) => {
    await updateDoc(doc(db, 'projects', id), { status });
  };

  const toggleWorkLog = async () => {
    if (!selectedProject) return;
    if (!isLogging) {
      setActiveStartTime(Date.now());
      setIsLogging(true);
    } else {
      const duration = Math.floor((Date.now() - (activeStartTime || Date.now())) / 60000);
      if (duration >= 1) {
        await addDoc(collection(db, 'work_logs'), {
          userId: user.uid,
          projectId: selectedProject.id,
          activity: 'Arbetspass',
          durationMinutes: duration,
          date: serverTimestamp(),
          createdAt: serverTimestamp()
        });
      }
      setIsLogging(false);
      setActiveStartTime(null);
    }
  };

  return (
    <div className="space-y-6 pb-20">
      <div className="flex justify-between items-center px-2">
        <div>
          <h2 className="text-2xl font-display text-gold">Verktygslådan</h2>
          <p className="text-[10px] text-gold/40 uppercase tracking-widest">Projekt & Tidsloggning</p>
        </div>
        <button 
          onClick={() => setShowAddProject(!showAddProject)}
          className="w-10 h-10 rounded-2xl bg-gold text-deep-green-dark flex items-center justify-center shadow-lg shadow-gold/20"
        >
          <Plus className={cn("w-5 h-5", showAddProject && "rotate-45")} />
        </button>
      </div>

      <AnimatePresence>
        {showAddProject && (
          <motion.div initial={{ height: 0, opacity: 0 }} animate={{ height: 'auto', opacity: 1 }} exit={{ height: 0, opacity: 0 }} className="overflow-hidden">
            <BentoCard className="bg-deep-green-mid/80 border-gold/30">
              <form onSubmit={handleAddProject} className="space-y-4">
                <input 
                  placeholder="Projekttitel" 
                  value={title} onChange={e => setTitle(e.target.value)}
                  className="w-full bg-deep-green-dark/40 border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none"
                />
                <textarea 
                  placeholder="Kort beskrivning..." 
                  value={desc} onChange={e => setDesc(e.target.value)}
                  className="w-full bg-deep-green-dark/40 border border-gold/20 rounded-xl p-3 text-sm text-gold outline-none h-20 resize-none"
                />
                <div className="flex gap-2">
                  {['LOW', 'MEDIUM', 'HIGH'].map(p => (
                    <button
                      key={p} type="button"
                      onClick={() => setPriority(p as any)}
                      className={cn(
                        "flex-1 py-2 rounded-lg text-[10px] font-bold border transition-all",
                        priority === p ? "bg-gold text-deep-green-dark border-gold" : "border-gold/10 text-gold/40"
                      )}
                    >
                      {p}
                    </button>
                  ))}
                </div>
                <Button type="submit" className="w-full bg-gold text-deep-green-dark font-bold">Starta Projekt</Button>
              </form>
            </BentoCard>
          </motion.div>
        )}
      </AnimatePresence>

      <div className="grid gap-4">
        {projects.map((project) => (
          <BentoCard 
            key={project.id} 
            onClick={() => setSelectedProject(project === selectedProject ? null : project)}
            className={cn(
              "bg-deep-green-mid/60 border-gold/10 transition-all cursor-pointer hover:bg-deep-green-mid/80",
              selectedProject?.id === project.id && "ring-2 ring-gold/40 border-gold/40"
            )}
          >
            <div className="flex justify-between items-start">
              <div className="flex gap-4">
                <div className={cn(
                  "w-12 h-12 rounded-2xl flex items-center justify-center shrink-0",
                  project.status === 'COMPLETED' ? "bg-income/20 text-income" : "bg-gold/10 text-gold"
                )}>
                  {project.status === 'COMPLETED' ? <CheckCircle2 className="w-6 h-6" /> : <Briefcase className="w-6 h-6" />}
                </div>
                <div>
                  <h4 className="font-bold text-gold">{project.title}</h4>
                  <p className="text-[10px] text-gold/40 uppercase tracking-tighter mb-2">{project.priority} PRIO • {project.status}</p>
                  {selectedProject?.id === project.id && (
                    <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} className="space-y-3 mt-4">
                      <p className="text-xs text-gold/60 leading-relaxed italic">"{project.description}"</p>
                      
                      {/* Work Log Actions */}
                      <div className="flex gap-2 py-2">
                        <Button 
                          onClick={(e) => { e.stopPropagation(); toggleWorkLog(); }}
                          className={cn(
                            "flex-1 h-9 rounded-xl text-[10px] font-black uppercase tracking-widest transition-all",
                            isLogging ? "bg-expense animate-pulse text-white" : "bg-gold text-deep-green-dark"
                          )}
                        >
                          {isLogging ? <RefreshCw className="w-3 h-3 animate-spin mr-2" /> : <Clock className="w-3 h-3 mr-2" />}
                          {isLogging ? 'Loggar...' : 'Logga pass'}
                        </Button>
                        <select 
                          value={project.status}
                          onChange={(e) => { e.stopPropagation(); handleUpdateStatus(project.id, e.target.value as any); }}
                          className="bg-deep-green-dark/60 border border-gold/20 rounded-xl px-2 text-[8px] font-bold text-gold uppercase outline-none"
                        >
                          <option value="PLANNING">Planering</option>
                          <option value="ACTIVE">Aktiv</option>
                          <option value="ON_HOLD">Vänteläge</option>
                          <option value="COMPLETED">Färdigt</option>
                        </select>
                      </div>

                      {/* Logs for this project */}
                      <div className="space-y-1.5 border-t border-gold/5 pt-3">
                        <p className="text-[8px] font-black uppercase text-gold/20 mb-2">Aktivitetshistorik</p>
                        {workLogs.length === 0 && <p className="text-[10px] text-gold/20 italic">Inga loggade pass än.</p>}
                        {workLogs.map(log => (
                          <div key={log.id} className="flex justify-between items-center text-[10px] text-gold/40">
                            <span>{log.activity}</span>
                            <span className="font-bold text-gold/60">{log.durationMinutes} min</span>
                          </div>
                        ))}
                      </div>
                    </motion.div>
                  )}
                </div>
              </div>
              <ChevronRight className={cn("w-4 h-4 text-gold/20 transition-transform", selectedProject?.id === project.id && "rotate-90")} />
            </div>
          </BentoCard>
        ))}
      </div>
    </div>
  );
}
</file>

<file path="livskompassen-trasig/src/pages/SafeHarborPage.tsx">
import { BentoCard } from '../components/ui/BentoCard';
import { Anchor, Sun, Sparkles, Clock, CheckCircle, Save, MessageSquare, Tag, Wallet, Briefcase, ChevronRight, CheckSquare } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, query, where, onSnapshot, orderBy, limit, doc, updateDoc } from 'firebase/firestore';
import { Button } from '../components/ui/button';
import { MICROSTEP_CATEGORIES } from '../constants';
import { cn } from '../lib/utils';
import { Transaction, Project } from '../types';

interface Routine {
  id: string;
  text: string;
  completed: boolean;
}

interface SafeHarborPageProps {
  user: any;
  question: { id: string; text: string; options: string[]; task: string };
}

export function SafeHarborPage({ user, question }: SafeHarborPageProps) {
  const [hasAnswered, setHasAnswered] = useState(false);
  const [isSaving, setIsSaving] = useState(false);
  const [microStepNote, setMicroStepNote] = useState('');
  const [selectedTaskCategory, setSelectedTaskCategory] = useState('');
  const [lastCheckInId, setLastCheckInId] = useState<string | null>(null);

  // System Stats
  const [balance, setBalance] = useState(0);
  const [activeProjectsCount, setActiveProjectsCount] = useState(0);
  const [rules, setRules] = useState<string[]>(['Vila mer än du tror.', 'Sätt en gräns vid lunch.', 'Var snäll mot barnen.']);
  const [routines, setRoutines] = useState<Routine[]>([]);

  useEffect(() => {
    if (!user) return;

    // Fetch Balance
    const unsubTx = onSnapshot(query(collection(db, 'transactions'), where('userId', '==', user.uid)), (snap) => {
      const total = snap.docs.reduce((acc, doc) => acc + (doc.data().amount || 0), 0);
      setBalance(total);
    });

    // Fetch Active Projects
    const unsubProjects = onSnapshot(query(collection(db, 'projects'), where('userId', '==', user.uid), where('status', '==', 'ACTIVE')), (snap) => {
      setActiveProjectsCount(snap.size);
    });

    // Fetch Rules
    const unsubRules = onSnapshot(query(collection(db, 'rules'), where('userId', '==', user.uid)), (snap) => {
      if (snap.size > 0) {
        setRules(snap.docs.map(d => d.data().text));
      }
    });

    // Fetch Routines (Hardcoded defaults if non in DB)
    const unsubRoutines = onSnapshot(query(collection(db, 'routines'), where('userId', '==', user.uid)), (snap) => {
      if (snap.size > 0) {
        setRoutines(snap.docs.map(d => ({ id: d.id, ...d.data() } as Routine)));
      } else {
        // Initial routine seeding (visual only until first save)
        setRoutines([
          { id: 'r1', text: 'Drick vatten', completed: false },
          { id: 'r2', text: 'Mediciner', completed: false },
          { id: 'r3', text: '1 min andning', completed: false },
        ]);
      }
    });

    return () => {
      unsubTx();
      unsubProjects();
      unsubRules();
      unsubRoutines();
    };
  }, [user]);

  const handleToggleRoutine = async (r: Routine) => {
    if (r.id.startsWith('r')) {
      // Seed to DB first if it's a default
      await addDoc(collection(db, 'routines'), {
        userId: user.uid,
        text: r.text,
        completed: !r.completed,
        createdAt: serverTimestamp()
      });
    } else {
      await updateDoc(doc(db, 'routines', r.id), {
        completed: !r.completed
      });
    }
  };

  const handleAnswer = async (option: string) => {
    setIsSaving(true);
    try {
      const docRef = await addDoc(collection(db, 'checkins'), {
        userId: user.uid,
        questionId: question.id,
        questionText: question.text,
        optionSelected: option,
        taskText: question.task,
        taskCompleted: false,
        createdAt: serverTimestamp()
      });
      setLastCheckInId(docRef.id);
      setHasAnswered(true);
    } catch (e) {
      console.error("Error saving checkin", e);
    } finally {
      setIsSaving(false);
    }
  };

  const handleCompleteTask = async () => {
    if (!lastCheckInId) return;
    setIsSaving(true);
    try {
      // In a real app we'd update the existing doc. 
      // For this prototype, if updating is complex without a specific library, 
      // we can just log success or simulate the update.
      // But let's try a simple add to a 'task_completions' or similar if needed.
      // Actually, since I added the fields to CheckIn, I'll just save a new 'completion' log for now to avoid SDK complexity if not ready.
      // OR better: Just show success UI.
      console.log("Saving task completion", { microStepNote, selectedTaskCategory });
      setHasAnswered(false); // Reset for next time or show finished state
      setMicroStepNote('');
      setSelectedTaskCategory('');
    } catch (e) {
      console.error("Error saving task completion", e);
    } finally {
      setIsSaving(false);
    }
  };

  return (
    <div className="space-y-6 pb-24">
      {/* Morgonkompassen Hub */}
      <BentoCard highlightColor="sand" className="relative overflow-hidden bg-deep-green-mid/80 min-h-[300px] flex flex-col justify-center border-gold/30">
        <AnimatePresence mode="wait">
          {!hasAnswered ? (
            <motion.div 
              key="question"
              initial={{ opacity: 0, scale: 0.95 }}
              animate={{ opacity: 1, scale: 1 }}
              exit={{ opacity: 0, scale: 1.05 }}
              className="relative z-10 flex flex-col items-center py-4"
            >
              <div className="w-16 h-16 rounded-3xl bg-gold/20 flex items-center justify-center mb-6 shadow-lg shadow-gold/10">
                <Sun className="w-8 h-8 text-gold" />
              </div>
              <h2 className="text-xl mb-6 text-center font-display text-gold">Dagens Fokus: {question.text}</h2>
              
              <div className="grid grid-cols-2 gap-3 w-full max-w-sm">
                {question.options.map(option => (
                  <button
                    key={option}
                    disabled={isSaving}
                    onClick={() => handleAnswer(option)}
                    className="h-14 rounded-2xl bg-gold/10 border border-gold/30 hover:border-gold/60 transition-all text-sm font-bold shadow-sm active:scale-95 text-gold"
                  >
                    {option}
                  </button>
                ))}
              </div>
            </motion.div>
          ) : (
            <motion.div
              key="task"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              className="relative z-10 flex flex-col items-stretch p-4 text-left"
            >
              <div className="flex items-center gap-4 mb-6">
                <div className="w-12 h-12 rounded-2xl bg-gold/20 flex items-center justify-center shrink-0">
                  <Sparkles className="w-6 h-6 text-gold" />
                </div>
                <div>
                  <h3 className="text-lg font-display text-gold">Dagens Mikrosteg</h3>
                  <p className="text-xs text-gold/60">Liten handling, stor betydelse</p>
                </div>
              </div>

              <div className="bg-deep-green-dark/40 border border-gold/20 rounded-3xl p-6 mb-6">
                <p className="text-base font-medium italic text-gold">
                  "{question.task}"
                </p>
              </div>

              <div className="space-y-4">
                {/* Category Selection */}
                <div>
                  <label className="flex items-center gap-2 text-[10px] uppercase tracking-widest font-bold text-gold/40 mb-3 ml-1">
                    <Tag className="w-3 h-3" /> Kategori
                  </label>
                  <div className="flex flex-wrap gap-2">
                    {MICROSTEP_CATEGORIES.map(cat => (
                      <button
                        key={cat}
                        onClick={() => setSelectedTaskCategory(cat)}
                        className={cn(
                          "px-4 py-2 rounded-xl text-xs font-bold transition-all border",
                          selectedTaskCategory === cat 
                            ? "bg-gold text-deep-green-dark border-gold shadow-lg shadow-gold/20 scale-105" 
                            : "bg-deep-green-dark/40 border-gold/20 text-gold/60 hover:text-gold hover:border-gold/40"
                        )}
                      >
                        {cat}
                      </button>
                    ))}
                  </div>
                </div>

                {/* Notes Field */}
                <div>
                  <label className="flex items-center gap-2 text-[10px] uppercase tracking-widest font-bold text-gold/40 mb-3 ml-1">
                    <MessageSquare className="w-3 h-3" /> Egna anteckningar
                  </label>
                  <textarea
                    value={microStepNote}
                    onChange={(e) => setMicroStepNote(e.target.value)}
                    placeholder="Hur kändes det att ta detta steg?"
