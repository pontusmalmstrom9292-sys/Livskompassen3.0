import { Compass, Shield, Heart, Zap, Copy, Check, Loader2, ArrowRight, Sparkles, Brain } from 'lucide-react';
import { geminiService } from '../services/geminiService';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp, query, where, orderBy, limit, onSnapshot, getDocs } from 'firebase/firestore';
import { cn } from '../lib/utils';

type ViewState = 'IDLE' | 'VALUES' | 'IDENTITY_ANALYSIS' | 'BOUNDARY_START' | 'ANALYSIS' | 'GENERATING' | 'SCRIPTS';

export const ValueCompass = ({ userId }: { userId: string }) => {
  const [view, setView] = useState<ViewState>('IDLE');
  const [isAnalyzingIdentity, setIsAnalyzingIdentity] = useState(false);
  const [identityResults, setIdentityResults] = useState<any>(null);
  const [coreValues, setCoreValues] = useState<string[]>([]);
  const [isSavingValues, setIsSavingValues] = useState(false);
  const [requestText, setRequestText] = useState('');
  const [analysis, setAnalysis] = useState({
    bandwidth: false,
    aligns: false,
    fear: false
  });
  const [scripts, setScripts] = useState<any>(null);
  const [copied, setCopied] = useState<string | null>(null);

  useEffect(() => {
    if (!userId) return;
    const q = query(collection(db, 'core_values'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(1));
    const unsub = onSnapshot(q, (snap) => {
      if (!snap.empty) {
        setCoreValues(snap.docs[0].data().values);
      }
    });
    return unsub;
  }, [userId]);

  const handleStartAnalysis = () => {
    if (!requestText.trim()) return;
    setView('ANALYSIS');
  };

  const saveValues = async (values: string[]) => {
    if (!userId) return;
    setIsSavingValues(true);
    try {
      await addDoc(collection(db, 'core_values'), {
        userId,
        values,
        timestamp: serverTimestamp()
      });
      setCoreValues(values);
      setView('IDLE');
    } catch (error) {
      console.error("Values save failed:", error);
    } finally {
      setIsSavingValues(false);
    }
  };

  const handleIdentityAnalysis = async () => {
    if (!userId) return;
    setIsAnalyzingIdentity(true);
    setView('IDENTITY_ANALYSIS');
    try {
      const diaryQ = query(collection(db, 'diary_entries'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(10));
      const diarySnap = await getDocs(diaryQ);
      const diary = diarySnap.docs.map(d => d.data());

      const eventsQ = query(collection(db, 'events'), where('userId', '==', userId), orderBy('timestamp', 'desc'), limit(10));
      const eventsSnap = await getDocs(eventsQ);
      const events = eventsSnap.docs.map(d => d.data());

      const res = await geminiService.analyzeIdentity(diary, events);
      setIdentityResults(res);
    } catch (error) {
      console.error("Identity analysis failed:", error);
    } finally {
      setIsAnalyzingIdentity(false);
    }
  };

  const handleGenerate = async () => {
    setView('GENERATING');
    try {
      const result = await geminiService.generateBoundaryScripts(requestText, {
        ...analysis,
        coreValues // Pass context
      } as any);
      setScripts(result);
      setView('SCRIPTS');
    } catch (error) {
      console.error("Boundary generation failed:", error);
      setView('BOUNDARY_START');
    }
  };

  const copyToClipboard = (text: string, id: string) => {
    navigator.clipboard.writeText(text);
    setCopied(id);
    setTimeout(() => setCopied(null), 2000);
  };

  const renderContent = () => {
    switch (view) {
      case 'IDLE':
        return (
          <div className="space-y-8">
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-4">
                <div className="p-3 bg-indigo-500/10 rounded-2xl border border-indigo-500/20">
                  <Compass className="w-5 h-5 text-indigo-400" />
                </div>
                <div>
                  <h3 className="text-xl text-slate-100 font-outfit font-light">Värdekompassen</h3>
                  <p className="text-[10px] text-slate-500 uppercase tracking-widest font-bold">Ditt Inre Ankare</p>
                </div>
              </div>
              <button 
                onClick={() => setView('VALUES')}
                className="text-[9px] uppercase font-bold text-indigo-400 hover:text-indigo-300"
              >
                {coreValues.length > 0 ? 'Uppdatera Värden' : 'Ställ in Värden'}
              </button>
            </div>

            {coreValues.length > 0 ? (
              <div className="flex flex-wrap gap-2">
                {coreValues.map((v, i) => (
                  <span key={i} className="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[10px] text-indigo-300 font-bold uppercase tracking-wider">
                    {v}
                  </span>
                ))}
              </div>
            ) : (
              <div className="p-6 bg-indigo-500/5 border border-dashed border-indigo-500/20 rounded-3xl text-center">
                <p className="text-xs text-slate-500 italic">Du har inte identifierat dina kärnvärden än. Detta är din sköld mot manipulation.</p>
                <button onClick={() => setView('VALUES')} className="mt-4 text-[10px] font-bold text-indigo-400 uppercase tracking-widest border-b border-indigo-500/20 pb-1">Börja här</button>
              </div>
            )}
            
            <div className="pt-6 border-t border-white/5">
              <button 
                onClick={() => setView('BOUNDARY_START')}
                className="w-full py-4 rounded-2xl bg-white/5 hover:bg-white/10 text-slate-300 border border-white/10 font-outfit font-bold text-xs uppercase tracking-widest transition-all"
              >
                Pröva en Gräns
              </button>
            </div>
          </div>
        );

      case 'VALUES':
        return (
          <div className="space-y-6">
            <div className="flex items-center justify-between">
              <h3 className="text-lg text-white font-outfit">Vad är verkligen viktigt för DIG?</h3>
              <button 
                onClick={handleIdentityAnalysis}
                className="text-[9px] uppercase font-bold text-indigo-400 flex items-center gap-1"
              >
                <Sparkles className="w-3 h-3" /> Hjälp mig se mönster
              </button>
            </div>
            <p className="text-xs text-slate-500 leading-relaxed">Välj de 3-5 värden som du vill ska styra dina beslut, oavsett vad andra kräver.</p>
            <div className="grid grid-cols-2 gap-2">
              {['Trygghet', 'Lugn', 'Ärlighet', 'Frihet', 'Barnens bästa', 'Självrespekt', 'Autenticitet', 'Hälsa', 'Rättvisa', 'Glädje'].map(v => (
                <button
                  key={v}
                  onClick={() => {
                    if (coreValues.includes(v)) setCoreValues(prev => prev.filter(x => x !== v));
                    else if (coreValues.length < 5) setCoreValues(prev => [...prev, v]);
                  }}
                  className={cn(
                    "p-3 rounded-xl text-xs font-medium transition-all text-left",
                    coreValues.includes(v) ? "bg-indigo-600 text-white" : "bg-white/5 text-slate-400 border border-white/5"
                  )}
                >
                  {v}
                </button>
              ))}
            </div>
            <div className="flex gap-3">
              <button onClick={() => setView('IDLE')} className="flex-1 py-4 bg-white/5 text-slate-500 rounded-xl font-bold text-[10px] uppercase tracking-widest">Avbryt</button>
              <button 
                onClick={() => saveValues(coreValues)}
                disabled={coreValues.length < 1 || isSavingValues}
                className="flex-[2] py-4 bg-indigo-600 text-white rounded-xl font-bold text-[10px] uppercase tracking-widest"
              >
                {isSavingValues ? <Loader2 className="w-4 h-4 animate-spin mx-auto" /> : "Spara mitt ankare"}
              </button>
            </div>
          </div>
        );

      case 'IDENTITY_ANALYSIS':
        return (
          <div className="space-y-6">
            <div className="flex items-center gap-3">
              <div className="p-2 bg-indigo-500/10 rounded-lg">
                <Brain className="w-4 h-4 text-indigo-400" />
              </div>
              <h3 className="text-lg text-white font-outfit">Identitets-spegling</h3>
            </div>
            
            {isAnalyzingIdentity ? (
              <div className="py-12 flex flex-col items-center justify-center gap-4">
                <Loader2 className="w-8 h-8 text-indigo-500 animate-spin" />
                <p className="text-[10px] uppercase font-bold text-slate-500 tracking-widest animate-pulse">Skannar tidslinjen efter sanningen...</p>
              </div>
            ) : identityResults ? (
              <div className="space-y-6">
                <div className="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-[2rem]">
                  <p className="text-sm text-slate-200 italic leading-relaxed">
                    "{identityResults.identityBrief}"
                  </p>
                </div>

                <div className="space-y-3">
                  <p className="text-[9px] uppercase font-bold text-slate-500 tracking-widest px-2">Föreslagna Ankare</p>
                  {identityResults.suggestedValues.map((v: any, i: number) => (
                    <button 
                      key={i}
                      onClick={() => {
                        if (!coreValues.includes(v.value) && coreValues.length < 5) {
                          setCoreValues(prev => [...prev, v.value]);
                        }
                      }}
                      className={cn(
                        "w-full p-4 rounded-2xl border text-left transition-all group",
                        coreValues.includes(v.value) ? "bg-indigo-500/20 border-indigo-500/40" : "bg-white/5 border-white/5 hover:bg-white/10"
                      )}
                    >
                      <div className="flex justify-between items-center mb-1">
                        <span className="text-sm font-bold text-slate-100">{v.value}</span>
                        {coreValues.includes(v.value) && <Check className="w-4 h-4 text-teal-400" />}
                      </div>
                      <p className="text-[11px] text-slate-500 italic leading-tight group-hover:text-slate-400 transition-colors">
                        {v.reason}
                      </p>
                    </button>
                  ))}
                </div>

                <button 
                  onClick={() => setView('VALUES')}
                  className="w-full py-4 bg-indigo-600 text-white rounded-xl font-bold text-[10px] uppercase tracking-widest"
                >
                  Gå vidare till urval
                </button>
              </div>
            ) : null}
          </div>
        );

      case 'BOUNDARY_START':
        return (
          <div className="space-y-6">
            <div className="flex items-center gap-4">
              <button onClick={() => setView('IDLE')} className="p-2 hover:bg-white/5 rounded-full transition-all">
                <ArrowRight className="w-4 h-4 text-slate-500 rotate-180" />
              </button>
              <h3 className="text-lg text-slate-100 font-outfit">Gränssättnings-Skölden</h3>
            </div>
            
            <p className="text-sm text-slate-400 font-inter italic leading-relaxed">
              Har någon bett dig om något som skaver? Klistra in förfrågan här så prövar vi den mot dina värderingar.
            </p>

            <textarea 
              value={requestText}
              onChange={(e) => setRequestText(e.target.value)}
              placeholder="Vad vill de att du ska göra?"
              className="w-full bg-black/40 border border-white/5 rounded-2xl p-5 text-slate-200 text-sm focus:outline-none focus:border-indigo-500/30 transition-all min-h-[120px] resize-none"
            />

            <button 
              onClick={() => setView('ANALYSIS')}
              disabled={!requestText.trim()}
              className="w-full py-4 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-outfit font-bold text-sm transition-all disabled:opacity-30"
            >
              Nästa Steg
            </button>
          </div>
        );

      case 'ANALYSIS':
        return (
          <div className="space-y-8 py-4">
            <div className="text-center space-y-2">
              <h3 className="text-lg text-white font-outfit">Sanningens Ögonblick</h3>
              <p className="text-xs text-slate-500">Svara ärligt för att skydda din energi.</p>
            </div>

            <div className="space-y-4">
              {[
                { id: 'bandwidth', label: 'Har jag egentligen energi för detta idag?', icon: Zap, color: 'text-amber-400' },
                { id: 'aligns', label: 'Gynnar detta mitt lugn och min trygghet?', icon: Heart, color: 'text-rose-400' },
                { id: 'fear', label: 'Drivs mitt beslut av rädsla för konflikten?', icon: Shield, color: 'text-indigo-400' },
              ].map((q) => (
                <button 
                  key={q.id}
                  onClick={() => setAnalysis(prev => ({ ...prev, [q.id]: !prev[q.id as keyof typeof analysis] }))}
                  className={cn(
                    "w-full flex items-center justify-between p-4 rounded-2xl border transition-all",
                    analysis[q.id as keyof typeof analysis] 
                      ? "bg-indigo-500/10 border-indigo-500/50" 
                      : "bg-white/5 border-white/5"
                  )}
                >
                  <div className="flex items-center gap-3">
                    <q.icon className={cn("w-4 h-4", analysis[q.id as keyof typeof analysis] ? q.color : "text-slate-600")} />
                    <span className="text-sm text-slate-300 text-left">{q.label}</span>
                  </div>
                  <div className={cn(
                    "w-5 h-5 rounded-full border flex items-center justify-center transition-all shrink-0",
                    analysis[q.id as keyof typeof analysis] ? "bg-indigo-500 border-indigo-400" : "border-white/20"
                  )}>
                    {analysis[q.id as keyof typeof analysis] && <Check className="w-3 h-3 text-white" />}
                  </div>
                </button>
              ))}
            </div>

            <div className="flex gap-3">
              <button 
                onClick={() => setView('IDLE')}
                className="flex-1 py-4 bg-white/5 text-slate-500 rounded-xl font-bold text-[10px] uppercase tracking-widest"
              >
                Tillbaka
              </button>
              <button 
                onClick={handleGenerate}
                className="flex-[2] py-4 bg-indigo-600 text-white rounded-xl font-bold text-[10px] uppercase tracking-widest"
              >
                Hämta Försvarsmanus
              </button>
            </div>
          </div>
        );

      case 'GENERATING':
        return (
          <div className="flex flex-col items-center justify-center py-20 space-y-4 text-center">
            <Loader2 className="w-8 h-8 text-indigo-500 animate-spin" />
            <p className="text-sm text-indigo-400 uppercase tracking-widest font-bold">Gränssättnings-Agenten tänker...</p>
          </div>
        );

      case 'SCRIPTS':
        return (
          <div className="space-y-6">
            <div className="p-4 bg-indigo-500/10 border border-indigo-500/20 rounded-2xl">
              <p className="text-sm text-indigo-200 font-inter italic leading-relaxed">
                "{scripts.validation}"
              </p>
            </div>

            <div className="space-y-4 max-h-[350px] overflow-y-auto pr-2 scrollbar-thin scrollbar-thumb-white/10">
              {[
                { id: 'soft', title: 'Mjuk & Bestämd', text: scripts.scripts.soft },
                { id: 'biff', title: 'BIFF (Kort & Formell)', text: scripts.scripts.biff },
                { id: 'greyRock', title: 'Grey Rock (Stängd)', text: scripts.scripts.greyRock },
              ].map((s) => (
                <div key={s.id} className="p-4 bg-white/[0.03] border border-white/5 rounded-2xl space-y-3 group hover:border-indigo-500/30 transition-all">
                  <div className="flex items-center justify-between">
                    <span className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">{s.title}</span>
                    <button 
                      onClick={() => copyToClipboard(s.text, s.id)}
                      className="p-2 hover:bg-white/10 rounded-lg transition-all"
                    >
                      {copied === s.id ? <Check className="w-3 h-3 text-teal-400" /> : <Copy className="w-3 h-3 text-slate-600" />}
                    </button>
                  </div>
                  <p className="text-sm text-slate-300 leading-relaxed font-inter">
                    {s.text}
                  </p>
                </div>
              ))}
            </div>

            <button 
              onClick={() => {
                setView('IDLE');
                setRequestText('');
                setAnalysis({ bandwidth: false, aligns: false, fear: false });
              }}
              className="w-full py-4 border border-white/10 text-slate-500 rounded-xl font-bold text-[10px] uppercase tracking-widest hover:bg-white/5 transition-all"
            >
              Ny Prövning
            </button>
          </div>
        );
    }
  };

  return (
    <div className="bg-[#020617]/60 backdrop-blur-2xl border border-white/5 rounded-[3rem] p-8 lg:p-10 relative overflow-hidden shadow-2xl transition-all duration-700 h-full">
      {/* Glow effect */}
      <div className="absolute -top-24 -left-24 w-64 h-64 bg-indigo-500/5 rounded-full blur-[100px]" />
      
      <div className="relative h-full">
        <AnimatePresence mode="wait">
          <motion.div
            key={view}
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            transition={{ duration: 0.3 }}
            className="h-full"
          >
            {renderContent()}
          </motion.div>
        </AnimatePresence>
      </div>
    </div>
  );
};
</file>

