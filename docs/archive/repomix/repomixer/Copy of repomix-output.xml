                    <div className="relative z-10 space-y-3 pl-4 border-l-2 border-teal-500/20">
                      <p className="text-[9px] text-slate-500 uppercase font-black tracking-widest">Rationell Grund</p>
                      <p className="text-sm text-slate-400 italic leading-relaxed font-inter">
                        {result.strategicAdvice.rationale}
                      </p>
                    </div>

                    {!isApproved ? (
                      <button 
                        onClick={() => {
                          setIsApproved(true);
                          navigator.clipboard.writeText(result.strategicAdvice.script);
                        }}
                        className="w-full py-6 bg-teal-600 hover:bg-teal-500 text-white rounded-[1.8rem] font-bold text-xs uppercase tracking-[0.3em] transition-all flex items-center justify-center gap-4 shadow-2xl shadow-teal-900/40 active:scale-95 group/approve"
                      >
                        <Check className="w-5 h-5 group-hover:scale-125 transition-transform" /> 
                        Godkänn & Kopiera Svar
                      </button>
                    ) : (
                      <div className="w-full py-6 bg-teal-500/20 border border-teal-500/30 text-teal-400 rounded-[1.8rem] font-bold text-xs uppercase tracking-[0.3em] flex items-center justify-center gap-4">
                        <ShieldCheck className="w-5 h-5" /> Analys Godkänd & Arkiverad
                      </div>
                    )}
                  </div>
                )}

                {/* ─── Grounding Points ───────────────────────────────────────── */}
                <div className="space-y-6">
                   <div className="flex items-center gap-3 text-[10px] font-black uppercase tracking-widest text-slate-600">
                    <ShieldCheck className="w-4 h-4" /> Arkiv-Jordning (Verifierad Fakta)
                  </div>
                  <div className="flex flex-wrap gap-3">
                    {result.groundingPoints?.map((p: string, i: number) => (
                      <motion.div 
                        key={i} 
                        initial={{ scale: 0.8, opacity: 0 }}
                        animate={{ scale: 1, opacity: 1 }}
                        transition={{ delay: i * 0.1 }}
                        className="px-6 py-3 bg-white/[0.03] rounded-2xl text-[11px] text-slate-400 border border-white/5 font-inter font-light italic"
                      >
                        ⚓ {p}
                      </motion.div>
                    ))}
                  </div>
                </div>

                <div className="flex gap-4 pt-10 border-t border-white/5">
                  <button 
                    onClick={() => {
                      setResult(null);
                      setIsApproved(false);
                    }}
                    className="flex-1 py-6 rounded-[2rem] bg-white/[0.02] border border-white/5 text-slate-500 font-bold text-[10px] uppercase tracking-widest hover:bg-white/5 hover:text-slate-300 transition-all active:scale-95"
                  >
                    Ny Analys
                  </button>
                  <button 
                    onClick={onClose}
                    className="flex-[2] py-6 rounded-[2rem] bg-indigo-600/20 border border-indigo-500/30 hover:bg-indigo-600/30 text-indigo-300 font-outfit font-bold text-sm tracking-[0.2em] transition-all shadow-2xl active:scale-95"
                  >
                    Färdig i Valvet
                  </button>
                </div>
              </motion.div>
            )}
          </div>
        </motion.div>
      </div>
    </AnimatePresence>
  );
};
