"""
Agent 1: Eskalerings-Detektorn (EscalationAgent)

Uppdrag:
  Jämför en ny händelse mot den historiska radarloggen.
  Avgör om situationen eskalerar, är stabil eller deeskalerar.
  Identifierar specifika varningssignaler och rekommenderar proaktiva åtgärder.

Triggers:
  - Automatiskt vid varje ny RadarEvent-logg
  - Manuellt via /escalation-endpunkt

Output:
  {
    "escalationLevel": "CRITICAL|HIGH|MEDIUM|LOW|STABLE",
    "escalationScore": 0-100,
    "trendDirection": "ESCALATING|STABLE|DE-ESCALATING",
    "matchedPatterns": [{"pattern": str, "frequency": int, "lastSeen": str}],
    "newIndicators": ["Ny taktik som inte setts förut"],
    "immediateWarnings": ["Konkreta varningar som kräver action nu"],
    "recommendedActions": [{"priority": "URGENT|HIGH|MEDIUM", "action": str, "rationale": str}],
    "timelineInsight": "Hur länge detta mönster pågått",
    "groundingPoints": ["Fakta från manualer som stödjer analysen"]
  }
"""
import json
from typing import Dict, Any, List
from .base_agent import BaseAgent



class EscalationAgent(BaseAgent):
    AGENT_NAME = "Eskalerings-Detektorn"
    AGENT_ROLE = "Identifierar och varnar för eskalerande mönster i Eftervåld och psykologisk manipulation"

    async def analyze(self, data: Dict[str, Any]) -> Dict:
        new_event = data.get("newEvent", "")
        historical_events = data.get("historicalEvents", [])
        actor_profiles = data.get("actorProfiles", [])

        # 1. Jordar mot BIFF-manual och forskning om Coercive Control
        grounding = await self._ground_with_vertex_search(
            f"eskalering eftervåld coercive control mönster: {new_event[:200]}"
        )
        context_block = self._build_context_block(grounding)

        # SYNAPSE: Query Chronos for temporal patterns
        temporal_insight = {}
        try:
            temporal_insight = await self.query_agent("chronos", {"events": historical_events + [data.get("newEvent")]})
        except Exception as e:
            temporal_insight = {"error": str(e)}

        # 2. Bygg historisk kontext (max 15 senaste händelser för att hålla prompt compact)
        history_block = "\n".join([
            f"[{e.get('timestamp', 'okänt datum')}] ({e.get('type', 'Okänt')}): {e.get('description', '')}"
            for e in historical_events[-15:]
        ])
        actor_block = "\n".join([
            f"- {a.get('name', 'Okänd')} | Roll: {a.get('role', '')} | Förtroende: {a.get('trustLevel', '')}"
            for a in actor_profiles[:10]
        ])

        prompt = f"""
Du är "Eskalerings-Detektorn" – ett specialiserat AI-system för att identifiera
eskalerande psykologisk manipulation och Eftervåld i separationskonflikter.

JORDNINGSDATA (Från manualer om Coercive Control och BIFF):
{context_block}

INBLANDADE AKTÖRER:
{actor_block if actor_block else "Inga aktörsprofiler tillgängliga"}

HISTORISKA HÄNDELSER (äldst → nyast):
{history_block if history_block else "Inga historiska händelser"}

TEMPORALA SYNAPSER (Från ChronosAgent):
{json.dumps(temporal_insight) if temporal_insight else "Ingen temporal data"}

NY HÄNDELSE ATT ANALYSERA:
{new_event}

UPPGIFT:
1. Jämför den nya händelsen mot historiken
2. Identifiera om intensiteten ökar (frekvens, allvarlighetsgrad, nya taktiker)
3. Beräkna en eskaleringspoäng (0=lugnt, 100=akut kris)
4. Ge konkreta, prioriterade åtgärder

Svara STRIKT i JSON (inga kommentarer, inga förklaringar utanför JSON):
{{
  "escalationLevel": "CRITICAL|HIGH|MEDIUM|LOW|STABLE",
