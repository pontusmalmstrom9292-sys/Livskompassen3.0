"""
Agent 2: Kris-Stabilisatorn (CrisisAgent)

Uppdrag:
  Analyserar dagbokstext och mooddata i realtid för tecken på akut distress.
  Aktiverar ett trauma-informerat, stegvist stödprogram för omedelbar
  kognitiv nedreglering (ADHD/GAD-anpassat).

Triggers:
  - Automatiskt när dagbok-text sparas med hög stressnivå
  - Manuellt via "Akut Stöd"-knappen

Output:
  {
    "distressLevel": "ACUTE|HIGH|MODERATE|LOW",
    "distressScore": 0-100,
    "detectedSignals": [{"signal": str, "type": "COGNITIVE|SOMATIC|EMOTIONAL|BEHAVIORAL"}],
    "groundingProtocol": {
      "name": str,
      "steps": [{"step": int, "instruction": str, "durationSeconds": int, "sensory": str}]
    },
    "affirmation": "En personlig, stärkande mening",
    "safetyCheck": {"isInImmediateDanger": bool, "recommendProfessionalHelp": bool, "hotlineInfo": str},
    "followUpIn": "5min|1h|24h",
    "groundingPoints": ["Fakta från stödmanualer"]
  }
"""
import json
from typing import Dict, Any
from .base_agent import BaseAgent



class CrisisAgent(BaseAgent):
    AGENT_NAME = "Kris-Stabilisatorn"
    AGENT_ROLE = "Akut traumainformerat stöd för ADHD/GAD vid emotionell överväldigande"

    async def analyze(self, data: Dict[str, Any]) -> Dict:
        diary_text = data.get("diaryText", "")
        mood_score = data.get("moodScore", 5)   # 1-10, där 1 = värst
        stress_level = data.get("stressLevel", 5)
        recent_events = data.get("recentEvents", [])

        # 1. Jordar mot psykologiska stödmanualer och trauma-forskning
        grounding = await self._ground_with_vertex_search(
            f"akut ångest ADHD nedreglering grounding teknik: {diary_text[:150]}"
        )
        context_block = self._build_context_block(grounding)

        events_block = "\n".join([
            f"- {e.get('description', '')}" for e in recent_events[-5:]
        ])

        # SYNAPSE: If distress is high, query Vagus for immediate somatic grounding
        vagus_grounding = {}
        if mood_score <= 3 or stress_level >= 8:
            try:
                vagus_grounding = await self.query_agent("vagus", {
                    "stressScore": stress_level * 10,
                    "signals": ["Acute distress detected by CrisisAgent"]
                })
            except Exception:
                vagus_grounding = {"note": "Vagus-synaps ej tillgänglig"}


        prompt = f"""
Du är "Kris-Stabilisatorn" – ett AI-stödsystem specialiserat på
trauma-informerad krishantering för personer med ADHD och GAD.
Du är ALDRIG dömande. Du är ett ankare i stormen.

STÖDMANUALER (Jordning):
{context_block}

KONTEXT:
- Sinnesstämning: {mood_score}/10 (10 = utmärkt)
- Stressnivå: {stress_level}/10 (10 = maxstress)
- Senaste händelser:
{events_block if events_block else "Inga loggade händelser"}

VAGUS-SYNAPS (Somatisk data):
{json.dumps(vagus_grounding) if vagus_grounding else "Ingen vagus-data tillgänglig"}

PERSONENS EGNA ORD:
"{diary_text}"

UPPGIFT:
1. Identifiera distress-signaler (kognitiva, somatiska, emotionella, beteendemässiga)
2. Välj rätt protocol (5-4-3-2-1 Senses, Box Breathing, Safe Space, TIPP, Progressive Relaxation)
3. Om Vagus-synapsen gav förslag, integrera dem i ditt groundingProtocol.
4. Anpassa för ADHD (korta steg, konkret, sensoriskt)
5. Inkludera en personlig, icke-generisk affirmation baserad på texten


Svara STRIKT i JSON:
{{
  "distressLevel": "ACUTE|HIGH|MODERATE|LOW",
  "distressScore": <0-100>,
  "detectedSignals": [
    {{"signal": "<observerad signal>", "type": "COGNITIVE|SOMATIC|EMOTIONAL|BEHAVIORAL"}}
  ],
  "groundingProtocol": {{
    "name": "<protokollnamn>",
    "rationale": "<varför detta protokoll för just denna person>",
    "steps": [
      {{"step": 1, "instruction": "<konkret instruktion>", "durationSeconds": <sekunder>, "sensory": "SYN|LJUD|BERÖRING|LUKT|SMAK|ANDNING|RÖRELSE"}}
    ]
  }},
  "affirmation": "<personlig, specifik stärkande mening baserad på personens text>",
  "safetyCheck": {{
    "isInImmediateDanger": false,
    "recommendProfessionalHelp": <bool>,
    "note": "<kort, varm notis>"
  }},
  "followUpIn": "5min|1h|4h|24h",
  "groundingPoints": ["<relevantt fakta från stödmanualer>"]
}}
"""
        return self._call_model(prompt)
