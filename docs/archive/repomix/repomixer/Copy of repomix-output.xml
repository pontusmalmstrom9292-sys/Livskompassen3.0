  - Automatiskt när ny aktör läggs till eller eskalering detekteras

Output:
  {
    "networkHealth": "STRONG|MODERATE|VULNERABLE|ISOLATED",
    "isolationRisk": 0-100,
    "keyAllies": [{"name": str, "role": str, "reliability": str, "contactPriority": str}],
    "riskActors": [{"name": str, "tactics": [], "influenceLevel": str}],
    "influenceMap": [{"from": str, "to": str, "type": str, "strength": str}],
    "blindSpots": ["Relationer som saknas eller behöver stärkas"],
    "isolationTactics": ["Detekterade taktiker för att isolera användaren"],
    "networkActions": [{"action": str, "targetPerson": str, "priority": str}],
    "groundingPoints": [...]
  }
"""
from typing import Dict, Any, List
from .base_agent import BaseAgent


class NetworkAgent(BaseAgent):
    AGENT_NAME = "Nätverks-Kartläggaren"
    AGENT_ROLE = "Kartlägger relationer, identifierar allierade och isoleringstaktiker"

    async def analyze(self, data: Dict[str, Any]) -> Dict:
        actors = data.get("actors", [])
        network_members = data.get("networkMembers", [])
        recent_events = data.get("recentEvents", [])
        user_description = data.get("userDescription", "")

        # 1. Jordar mot isolering och coercive control-forskning
        grounding = await self._ground_with_vertex_search(
            "isolering socialt nätverk coercive control separation stöd"
        )
        context_block = self._build_context_block(grounding)

        # 2. Bygg aktörsblock
        actors_block = "\n".join([
            f"  - {a.get('name', 'Okänd')} | Kategori: {a.get('category', '')} | "
            f"Förtroende: {a.get('trustLevel', '')} | Roll: {a.get('role', '')}"
            for a in actors[:20]
        ])

        network_block = "\n".join([
            f"  - {m.get('name', 'Okänd')} | Kategori: {m.get('category', '')} | "
            f"Allierad: {m.get('isAlly', False)} | Risknivå: {m.get('riskLevel', 0)}/10"
            for m in network_members[:20]
        ])

        # 3. Identifiera interaktionsmönster från händelser
        actor_mentions: Dict[str, int] = {}
        for event in recent_events[-20:]:
            for actor_id in event.get("involvedActors", []):
                actor_mentions[actor_id] = actor_mentions.get(actor_id, 0) + 1
        mentions_block = "\n".join([
            f"  {actor_id}: {count} gånger" for actor_id, count in
            sorted(actor_mentions.items(), key=lambda x: x[1], reverse=True)[:10]
        ])

        prompt = f"""
Du är "Nätverks-Kartläggaren" – ett AI-system som specialiserar sig på
social nätverksanalys i kontexten av separation och Eftervåld.

REFERENSFAKTA (Från manualer om isolering och stödnätverk):
{context_block}

REGISTRERADE AKTÖRER:
{actors_block if actors_block else "Inga aktörer registrerade"}

SOCIALT NÄTVERK:
{network_block if network_block else "Inget nätverk registrerat"}

AKTÖRSFREKVENS I HÄNDELSELOGGEN:
{mentions_block if mentions_block else "Inga data"}

ANVÄNDARENS EGNA ORD OM NÄTVERKET:
{user_description if user_description else "Ingen beskrivning"}

UPPGIFT:
1. Bedöm nätverkets styrka och mångfald (socialt kapital)
2. Identifiera isoleringstaktiker som används mot användaren
3. Kartlägg influensflöden (vem påverkar vem, hur)
4. Hitta blinda fläckar (relationer som saknas)
5. Prioritera åtgärder för att stärka nätverket

Svara STRIKT i JSON:
{{
  "networkHealth": "STRONG|MODERATE|VULNERABLE|ISOLATED",
  "isolationRisk": <0-100>,
  "keyAllies": [
    {{"name": "<namn>", "role": "<roll>", "reliability": "HÖG|MEDEL|LÅGA", "contactPriority": "OMEDELBAR|HÖG|MEDIUM", "why": "<varför viktig>"}}
  ],
  "riskActors": [
    {{"name": "<namn>", "tactics": ["<taktik>"], "influenceLevel": "HÖG|MEDEL|LÅG", "mitigation": "<åtgärd>"}}
  ],
  "influenceMap": [
    {{"from": "<person>", "to": "<person>", "type": "STÖD|KONTROLL|MANIPULATION|NEUTRAL", "strength": "STARK|MEDEL|SVAG"}}
  ],
  "blindSpots": ["<relation eller stöd som saknas och behövs>"],
  "isolationTactics": ["<detekterad isoleringsstrategi>"],
  "networkActions": [
    {{"action": "<konkret åtgärd>", "targetPerson": "<vem>", "priority": "OMEDELBAR|HÖG|MEDIUM"}}
  ],
  "groundingPoints": ["<fakta från manualerna>"]
}}
"""
        return self._call_model(prompt)
