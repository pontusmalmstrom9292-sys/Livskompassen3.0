import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  User, ShieldCheck, XCircle, FileText, Loader2, HelpCircle,
  Baby, Gavel, BarChart3, ShieldAlert, Sparkles, Lock, Zap,
  Type, History, Eye, Wallet, Network, Download, UploadCloud,
  MessageSquare, LayoutGrid, ArrowRight, Shield, Database, Copy, TrendingUp, Calendar, PiggyBank
} from 'lucide-react';
import { radarService, RadarEvent } from '../services/radarService';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { useLearning } from '../contexts/LearningContext';
import { collection, addDoc, serverTimestamp, query, where, orderBy, limit, onSnapshot } from 'firebase/firestore';
import { db } from '../lib/firebase';
import { cn } from '../lib/utils';
import { VivirEmergencyFilter } from './VivirEmergencyFilter';
import { RealityMirror } from './RealityMirror';
import { EconomicAuditor } from './EconomicAuditor';
import { ChildSafetyLog } from './ChildSafetyLog';
import { SystemManual } from './SystemManual';
import { TacticalStatusBoard } from './TacticalStatusBoard';
import { shieldApi } from '../services/apiService';
import { driveService } from '../services/driveService';
import { circuitBreaker } from '../services/circuitBreaker';
import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';

// Modular Components
import { VaultCommand } from './vault/VaultCommand';
import { VaultRealityShield } from './vault/VaultRealityShield';
import { VaultSynapse } from './vault/VaultSynapse';
import { VaultIntelligence } from './vault/VaultIntelligence';
import { VaultChronos } from './vault/VaultChronos';
import { VaultDossier } from './vault/VaultDossier';
import { ScheduleAssistant } from './ScheduleAssistant';
import { PennyAgent } from './PennyAgent';

type VaultTab = 'COMMAND' | 'INTELLIGENCE' | 'SYNAPSE' | 'MIRROR' | 'ECONOMY' | 'NETWORK' | 'CHRONOS' | 'DOSSIER' | 'MANUAL' | 'CHILD' | 'SCAN' | 'SCHEMA' | 'PENNY';

export const VaultArchive = ({ userId }: { userId: string }) => {
  const { entities } = useSystemMemory();
  const { triggerStrengthMessage } = useLearning();
  
  const [activeTab, setActiveTab] = useState<VaultTab>('COMMAND');
  const [intelReport, setIntelReport] = useState<any>(null);
  const [activeAgent, setActiveAgent] = useState<string | null>(null);
  const [driveStatus, setDriveStatus] = useState<any>(null);

  useEffect(() => {
    driveService.getVaultStatus().then(setDriveStatus);
  }, []);

  const agents = [
    { id: 'escalation', name: 'Eskalerings-Detektorn', icon: TrendingUp, color: 'text-rose-400', desc: 'Jämför nya händelser mot historik för att hitta varningssignaler.' },
    { id: 'crisis', name: 'Kris-Stabilisatorn', icon: Zap, color: 'text-amber-400', desc: 'Analyserar distress och ger trauma-informerade jordningsprotokoll.' },
    { id: 'economic', name: 'Ekonomisk Fotspår-Agenten', icon: Wallet, color: 'text-orange-400', desc: 'Upptäcker mönster av ekonomisk kontroll och manipulation.' },
    { id: 'network', name: 'Nätverks-Kartläggaren', icon: Network, color: 'text-indigo-400', desc: 'Identifierar isoleringstaktiker och kartlägger dina allierade.' },
    { id: 'report', name: 'Rapport-Generatorn', icon: FileText, color: 'text-teal-400', desc: 'Sammanställer data till ett BBIC-kompatibelt utkast.' },
    { id: 'orchestrator', name: 'System-Orkestrator', icon: ShieldCheck, color: 'text-blue-400', desc: 'Genererar en strategisk helhetsrapport (BBIC/Juridik).' }
  ];

  const [isNeuralSearching, setIsNeuralSearching] = useState(false);
  const [isScanning, setIsScanning] = useState(false);
  const [uploading, setUploading] = useState(false);
  const [searchTerm, setSearchTerm] = useState('');
  const [scanContent, setScanContent] = useState('');
  const [scanResult, setScanResult] = useState<any>(null);
  const [intelligence, setIntelligence] = useState<any[]>([]);
  const [events, setEvents] = useState<RadarEvent[]>([]);
  const [transactions, setTransactions] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [showVivir, setShowVivir] = useState(false);

  useEffect(() => {
    if (!userId) return;
    const unsubIntel = radarService.subscribeToIntelligence(userId, (data) => {
      setIntelligence(data);
      setLoading(false);
    });
    const fetchEvents = async () => {
      const data = await radarService.getEvents(userId);
      setEvents(data);
    };
    fetchEvents();
    const qTx = query(collection(db, 'transactions'), where('userId', '==', userId), orderBy('createdAt', 'desc'), limit(50));
    const unsubTx = onSnapshot(qTx, (snap) => setTransactions(snap.docs.map(d => ({ id: d.id, ...d.data() }))));
    return () => {
      unsubIntel();
      unsubTx();
    };
  }, [userId]);

  const runNeuralSearch = async () => {
    if (!searchTerm.trim()) return;
    setIsNeuralSearching(true);
    try {
      const res = await shieldApi.analyze({
        content: searchTerm,
        mode: "PATTERN",
        context: { events, entities, intelligence }
      });
      // Handle neural results - for now we just filter local view
      triggerStrengthMessage('PATTERN_DETECTED', 'AI-sökning slutförd med djupanalys.');
    } catch (error) {
      console.error("Neural search failed:", error);
    } finally {
      setIsNeuralSearching(false);
    }
  };

  const runAgentAnalysis = async (agentId: string) => {
    setActiveAgent(agentId);
    setIsScanning(true);
    try {
      await circuitBreaker.execute(agentId, async () => {
        let result;
        if (agentId === 'report' || agentId === 'orchestrator') {
          result = await shieldApi.generateComprehensiveReport({
            events: events.slice(0, 50),
            actors: entities,
            networkMembers: [],
            transactions: [],
            diaryEntries: []
          });
          setIntelReport({ ...result, reportTitle: agentId === 'report' ? "Strategisk Helhetsrapport" : "Strategisk Ledningsrapport" });
        } else if (agentId === 'escalation') {
          result = await shieldApi.analyzeEscalation({ newEvent: "", historicalEvents: events, actorProfiles: entities });
          setIntelReport({ ...result, reportTitle: "Eskalerings-Analys" });
        } else if (agentId === 'child') {
          result = await shieldApi.generateComprehensiveReport({ events, actors: entities });
          setIntelReport({ ...result, reportTitle: "BBIC Barnrätts-Rapport" });
        } else if (agentId === 'pattern') {
          result = await shieldApi.analyze({ content: "Analysera mönster", mode: "PATTERN", context: { events } });
          setIntelReport({ ...result, reportTitle: "Chronos Mönster-Rapport" });
        } else {
          result = await shieldApi.analyze({ content: "Analysera läge", mode: "PATTERN", context: { events } });
          setIntelReport({ ...result, reportTitle: "System-Analys" });
        }
      });
      triggerStrengthMessage('ANALYSIS_COMPLETE', `Agent ${agentId} har slutfört sitt uppdrag.`);
    } catch (error: any) {
      console.error("Agent analysis failed:", error);
      triggerStrengthMessage('SYSTEM_ERROR', error.message || 'Agenten kunde inte slutföra analysen just nu.');
    } finally {
      setIsScanning(false);
    }
  };

  const handleFileUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file || !userId) return;
    setUploading(true);
    try {
      await radarService.uploadEvidence(userId, file);
      const reader = new FileReader();
      reader.onload = async (event) => {
        const content = event.target?.result as string;
        await driveService.syncFile(`ARKIV_${new Date().toISOString().split('T')[0]}_${file.name}`, content, file.type);
        driveService.getVaultStatus().then(setDriveStatus);
      };
      reader.readAsText(file);
      triggerStrengthMessage('VAULT_SAVE', 'Bevis har arkiverats och synkroniserats med ditt Drive-valv.');
    } catch (error) {
      console.error("Arkivering misslyckades:", error);
    } finally {
      if (e.target) e.target.value = '';
      setUploading(false);
    }
  };

  const runQuickScan = async () => {
    if (!scanContent.trim()) return;
    setIsScanning(true);
    try {
      const res = await shieldApi.analyze({ content: scanContent, mode: "PATTERN", context: { entities } });
      setScanResult(res);
      triggerStrengthMessage('PATTERN_DETECTED');
    } catch (error) {
      console.error("Scan failed:", error);
    } finally {
      setIsScanning(false);
    }
  };

  const saveScanResult = async () => {
    if (!scanResult || !scanContent) return;
    setUploading(true);
    try {
      await addDoc(collection(db, 'vault_intelligence'), {
        userId,
        fileName: `Quick-Scan: ${new Date().toLocaleDateString()}`,
        originalText: scanContent,
        analysis: scanResult,
        timestamp: serverTimestamp(),
        isSelfMade: true,
        isAuthentic: true
      });
      setScanContent('');
      setScanResult(null);
      triggerStrengthMessage('VAULT_SAVE', 'Analysen har sparats i arkivet.');
      setActiveTab('INTELLIGENCE');
    } catch (error) {
      console.error("Kunde inte spara scan:", error);
    } finally {
      setUploading(false);
    }
  };

  const handleDownloadPDF = () => {
    if (!intelReport) return;
    const doc = new jsPDF();
    doc.setFontSize(22);
    doc.text(intelReport.reportTitle || "Intelligensrapport", 14, 22);
    doc.setFontSize(10);
    doc.text(`Genererad: ${new Date().toLocaleString('sv-SE')}`, 14, 30);
    doc.line(14, 40, 196, 40);
    let content = JSON.stringify(intelReport, null, 2);
    let splitContent = doc.splitTextToSize(content, 180);
    doc.text(splitContent, 14, 50);
    doc.save(`Rapport_${new Date().toISOString().split('T')[0]}.pdf`);
  };

  const filteredIntelligence = intelligence.filter(item => {
    if (!searchTerm) return true;
    return JSON.stringify(item).toLowerCase().includes(searchTerm.toLowerCase());
  });

  return (
    <div className="space-y-12 pb-40 px-6 max-w-7xl mx-auto">
      {/* Header Section */}
      <div className="flex flex-col md:flex-row justify-between items-start md:items-center gap-10 mt-10">
        <div className="space-y-2">
          <h2 className="text-4xl md:text-5xl text-white font-outfit font-light tracking-tighter flex items-center gap-5">
            <div className="p-4 bg-indigo-500/10 rounded-[2rem] border border-indigo-500/20">
              <Lock className="w-8 h-8 text-indigo-400" />
            </div>
            Verklighetsvalvet
          </h2>
          <p className="text-lg text-slate-500 font-outfit font-light max-w-2xl">
            Säkrad ledningscentral för bevisföring och strategisk analys.
          </p>
          {driveStatus?.active && (
            <div className="flex items-center gap-3 px-4 py-2 bg-teal-500/10 border border-teal-500/20 rounded-xl w-fit mt-4">
               <Database className="w-4 h-4 text-teal-400" />
               <span className="text-[10px] font-black text-teal-400 uppercase tracking-widest">
                 Drive-Valv Aktivt ({driveStatus.fileCount} objekt)
               </span>
            </div>
          )}
        </div>

        <div className="flex items-center gap-4">
          <button 
            onClick={() => setShowVivir(true)}
            className="flex items-center gap-4 px-8 py-5 rounded-3xl font-outfit font-bold text-xs bg-rose-500/10 text-rose-400 border border-rose-500/20 hover:bg-rose-500/20 transition-all uppercase tracking-widest shadow-xl"
          >
            <ShieldAlert className="w-5 h-5" />
            Akut-Filter
          </button>

          <label className={cn(
            "flex items-center gap-4 px-10 py-5 rounded-3xl font-outfit font-bold text-sm cursor-pointer transition-all active:scale-95 shadow-2xl",
            uploading ? "bg-slate-800 text-slate-500" : "bg-indigo-600 text-white hover:bg-indigo-500 shadow-indigo-900/40"
          )}>
            {uploading ? <Loader2 className="w-5 h-5 animate-spin" /> : <UploadCloud className="w-5 h-5" />}
            {uploading ? "Säkrar..." : "Arkivera Bevis"}
            <input type="file" className="hidden" onChange={handleFileUpload} disabled={uploading} />
          </label>
        </div>
      </div>

      <AnimatePresence>
        {showVivir && <VivirEmergencyFilter userId={userId} onClose={() => setShowVivir(false)} />}
      </AnimatePresence>

      {/* Tabs Navigation */}
      <div className="flex flex-wrap gap-2 p-2 bg-slate-950/40 border border-white/5 rounded-[2rem] backdrop-blur-xl">
        {[
          { id: 'COMMAND', label: 'Ledning', icon: LayoutGrid },
          { id: 'SCAN', label: 'Sköld', icon: Zap },
          { id: 'INTELLIGENCE', label: 'Arkiv', icon: Database },
          { id: 'SYNAPSE', label: 'Synapser', icon: Network },
          { id: 'CHRONOS', label: 'Mönster', icon: History },
          { id: 'DOSSIER', label: 'Dossier', icon: FileText },
          { id: 'CHILD', label: 'Barn', icon: Baby },
          { id: 'ECONOMY', label: 'Ekonomi', icon: Wallet },
          { id: 'SCHEMA', label: 'Schema', icon: Calendar },
          { id: 'PENNY', label: 'Penny', icon: PiggyBank },
          { id: 'MIRROR', label: 'Spegling', icon: Eye },
          { id: 'MANUAL', label: 'Hjälp', icon: HelpCircle },
        ].map(tab => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as VaultTab)}
            className={cn(
              "px-5 py-3 rounded-2xl text-[10px] font-bold uppercase tracking-widest transition-all flex items-center gap-2 border",
              activeTab === tab.id 
                ? "bg-indigo-500/20 border-indigo-500/30 text-indigo-300 shadow-lg" 
                : "bg-transparent border-transparent text-slate-500 hover:text-slate-300 hover:bg-white/5"
            )}
          >
            <tab.icon className="w-3.5 h-3.5" />
            <span>{tab.label}</span>
          </button>
        ))}
      </div>

      <main className="relative min-h-[600px]">
        <AnimatePresence mode="wait">
          {activeTab === 'COMMAND' && (
            <motion.div key="command" initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0 }}>
              <TacticalStatusBoard userId={userId} />
              <VaultCommand 
                agents={agents}
                activeAgent={activeAgent}
                isScanning={isScanning}
                runAgentAnalysis={runAgentAnalysis}
                intelReport={intelReport}
                handleDownloadPDF={handleDownloadPDF}
              />
            </motion.div>
          )}

          {activeTab === 'SCAN' && (
            <VaultRealityShield 
              scanContent={scanContent}
              setScanContent={setScanContent}
              runQuickScan={runQuickScan}
              isScanning={isScanning}
              scanResult={scanResult}
              saveScanResult={saveScanResult}
              uploading={uploading}
            />
          )}

          {activeTab === 'INTELLIGENCE' && (
            <VaultIntelligence 
              searchTerm={searchTerm}
              setSearchTerm={setSearchTerm}
              runNeuralSearch={runNeuralSearch}
              isNeuralSearching={isNeuralSearching}
              loading={loading}
              filteredIntelligence={filteredIntelligence}
            />
          )}

          {activeTab === 'SYNAPSE' && (
            <VaultSynapse 
              intelReport={intelReport}
              runAgentAnalysis={runAgentAnalysis}
              isScanning={isScanning}
              agents={agents}
            />
          )}

          {activeTab === 'CHRONOS' && (
            <VaultChronos 
              isScanning={isScanning}
              runAgentAnalysis={runAgentAnalysis}
              intelReport={intelReport}
            />
          )}

          {activeTab === 'DOSSIER' && (
            <VaultDossier 
              events={events}
              isScanning={isScanning}
              runAgentAnalysis={runAgentAnalysis}
              intelReport={intelReport}
              handleDownloadPDF={handleDownloadPDF}
            />
          )}

          {activeTab === 'CHILD' && (
            <motion.div key="child" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <ChildSafetyLog userId={userId} />
            </motion.div>
          )}

          {activeTab === 'ECONOMY' && (
            <motion.div key="economy" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <EconomicAuditor transactions={transactions} />
            </motion.div>
          )}

          {activeTab === 'SCHEMA' && (
            <motion.div key="schema" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <ScheduleAssistant />
            </motion.div>
          )}

          {activeTab === 'PENNY' && (
            <motion.div key="penny" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <PennyAgent userId={userId} />
            </motion.div>
          )}

          {activeTab === 'MIRROR' && (
            <motion.div key="mirror" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <RealityMirror userId={userId} />
            </motion.div>
          )}

          {activeTab === 'MANUAL' && (
            <motion.div key="manual" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }}>
              <SystemManual />
            </motion.div>
          )}
        </AnimatePresence>
      </main>
    </div>
  );
};
