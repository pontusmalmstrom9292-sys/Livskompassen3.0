/**
 * LivsKompassen - Google Apps Script Frontend Gateway
 * Syfte: Renderar UI och sköter säker kommunikation (OIDC) med backend.
 */

function doGet() {
  return HtmlService.createHtmlOutputFromFile('Index')
      .setTitle('LivsKompassen')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no')
      .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

/**
 * Funktion som anropas av gränssnittet för att prata med Cloud Run.
 * Sköter säker kommunikation via OIDC-token.
 */
function askAgent(moduleName, userInput) {
  // URL till din framtida Cloud Run-tjänst (Backend)
  const cloudRunUrl = 'https://ditt-unika-cloud-run-namn.a.run.app/analyze';
  
  // Hämtar en säker OIDC-token för dig som inloggad användare
  const idToken = ScriptApp.getIdentityToken();
  
  const options = {
    method: 'post',
    contentType: 'application/json',
    headers: {
      'Authorization': 'Bearer ' + idToken
    },
    payload: JSON.stringify({
      mode: moduleName,
      content: userInput
    }),
    muteHttpExceptions: true
  };

  try {
    const response = UrlFetchApp.fetch(cloudRunUrl, options);
    const content = response.getContentText();
    return JSON.parse(content);
  } catch (error) {
    return { error: "Kunde inte nå Intelligence Hub: " + error.toString() };
  }
}

/**
 * Sparar ett dokument säkert i användarens Google Drive.
 * Skapar mappen "Verklighetsvalvet" om den inte finns.
 */
function syncToDriveVault(fileName, content, mimeType = "text/plain") {
  const FOLDER_NAME = "Verklighetsvalvet_Arkiv";
  try {
    let folder;
    const folders = DriveApp.getFoldersByName(FOLDER_NAME);
    
    if (folders.hasNext()) {
      folder = folders.next();
    } else {
      folder = DriveApp.createFolder(FOLDER_NAME);
      folder.setDescription("Säkert arkiv för Verklighetsvalvet. Innehåller bevisföring och intelligensrapporter.");
    }
    
    // Skapa filen
    const file = folder.createFile(fileName, content, mimeType);
    
    // Gör filen "Skrivskyddad" för att simulera WORM-protokoll (valfritt men säkert)
    // file.setViewerCanDownload(true); 
    
    return { 
      success: true, 
      fileId: file.getId(), 
      url: file.getUrl(),
      timestamp: new Date().toISOString()
    };
  } catch (error) {
    return { success: false, error: error.toString() };
  }
}

/**
 * Hämtar status för Drive-valvet.
 */
function getDriveVaultStatus() {
  const FOLDER_NAME = "Verklighetsvalvet_Arkiv";
  try {
    const folders = DriveApp.getFoldersByName(FOLDER_NAME);
    if (folders.hasNext()) {
      const folder = folders.next();
      const files = folder.getFiles();
      let count = 0;
      while (files.hasNext()) {
        files.next();
        count++;
      }
      return { active: true, fileCount: count, folderUrl: folder.getUrl() };
    }
    return { active: false, fileCount: 0 };
  } catch (error) {
    return { active: false, error: error.toString() };
  }
}
</file>

