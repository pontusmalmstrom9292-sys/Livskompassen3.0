      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data()
      } as SystemSynapse));
      
      // If no synapses in DB, we could show the INITIAL_SYNAPSES as placeholders or seed them
      setSynapses(docs.length > 0 ? docs : INITIAL_SYNAPSES.map(s => ({ ...s, userId: user.uid })));
