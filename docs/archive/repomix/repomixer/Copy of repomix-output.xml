"""
Agent 3: Ekonomisk Fotspår-Agenten (EconomicAgent)

Uppdrag:
  Analyserar transaktionsdata och ekonomiskt beteende för mönster av
  ekonomisk kontroll, manipulation och finansiellt missbruk.
  Identifierar impulsivitet (ADHD-kopplat) vs. extern press.

Triggers:
  - Manuellt via "Ekonomisk Analys"-knappen i Ekonomi-sidan
  - Automatiskt månadsvis

Output:
  {
    "healthScore": 0-100,
    "controlPatterns": [{"pattern": str, "evidence": str, "riskLevel": str}],
    "abuseIndicators": [{"indicator": str, "amount": float, "date": str}],
    "impulsivityScore": 0-100,
    "externalPressureScore": 0-100,
    "safeguardingAdvice": [{"action": str, "priority": str}],
    "monthlyTrend": "IMPROVING|STABLE|DETERIORATING",
    "forensicSummary": "Sammanfattning lämplig för juridisk dokumentation",
    "groundingPoints": [...]
  }
"""
from typing import Dict, Any, List
from .base_agent import BaseAgent


class EconomicAgent(BaseAgent):
    AGENT_NAME = "Ekonomisk Fotspår-Agenten"
    AGENT_ROLE = "Identifierar ekonomisk kontroll, manipulation och finansiellt missbruk"

    async def analyze(self, data: Dict[str, Any]) -> Dict:
        transactions = data.get("transactions", [])
        savings_goals = data.get("savingsGoals", [])
        time_period = data.get("timePeriod", "30 dagar")
        context_notes = data.get("contextNotes", "")

        # 1. Jordar mot ekonomisk kontroll och financial abuse-forskning
        grounding = await self._ground_with_vertex_search(
            "ekonomisk kontroll finansiellt missbruk separation eftervåld"
        )
        context_block = self._build_context_block(grounding)

        # 2. Bygg transaktionssammanfattning (anonymiserar känsliga detaljer i prompt)
        total_income = sum(t.get("amount", 0) for t in transactions if t.get("amount", 0) > 0)
        total_expenses = abs(sum(t.get("amount", 0) for t in transactions if t.get("amount", 0) < 0))

        categories: Dict[str, float] = {}
        for t in transactions:
            cat = t.get("category", "Övrigt")
            categories[cat] = categories.get(cat, 0) + abs(t.get("amount", 0))

        category_block = "\n".join([f"  {cat}: {amt:.0f} kr" for cat, amt in sorted(categories.items(), key=lambda x: x[1], reverse=True)])

        # Flaggar suspekta transaktioner
        suspicious = [
            t for t in transactions
            if any(kw in (t.get("description", "") or "").lower()
                   for kw in ["kontant", "cash", "untaxed", "dolda", "okänd", "anonym"])
        ]
        suspicious_block = "\n".join([
            f"  [{t.get('date', '')}] {t.get('description', '')} – {t.get('amount', 0)} kr"
            for t in suspicious[:10]
        ])

        prompt = f"""
Du är "Ekonomisk Fotspår-Agenten" – ett AI-system som analyserar ekonomiska mönster
för att identifiera finansiellt missbruk, ekonomisk kontroll och manipulativa mönster
i separationskonflikter.

REFERENSFAKTA (Från manualer):
{context_block}

EKONOMISK ÖVERSIKT (Perioden: {time_period}):
- Total inkomst: {total_income:.0f} kr
- Totala utgifter: {total_expenses:.0f} kr
- Netto: {total_income - total_expenses:.0f} kr

UTGIFTER PER KATEGORI:
{category_block if category_block else "Inga kategorier"}

SUSPEKTA TRANSAKTIONER:
{suspicious_block if suspicious_block else "Inga suspekta transaktioner identifierade"}

SPARMÅL:
{', '.join([f"{g.get('title', '')} ({g.get('currentAmount', 0)}/{g.get('targetAmount', 0)} kr)" for g in savings_goals[:5]]) if savings_goals else "Inga sparmål"}

KONTEXT FRÅN ANVÄNDAREN:
{context_notes if context_notes else "Ingen extra kontext"}

UPPGIFT:
1. Identifiera mönster av ekonomisk kontroll eller press utifrån
2. Bedöm impulsivitet vs. yttre press (ADHD-kontextualisera)
3. Ge juridiskt användbar forensisk sammanfattning
4. Föreslå konkreta skyddsåtgärder

Svara STRIKT i JSON:
{{
  "healthScore": <0-100, 100=perfekt ekonomisk hälsa>,
  "controlPatterns": [
    {{"pattern": "<mönsternamn>", "evidence": "<bevis från data>", "riskLevel": "HÖG|MEDEL|LÅG"}}
  ],
  "abuseIndicators": [
    {{"indicator": "<indikator>", "type": "EXTERN_KONTROLL|SABOTAGE|UTTARMNING|ISOLERING"}}
  ],
  "impulsivityScore": <0-100, relaterat till ADHD>,
  "externalPressureScore": <0-100, ekonomisk press utifrån>,
  "safeguardingAdvice": [
    {{"action": "<åtgärd>", "priority": "OMEDELBAR|HÖG|MEDIUM", "rationale": "<varför>"}}
  ],
  "monthlyTrend": "IMPROVING|STABLE|DETERIORATING",
  "forensicSummary": "<objektiv sammanfattning lämplig för juridisk dokumentation, neutral ton>",
  "groundingPoints": ["<fakta från manualerna>"]
}}
"""
        return self._call_model(prompt)
