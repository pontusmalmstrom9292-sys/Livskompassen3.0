<file path="livskompassen-trasig-1/src/components/VaultDocumentation.tsx">
import React, { useState, useRef } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { 
  MessageSquare, UploadCloud, FileText, Phone, Loader2, Check, 
  Lock, Plus, X, Mic, Image, ChevronRight, Users, Calendar, Sparkles,
  Shield, Brain, Heart, AlertCircle, Quote
} from 'lucide-react';
import { geminiService } from '../services/geminiService';
import { radarService } from '../services/radarService';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { cn } from '../lib/utils';

type DocTab = 'TEXT' | 'COMM' | 'QUICK' | 'MEDIA';

interface VaultDocumentationProps {
  userId: string;
  onPanic?: () => void;
}

const parseJSON = (d: any) => {
  if (typeof d === 'object' && d !== null) return d;
  try { return JSON.parse((d as string).replace(/```json/g, '').replace(/```/g, '').trim()); }
  catch { return {}; }
};

export const VaultDocumentation: React.FC<VaultDocumentationProps> = ({ userId, onPanic }) => {
  const { entities } = useSystemMemory();
  const [tab, setTab] = useState<DocTab>('TEXT');
  const [isSaving, setIsSaving] = useState(false);
  const [saveSuccess, setSaveSuccess] = useState(false);
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [analysisResult, setAnalysisResult] = useState<any>(null);
  const fileRef = useRef<HTMLInputElement>(null);

  // Text tab state
  const [textContent, setTextContent] = useState('');
  const [selectedEntity, setSelectedEntity] = useState('');
  const [evidenceType, setEvidenceType] = useState('SMS');

  // Comm log tab state
  const [commParty, setCommParty] = useState('');
  const [commChannel, setCommChannel] = useState('Mejl');
  const [commDate, setCommDate] = useState(new Date().toISOString().split('T')[0]);
  const [commSummary, setCommSummary] = useState('');
  const [commOutcome, setCommOutcome] = useState('');

  // Quick note tab
  const [quickNote, setQuickNote] = useState('');

  const EVIDENCE_TYPES = ['SMS', 'Mejl', 'Telefonsamtal', 'Möte', 'Beslut', 'Observation', 'Vittnesmål', 'Övrigt'];
  const CHANNELS = ['Mejl', 'Telefon', 'Möte', 'Brev', 'SMS', 'Teams/Zoom', 'Övrigt'];

  const [isSelfMade, setIsSelfMade] = useState(true);
  const [isAuthentic, setIsAuthentic] = useState(true);

  const handleAnalyzeAndSave = async () => {
    if (!textContent.trim()) return;
    setIsAnalyzing(true);
    setAnalysisResult(null);
    try {
      // 6-Agent Parallel Analysis via Gemini
      const [patternRes, legalRes, biffRes, actorRes] = await Promise.all([
        geminiService.subAgentAnalysis(textContent, 'PATTERN'),
        geminiService.subAgentAnalysis(textContent, 'LEGAL'),
        geminiService.subAgentAnalysis(textContent, 'BIFF'),
        geminiService.subAgentAnalysis(textContent, 'ACTOR_ID', entities),
      ]);

      const coordRes = await geminiService.coordinateAnalysis(
        { 
          pattern: parseJSON(patternRes), 
          legal: parseJSON(legalRes), 
          biff: parseJSON(biffRes), 
          actors: parseJSON(actorRes) 
        },
        entities.map(e => `${e.name}: ${e.bio || ''}`).join('. ')
      );
      
      const result = parseJSON(coordRes);
      setAnalysisResult(result);

      // Auto-save to vault with immutable ledger protocol
      await radarService.saveEvent(userId, {
        type: evidenceType,
        description: result.masterInsight || textContent.substring(0, 120),
        originalText: textContent,
        aiAnalysis: {
          redFlags: result.detectedTactics?.map((t: any) => t.name) || [],
          biffResponse: result.biffResponse || '',
          unidentifiedActors: parseJSON(actorRes)?.unidentified || []
        },
        involvedActors: selectedEntity ? [selectedEntity] : (parseJSON(actorRes)?.involvedActors || []),
        timestamp: new Date(),
        isSelfMade,
        isAuthentic
      });

      setSaveSuccess(true);
      setTimeout(() => setSaveSuccess(false), 3000);
      setTextContent('');
    } catch (err) {
      console.error('Analysis failed:', err);
    } finally {
      setIsAnalyzing(false);
    }
  };

  const handleSaveComm = async () => {
    if (!commParty.trim() || !commSummary.trim()) return;
    setIsSaving(true);
    try {
      await radarService.addCommunicationEntry(userId, {
        party: commParty,
        channel: commChannel,
        summary: commSummary,
        outcome: commOutcome,
        date: commDate
      });
      setCommParty(''); setCommSummary(''); setCommOutcome('');
      setSaveSuccess(true);
      setTimeout(() => setSaveSuccess(false), 2000);
    } catch (e) {
      console.error(e);
    } finally {
      setIsSaving(false);
    }
  };

  const handleSaveQuick = async () => {
    if (!quickNote.trim()) return;
    setIsSaving(true);
    try {
      await radarService.saveEvent(userId, {
        type: 'SNABBNOTERING',
        description: quickNote.substring(0, 150),
        originalText: quickNote,
        aiAnalysis: { redFlags: [], biffResponse: '', unidentifiedActors: [] },
        involvedActors: [],
        timestamp: new Date()
      });
      setQuickNote('');
      setSaveSuccess(true);
      setTimeout(() => setSaveSuccess(false), 2000);
    } catch (e) {
      console.error(e);
    } finally {
      setIsSaving(false);
    }
  };

  const handleMediaUpload = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    setIsSaving(true);
    try {
      await radarService.uploadEvidence(userId, file);
      setSaveSuccess(true);
      setTimeout(() => setSaveSuccess(false), 3000);
    } catch (err) {
      console.error(err);
    } finally {
      setIsSaving(false);
      if (e.target) e.target.value = '';
    }
  };

  const TABS: { id: DocTab; label: string; icon: any; color: string }[] = [
    { id: 'TEXT', label: 'Analysera Text', icon: Sparkles, color: 'indigo' },
    { id: 'COMM', label: 'Kontakt-Logg', icon: Phone, color: 'teal' },
    { id: 'QUICK', label: 'Snabbrapport', icon: Quote, color: 'amber' },
    { id: 'MEDIA', label: 'Fil / Bevis', icon: Image, color: 'violet' },
  ];

  return (
    <div className="space-y-8 max-w-4xl mx-auto pb-20 animate-in fade-in slide-in-from-bottom-4 duration-1000">
      {/* Panic Close if provided */}
      {onPanic && (
        <div className="flex justify-end">
          <button onClick={onPanic} className="px-6 py-2 bg-rose-500/10 text-rose-400 border border-rose-500/20 rounded-full text-[10px] font-black uppercase tracking-widest hover:bg-rose-500 hover:text-white transition-all">
            Panik-Stäng
          </button>
        </div>
      )}

      {/* Tab Selector - "Atmospheric Zen" Grid */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
        {TABS.map(t => (
          <button
            key={t.id}
            onClick={() => { setTab(t.id); setAnalysisResult(null); }}
            className={cn(
              'flex flex-col items-center gap-3 py-6 px-4 rounded-[2rem] border transition-all duration-500',
              tab === t.id
                ? `bg-${t.color}-500/10 border-${t.color}-500/30 text-${t.color}-300 shadow-2xl shadow-${t.color}-900/20 scale-[1.02]`
                : 'bg-white/[0.02] border-white/5 text-slate-500 hover:text-slate-300 hover:bg-white/5'
            )}
          >
            <t.icon className={cn("w-5 h-5", tab === t.id ? "animate-pulse" : "")} />
            <span className="text-[9px] font-black uppercase tracking-[0.2em] text-center leading-tight">{t.label}</span>
          </button>
        ))}
      </div>

      <AnimatePresence mode="wait">
        {/* ── TEXT ANALYSIS ── */}
        {tab === 'TEXT' && (
          <motion.div key="text" initial={{ opacity: 0, scale: 0.98 }} animate={{ opacity: 1, scale: 1 }} exit={{ opacity: 0, scale: 0.98 }}
            className="bg-[#05050a]/60 backdrop-blur-3xl border border-white/5 rounded-[3rem] p-8 lg:p-12 space-y-10 shadow-2xl">

            <div className="space-y-3">
              <h3 className="text-3xl font-outfit font-light text-white tracking-tight">Intelligence Input</h3>
              <p className="text-[10px] text-indigo-400 uppercase tracking-[0.3em] font-black">6-agents parallellanalys + Automatisk Arkivering</p>
            </div>

            <div className="space-y-6">
              {/* Evidence type selector */}
              <div>
                <p className="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-4">Bevistyp</p>
                <div className="flex flex-wrap gap-2">
                  {EVIDENCE_TYPES.map(type => (
                    <button key={type} onClick={() => setEvidenceType(type)}
                      className={cn('px-4 py-2 rounded-full text-[9px] font-black uppercase tracking-widest border transition-all',
                        evidenceType === type ? 'bg-indigo-500/20 border-indigo-500/40 text-indigo-300' : 'border-white/5 text-slate-500 hover:border-white/10'
                      )}>
                      {type}
                    </button>
                  ))}
                </div>
              </div>

              {/* Entity tag */}
              {entities.length > 0 && (
                <div>
                  <p className="text-[9px] font-black text-slate-500 uppercase tracking-widest mb-4">Tagga Aktör</p>
                  <div className="flex flex-wrap gap-2">
                    <button onClick={() => setSelectedEntity('')}
                      className={cn('px-4 py-2 rounded-full text-[9px] font-black border transition-all uppercase tracking-widest',
                        selectedEntity === '' ? 'bg-slate-800 border-slate-600 text-white' : 'border-white/5 text-slate-500'
                      )}>
                      Ingen
                    </button>
                    {entities.map(e => (
                      <button key={e.id} onClick={() => setSelectedEntity(e.id || '')}
                        className={cn('px-4 py-2 rounded-full text-[9px] font-black border transition-all flex items-center gap-2 uppercase tracking-widest',
                          selectedEntity === e.id ? 'bg-indigo-500/20 border-indigo-500/40 text-indigo-300' : 'border-white/5 text-slate-500 hover:border-white/10'
                        )}>
                        <Users className="w-3 h-3" />
                        {e.name}
                      </button>
                    ))}
                  </div>
                </div>
              )}

              <div className="relative">
                <textarea
                  value={textContent}
                  onChange={e => setTextContent(e.target.value)}
                  placeholder="Klistra in SMS, mejl, domar eller egna anteckningar..."
                  className="w-full h-64 bg-black/40 border border-white/5 rounded-[2rem] p-8 text-slate-200 placeholder-slate-800 focus:outline-none focus:ring-1 focus:ring-indigo-500/30 transition-all font-inter leading-relaxed resize-none text-sm shadow-inner"
                />
                <div className="absolute bottom-6 right-6 flex gap-2">
                  <div className="p-2 bg-indigo-500/10 rounded-lg border border-indigo-500/20">
                    <Brain className="w-4 h-4 text-indigo-400" />
                  </div>
                </div>
              </div>

              <div className="flex flex-wrap gap-4">
                <button onClick={() => setIsSelfMade(!isSelfMade)}
                  className={cn('px-6 py-3 rounded-2xl text-[9px] font-black uppercase tracking-widest border transition-all flex items-center gap-3',
                    isSelfMade ? 'bg-teal-500/10 border-teal-500/30 text-teal-400' : 'border-white/5 text-slate-500'
                  )}>
                  <FileText className="w-4 h-4" /> Egenupprättat
                </button>
                <button onClick={() => setIsAuthentic(!isAuthentic)}
                  className={cn('px-6 py-3 rounded-2xl text-[9px] font-black uppercase tracking-widest border transition-all flex items-center gap-3',
                    isAuthentic ? 'bg-indigo-500/10 border-indigo-500/30 text-indigo-400' : 'border-white/5 text-slate-500'
                  )}>
                  <Shield className="w-4 h-4" /> Garanterat Äkta
                </button>
              </div>

              <button
                onClick={handleAnalyzeAndSave}
                disabled={isAnalyzing || !textContent.trim()}
                className="w-full py-6 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-30 text-white rounded-[1.8rem] font-outfit font-black tracking-[0.3em] uppercase text-[10px] flex items-center justify-center gap-4 shadow-2xl shadow-indigo-900/40 transition-all active:scale-[0.99] group"
              >
                {isAnalyzing ? <><Loader2 className="w-5 h-5 animate-spin" /> Analyserar...</> : saveSuccess ? <><Check className="w-5 h-5" /> Säkrat i Valvet</> : <><Lock className="w-5 h-5 group-hover:animate-bounce" /> Analysera & Försegla</>}
              </button>
            </div>

            {/* Analysis result */}
            <AnimatePresence>
              {analysisResult && (
                <motion.div initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }}
                  className="space-y-8 pt-10 border-t border-white/5">

                  <div className="p-8 bg-indigo-500/5 border border-indigo-500/10 rounded-[2.5rem] space-y-4">
                    <div className="flex items-center gap-3">
                      <Sparkles className="w-4 h-4 text-indigo-400" />
                      <p className="text-[10px] font-black text-indigo-400 uppercase tracking-[0.2em]">Kärnan i Kommunikation</p>
                    </div>
                    <p className="text-xl text-slate-100 font-outfit leading-relaxed font-light">{analysisResult.masterInsight}</p>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {analysisResult.detectedTactics?.length > 0 && (
                      <div className="space-y-4">
                        <p className="text-[9px] font-black text-rose-400 uppercase tracking-widest px-4">Identifierade Taktiker</p>
                        <div className="flex flex-wrap gap-2 px-2">
                          {analysisResult.detectedTactics.map((t: any, i: number) => (
                            <span key={i} className="px-4 py-2 bg-rose-500/10 border border-rose-500/20 rounded-full text-[9px] font-black text-rose-400 uppercase tracking-widest">{t.name}</span>
                          ))}
                        </div>
                      </div>
                    )}

                    {analysisResult.biffResponse && (
                      <div className="space-y-4">
                         <p className="text-[9px] font-black text-teal-400 uppercase tracking-widest px-4">BIFF-Svarsförslag</p>
                        <div className="p-6 bg-teal-500/5 border border-teal-500/10 rounded-[2rem] relative group">
                          <p className="text-sm text-slate-300 italic leading-relaxed">"{analysisResult.biffResponse}"</p>
