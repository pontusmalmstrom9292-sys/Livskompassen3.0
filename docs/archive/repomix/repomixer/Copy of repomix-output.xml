import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { geminiService } from '../services/geminiService';
import { radarService } from '../services/radarService';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { Shield, Sparkles, ArrowRight, CheckCircle2, Timer, RefreshCw, X, Lock } from 'lucide-react';

interface TaskStep {
  id: number;
  text: string;
}

export const ProcrastinationStopper = () => {
  const { entities } = useSystemMemory(); // För framtida kopplingar
  const [task, setTask] = useState('');
  const [steps, setSteps] = useState<TaskStep[]>([]);
  const [currentStepIdx, setCurrentStepIdx] = useState(0);
  const [isLoading, setIsLoading] = useState(false);
  const [isSaving, setIsSaving] = useState(false);
  const [encouragement, setEncouragement] = useState('');
  const [isTimerActive, setIsTimerActive] = useState(false);
  const [timeLeft, setTimeLeft] = useState(300); // 5 minuter i sekunder
  const [isFinished, setIsFinished] = useState(false);

  useEffect(() => {
    let timer: NodeJS.Timeout;
    if (isTimerActive && timeLeft > 0) {
      timer = setInterval(() => setTimeLeft(prev => prev - 1), 1000);
    } else if (timeLeft === 0) {
      setIsTimerActive(false);
    }
    return () => clearInterval(timer);
  }, [isTimerActive, timeLeft]);

  const parseAI = (data: any) => {
    if (typeof data === 'object' && data !== null && data.steps) return data;
    try {
      const cleaned = data.replace(/```json/g, '').replace(/```/g, '').trim();
      return JSON.parse(cleaned);
    } catch (e) {
      console.error("Parse error", e);
      return null;
    }
  };

  const handleBreakDown = async () => {
    if (!task.trim()) return;
    setIsLoading(true);
    try {
      const res = await geminiService.breakDownTask(task);
      const data = parseAI(res);
      if (data && data.steps) {
        setSteps(data.steps);
        setEncouragement(data.encouragement);
        setCurrentStepIdx(0);
      }
    } catch (e) {
      console.error("Task breakdown error", e);
    } finally {
      setIsLoading(false);
    }
  };

  const reset = () => {
    setTask('');
    setSteps([]);
    setCurrentStepIdx(0);
    setIsTimerActive(false);
    setTimeLeft(300);
    setIsFinished(false);
  };

  const formatTime = (seconds: number) => {
    const m = Math.floor(seconds / 60);
    const s = seconds % 60;
    return `${m}:${s.toString().padStart(2, '0')}`;
  };

  return (
    <div className="w-full max-w-md mx-auto bg-[#0b3d2e] border border-[#d4af37]/20 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden min-h-[450px] flex flex-col">
      {/* Bakgrunds-glow */}
      <div className="absolute top-0 right-0 w-32 h-32 bg-[#d4af37]/5 blur-3xl rounded-full -mr-16 -mt-16" />
      
      <div className="relative z-10 flex-1 flex flex-col">
        <header className="mb-8 flex justify-between items-start">
          <div>
            <h3 className="text-2xl text-[#d4af37] font-serif tracking-wide">Sysslostopparen</h3>
            <p className="text-[10px] text-white/40 uppercase tracking-[0.2em] mt-1 font-bold italic">Övervinn motståndet</p>
          </div>
          {(steps.length > 0 || task) && (
            <button onClick={reset} className="p-2 hover:bg-white/5 rounded-full text-white/30 hover:text-white/60 transition-colors">
              <X className="w-4 h-4" />
            </button>
          )}
        </header>

        <AnimatePresence mode="wait">
          {isFinished ? (
            <motion.div
              key="finished"
              initial={{ opacity: 0, scale: 0.8 }}
              animate={{ opacity: 1, scale: 1 }}
              exit={{ opacity: 0, scale: 1.1 }}
              className="flex-1 flex flex-col items-center justify-center text-center space-y-6"
            >
              <div className="w-24 h-24 bg-[#d4af37]/20 rounded-full flex items-center justify-center border border-[#d4af37]/40 shadow-[0_0_50px_rgba(212,175,55,0.2)]">
                <CheckCircle2 className="w-12 h-12 text-[#d4af37]" />
              </div>
              <div>
                <h4 className="text-2xl text-white font-serif mb-2">Snyggt jobbat, Pontus!</h4>
                <p className="text-sm text-[#d4af37]/70 italic">"Varje liten seger räknas. Du övervann motståndet idag."</p>
              </div>
              <button
                onClick={reset}
                className="px-8 h-12 bg-white/5 border border-white/10 text-white rounded-full text-[10px] font-bold uppercase tracking-widest hover:bg-white/10 transition-all"
              >
                Gör något mer?
              </button>
            </motion.div>
          ) : steps.length === 0 ? (
            <motion.div
              key="input"
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -10 }}
              className="space-y-6 flex-1 flex flex-col justify-center"
            >
              <div className="space-y-3">
                <label className="text-[10px] text-[#F4F4F4]/50 uppercase tracking-[0.2em] font-bold ml-1">Vad känns övermäktigt just nu?</label>
                <textarea
                  value={task}
                  onChange={(e) => setTask(e.target.value)}
                  placeholder="T.ex. 'Diska berget i köket' eller 'Skriva klart rapporten'..."
                  className="w-full bg-[#082a20] border border-[#d4af37]/20 rounded-[2rem] p-6 text-[#F4F4F4] text-base focus:outline-none focus:border-[#d4af37]/50 transition-all placeholder:text-white/10 resize-none h-36 leading-relaxed shadow-inner"
                />
              </div>
              <button
                onClick={handleBreakDown}
                disabled={isLoading || !task.trim()}
                className="w-full h-14 bg-gradient-to-r from-[#d4af37] to-[#e6c96a] text-[#0b3d2e] rounded-full font-bold shadow-lg shadow-[#d4af37]/10 hover:opacity-90 transition-all flex items-center justify-center gap-3 disabled:opacity-30"
              >
                {isLoading ? (
                  <RefreshCw className="w-5 h-5 animate-spin" />
                ) : (
                  <>
                    <Sparkles className="w-5 h-5" />
                    Hjälp mig börja
                  </>
                )}
              </button>
            </motion.div>
          ) : (
            <motion.div
              key="steps"
              initial={{ opacity: 0, scale: 0.95 }}
              animate={{ opacity: 1, scale: 1 }}
              className="space-y-8 flex-1 flex flex-col"
            >
              {/* Det enda steget som räknas nu */}
              <div className="bg-[#082a20]/80 border border-[#d4af37]/20 rounded-[2rem] p-8 text-center relative overflow-hidden group shadow-inner">
                <div className="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#d4af37]/40 to-transparent" />
                <p className="text-[10px] text-[#d4af37]/50 uppercase tracking-[0.3em] font-bold mb-4">Gör bara detta:</p>
                <h4 className="text-xl text-white font-medium leading-relaxed italic">
                  "{steps[currentStepIdx]?.text}"
                </h4>
              </div>

              <div className="flex-1 space-y-6">
                {/* Micro Timer - 5 minuter är allt som krävs */}
                <div className="bg-white/5 rounded-3xl p-6 flex items-center justify-between border border-white/5 relative overflow-hidden">
                  {/* Progress bar background */}
                  <motion.div 
                    initial={{ width: '0%' }}
                    animate={{ width: `${((300 - timeLeft) / 300) * 100}%` }}
                    className="absolute inset-0 bg-[#d4af37]/5 pointer-events-none"
                  />
                  
                  <div className="flex items-center gap-4 relative z-10">
                    <div className={`p-3 rounded-2xl transition-colors duration-500 ${isTimerActive ? 'bg-[#d4af37]/20 text-[#d4af37] animate-pulse' : 'bg-white/5 text-white/20'}`}>
                      <Timer className="w-6 h-6" />
                    </div>
                    <div>
                      <p className="text-[10px] text-white/40 uppercase tracking-widest font-bold">Bara 5 minuter</p>
                      <p className={`text-2xl font-mono tracking-wider ${isTimerActive ? 'text-white' : 'text-white/30'}`}>{formatTime(timeLeft)}</p>
                    </div>
                  </div>
                  <button
                    onClick={() => setIsTimerActive(!isTimerActive)}
                    className={`px-6 h-12 rounded-full text-[10px] font-bold uppercase tracking-[0.2em] transition-all relative z-10 ${
                      isTimerActive 
                        ? 'bg-white/10 text-white' 
                        : 'bg-[#d4af37]/10 text-[#d4af37] border border-[#d4af37]/30 hover:bg-[#d4af37]/20'
                    }`}
                  >
                    {isTimerActive ? 'Pausa' : 'Starta'}
                  </button>
                </div>

                {encouragement && (
                  <p className="text-xs text-center text-[#d4af37]/70 italic font-medium px-4 leading-relaxed opacity-80">
                    "{encouragement}"
                  </p>
                )}
              </div>

              <div className="flex gap-4 pt-4">
                <button
                  onClick={() => setCurrentStepIdx(prev => Math.min(steps.length - 1, prev + 1))}
                  disabled={currentStepIdx === steps.length - 1}
                  className="flex-1 h-14 bg-white/5 border border-white/10 text-white/60 rounded-full font-bold text-[10px] uppercase tracking-[0.2em] hover:bg-white/10 transition-all disabled:opacity-20"
                >
                  Visa nästa mikrosteg
                </button>
                <button
                  onClick={() => setIsFinished(true)}
                  className="h-14 w-14 bg-gradient-to-tr from-[#d4af37]/20 to-[#d4af37]/40 border border-[#d4af37]/40 text-[#d4af37] rounded-full flex items-center justify-center hover:bg-[#d4af37]/30 transition-all shadow-lg shadow-[#d4af37]/10"
                >
                  <CheckCircle2 className="w-6 h-6" />
                </button>
              </div>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
};
</file>

