<file path="livskompassen-trasig-1/src/components/ThoughtfulNo.tsx">
import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { Hand, Clock, ShieldAlert, CheckCircle2, MessageSquare, Loader2, Copy } from 'lucide-react';
import { geminiService } from '../services/geminiService';
import { useLearning } from '../contexts/LearningContext';

export const ThoughtfulNo = () => {
  const [step, setStep] = useState<'IDLE' | 'COUNTDOWN' | 'REFLECT' | 'RESULT'>('IDLE');
  const [countdown, setCountdown] = useState(10);
  const [requestText, setRequestText] = useState('');
  const [isGenerating, setIsGenerating] = useState(false);
  const [boundaryResults, setBoundaryResults] = useState<{ validation: string, scripts: { soft: string, biff: string, greyRock: string } } | null>(null);
  const [selectedScriptType, setSelectedScriptType] = useState<'soft' | 'biff' | 'greyRock'>('biff');
  const { triggerStrengthMessage } = useLearning();

  useEffect(() => {
    let timer: NodeJS.Timeout;
    if (step === 'COUNTDOWN' && countdown > 0) {
      timer = setTimeout(() => setCountdown(c => c - 1), 1000);
    } else if (step === 'COUNTDOWN' && countdown === 0) {
      setStep('REFLECT');
    }
    return () => clearTimeout(timer);
  }, [step, countdown]);

  const handleStart = () => {
    if (!requestText.trim()) return;
    setStep('COUNTDOWN');
    setCountdown(10);
  };

  const generateReply = async () => {
    setIsGenerating(true);
    try {
      // Vi simulerar en snabb analys av inre status (vi kan bygga ut detta senare)
      const analysis = { bandwidth: false, aligns: true, fear: true };
      const res = await (geminiService as any).generateBoundaryScripts(requestText, analysis);
      setBoundaryResults(res);
      setStep('RESULT');
      triggerStrengthMessage('IMPULSE_AVOIDED', 'Bravo. Du tog makten över pausen och lät inte stressen styra ditt svar.');
    } catch (e) {
      console.error(e);
      setBoundaryResults({
        validation: "Det är okej att ta tid på sig att svara.",
        scripts: {
          soft: "Jag har sett ditt meddelande och återkommer när jag har möjlighet.",
          biff: "Jag har tagit emot informationen. Jag återkommer imorgon med svar.",
          greyRock: "Mottaget."
        }
      });
      setStep('RESULT');
    } finally {
      setIsGenerating(false);
    }
  };

  const copyToClipboard = () => {
    const text = boundaryResults?.scripts[selectedScriptType] || "";
    navigator.clipboard.writeText(text);
    triggerStrengthMessage('COMPASS_COMPLETE', 'Svaret är kopierat. Klistra in och skicka. Du är trygg.');
    setTimeout(() => {
      setStep('IDLE');
      setRequestText('');
      setBoundaryResults(null);
    }, 2000);
  };

  return (
    <div className="bg-[#0f172a]/60 backdrop-blur-xl border border-indigo-500/20 rounded-[2.5rem] p-8 shadow-2xl relative overflow-hidden">
      <div className="absolute top-0 right-0 w-64 h-64 bg-indigo-500/5 rounded-full blur-[80px]" />
      
      <div className="flex items-center gap-4 mb-6 relative z-10">
        <div className="w-12 h-12 bg-indigo-500/10 rounded-2xl border border-indigo-500/20 flex items-center justify-center">
          <Hand className="w-6 h-6 text-indigo-400" />
        </div>
        <div>
          <h3 className="text-xl text-slate-100 font-outfit font-light tracking-wide">Det Tänksamma Nej-et</h3>
          <p className="text-[10px] text-indigo-400 uppercase tracking-widest font-bold">Impuls-broms för orimliga krav</p>
        </div>
      </div>

      <AnimatePresence mode="wait">
        {step === 'IDLE' && (
          <motion.div key="idle" initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="space-y-4 relative z-10">
            <p className="text-sm text-slate-400 italic">
              Har du precis fått ett sms eller krav som fick din puls att öka? Klistra in det här innan du svarar.
            </p>
            <textarea
              value={requestText}
              onChange={(e) => setRequestText(e.target.value)}
              placeholder="Vad vill de att du ska göra?"
              className="w-full h-24 bg-black/40 border border-white/5 rounded-2xl p-4 text-sm text-slate-200 placeholder:text-slate-600 focus:outline-none focus:border-indigo-500/30 resize-none"
            />
            <button
              onClick={handleStart}
              disabled={!requestText.trim()}
              className="w-full py-4 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl font-bold text-sm tracking-widest uppercase transition-all disabled:opacity-30 flex items-center justify-center gap-2"
            >
              <ShieldAlert className="w-4 h-4" />
              Bromsa & Reflektera
            </button>
          </motion.div>
        )}

        {step === 'COUNTDOWN' && (
          <motion.div key="countdown" initial={{ scale: 0.9, opacity: 0 }} animate={{ scale: 1, opacity: 1 }} exit={{ scale: 1.1, opacity: 0 }} className="flex flex-col items-center justify-center py-10 relative z-10">
            <div className="relative flex items-center justify-center w-32 h-32 mb-6">
              <svg className="absolute inset-0 w-full h-full transform -rotate-90">
                <circle cx="64" cy="64" r="60" stroke="#1e293b" strokeWidth="8" fill="none" />
                <circle cx="64" cy="64" r="60" stroke="#818cf8" strokeWidth="8" fill="none" strokeDasharray="377" strokeDashoffset={377 - (377 * countdown) / 10} className="transition-all duration-1000 ease-linear" />
              </svg>
              <span className="text-4xl font-outfit font-light text-indigo-400">{countdown}</span>
            </div>
            <h4 className="text-lg text-slate-200 mb-2 font-outfit tracking-wide">Pausa och Andas</h4>
            <p className="text-xs text-slate-400 uppercase tracking-widest font-bold">Låt amygdalan lugna ner sig</p>
          </motion.div>
        )}

        {step === 'REFLECT' && (
          <motion.div key="reflect" initial={{ opacity: 0, y: 20 }} animate={{ opacity: 1, y: 0 }} exit={{ opacity: 0, y: -20 }} className="space-y-6 relative z-10">
            <div className="p-6 bg-amber-500/10 border border-amber-500/20 rounded-2xl">
              <h4 className="text-sm font-bold text-amber-500 uppercase tracking-widest mb-4 flex items-center gap-2">
                <Clock className="w-4 h-4" /> Sanningens Frågor
              </h4>
              <ul className="space-y-4">
                <li className="text-sm text-slate-300 italic flex items-start gap-3">
                  <span className="text-amber-500 mt-1">•</span>
                  Hjälper detta verkligen barnen, eller försöker jag bara undvika en konflikt?
                </li>
                <li className="text-sm text-slate-300 italic flex items-start gap-3">
                  <span className="text-amber-500 mt-1">•</span>
                  Är detta mitt ansvar, eller försöker någon flytta sina egna konsekvenser till mig?
                </li>
              </ul>
            </div>
            
            <button
              onClick={generateReply}
              disabled={isGenerating}
              className="w-full py-4 bg-teal-600/20 hover:bg-teal-600/30 text-teal-400 border border-teal-500/30 rounded-2xl font-bold text-sm tracking-widest uppercase transition-all flex items-center justify-center gap-2"
            >
              {isGenerating ? <Loader2 className="w-5 h-5 animate-spin" /> : <><MessageSquare className="w-4 h-4" /> Generera ett BIFF-svar</>}
            </button>
          </motion.div>
        )}

        {step === 'RESULT' && boundaryResults && (
          <motion.div key="result" initial={{ opacity: 0, scale: 0.95 }} animate={{ opacity: 1, scale: 1 }} className="space-y-6 relative z-10">
            <div className="p-4 bg-teal-500/10 border border-teal-500/20 rounded-2xl">
              <p className="text-[11px] text-teal-300 italic leading-relaxed">
                "{boundaryResults.validation}"
              </p>
            </div>

            <div className="flex bg-black/40 p-1 rounded-xl border border-white/5">
              {(['soft', 'biff', 'greyRock'] as const).map((type) => (
                <button
                  key={type}
                  onClick={() => setSelectedScriptType(type)}
                  className={cn(
                    "flex-1 py-2 text-[9px] font-bold uppercase tracking-widest rounded-lg transition-all",
                    selectedScriptType === type ? "bg-indigo-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-300"
                  )}
                >
                  {type === 'greyRock' ? 'Grey Rock' : type.toUpperCase()}
                </button>
              ))}
            </div>

            <div className="p-6 bg-white/[0.03] border border-white/5 rounded-2xl relative group">
              <p className="text-sm text-slate-200 leading-relaxed font-inter">
                {boundaryResults.scripts[selectedScriptType]}
              </p>
            </div>

            <button
              onClick={copyToClipboard}
              className="w-full py-4 bg-slate-800 hover:bg-slate-700 text-slate-200 border border-white/10 rounded-2xl font-bold text-xs tracking-widest uppercase transition-all flex items-center justify-center gap-2"
            >
              <Copy className="w-4 h-4" /> Kopiera och avsluta
            </button>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
};
</file>

