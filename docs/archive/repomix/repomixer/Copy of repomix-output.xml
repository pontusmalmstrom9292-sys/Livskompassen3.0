import React from 'react';
import { motion } from 'framer-motion';
import { Database, Search, Loader2, ArrowRight, User, ShieldCheck, XCircle } from 'lucide-react';
import { cn } from '../../lib/utils';

interface VaultIntelligenceProps {
  searchTerm: string;
  setSearchTerm: (val: string) => void;
  runNeuralSearch: () => void;
  isNeuralSearching: boolean;
  loading: boolean;
  filteredIntelligence: any[];
}

export const VaultIntelligence: React.FC<VaultIntelligenceProps> = ({ 
  searchTerm, setSearchTerm, runNeuralSearch, isNeuralSearching, loading, filteredIntelligence 
}) => {
  return (
    <div className="space-y-10">
      <div className="relative group max-w-3xl mx-auto">
        <div className="absolute -inset-1 bg-gradient-to-r from-indigo-500/20 to-purple-500/20 rounded-3xl blur opacity-25 group-focus-within:opacity-100 transition-opacity" />
        <div className="relative flex items-center">
          <input 
            type="text"
            placeholder="Neural Sökning: Sök efter mönster, inte bara ord..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
            onKeyDown={(e) => e.key === 'Enter' && runNeuralSearch()}
            className="w-full bg-[#0f172a] border border-white/10 rounded-2xl px-14 py-6 text-sm text-slate-200 placeholder-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all shadow-2xl"
          />
          <button 
            onClick={runNeuralSearch}
            disabled={isNeuralSearching || !searchTerm.trim()}
            className="absolute right-4 p-3 bg-indigo-600 hover:bg-indigo-500 rounded-xl text-white transition-all disabled:opacity-30"
          >
            {isNeuralSearching ? <Loader2 className="w-4 h-4 animate-spin" /> : <Search className="w-4 h-4" />}
          </button>
        </div>
        <Database className="absolute left-6 top-1/2 -translate-y-1/2 w-5 h-5 text-indigo-500/50 z-10" />
        {searchTerm && (
          <button onClick={() => setSearchTerm('')} className="absolute right-16 top-1/2 -translate-y-1/2 p-2 hover:bg-white/5 rounded-full z-10">
            <XCircle className="w-4 h-4 text-slate-500" />
          </button>
