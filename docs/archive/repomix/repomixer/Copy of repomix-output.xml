<file path="livskompassen-trasig-1/src/components/VivirEmergencyFilter.tsx">
import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { ShieldAlert, Zap, MessageSquare, ArrowRight, X, Loader2, Sparkles, AlertTriangle } from 'lucide-react';
import { shieldApi } from '../services/apiService';
import { cn } from '../lib/utils';

interface VivirProps {
  onClose: () => void;
  userId: string;
}

export const VivirEmergencyFilter: React.FC<VivirProps> = ({ onClose, userId }) => {
  const [input, setInput] = useState('');
  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [result, setResult] = useState<any>(null);

  const handleDeconstruct = async () => {
    if (!input.trim()) return;
    setIsAnalyzing(true);
    try {
      const res = await shieldApi.analyze({
        content: input,
        mode: "BIFF",
        context: { userId }
      });
      
      setResult({
        cleanMessage: res.masterInsight,
        detectedTactics: res.detectedTactics.map(t => ({ name: t.tactic, explanation: t.explanation })),
        poisonRemoved: res.groundingPoints, // Vi mappar grounding points som de delar som filtrerats bort/identifierats
        strategicAdvice: res.strategicAdvice.script
      });
    } catch (error) {
      console.error("VIVIR failed:", error);
    } finally {
      setIsAnalyzing(false);
    }
  };

  return (
    <motion.div 
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      className="fixed inset-0 z-[150] flex items-center justify-center p-4 bg-[#020617]/95 backdrop-blur-2xl"
    >
      <div className="max-w-2xl w-full bg-[#0f172a] border border-indigo-500/30 rounded-[3rem] p-8 lg:p-12 relative shadow-[0_0_100px_rgba(79,70,229,0.2)] overflow-hidden">
        {/* Background Animation */}
        <div className="absolute -top-24 -right-24 w-64 h-64 bg-indigo-500/10 rounded-full blur-[100px] animate-pulse" />
        
        <div className="relative space-y-8">
          <div className="flex justify-between items-start">
            <div className="flex items-center gap-4">
              <div className="p-4 bg-indigo-500/20 rounded-[1.5rem] border border-indigo-500/30">
                <ShieldAlert className="w-6 h-6 text-indigo-400" />
              </div>
              <div>
                <h2 className="text-2xl text-white font-outfit tracking-wide">VIVIR Akut-Filter</h2>
                <p className="text-[10px] text-indigo-400 uppercase font-bold tracking-[0.2em]">De-eskalerings-motor</p>
              </div>
            </div>
            <button onClick={onClose} className="p-3 hover:bg-white/5 rounded-2xl text-slate-500 hover:text-white transition-all">
              <X className="w-6 h-6" />
            </button>
          </div>

          <p className="text-sm text-slate-400 leading-relaxed italic">
            Har du blivit utsatt för en "dokument-attack"? Klistra in det aggressiva meddelandet här. 
            VIVIR filtrerar bort allt gift och lämnar bara kvar den information du faktiskt behöver svara på.
          </p>

          {!result ? (
            <div className="space-y-6">
              <textarea 
                value={input}
                onChange={(e) => setInput(e.target.value)}
                placeholder="Klistra in det aggressiva innehållet här..."
                className="w-full h-48 bg-black/40 border border-white/5 rounded-[2rem] p-6 text-slate-200 placeholder-slate-700 focus:outline-none focus:border-indigo-500/30 transition-all font-inter leading-relaxed resize-none"
              />
              <button 
                onClick={handleDeconstruct}
                disabled={isAnalyzing || !input.trim()}
                className="w-full py-5 bg-indigo-600 hover:bg-indigo-500 disabled:opacity-30 text-white rounded-[1.5rem] font-outfit font-bold text-sm tracking-[0.2em] uppercase shadow-2xl transition-all flex items-center justify-center gap-3"
              >
                {isAnalyzing ? <Loader2 className="w-5 h-5 animate-spin" /> : <Zap className="w-5 h-5" />}
                Filtrera bort giftet
              </button>
            </div>
          ) : (
            <motion.div 
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              className="space-y-8"
            >
              <div className="p-8 bg-teal-500/5 border border-teal-500/20 rounded-[2.5rem] space-y-4">
                <div className="flex items-center gap-2">
                  <Sparkles className="w-4 h-4 text-teal-400" />
                  <span className="text-[10px] font-black text-teal-400 uppercase tracking-widest">Renad Information</span>
                </div>
                <p className="text-lg text-slate-100 font-outfit leading-relaxed">
                  {result.cleanMessage}
                </p>
              </div>

              <div className="space-y-4">
                <div className="flex items-center gap-2 px-2">
                  <AlertTriangle className="w-4 h-4 text-rose-500" />
                  <span className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Identifierade Taktiker</span>
                </div>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                  {result.detectedTactics?.map((tactic: any, i: number) => (
                    <div key={i} className="p-4 bg-white/5 border border-white/5 rounded-2xl">
                      <p className="text-[10px] font-black text-rose-400 uppercase tracking-tighter mb-1">{tactic.name}</p>
                      <p className="text-[10px] text-slate-400 leading-relaxed italic">{tactic.explanation}</p>
                    </div>
                  ))}
                </div>
              </div>

              <div className="space-y-4">
                <div className="flex items-center gap-2 px-2">
                  <X className="w-4 h-4 text-slate-500" />
                  <span className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">Filtrerat Brus/Gift</span>
                </div>
                <div className="flex flex-wrap gap-2">
                  {result.poisonRemoved.map((poison: string, i: number) => (
                    <span key={i} className="px-3 py-1 bg-white/5 border border-white/5 rounded-full text-[9px] font-bold text-slate-500 uppercase">
                      {poison}
                    </span>
                  ))}
                </div>
              </div>

              <div className="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-[2rem] flex items-start gap-4">
                <MessageSquare className="w-5 h-5 text-indigo-400 shrink-0 mt-1" />
                <div>
                  <p className="text-[10px] text-indigo-400 uppercase font-black tracking-widest mb-1">Strategiskt Råd (BIFF)</p>
                  <p className="text-xs text-indigo-100 font-medium leading-relaxed">
                    {result.strategicAdvice}
                  </p>
                </div>
              </div>

              <div className="pt-6 border-t border-white/5">
                <button 
                  onClick={() => {
                    setResult(null);
                    setInput('');
                  }}
                  className="w-full py-4 bg-white/5 hover:bg-white/10 rounded-2xl text-xs font-bold text-slate-400 uppercase tracking-widest transition-all"
                >
                  Rensa & Nytt filter
                </button>
              </div>
            </motion.div>
          )}
        </div>
      </div>
    </motion.div>
  );
};
</file>

