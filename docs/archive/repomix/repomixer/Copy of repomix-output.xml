<file path="livskompassen-trasig-1/firestore.rules">
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // IMMUTABLE LEDGER FOR KNOWLEDGE BASE DOCS (Verklighetsvalvet Bevis)
    match /kb_docs/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Server-Side Timestamp Validation: Måste använda serverTimestamp()
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.createdAt == request.time;
                    
      // STRICT IMMUTABILITY: Aldrig tillåtet att ändra eller radera bevis
      allow update: if false;
      allow delete: if false;
    }
    
    // IMMUTABLE LEDGER FOR LEGACY VAULT
    match /vault/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.createdAt == request.time;
      // STRICT IMMUTABILITY
      allow update: if false;
      allow delete: if false;
    }
    
    // IMMUTABLE LEDGER FOR SYNAPSES (Systemanalyser)
    match /synapses/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.createdAt == request.time;
      allow update: if false;
      allow delete: if false;
    }
    
    // IMMUTABLE LEDGER FOR AI INTELLIGENCE (Självlärande Valvet)
    match /vault_intelligence/{docId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Endast Admin (Cloud Functions) får skriva hit. 
      // Klienten blockeras helt från att manipulera intelligens-data.
      allow create, update, delete: if false;
    }
    
    // Fallback för andra kollektioner (t.ex. users, checkins)
    match /{document=**} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
  }
}
</file>

