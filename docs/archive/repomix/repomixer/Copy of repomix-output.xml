  baseURL: API_BASE_URL,
  timeout: 45000,
  headers: {
    'Content-Type': 'application/json',
  }
});

// Breakthrough: Centralized Stability Interceptor
api.interceptors.response.use(
  (response) => response,
  async (error) => {
    const { config, response } = error;
    
    // Retry logic for 500 errors or timeouts (max 3 retries)
    if (config && (response?.status >= 500 || error.code === 'ECONNABORTED')) {
      config._retryCount = config._retryCount || 0;
      if (config._retryCount < 3) {
        config._retryCount += 1;
        const delay = Math.pow(2, config._retryCount) * 1000;
        await new Promise(resolve => setTimeout(resolve, delay));
        return api(config);
      }
    }
    
    // Map backend errors to trauma-informed messages
    const mappedError = {
      message: response?.data?.detail || "Systemet är tillfälligt överbelastat. Vi arbetar på att återställa anslutningen.",
      severity: response?.status >= 500 ? 'CRITICAL' : 'WARNING',
      status: response?.status,
      code: error.code || 'UNKNOWN_ERROR'
    };
    
    return Promise.reject(mappedError);
  }
);

