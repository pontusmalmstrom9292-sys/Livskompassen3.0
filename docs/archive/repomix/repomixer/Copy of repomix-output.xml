import asyncio
from typing import Dict, Any, List, Optional
from services.synapse_service import synapse_bus, SynapseEvent

class AgentOrchestrator:
    """
    Intelligence Bus Orchestrator - Primary entry point for multi-agent coordination.
    Wraps the SynapseBus for high-level tasks and complex multi-agent flows.
    """
    
    def __init__(self):
        self.bus = synapse_bus

    async def dispatch(self, mode: str, data: Dict[str, Any]) -> Dict[str, Any]:
        """
        Dispatches a request to a specific agent via the Synapse Bus.
        """
        mode = mode.upper()
        self.bus.logger.info(f"Orchestrator: Dispatching to {mode}...")
        
        # We try to ask the agent directly via the bus
        result = await self.bus.ask_agent(mode, data)
        
        if not result:
            return {
                "error": f"Agent {mode} not found or failed to respond.",
                "status": "FAIL",
                "masterInsight": f"Modulen {mode} är för tillfället inte tillgänglig."
            }
            
        return result

    async def cross_analyze(self, content: str, relevant_synapses: List[str] = None) -> Dict[str, Any]:
        """
        Runs multiple agents in parallel for a holistic view.
        """
        if not relevant_synapses:
            relevant_synapses = ["LEGAL", "ESCALATION"]
            
        tasks = []
        for synapse in relevant_synapses:
            synapse = synapse.upper()
            # Standardize payload for common agents
            payload = {"content": content}
            if synapse == "ESCALATION":
                payload.update({"newEvent": content, "historicalEvents": [], "actorProfiles": []})
            elif synapse == "LEGAL":
                payload.update({"text": content, "context": {}})
                
            tasks.append(self.dispatch(synapse, payload))
            
        results = await asyncio.gather(*tasks)
        
        # Combine results into a structured output
        combined = {}
        for i, synapse in enumerate(relevant_synapses):
            combined[synapse.lower()] = results[i]
            
        return combined

    async def smart_dispatch(self, content: str, user_context: Optional[Dict] = None) -> Dict[str, Any]:
        """
        Autonomous 'Smart Analysis' - Sequential analysis with cross-agent feedback.
        """
        # 1. Emit an initial observation event (triggers any passive listeners/loggers)
        event = SynapseEvent(
            sender="Orchestrator", 
            event_type="NEW_OBSERVATION", 
            payload={"content": content, "context": user_context}
        )
        await self.bus.emit(event)
        
        # 2. Parallel Core Analysis (Legal + Escalation)
        core_analysis = await self.cross_analyze(content, ["LEGAL", "ESCALATION"])
        
        # 3. Tactical Response (BIFF)
        # Tactical agent often needs the legal/escalation context to give better advice
        tactical_payload = {
            "content": content, 
            "context": core_analysis
        }
        tactical = await self.bus.ask_agent("tactical", tactical_payload)
        
        # 4. Stress Check (Vagus)
        stress = await self.bus.ask_agent("vagus", {"content": content})
        
        return {
            "status": "SUCCESS",
            "masterInsight": tactical.get("masterInsight", "Analys genomförd.") if isinstance(tactical, dict) else "Analys genomförd.",
            "tactical": tactical,
            "legal": core_analysis.get("legal"),
            "escalation": core_analysis.get("escalation"),
            "wellbeing": stress,
            "synapseHistory": self.bus.get_history(5)
        }
