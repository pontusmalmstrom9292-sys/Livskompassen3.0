<file path="livskompassen-trasig-1/src/contexts/SystemMemoryContext.tsx">
import React, { createContext, useContext, useState, ReactNode, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, query, where, onSnapshot, addDoc, deleteDoc, doc, updateDoc, setDoc, serverTimestamp } from 'firebase/firestore';

export interface MemoryEntity {
  id: string;
  name: string;
  role: string;
  bio?: string;
  category: 'Myndighet' | 'Privat' | 'Ombud' | 'Övrig familj';
  colorCode: string;
  trustLevel: 'Neutral' | 'Fientlig' | 'Allierad';
  createdAt: any;
  riskLevel?: number; // Behålls för intern logik om det behövs
  patterns?: string;
}

export interface DailyVibe {
  stressLevel: number;
  energyLevel: number;
  lastUpdated: any;
  groundingStatus?: 'STABLE' | 'DRIFTING' | 'CRITICAL';
}

export interface IntelligencePost {
  id: string;
  agent: string;
  type: 'PATTERN' | 'BUDGET' | 'SAFETY' | 'STRATEGY';
  message: string;
  timestamp: any;
  priority: 'LOW' | 'MEDIUM' | 'HIGH';
  metadata?: any;
}

interface SystemMemoryState {
  entities: MemoryEntity[];
  dailyVibe: DailyVibe | null;
  intelligenceFeed: IntelligencePost[];
  addEntity: (entity: Omit<MemoryEntity, 'id' | 'createdAt'>) => Promise<void>;
  updateEntity: (id: string, entity: Partial<MemoryEntity>) => Promise<void>;
  removeEntity: (id: string) => Promise<void>;
  updateDailyVibe: (vibe: Omit<DailyVibe, 'lastUpdated'>) => Promise<void>;
  postToIntelligenceFeed: (post: Omit<IntelligencePost, 'id' | 'timestamp'>) => Promise<void>;
}

const SystemMemoryContext = createContext<SystemMemoryState | undefined>(undefined);

export const SystemMemoryProvider = ({ children, user }: { children: ReactNode, user?: any }) => {
  const [entities, setEntities] = useState<MemoryEntity[]>([]);
  const [dailyVibe, setDailyVibe] = useState<DailyVibe | null>(null);
  const [intelligenceFeed, setIntelligenceFeed] = useState<IntelligencePost[]>([]);

  useEffect(() => {
    if (!user) return;
    
    // Actors listener (tidigare system_entities)
    const q = query(collection(db, 'actors'), where('userId', '==', user.uid));
    const unsubEntities = onSnapshot(q, (snapshot) => {
      setEntities(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as MemoryEntity)));
    });

    // Daily Vibe listener
    const vibeRef = doc(db, 'daily_vibes', user.uid);
    const unsubVibe = onSnapshot(vibeRef, (docSnap) => {
      if (docSnap.exists()) {
        setDailyVibe(docSnap.data() as DailyVibe);
      }
    });

    // Intelligence Feed listener
    const feedQ = query(
      collection(db, 'intelligence_feed'), 
      where('userId', '==', user.uid),
      orderBy('timestamp', 'desc'),
      limit(10)
    );
    const unsubFeed = onSnapshot(feedQ, (snapshot) => {
      setIntelligenceFeed(snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() } as IntelligencePost)));
    });

    return () => {
      unsubEntities();
      unsubVibe();
      unsubFeed();
    };
  }, [user]);

  const addEntity = async (entityData: Omit<MemoryEntity, 'id' | 'createdAt'>) => {
    if (!user) return;
    await addDoc(collection(db, 'actors'), {
      ...entityData,
      userId: user.uid,
      createdAt: serverTimestamp()
    });
  };

  const updateEntity = async (id: string, updates: Partial<MemoryEntity>) => {
    await updateDoc(doc(db, 'actors', id), updates);
  };

  const removeEntity = async (id: string) => {
    await deleteDoc(doc(db, 'actors', id));
  };

  const updateDailyVibe = async (vibeData: Omit<DailyVibe, 'lastUpdated'>) => {
    if (!user) return;
    await setDoc(doc(db, 'daily_vibes', user.uid), {
      ...vibeData,
      lastUpdated: serverTimestamp()
    });
  };

  const postToIntelligenceFeed = async (postData: Omit<IntelligencePost, 'id' | 'timestamp'>) => {
    if (!user) return;
    await addDoc(collection(db, 'intelligence_feed'), {
      ...postData,
      userId: user.uid,
      timestamp: serverTimestamp()
    });
  };

  return (
    <SystemMemoryContext.Provider value={{ 
      entities, 
      dailyVibe, 
      intelligenceFeed,
      addEntity, 
      updateEntity, 
      removeEntity, 
      updateDailyVibe,
      postToIntelligenceFeed
    }}>
      {children}
    </SystemMemoryContext.Provider>
  );
};

export const useSystemMemory = () => {
  const context = useContext(SystemMemoryContext);
  if (context === undefined) {
    throw new Error('useSystemMemory måste användas innanför en SystemMemoryProvider');
  }
  return context;
};
</file>

