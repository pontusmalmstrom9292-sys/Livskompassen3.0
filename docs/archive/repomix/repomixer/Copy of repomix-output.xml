      <div className="grid gap-3">
        {mockResults.map((res) => (
          <BentoCard 
            key={res.id} 
            className={cn(
              "cursor-pointer group hover:border-white/20 transition-all",
              res.status === 'WARNING' ? "bg-warm-orange/5 border-warm-orange/10" : "bg-white/5 border-white/5"
            )}
            onClick={() => setSelectedFile(res.id === selectedFile ? null : res.id)}
          >
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <FileText className={cn("w-4 h-4", res.status === 'WARNING' ? "text-warm-orange" : "text-blue-400")} />
                <div>
                  <p className="text-xs font-bold">{res.fileName}</p>
                  <p className="text-[10px] opacity-40 uppercase font-black tracking-tighter">{res.category}</p>
                </div>
              </div>
              <div className="flex items-center gap-2">
                {res.status === 'SAFE' ? (
                  <CheckCircle2 className="w-3.5 h-3.5 text-emerald-400" />
                ) : (
                  <AlertCircle className="w-3.5 h-3.5 text-warm-orange" />
                )}
                <span className={cn(
                  "text-[9px] font-bold",
                  res.status === 'SAFE' ? "text-emerald-400" : "text-warm-orange"
                )}>
                  {res.status === 'SAFE' ? 'Verifierad' : 'Varning'}
                </span>
              </div>
            </div>

            {selectedFile === res.id && (
              <motion.div 
                initial={{ height: 0, opacity: 0 }}
                animate={{ height: 'auto', opacity: 1 }}
                className="mt-4 pt-4 border-t border-white/5 space-y-2 overflow-hidden"
              >
                <div className="flex items-center gap-2 text-[10px] text-sand mb-2">
                  <Brain className="w-3 h-3" />
                  <span className="uppercase font-bold tracking-widest">Arkivariens Insikt:</span>
                </div>
                {res.findings.map((f, i) => (
                  <p key={i} className="text-[11px] opacity-60 leading-relaxed pl-4 border-l border-white/10">
                    {f}
                  </p>
                ))}
              </motion.div>
            )}
          </BentoCard>
        ))}
      </div>
    </div>
  );
}
