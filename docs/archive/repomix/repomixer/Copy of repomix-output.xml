                className="w-full h-32 bg-[#020617]/50 border border-slate-800 rounded-xl p-3 text-slate-300 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-indigo-500/30 focus:border-indigo-500/30 resize-none transition-all font-inter text-sm"
              />
