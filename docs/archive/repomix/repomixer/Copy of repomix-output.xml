          {/* Trend Logic */}
          <div className="pt-20 border-t border-white/5 space-y-16">
             <div className="flex items-center justify-between">
                <div className="flex items-center gap-6">
                   <div className="p-4 bg-teal-500/10 rounded-2xl border border-teal-500/20">
                      <TrendingUp className="w-6 h-6 text-teal-400" />
                   </div>
                   <div>
                      <h4 className="text-2xl font-outfit font-light text-white tracking-tight">Verklighets-Resiliens</h4>
                      <p className="text-[10px] text-slate-500 uppercase tracking-[0.4em] font-black">Trend över tid</p>
                   </div>
                </div>
                <button 
