const PatternIntelligence = ({ userId }: { userId: string }) => {
  const [recentFlags, setRecentFlags] = useState<string[]>([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    const q = query(
      collection(db, 'events'),
      where('userId', '==', userId),
      orderBy('timestamp', 'desc'),
      limit(10)
    );
    return onSnapshot(q, (snapshot) => {
      const allFlags = snapshot.docs.flatMap(doc => {
        const data = doc.data() as RadarEvent;
        return data.aiAnalysis?.redFlags || [];
      });
      setRecentFlags([...new Set(allFlags)].slice(0, 4));
      setLoading(false);
