<file path="livskompassen-trasig-1/src/components/ActorPromotionAlert.tsx">
import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { UserPlus, Loader2, ShieldAlert, Sparkles, X, ChevronRight, Check, UserX } from 'lucide-react';
import { geminiService } from '../services/geminiService';
import { radarService } from '../services/radarService';
import { cn } from '../lib/utils';

interface ActorPromotion {
  name: string;
  count: number;
}

interface ActorPromotionAlertProps {
  promotions: ActorPromotion[];
  userId: string;
  onDismiss: () => void;
}

const TRUST_OPTIONS: { value: 'Neutral' | 'Fientlig' | 'Allierad'; label: string; color: string; bg: string }[] = [
  { value: 'Allierad', label: '🤝 Allierad', color: 'text-teal-400', bg: 'bg-teal-500/20 border-teal-500/40' },
  { value: 'Neutral', label: '⚖️ Neutral', color: 'text-slate-300', bg: 'bg-slate-500/10 border-slate-500/30' },
  { value: 'Fientlig', label: '⚠️ Fientlig', color: 'text-rose-400', bg: 'bg-rose-500/20 border-rose-500/40' },
];

const SinglePromotion: React.FC<{
  promotion: ActorPromotion;
  userId: string;
  onDone: () => void;
  onSkip: () => void;
}> = ({ promotion, userId, onDone, onSkip }) => {
  const [step, setStep] = useState<'ANALYZING' | 'CONFIRM' | 'DONE'>('ANALYZING');
  const [analysis, setAnalysis] = useState<any>(null);
  const [trust, setTrust] = useState<'Neutral' | 'Fientlig' | 'Allierad'>('Neutral');
  const [isPromoting, setIsPromoting] = useState(false);

  React.useEffect(() => {
    const analyze = async () => {
      try {
        const events = await radarService.getEventsByUnidentifiedName(userId, promotion.name);
        const result = await geminiService.generateActorPromotionAnalysis(promotion.name, events);
        setAnalysis(result);
        setTrust(result.suggestedTrustLevel || 'Neutral');
        setStep('CONFIRM');
      } catch (err) {
        console.error("Promotion analysis failed:", err);
        setStep('CONFIRM');
      }
    };
    analyze();
  }, []);

  const handlePromote = async () => {
    setIsPromoting(true);
    try {
      await radarService.promoteToActor(
        userId,
        promotion.name,
        analysis?.suggestedRole || 'Okänd',
        trust,
        analysis?.suggestedBio || ''
      );
      setStep('DONE');
      setTimeout(onDone, 1500);
    } catch (err) {
      console.error("Promotion failed:", err);
    } finally {
      setIsPromoting(false);
    }
  };

  const handleMute = async () => {
    await radarService.muteUnidentifiedActor(userId, promotion.name);
    onSkip();
  };

  if (step === 'ANALYZING') {
    return (
      <div className="flex flex-col items-center justify-center py-12 space-y-4">
        <div className="relative">
          <div className="w-16 h-16 rounded-full border border-indigo-500/20 flex items-center justify-center">
            <Loader2 className="w-7 h-7 text-indigo-400 animate-spin" />
          </div>
          <div className="absolute inset-0 rounded-full bg-indigo-500/5 blur-xl animate-pulse" />
        </div>
        <p className="text-[10px] uppercase font-bold text-slate-500 tracking-[0.3em] text-center">
          Mönster-Analytikern skannar historiken för<br />
          <span className="text-indigo-400">{promotion.name}</span>
        </p>
      </div>
    );
  }

  if (step === 'DONE') {
    return (
      <div className="flex flex-col items-center justify-center py-12 space-y-4">
