<file path="src/pages/WellnessPage.tsx">
import { BentoCard } from '../components/ui/BentoCard';
import { Sprout, Wind, Brain, Droplets, Battery, Activity, Shield, RefreshCw, Zap, Save, Calendar, MessageCircle, Star, BrainCircuit } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { useState, useEffect } from 'react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp } from 'firebase/firestore';
import { DIARY_CATEGORIES } from '../constants';
import { DiaryEntry } from '../types';
import { Button } from '../components/ui/button';
import { geminiService } from '../services/geminiService';
import { cn } from '../lib/utils';

interface WellnessPageProps {
  user: any;
}

type WellnessTab = 'PULS' | 'REFLEKTION';

export function WellnessPage({ user }: WellnessPageProps) {
  const [activeTab, setActiveTab] = useState<WellnessTab>('PULS');
  
  // Diary State
  const [entries, setEntries] = useState<DiaryEntry[]>([]);
  const [text, setText] = useState('');
  const [energy, setEnergy] = useState(3);
  const [category, setCategory] = useState(DIARY_CATEGORIES[0]);
  const [isSaving, setIsSaving] = useState(false);

  // Reflection State
  const [reflectionQuestion, setReflectionQuestion] = useState<{ agentName: string; question: string; category: string } | null>(null);
  const [reflectionAnswer, setReflectionAnswer] = useState('');
  const [reflections, setReflections] = useState<any[]>([]);
  const [isReflecting, setIsReflecting] = useState(false);

  useEffect(() => {
    if (!user) return;

    // Pulse (Diary) entries
    const qPulse = query(
      collection(db, 'diary'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribePulse = onSnapshot(qPulse, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data(),
        date: doc.data().createdAt?.toDate().toLocaleDateString('sv-SE', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) || 'Sparar...'
      } as DiaryEntry));
      setEntries(docs);
    });

    // Reflection entries
    const qReflection = query(
      collection(db, 'reflections'),
      where('userId', '==', user.uid),
      orderBy('createdAt', 'desc')
    );

    const unsubscribeReflection = onSnapshot(qReflection, (snapshot) => {
      const docs = snapshot.docs.map(doc => ({
        id: doc.id,
        ...doc.data(),
        date: doc.data().createdAt?.toDate().toLocaleDateString('sv-SE', { month: 'short', day: 'numeric' }) || '...'
      }));
      setReflections(docs);
    });

    return () => {
      unsubscribePulse();
      unsubscribeReflection();
    };
  }, [user]);

  useEffect(() => {
    if (activeTab === 'REFLEKTION' && !reflectionQuestion) {
      loadNewQuestion();
    }
  }, [activeTab]);

  const loadNewQuestion = async () => {
    const context = entries.map(e => e.text).join('\n').slice(0, 1000);
    const result = await geminiService.generateReflectionQuestion(context);
    setReflectionQuestion(result);
  };

  const handleSaveDiary = async () => {
    if (!text) return;
    setIsSaving(true);
    try {
      await addDoc(collection(db, 'diary'), {
        userId: user.uid,
        text,
        energy,
        category,
        createdAt: serverTimestamp()
      });
      setText('');
      setEnergy(3);
    } catch (e) {
      console.error("Diary save error", e);
    } finally {
      setIsSaving(false);
    }
  };

  const handleSaveReflection = async () => {
    if (!reflectionAnswer || !reflectionQuestion) return;
    setIsReflecting(true);
    try {
      await addDoc(collection(db, 'reflections'), {
        userId: user.uid,
        agentName: reflectionQuestion.agentName,
        question: reflectionQuestion.question,
        category: reflectionQuestion.category,
        answer: reflectionAnswer,
        createdAt: serverTimestamp()
      });
      setReflectionAnswer('');
      loadNewQuestion();
    } catch (e) {
      console.error("Reflection save error", e);
    } finally {
      setIsReflecting(false);
    }
  };

  return (
    <div className="space-y-6 pb-20">
      {/* Sub-nav Tabs */}
      <div className="flex p-1 bg-black/40 backdrop-blur-xl rounded-[2rem] border border-white/5 mx-auto max-w-xs">
        {[
          { id: 'PULS', label: 'Puls', icon: Activity },
          { id: 'REFLEKTION', label: 'Spegling', icon: BrainCircuit },
        ].map((tab) => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id as WellnessTab)}
            className={cn(
              "flex-1 flex items-center justify-center gap-2 py-3 px-4 rounded-[1.8rem] text-[10px] uppercase font-bold tracking-widest transition-all",
              activeTab === tab.id ? "bg-turquoise text-white shadow-lg shadow-turquoise/20" : "text-white/40 hover:text-white/60"
            )}
          >
            <tab.icon className="w-4 h-4" />
            {tab.label}
          </button>
        ))}
      </div>

      <AnimatePresence mode="wait">
        {activeTab === 'PULS' ? (
          <motion.div
            key="puls"
            initial={{ opacity: 0, scale: 0.98 }}
            animate={{ opacity: 1, scale: 1 }}
            exit={{ opacity: 0, scale: 0.98 }}
            className="space-y-6"
          >
            {/* Mental Pulse Header */}
            <BentoCard highlightColor="turquoise" className="bg-deep-green-mid/80 border-gold/30">
              <div className="flex justify-between items-center mb-6 relative z-10">
                <div className="w-12 h-12 rounded-2xl bg-gold/20 flex items-center justify-center shadow-lg shadow-gold/10">
                  <Activity className="w-6 h-6 text-gold" />
                </div>
                <div className="text-right">
                  <p className="text-[10px] font-bold uppercase tracking-tighter text-gold opacity-60">Energinivå</p>
                  <p className="text-sm font-medium text-gold">{entries[0]?.energy || 0} / 5</p>
                </div>
              </div>

              <div className="relative h-24 flex items-center justify-center z-10">
                <div className="flex gap-1 items-end h-12">
                  {[30, 60, 45, 80, 50, 40, 90, 30, 55].map((h, i) => (
                    <motion.div 
                      key={i}
                      initial={{ height: 0 }}
                      animate={{ height: h }}
                      transition={{ delay: i * 0.05, duration: 0.5, repeat: Infinity, repeatType: 'mirror' }}
                      className="w-2 bg-gold/40 rounded-full"
                    />
                  ))}
                </div>
              </div>
            </BentoCard>

            {/* New Entry */}
            <BentoCard className="bg-deep-green-mid/80 border-gold/30">
              <h3 className="text-sm font-bold uppercase tracking-widest text-gold mb-4">Livsarkivet</h3>
              <div className="space-y-4">
                <textarea
                  placeholder="Hur mår du egentligen? Släpp ut tankarna här..."
                  value={text}
                  onChange={(e) => setText(e.target.value)}
                  className="w-full h-32 rounded-2xl bg-deep-green-dark/40 border border-gold/20 p-4 text-sm text-gold outline-none focus:border-gold/50 resize-none transition-colors placeholder:text-gold/20"
                />
                
                <div className="flex items-center justify-between">
                  <div className="flex gap-2">
                    {[1, 2, 3, 4, 5].map((num) => (
                      <button
                        key={num}
                        onClick={() => setEnergy(num)}
                        className={cn(
                          "w-10 h-10 rounded-xl transition-all",
                          energy === num ? 'bg-gold text-deep-green-dark shadow-lg shadow-gold/20' : 'bg-deep-green-dark/40 text-gold/40 hover:text-gold'
                        )}
                      >
                        {num}
                      </button>
                    ))}
                  </div>
                  <select 
                    value={category} 
                    onChange={(e) => setCategory(e.target.value)}
                    className="h-10 rounded-xl bg-deep-green-dark/40 border border-gold/20 px-3 text-xs text-gold outline-none"
                  >
                    {DIARY_CATEGORIES.map(c => <option key={c} value={c}>{c}</option>)}
                  </select>
                </div>

                <Button disabled={isSaving || !text} onClick={handleSaveDiary} className="w-full bg-gold text-deep-green-dark hover:bg-gold/90">
                  {isSaving ? 'Sparar...' : 'Spara i Arkivet'}
                </Button>
              </div>
            </BentoCard>

            {/* Toolbox Quick Actions */}
            <div className="grid grid-cols-2 gap-4">
              <BentoCard delay={0.1} className="flex flex-col items-center justify-center py-6 hover:bg-gold/5 transition-colors cursor-pointer bg-deep-green-mid/80 border-gold/30">
                <Wind className="w-6 h-6 text-gold mb-2" />
                <p className="text-sm text-gold">Andas</p>
                <p className="text-[10px] text-gold/40">4-7-8 metod</p>
              </BentoCard>

              <BentoCard delay={0.2} className="flex flex-col items-center justify-center py-6 hover:bg-gold/5 transition-colors cursor-pointer bg-deep-green-mid/80 border-gold/30">
                <Battery className="w-6 h-6 text-gold mb-2" />
                <p className="text-sm text-gold">Vila</p>
                <p className="text-[10px] text-gold/40">Kravlös tid</p>
              </BentoCard>
            </div>

            {/* History */}
            <div className="space-y-4">
              <div className="flex items-center gap-2 opacity-30 px-2 text-gold">
                <Calendar className="w-4 h-4" />
                <span className="text-[10px] font-bold uppercase tracking-widest">Historik</span>
              </div>
              {entries.map((entry) => (
                <BentoCard key={entry.id} className="bg-deep-green-mid/60 border-gold/10 group">
                  <div className="flex justify-between items-center mb-2">
                    <span className="text-[10px] font-bold text-gold/60">{entry.category}</span>
                    <span className="text-[10px] text-gold/40">{entry.date}</span>
                  </div>
                  <p className="text-sm leading-relaxed text-gold/80 group-hover:text-gold transition-opacity">{entry.text}</p>
                  <div className="mt-3 flex gap-1">
                    {[...Array(entry.energy)].map((_, i) => (
                      <div key={i} className="w-1.5 h-1.5 rounded-full bg-gold" />
                    ))}
                  </div>
                </BentoCard>
              ))}
            </div>
          </motion.div>
        ) : (
          <motion.div
            key="reflection"
            initial={{ opacity: 0, x: 20 }}
            animate={{ opacity: 1, x: 0 }}
            exit={{ opacity: 0, x: -20 }}
            className="space-y-6"
          >
            {/* System Reflection Question (The "Quiz") */}
            <BentoCard highlightColor="turquoise" className="bg-deep-green-mid/80 border-gold/30">
              <div className="flex items-center gap-4 mb-6">
                <div className="w-12 h-12 rounded-2xl bg-gold/10 flex items-center justify-center shadow-lg shadow-gold/10">
                  <Star className="w-6 h-6 text-gold animate-pulse" />
                </div>
                <div>
                  <h3 className="text-sm font-bold uppercase tracking-widest text-gold/60">Speglings-Agenten</h3>
                  <p className="text-[10px] text-gold/40">System-lärande pågår</p>
                </div>
              </div>

              <AnimatePresence mode="wait">
                {reflectionQuestion ? (
                  <motion.div
                    initial={{ opacity: 0, y: 10 }}
                    animate={{ opacity: 1, y: 0 }}
                    key={reflectionQuestion.question}
                    className="space-y-6"
                  >
                    <div className="bg-deep-green-dark/40 p-6 rounded-3xl border border-gold/40">
                      <p className="text-base font-display leading-relaxed text-gold">
                        "{reflectionQuestion.question}"
                      </p>
                      <div className="mt-3 inline-block px-2 py-0.5 bg-gold/10 text-gold text-[8px] font-black uppercase rounded">
                        Kategori: {reflectionQuestion.category}
                      </div>
                    </div>

                    <div className="space-y-4">
                      <textarea
                        placeholder="Ditt svar här..."
                        value={reflectionAnswer}
                        onChange={(e) => setReflectionAnswer(e.target.value)}
                        className="w-full h-32 rounded-2xl bg-deep-green-dark/40 border border-gold/20 p-4 text-sm text-gold outline-none focus:border-gold/50 resize-none transition-colors placeholder:text-gold/20"
                      />
                      <div className="flex gap-3">
                        <Button 
                          disabled={isReflecting || !reflectionAnswer} 
                          onClick={handleSaveReflection}
                          className="flex-1 bg-gold text-deep-green-dark"
                        >
                          Svara {reflectionQuestion.agentName}
                        </Button>
                        <button 
                          onClick={() => { setReflectionQuestion(null); loadNewQuestion(); }}
                          className="w-12 h-12 rounded-2xl bg-gold/10 flex items-center justify-center hover:bg-gold/20 transition-all"
                        >
                          <RefreshCw className="w-5 h-5 text-gold/40" />
                        </button>
                      </div>
                    </div>
                  </motion.div>
                ) : (
                  <div className="h-40 flex items-center justify-center">
                    <RefreshCw className="w-6 h-6 text-gold animate-spin opacity-20" />
                  </div>
                )}
              </AnimatePresence>
            </BentoCard>

            {/* Past Reflections / Insights */}
            <div className="space-y-4">
              <div className="flex items-center gap-2 opacity-30 px-2 text-gold">
                <Brain className="w-4 h-4" />
                <span className="text-[10px] font-bold uppercase tracking-widest">Insiktsvalvet</span>
              </div>
              
              {reflections.length === 0 && (
                <div className="p-8 text-center text-gold/20 italic text-xs">
                  Här sparas dina svar så att systemet kan lära känna dig bättre.
                </div>
              )}

              {reflections.map((ref) => (
                <BentoCard key={ref.id} className="bg-deep-green-mid/60 border-gold/5 space-y-3">
                  <div className="flex justify-between items-center text-[10px] font-bold text-gold/60">
                    <span>Av: {ref.agentName}</span>
                    <span className="opacity-40">{ref.date}</span>
                  </div>
                  <div className="space-y-2">
                    <p className="text-[11px] text-gold/40 italic">Q: {ref.question}</p>
                    <p className="text-sm font-medium text-gold/80 border-l-2 border-gold/20 pl-3 py-1">
                      {ref.answer}
                    </p>
                  </div>
                </BentoCard>
              ))}
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
