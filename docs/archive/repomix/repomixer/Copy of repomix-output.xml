<file path="livskompassen-trasig-1/functions/src/index.ts">
import * as functions from "firebase-functions";
import * as admin from "firebase-admin";
import { GoogleGenerativeAI } from "@google/generative-ai";

admin.initializeApp();
const db = admin.firestore();

const genAI = new GoogleGenerativeAI(functions.config().gemini?.key || process.env.GEMINI_API_KEY || "");

/**
 * TRIGGER 1: Automatisk AI-analys vid nytt bevis
 * Kör när en ny fil laddas upp i Storage: vault/{userId}/...
 */
export const analyzeEvidence = functions
  .region("europe-west1")
  .storage.object()
  .onFinalize(async (object) => {
    const filePath = object.name;
    if (!filePath || !filePath.startsWith("vault/")) return;

    const pathParts = filePath.split("/");
    const userId = pathParts[1];
    const fileName = pathParts[pathParts.length - 1];

    try {
      const [actorsSnap, prevIntelSnap] = await Promise.all([
        db.collection("actors").where("userId", "==", userId).get(),
        db.collection("vault_intelligence")
          .where("userId", "==", userId)
          .orderBy("timestamp", "desc")
          .limit(5)
          .get()
      ]);

      const actors = actorsSnap.docs.map(doc => doc.data());
      const historicalContext = prevIntelSnap.docs.map(doc => ({
        tactic: doc.data().analysis?.detectedTactic,
        summary: doc.data().analysis?.summary,
        date: doc.data().timestamp?.toDate().toISOString().split("T")[0]
      }));

      const model = genAI.getGenerativeModel({
        model: "gemini-1.5-pro",
        systemInstruction: `Du är Livs-Arkivarien – en expert på rättspsykologi, BBIC och 
        mönsterigenkänning i högkonfliktsituationer. Du analyserar bevis objektivt och 
        identifierar systematiska mönster av coercive control och eftervåld.`
      });

      const prompt = `
UPPGIFT: Djupanalys av bevis "${fileName}".

REFERENSRAM:
Kända Aktörer: ${JSON.stringify(actors)}
Senaste AI-observationer: ${JSON.stringify(historicalContext)}

ANALYS-PROTOKOLL:
1. MOTSÄGELSE-KONTROLL: Jämför mot de 5 senaste observationerna.
2. TAKTISK DEKONSTRUKTION: Identifiera DARVO, Future Faking, Triangulering.
3. BBIC+ BARNPERSPEKTIV: Kumulativ trygghetsbedömning.
4. STRATEGISK PROGNOS: Eskaleringsrisk nästa 72 timmar.

SVAR I STRIKT JSON:
{
  "detectedTactic": "string",
  "psychologicalProfile": {
    "aggressionLevel": "Låg|Medium|Hög",
    "deceptionProbability": 0,
    "motive": "Makt|Sabotage|Projektion|Okänt"
  },
  "contradictions": ["Beskrivning av motsägelse"],
  "bbicImpact": {
    "category": "string",
    "longTermRisk": "Kumulativ riskbeskrivning"
  },
  "patternMatch": true,
  "summary": "Objektiv juridisk sammanfattning",
  "recommendedAction": "Grey Rock|BIFF|Dokumentera & Avvakta|Kontakta Ombud",
  "escalationRisk72h": "LÅG|MEDEL|HÖG|KRITISK"
}`;

      const result = await model.generateContent(prompt);
      const response = await result.response;
      const analysis = JSON.parse(
        response.text().replace(/```json/g, "").replace(/```/g, "").trim()
      );

      await db.collection("vault_intelligence").add({
        userId,
        fileName,
        analysis,
        timestamp: admin.firestore.FieldValue.serverTimestamp(),
        fileRef: filePath,
        status: "COMPLETED",
        version: "3.0"
      });

      // Kolla om eskalering krävs – sätt en systemnotis
      if (analysis.escalationRisk72h === "KRITISK" || analysis.escalationRisk72h === "HÖG") {
        await db.collection("system_alerts").add({
          userId,
          type: "ESCALATION_RISK",
          message: `Ny analys av "${fileName}" visar ${analysis.escalationRisk72h} risk för eskalering.`,
          analysis: analysis.summary,
          action: analysis.recommendedAction,
          timestamp: admin.firestore.FieldValue.serverTimestamp(),
          read: false
        });
      }

      console.log(`✅ Analys färdig: ${fileName} | Risk: ${analysis.escalationRisk72h}`);

    } catch (error) {
      console.error("❌ AI Analysis failed:", error);
      await db.collection("vault_intelligence").add({
        userId,
        fileName,
        error: "Analys misslyckades",
        status: "FAILED",
        timestamp: admin.firestore.FieldValue.serverTimestamp()
      });
    }
  });


/**
 * TRIGGER 2: Veckovis Proaktiv Mönsteranalys (Chronos Weekly Scan)
 * Kör varje måndag kl 07:00 CET och analyserar senaste veckans data.
 */
export const weeklyPatternScan = functions
  .region("europe-west1")
  .pubsub.schedule("0 7 * * 1") // Varje måndag kl 07:00
  .timeZone("Europe/Stockholm")
  .onRun(async () => {
    console.log("🔍 Startar veckovis mönsteranalys (Chronos Weekly Scan)...");

    // Hämta alla aktiva användare
    const usersSnap = await db.collection("users").get();

    for (const userDoc of usersSnap.docs) {
      const userId = userDoc.id;

      try {
        // Hämta senaste 7 dagarna av händelser
        const oneWeekAgo = new Date();
        oneWeekAgo.setDate(oneWeekAgo.getDate() - 7);

        const [eventsSnap, diarySnap] = await Promise.all([
          db.collection("events")
            .where("userId", "==", userId)
            .where("timestamp", ">=", oneWeekAgo)
            .orderBy("timestamp", "desc")
            .get(),
          db.collection("diary_entries")
            .where("userId", "==", userId)
            .where("timestamp", ">=", oneWeekAgo)
            .orderBy("timestamp", "desc")
            .get()
        ]);

        const events = eventsSnap.docs.map(d => d.data());
        const diary = diarySnap.docs.map(d => d.data());

        if (events.length < 2 && diary.length < 2) {
          console.log(`⏭ Hoppar ${userId}: För lite data`);
          continue;
        }

        const model = genAI.getGenerativeModel({
          model: "gemini-1.5-pro",
          systemInstruction: "Du är Chronos – en tidsserieanalytiker specialiserad på att identifiera mönster av psykologisk manipulation och coercive control."
        });

        const eventsText = events.map(e => 
          `[${e.type}] ${e.description || ""}`
        ).join("\n");

        const diaryText = diary.map(d => 
          `[${d.vibe}] ${(d.content || "").substring(0, 200)}`
        ).join("\n");

        const prompt = `
CHRONOS VECKOANALYS – Identifiera mönster från senaste 7 dagarna.

HÄNDELSER (${events.length} st):
${eventsText || "Inga händelser"}

DAGBOKSENTRIES (${diary.length} st):
${diaryText || "Inga entries"}

Returnera JSON:
{
  "weekSummary": "Kort sammanfattning av veckan",
  "dominantTactics": ["Taktik 1", "Taktik 2"],
  "stressPattern": "Beskrivning av stressmönster",
  "escalationTrend": "ESKALERANDE|STABIL|AVTAGANDE",
  "weeklyRiskScore": 5,
  "positiveObservations": ["Något positivt"],
  "nextWeekForecast": "Prognos för nästa vecka",
  "recommendedFocus": "Vad användaren bör fokusera på",
  "safetyNote": "Viktig säkerhetsinformation om relevant"
}`;

        const result = await model.generateContent(prompt);
        const response = await result.response;
        const weeklyAnalysis = JSON.parse(
          response.text().replace(/```json/g, "").replace(/```/g, "").trim()
        );

        // Spara veckoanalys
        await db.collection("weekly_intelligence").add({
          userId,
          weeklyAnalysis,
          eventCount: events.length,
          diaryCount: diary.length,
          weekStarting: oneWeekAgo,
          timestamp: admin.firestore.FieldValue.serverTimestamp(),
          status: "COMPLETED"
        });

        // Skapa systemnotis om eskalering
        if (weeklyAnalysis.escalationTrend === "ESKALERANDE" || weeklyAnalysis.weeklyRiskScore > 7) {
          await db.collection("system_alerts").add({
            userId,
            type: "WEEKLY_ESCALATION",
            message: `Veckoanalys visar: ${weeklyAnalysis.weekSummary}`,
            riskScore: weeklyAnalysis.weeklyRiskScore,
            timestamp: admin.firestore.FieldValue.serverTimestamp(),
            read: false
          });
        }

        console.log(`✅ Veckoanalys klar: ${userId} | Risk: ${weeklyAnalysis.weeklyRiskScore}/10`);

      } catch (error) {
        console.error(`❌ Veckoanalys misslyckades för ${userId}:`, error);
      }
    }

    console.log("✅ Chronos Weekly Scan komplett.");
    return null;
  });


/**
 * TRIGGER 3: Real-time Notis vid Ny Radarrapport
 * Kör direkt när användaren loggar en ny händelse – ger omedelbar feedback.
 */
export const onNewRadarEvent = functions
  .region("europe-west1")
  .firestore.document("events/{eventId}")
  .onCreate(async (snap, context) => {
    const event = snap.data();
    const userId = event.userId;

    if (!userId || !event.description) return;

    try {
      // Hämta de 5 senaste händelserna för kontext
      const recentSnap = await db.collection("events")
        .where("userId", "==", userId)
        .orderBy("timestamp", "desc")
        .limit(5)
        .get();
      
      const recentEvents = recentSnap.docs.map(d => d.data());

      // Kör snabb kontextanalys (ej fullständig djupanalys)
      const model = genAI.getGenerativeModel({ model: "gemini-1.5-flash" }); // Flash = snabbare
      
      const prompt = `
Ny händelse: "${event.description}" (Typ: ${event.type})
Kontext (senaste händelser): ${recentEvents.slice(1).map(e => e.description).join(", ")}

Är detta ett varningstecken? Svara KORT i JSON:
{
  "isPatternMatch": true/false,
  "quickTip": "En rad konkret råd (max 80 tecken)",
  "urgency": "LÅGT|MEDEL|HÖGT"
}`;

      const result = await model.generateContent(prompt);
      const quickAnalysis = JSON.parse(
        result.response.text().replace(/```json/g, "").replace(/```/g, "").trim()
      );

      // Uppdatera händelsedokumentet med snabbanalys
      await snap.ref.update({
        quickAnalysis,
        analyzedAt: admin.firestore.FieldValue.serverTimestamp()
      });

      // Om hög urgency – skapa systemnotis
      if (quickAnalysis.urgency === "HÖGT") {
        await db.collection("system_alerts").add({
          userId,
          type: "RADAR_ALERT",
          message: quickAnalysis.quickTip,
          eventRef: context.params.eventId,
          timestamp: admin.firestore.FieldValue.serverTimestamp(),
          read: false
        });
      }

    } catch (error) {
      console.warn("Quick analysis skipped:", error);
    }
  });
