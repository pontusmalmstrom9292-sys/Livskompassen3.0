@app.post("/analyze/schedule")
async def analyze_schedule(request: Dict[str, Any]):
    try:
        text = request.get('scheduleText', '')
        prompt = f"Analysera detta schema och extrahera logistik samt flagga risker för en ensamstående förälder: {text}. Returnera JSON."
        res = flash_model.run(prompt)
