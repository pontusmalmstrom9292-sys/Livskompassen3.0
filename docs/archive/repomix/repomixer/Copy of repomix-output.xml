<file path="livskompassen-trasig-1/src/components/SuperArchive.tsx">
import React, { useState, useCallback } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { db } from '../lib/firebase';
import { collection, addDoc, serverTimestamp } from 'firebase/firestore';
import { geminiService } from '../services/geminiService';
import { driveService } from '../services/driveService';
import { 
  Upload, 
  FileText, 
  ShieldAlert, 
  Gavel, 
  FileCheck, 
  Loader2, 
  Plus, 
  X, 
  CheckCircle2, 
  Activity,
  ArrowRight
} from 'lucide-react';

interface AnalyzedFile {
  id: string;
  name: string;
  status: 'PENDING' | 'ANALYZING' | 'COMPLETED' | 'ERROR';
  category?: string;
  summary?: string;
  patterns?: any[];
  facts?: any[];
  threatLevel?: string;
  masterInsight?: string;
  recommendedAction?: string;
}

export const SuperArchive = ({ userId }: { userId: string }) => {
  const [files, setFiles] = useState<AnalyzedFile[]>([]);
  const [isDragging, setIsDragging] = useState(false);

  const [isSelfMade, setIsSelfMade] = useState(true);
  const [isAuthentic, setIsAuthentic] = useState(true);

  const processFile = async (file: File) => {
    const id = Math.random().toString(36).substring(7);
    const newFile: AnalyzedFile = { id, name: file.name, status: 'ANALYZING' };
    setFiles(prev => [newFile, ...prev]);

    try {
      // 1. Läs filen (här simulerar vi textutdrag för demonstration)
      const content = `Innehåll från filen ${file.name}: "Jag tänker inte betala underhållet den här månaden eftersom du blockerade mig på Instagram igår. Det är ditt eget fel."`;

      // 2. Parallell analys med under-agenter
      const [patternRes, legalRes, catRes, bbicRes] = await Promise.all([
        geminiService.subAgentAnalysis(content, 'PATTERN'),
        geminiService.subAgentAnalysis(content, 'LEGAL'),
        geminiService.subAgentAnalysis(content, 'CAT'),
        geminiService.subAgentAnalysis(content, 'BBIC')
      ]);

      // 3. Koordinera resultaten (Runda Bordet)
      const masterInsightRes = await geminiService.coordinateAnalysis({
        pattern: patternRes,
        legal: legalRes,
        category: catRes,
        bbic: bbicRes
      });

      const analyzedData = {
        status: 'COMPLETED' as const,
        category: catRes?.category || 'Övrigt',
        summary: bbicRes?.summary || 'Sammanfattning saknas',
        patterns: patternRes?.patterns || [],
        facts: legalRes?.facts || [],
        threatLevel: patternRes?.threatLevel || 'LOW',
        masterInsight: masterInsightRes?.masterInsight || '',
        recommendedAction: masterInsightRes?.recommendedAction || '',
        isSelfMade,
        isAuthentic
      };

      // 4. Spara i Firestore (Verklighetsvalvet)
      await addDoc(collection(db, 'kb_docs'), {
        userId,
        title: file.name,
        content: content,
        ...analyzedData,
        createdAt: serverTimestamp()
      });

      // 5. Synka till Drive Vault (Nytt)
      await driveService.syncFile(
        `ARKIV_${new Date().toISOString().split('T')[0]}_${file.name}`,
        content,
        file.type
      );

      setFiles(prev => prev.map(f => f.id === id ? { ...f, ...analyzedData } : f));
    } catch (e) {
      console.error("Processing error", e);
      setFiles(prev => prev.map(f => f.id === id ? { ...f, status: 'ERROR' } : f));
    }
  };

  const onDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setIsDragging(false);
    const droppedFiles = Array.from(e.dataTransfer.files);
    droppedFiles.forEach(processFile);
  };

  return (
    <div className="space-y-8 max-w-5xl mx-auto">
      {/* Super-Inmatning (Drop Zone) */}
      <div 
        onDragOver={(e) => { e.preventDefault(); setIsDragging(true); }}
        onDragLeave={() => setIsDragging(false)}
        onDrop={onDrop}
        className={`relative h-64 rounded-[2.5rem] border-2 border-dashed transition-all duration-500 flex flex-col items-center justify-center overflow-hidden group ${
          isDragging 
            ? 'bg-indigo-500/10 border-indigo-400 scale-[1.02]' 
            : 'bg-[#0a0a12]/50 border-white/10 hover:border-white/20 hover:bg-[#0a0a12]/80'
        }`}
      >
        <div className="absolute inset-0 bg-gradient-to-br from-indigo-500/5 via-transparent to-teal-500/5 pointer-events-none" />
        
        <div className="relative z-10 flex flex-col items-center text-center px-6">
          <div className={`w-16 h-16 rounded-2xl mb-6 flex items-center justify-center transition-all duration-500 ${
            isDragging ? 'bg-indigo-500 text-white scale-110 rotate-12' : 'bg-white/5 text-slate-500 group-hover:scale-110'
          }`}>
            <Upload className="w-8 h-8" />
          </div>
          <h3 className="text-xl font-outfit text-slate-200 mb-2">Tryck in dina filer här</h3>
          <p className="text-sm text-slate-500 max-w-xs leading-relaxed">
            Släpp SMS-loggar, PDF:er eller skärmdumpar. Livs-Arkivarien och under-agenterna tar hand om resten.
          </p>
        </div>
      </div>
      
      {/* Proveniens & Sanningsförsäkran */}
      <div className="flex flex-wrap gap-4 justify-center">
        <button 
          onClick={() => setIsSelfMade(!isSelfMade)}
          className={cn(
            "px-6 py-3 rounded-2xl text-[9px] font-black uppercase tracking-widest border transition-all flex items-center gap-3",
            isSelfMade ? "bg-teal-500/10 border-teal-500/30 text-teal-400 shadow-lg shadow-teal-900/20" : "bg-white/5 border-white/5 text-slate-500"
          )}
        >
          <FileCheck className="w-4 h-4" /> Egenupprättat Dokument
        </button>
        <button 
          onClick={() => setIsAuthentic(!isAuthentic)}
          className={cn(
            "px-6 py-3 rounded-2xl text-[9px] font-black uppercase tracking-widest border transition-all flex items-center gap-3",
            isAuthentic ? "bg-indigo-500/10 border-indigo-500/30 text-indigo-400 shadow-lg shadow-indigo-900/20" : "bg-white/5 border-white/5 text-slate-500"
          )}
        >
          <ShieldAlert className="w-4 h-4" /> Garanterat Äkta (Original)
        </button>
      </div>

      {/* Intelligence Feed (Processing) */}
      <div className="space-y-4">
        <h4 className="text-[10px] uppercase font-bold tracking-[0.2em] text-slate-500 flex items-center gap-2 px-2">
          <Activity className="w-3.5 h-3.5" /> Intelligence Feed
        </h4>
        
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          <AnimatePresence>
            {files.map((file) => (
              <motion.div
                key={file.id}
                initial={{ opacity: 0, x: -20 }}
                animate={{ opacity: 1, x: 0 }}
                exit={{ opacity: 0, scale: 0.95 }}
                className="bg-[#0a0a12]/80 border border-white/10 rounded-[2rem] p-6 backdrop-blur-md relative overflow-hidden group"
              >
                <div className="flex justify-between items-start mb-6">
                  <div className="flex items-center gap-4">
                    <div className="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center">
                      {file.status === 'ANALYZING' ? (
                        <Loader2 className="w-5 h-5 text-indigo-400 animate-spin" />
                      ) : (
                        <FileText className="w-5 h-5 text-indigo-400" />
                      )}
                    </div>
                    <div>
                      <h5 className="text-sm font-medium text-slate-200 truncate max-w-[150px]">{file.name}</h5>
                      <span className="text-[10px] text-slate-500 uppercase tracking-widest">
                        {file.status === 'ANALYZING' ? 'Analyserar...' : file.category}
                      </span>
                    </div>
                  </div>
                  {file.status === 'COMPLETED' && (
                    <CheckCircle2 className="w-5 h-5 text-teal-400" />
                  )}
                </div>

                {file.status === 'ANALYZING' ? (
                  <div className="space-y-3">
                    <div className="h-1 w-full bg-white/5 rounded-full overflow-hidden">
                      <motion.div 
                        animate={{ x: ['-100%', '100%'] }}
                        transition={{ repeat: Infinity, duration: 1.5 }}
                        className="h-full w-1/3 bg-indigo-500"
                      />
                    </div>
                    <div className="flex justify-between text-[9px] text-slate-600 uppercase font-bold tracking-widest">
                      <span>Mönster-Agenten jobbar...</span>
                      <span>35%</span>
                    </div>
                  </div>
                ) : file.status === 'COMPLETED' ? (
                  <div className="space-y-4">
                    <div className="bg-white/5 rounded-xl p-3 border border-white/5">
                      <p className="text-[10px] text-slate-400 leading-relaxed italic">
                        "{file.summary?.substring(0, 80)}..."
                      </p>
                    </div>
                    <div className="flex gap-2">
                      {file.threatLevel === 'HIGH' && (
                        <span className="text-[9px] px-2 py-1 bg-red-500/10 text-red-400 border border-red-500/20 rounded-md flex items-center gap-1 uppercase font-bold tracking-widest">
                          <ShieldAlert className="w-3 h-3" /> Manipulation
                        </span>
                      )}
                      <span className="text-[9px] px-2 py-1 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 rounded-md flex items-center gap-1 uppercase font-bold tracking-widest">
                        <Gavel className="w-3 h-3" /> Juridiskt Bevis
                      </span>
                    </div>
                    {file.masterInsight && (
                      <div className="mt-4 pt-4 border-t border-white/5 space-y-3">
                        <p className="text-[11px] text-indigo-200 font-medium leading-relaxed">
                          <span className="text-indigo-400 font-bold uppercase text-[9px] block mb-1">Över-Arkivariens Slutsats:</span>
                          {file.masterInsight}
                        </p>
                        {file.recommendedAction && (
                          <div className="bg-indigo-500/10 rounded-xl p-3 border border-indigo-500/20">
                            <p className="text-[10px] text-indigo-300 font-bold uppercase tracking-wider flex items-center gap-2">
                              <ArrowRight className="w-3 h-3" /> {file.recommendedAction}
                            </p>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                ) : null}
              </motion.div>
            ))}
          </AnimatePresence>
        </div>
      </div>
    </div>
  );
};
</file>

