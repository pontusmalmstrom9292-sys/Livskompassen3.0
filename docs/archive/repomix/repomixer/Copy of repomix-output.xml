  const [selectedType, setSelectedType] = useState<'ALL' | 'DIARY' | 'RADAR'>('ALL');
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    if (!userId) return;

    const diaryQ = query(collection(db, 'diary_entries'), where('userId', '==', userId), orderBy('timestamp', 'desc'));
    const radarQ = query(collection(db, 'events'), where('userId', '==', userId), orderBy('timestamp', 'desc'));

    let diaryEntries: any[] = [];
    let radarEvents: any[] = [];

    const updateTimeline = () => {
      const combined = [
        ...diaryEntries.map(e => ({ ...e, itemType: 'DIARY' })),
        ...radarEvents.map(e => ({ ...e, itemType: 'RADAR' }))
      ].sort((a, b) => {
        const timeA = a.timestamp?.toDate?.()?.getTime() || 0;
        const timeB = b.timestamp?.toDate?.()?.getTime() || 0;
        return timeB - timeA;
      });
      setTimelineItems(combined);
      setLoading(false);
    };

    const unsubDiary = onSnapshot(diaryQ, (snapshot) => {
      diaryEntries = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      updateTimeline();
    });

    const unsubRadar = onSnapshot(radarQ, (snapshot) => {
      radarEvents = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
      updateTimeline();
    });

    const unsubIntelligence = radarService.subscribeToIntelligence(userId, (intel) => {
      setIntelligenceData(intel);
    });

    return () => {
      unsubDiary();
      unsubRadar();
      unsubIntelligence();
    };
  }, [userId]);

  const filteredItems = timelineItems.filter(item => {
