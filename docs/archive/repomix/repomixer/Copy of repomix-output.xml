import React, { useState, useEffect } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { db } from '../lib/firebase';
import { collection, addDoc, query, where, orderBy, onSnapshot, serverTimestamp, updateDoc, doc } from 'firebase/firestore';
import { Book, PenLine, Search, Compass, Sparkles, ChevronDown, ChevronUp, Heart, Save, History, Loader2 } from 'lucide-react';
import { cn } from '../lib/utils';

type Vibe = 'CALM' | 'ANXIOUS' | 'ANGRY' | 'SAD' | 'STRONG' | 'NEUTRAL';

const VIBES: { type: Vibe; icon: string; label: string; color: string }[] = [
  { type: 'STRONG', icon: '⚡', label: 'Stark', color: 'text-amber-400' },
  { type: 'CALM', icon: '🌿', label: 'Lugn', color: 'text-teal-400' },
  { type: 'NEUTRAL', icon: '😐', label: 'Neutral', color: 'text-slate-400' },
  { type: 'ANXIOUS', icon: '🫀', label: 'Orolig', color: 'text-indigo-400' },
  { type: 'SAD', icon: '🌧', label: 'Ledsen', color: 'text-blue-400' },
  { type: 'ANGRY', icon: '🌋', label: 'Arg', color: 'text-rose-400' },
];

interface DiaryEntry {
  id: string;
  userId: string;
  content: string;
  vibe: Vibe;
  timestamp: any;
  isDraft?: boolean;
  type?: string;
}

const DraftCard: React.FC<{ entry: DiaryEntry; onComplete: (id: string, content: string) => void }> = ({ entry, onComplete }) => {
  const [isExpanded, setIsExpanded] = useState(false);
  const [editedContent, setEditedContent] = useState(entry.content);
  const [isSaving, setIsSaving] = useState(false);

  const handleComplete = async () => {
    setIsSaving(true);
    try {
      await onComplete(entry.id, editedContent);
    } finally {
      setIsSaving(false);
    }
  };

  return (
    <motion.div 
      initial={{ opacity: 0, y: -10 }}
      animate={{ opacity: 1, y: 0 }}
      className="border border-[#FDE68A]/20 bg-[#FDE68A]/5 rounded-[2rem] overflow-hidden"
    >
      <button 
        className="w-full p-5 flex items-center justify-between gap-4 text-left"
        onClick={() => setIsExpanded(!isExpanded)}
      >
        <div className="flex items-center gap-3">
          <div className="w-9 h-9 rounded-xl bg-[#FDE68A]/20 flex items-center justify-center shrink-0">
            <Compass className="w-5 h-5 text-[#FDE68A]" />
          </div>
          <div>
            <p className="text-xs font-bold text-[#FDE68A] uppercase tracking-widest">Morgonkompassens Utkast</p>
            <p className="text-[10px] text-slate-500 mt-0.5">Redo för din kvällsreflektion</p>
          </div>
        </div>
        {isExpanded 
          ? <ChevronUp className="w-4 h-4 text-[#FDE68A]/40 shrink-0" /> 
          : <ChevronDown className="w-4 h-4 text-[#FDE68A]/40 shrink-0" />
        }
      </button>

      <AnimatePresence>
        {isExpanded && (
          <motion.div
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: 'auto', opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            className="px-5 pb-5 space-y-4 overflow-hidden"
          >
            <textarea
              value={editedContent}
              onChange={(e) => setEditedContent(e.target.value)}
              className="w-full h-48 bg-black/30 border border-[#FDE68A]/10 rounded-2xl p-5 text-slate-200 text-sm focus:outline-none focus:border-[#FDE68A]/30 transition-all font-inter leading-relaxed resize-none"
            />
            <div className="flex gap-3">
              <button 
                onClick={handleComplete}
                disabled={isSaving}
                className="flex-1 py-3 bg-[#FDE68A]/10 hover:bg-[#FDE68A]/20 text-[#FDE68A] border border-[#FDE68A]/20 rounded-xl font-outfit font-bold text-xs tracking-widest uppercase transition-all flex items-center justify-center gap-2"
              >
                {isSaving ? <Loader2 className="w-4 h-4 animate-spin" /> : <><Save className="w-4 h-4" /> Lås in reflektionen</>}
              </button>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </motion.div>
  );
};

const EntryCard: React.FC<{ entry: DiaryEntry }> = ({ entry }) => {
  const [isExpanded, setIsExpanded] = useState(false);
  const vibe = VIBES.find(v => v.type === entry.vibe);
  const date = entry.timestamp?.toDate ? entry.timestamp.toDate() : new Date();
  
  return (
    <motion.div 
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      className="p-5 bg-white/[0.02] border border-white/5 rounded-2xl hover:bg-white/[0.04] hover:border-white/10 transition-all cursor-pointer"
      onClick={() => setIsExpanded(!isExpanded)}
    >
      <div className="flex items-center justify-between gap-3">
        <div className="flex items-center gap-3">
          <span className="text-lg leading-none">{vibe?.icon || '📓'}</span>
          <div>
            <span className={cn("text-[10px] font-bold uppercase tracking-widest", vibe?.color || 'text-slate-400')}>{vibe?.label || 'Reflektion'}</span>
            <p className="text-[9px] text-slate-600 font-bold uppercase">{date.toLocaleDateString('sv-SE', { weekday: 'long', day: 'numeric', month: 'short' })}</p>
          </div>
        </div>
        {isExpanded ? <ChevronUp className="w-3.5 h-3.5 text-slate-600 shrink-0" /> : <ChevronDown className="w-3.5 h-3.5 text-slate-600 shrink-0" />}
      </div>
      
      <AnimatePresence>
        {isExpanded ? (
          <motion.p 
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: 'auto', opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            className="text-sm text-slate-300 leading-relaxed mt-4 overflow-hidden"
          >
            {entry.content}
          </motion.p>
        ) : (
          <p className="text-xs text-slate-500 line-clamp-2 leading-relaxed mt-2 italic">
            {entry.content}
          </p>
        )}
      </AnimatePresence>
    </motion.div>
  );
};

export const DiaryView: React.FC<{ userId: string }> = ({ userId }) => {
  const [entries, setEntries] = useState<DiaryEntry[]>([]);
  const [content, setContent] = useState('');
  const [selectedVibe, setSelectedVibe] = useState<Vibe>('NEUTRAL');
  const [isSaving, setIsSaving] = useState(false);
  const [filter, setFilter] = useState('');

  useEffect(() => {
    const q = query(
      collection(db, 'diary_entries'),
      where('userId', '==', userId),
      orderBy('timestamp', 'desc')
    );
    return onSnapshot(q, (snapshot) => {
      setEntries(snapshot.docs.map(d => ({ id: d.id, ...d.data() } as DiaryEntry)));
    });
  }, [userId]);

  const handleSave = async () => {
    if (!content.trim()) return;
    setIsSaving(true);
    try {
      await addDoc(collection(db, 'diary_entries'), {
        userId,
        content,
        vibe: selectedVibe,
        timestamp: serverTimestamp(),
        isDraft: false
      });
      setContent('');
      setSelectedVibe('NEUTRAL');
    } catch (error) {
      console.error("Save failed:", error);
    } finally {
      setIsSaving(false);
    }
  };

  const handleCompleteDraft = async (id: string, editedContent: string) => {
    await updateDoc(doc(db, 'diary_entries', id), {
      content: editedContent,
      isDraft: false,
      completedAt: serverTimestamp()
    });
  };

  const drafts = entries.filter(e => e.isDraft);
  const completed = entries.filter(e => !e.isDraft && e.content.toLowerCase().includes(filter.toLowerCase()));

  return (
    <div className="max-w-4xl mx-auto space-y-10 pb-20">
      <header className="space-y-4">
        <div className="flex items-center gap-3">
          <div className="w-12 h-12 rounded-2xl bg-rose-500/10 flex items-center justify-center border border-rose-500/20">
            <Book className="w-6 h-6 text-rose-400" />
          </div>
          <div>
            <h1 className="text-2xl font-outfit text-white font-light">Dagboken</h1>
            <p className="text-[10px] uppercase font-bold text-slate-500 tracking-widest">Din inre värld · Skyddad</p>
          </div>
        </div>
      </header>

      {/* Morning Drafts */}
      {drafts.length > 0 && (
        <div className="space-y-3">
          <div className="flex items-center gap-2 px-1">
            <Sparkles className="w-4 h-4 text-[#FDE68A]/60" />
            <p className="text-[10px] font-bold text-[#FDE68A]/60 uppercase tracking-widest">
              Väntar på dig ({drafts.length} utkast)
            </p>
          </div>
          {drafts.map(d => (
            <DraftCard key={d.id} entry={d} onComplete={handleCompleteDraft} />
          ))}
        </div>
      )}

      <div className="grid grid-cols-1 lg:grid-cols-12 gap-8">
        {/* Editor */}
        <div className="lg:col-span-7 space-y-4">
          <p className="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Ny anteckning</p>
          
          {/* Vibe selector */}
          <div className="flex flex-wrap gap-2">
            {VIBES.map(v => (
              <button
                key={v.type}
                onClick={() => setSelectedVibe(v.type)}
                className={cn(
                  "flex items-center gap-2 px-3 py-2 rounded-xl border text-xs font-bold transition-all",
                  selectedVibe === v.type 
                    ? "bg-white/10 border-white/20 text-white scale-105" 
                    : "bg-white/[0.02] border-white/5 text-slate-500 hover:bg-white/5"
                )}
              >
                <span>{v.icon}</span>
                <span className={selectedVibe === v.type ? v.color : ''}>{v.label}</span>
              </button>
            ))}
          </div>

          <div className="relative group">
            <div className="absolute inset-0 bg-rose-500/5 rounded-[2rem] blur-2xl opacity-0 group-focus-within:opacity-100 transition-opacity" />
            <textarea 
              value={content}
              onChange={(e) => setContent(e.target.value)}
              placeholder="Hur känns det just nu? Inga filter, bara du..."
              className="w-full h-56 bg-slate-900/40 border border-white/5 rounded-[2rem] p-8 text-slate-200 placeholder-slate-600 focus:outline-none focus:ring-1 focus:ring-rose-500/20 focus:border-rose-500/20 transition-all font-inter leading-relaxed relative z-10 resize-none"
            />
          </div>
          <button 
            onClick={handleSave}
            disabled={isSaving || !content.trim()}
            className="w-full py-4 bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 border border-rose-500/20 rounded-2xl font-outfit text-sm tracking-widest uppercase transition-all flex items-center justify-center gap-3 disabled:opacity-30"
          >
            {isSaving ? <Loader2 className="w-4 h-4 animate-spin" /> : <><PenLine className="w-4 h-4" /> Lås in tanken</>}
          </button>
        </div>

        {/* History */}
        <div className="lg:col-span-5 space-y-4">
          <div className="bg-slate-900/40 border border-white/5 rounded-[2rem] p-5 space-y-5 backdrop-blur-md">
            <div className="flex items-center gap-2">
              <Search className="w-4 h-4 text-slate-500" />
              <input 
                type="text"
                value={filter}
                onChange={(e) => setFilter(e.target.value)}
                placeholder="Sök i minnen..."
                className="bg-transparent border-none text-xs text-slate-300 focus:outline-none w-full"
              />
            </div>

            <div className="space-y-3 max-h-[500px] overflow-y-auto pr-1 scrollbar-hide">
              {completed.map(entry => (
                <EntryCard key={entry.id} entry={entry} />
              ))}
              {completed.length === 0 && (
                <div className="text-center py-12 opacity-20">
                  <History className="w-8 h-8 mx-auto mb-2" />
                  <p className="text-[10px] uppercase font-bold tracking-widest">Inga minnen än</p>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};
</file>

