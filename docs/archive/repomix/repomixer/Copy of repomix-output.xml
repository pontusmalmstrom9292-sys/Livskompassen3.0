import os
import asyncio
from typing import List, Optional, Dict, Any
from google.cloud import discoveryengine_v1 as discoveryengine
from google.api_core.exceptions import NotFound, PermissionDenied

class VertexSearchService:
    """
    Sanningens Sköld - Vertex AI Search Integration.
    Söker mot juridiska manualer, BIFF-guider och BBIC-dokumentation
    för att grunda AI-analysen i faktisk kunskap - ej gissningar.
    """
    
    def __init__(self, project_id: str, location: str, data_store_id: str):
        self.project_id = project_id
        self.location = location
        self.data_store_id = data_store_id
        self._client = None
    
    @property
    def client(self):
        """Lazy initialization för att undvika fel vid saknade credentials."""
        if self._client is None:
            self._client = discoveryengine.SearchServiceClient()
        return self._client

    async def search(self, query: str, mode: str = "DEFAULT") -> List[str]:
        """
        Söker i Vertex AI Search Data Store efter jordnings-information.
        mode: DEFAULT | LEGAL | BBIC | BIFF | PATTERN
        """
        if not self.project_id or not self.data_store_id:
            return self._get_fallback_grounding(mode)

        # Anpassa sökningen baserat på läge
        enhanced_query = self._enhance_query(query, mode)

        serving_config = self.client.serving_config_path(
            project=self.project_id,
            location=self.location,
            data_store=self.data_store_id,
            serving_config="default_config",
        )

        request = discoveryengine.SearchRequest(
            serving_config=serving_config,
            query=enhanced_query,
            page_size=5,
            content_search_spec=discoveryengine.SearchRequest.ContentSearchSpec(
                summary_spec=discoveryengine.SearchRequest.ContentSearchSpec.SummarySpec(
                    summary_result_count=5,
                    include_citations=True,
                    use_semantic_chunks=True,
                    model_spec=discoveryengine.SearchRequest.ContentSearchSpec.SummarySpec.ModelSpec(
                        version="stable"
                    )
                ),
                extractive_content_spec=discoveryengine.SearchRequest.ContentSearchSpec.ExtractiveContentSpec(
                    max_extractive_answer_count=3,
                    max_extractive_segment_count=3,
                )
            ),
            query_expansion_spec=discoveryengine.SearchRequest.QueryExpansionSpec(
                condition=discoveryengine.SearchRequest.QueryExpansionSpec.Condition.AUTO,
            ),
            spell_correction_spec=discoveryengine.SearchRequest.SpellCorrectionSpec(
                mode=discoveryengine.SearchRequest.SpellCorrectionSpec.Mode.AUTO
            )
        )

        try:
            # Kör synkront i en thread pool för att inte blockera event loop
            loop = asyncio.get_event_loop()
            response = await loop.run_in_executor(None, self.client.search, request)
            
            grounding_points = []
            
            # Primär: AI-genererad sammanfattning med källhänvisningar
            if response.summary and response.summary.summary_text:
                grounding_points.append(f"SYNTHESIS: {response.summary.summary_text}")
            
            # Sekundär: Relevanta dokumentutdrag
            for result in response.results:
                doc = result.document
                if hasattr(doc, 'derived_struct_data'):
                    data = doc.derived_struct_data
                    
                    # Extrahera svar från Extractive QA
                    answers = data.get('extractive_answers', [])
                    for answer in answers[:2]:
                        if answer.get('content'):
                            grounding_points.append(f"SOURCE: {answer.get('content', '')[:300]}")
                    
                    # Extrahera relevanta avsnitt
                    snippets = data.get('snippets', [])
                    for s in snippets[:2]:
                        if s.get('snippet'):
                            grounding_points.append(f"EXCERPT: {s.get('snippet', '')[:200]}")
            
            return grounding_points[:8] if grounding_points else self._get_fallback_grounding(mode)
            
        except (NotFound, PermissionDenied) as e:
            print(f"Vertex Search Auth/Config Error: {e}")
            return self._get_fallback_grounding(mode)
        except Exception as e:
            print(f"Vertex Search Error: {e}")
            return self._get_fallback_grounding(mode)

    async def search_for_evidence_pattern(self, events: List[Dict]) -> Dict[str, Any]:
        """
        Analyserar en lista av händelser och söker efter juridiskt relevanta mönster.
        Returnerar en strukturerad mönsteranalys.
        """
        if not events:
            return {"patterns": [], "risk_level": "OKÄNT", "legal_classification": ""}
        
        # Bygg en beskrivning av händelsemönstret
        event_summary = "; ".join([
            f"{e.get('type', 'HÄNDELSE')}: {e.get('description', '')[:100]}"
            for e in events[:10]
        ])
        
        query = f"Systematisk kontroll och eftervåld mönster: {event_summary}"
        grounding = await self.search(query, mode="LEGAL")
        
        return {
            "grounding_context": grounding,
            "event_count": len(events),
            "pattern_summary": event_summary[:500]
        }

    def _enhance_query(self, query: str, mode: str) -> str:
        """Förstärker sökmotorns fråga baserat på analysläge."""
        mode_prefixes = {
            "LEGAL": "Juridisk klassificering och rättslig bedömning av:",
            "BBIC": "BBIC barnperspektiv och socialtjänst bedömning av:",
            "BIFF": "BIFF-svar och kommunikationsstrategi för:",
            "PATTERN": "Mönsterigenkänning systematiskt våld och coercive control:",
            "DEFAULT": "Psykologisk analys och traumainformerat stöd för:"
        }
        prefix = mode_prefixes.get(mode, mode_prefixes["DEFAULT"])
        return f"{prefix} {query[:500]}"

    def _get_fallback_grounding(self, mode: str) -> List[str]:
        """Inbyggd jordning när Vertex Search ej är konfigurerat."""
        fallbacks = {
            "BIFF": [
                "BIFF-metoden: Kort, Informativt, Vänligt, Fast. Svara aldrig med känslor på manipulation.",
                "Grey Rock: Bli ointressant. Ge varken reaktion eller information utöver det nödvändiga.",
