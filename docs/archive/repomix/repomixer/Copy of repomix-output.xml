import { Activity, BrainCircuit, HeartPulse, Scale, ScanSearch, ShieldCheck, Database, GitBranch } from 'lucide-react';
import { cn } from '../lib/utils';

export function TerminalPage() {
  const [agents, setAgents] = useState([
    { id: 'jurist', name: 'Juridisk Agent (Svart/Vit)', active: false, icon: Scale, color: 'text-blue-400', desc: 'Iskall paragraf-ryttare. Söker övertramp och dolda klausuler.' },
    { id: 'psykolog', name: 'Psykologisk Speglings-Agent', active: true, icon: HeartPulse, color: 'text-teal-400', desc: 'Varm validering. Fokuserar på gaslighting och känslohantering.' },
    { id: 'revisor', name: 'Ekonomisk Revisor', active: false, icon: ScanSearch, color: 'text-indigo-400', desc: 'Spårar ekonomiskt våld och transaktionsmönster objektivt.' }
  ]);

  const [logs, setLogs] = useState<string[]>([]);
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    setLogs([
      `[SYS] Synapse Network Online...`,
      `[SYS] Vagus-Nerv simulering aktiv. Systemhälsa stabil.`,
      `[RAG] Kontext-minne låst: 1,045 noder indexerade.`
    ]);
  }, []);

  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
