import React, { useState, useEffect } from 'react';
import { motion } from 'motion/react';
import {
  Shield, Zap, Sun, Cloud, 
  CloudLightning, Loader2,
  BarChart3, AlertTriangle, Fingerprint, Network, Heart,
  TrendingUp, CheckCircle2, Target, Sparkles, Clock, History, AlertCircle
} from 'lucide-react';
import { db } from '../lib/firebase';
import { 
  collection, query, where, orderBy, limit, 
  onSnapshot 
} from 'firebase/firestore';
import { useSystemMemory } from '../contexts/SystemMemoryContext';
import { radarService } from '../services/radarService';
import { cn } from '../lib/utils';
import { useVertexAnalysis } from '../hooks/useVertexAnalysis';
import { shieldApi, EscalationAnalysis, NetworkAnalysis, ChronosAnalysisResult } from '../services/apiService';
import { ChronosPredictor } from './ChronosPredictor';

type WeatherStatus = 'LUGN' | 'MOLNIGT' | 'STORM';

const WeatherIcon = ({ status }: { status: WeatherStatus }) => {
  if (status === 'STORM') return <CloudLightning className="w-6 h-6 text-rose-400" />;
  if (status === 'MOLNIGT') return <Cloud className="w-6 h-6 text-amber-400" />;
  return <Sun className="w-6 h-6 text-teal-400" />;
};

export const TacticalStatusBoard = ({ userId }: { userId: string }) => {
  const { entities } = useSystemMemory();
  const { 
    isOnline: isShieldOnline 
  } = useVertexAnalysis() as any;

  const [brief, setBrief] = useState<any>(null);
  const [loading, setLoading] = useState(true);
  const [escalation, setEscalation] = useState<EscalationAnalysis | null>(null);
  const [network, setNetwork] = useState<NetworkAnalysis | null>(null);
  const [chronos, setChronos] = useState<ChronosAnalysisResult | null>(null);
  const [isChronosLoading, setIsChronosLoading] = useState(false);

  useEffect(() => {
    if (!userId) return;

    const q = query(
      collection(db, 'strategic_briefings'),
      where('userId', '==', userId),
      orderBy('timestamp', 'desc'),
      limit(1)
    );

    const unsub = onSnapshot(q, (snap) => {
      if (!snap.empty) {
        setBrief(snap.docs[0].data());
      }
      setLoading(false);
    });

    return unsub;
  }, [userId]);

  useEffect(() => {
    if (!userId || !isShieldOnline) return;

    const fetchAndAnalyze = async () => {
      const evs = await radarService.getEvents(userId);

      if (evs.length >= 2) {
        setIsChronosLoading(true);
        try {
          const [escRes, netRes, chronosRes] = await Promise.all([
            shieldApi.analyzeEscalation({
              newEvent: evs[0].description,
              historicalEvents: evs.slice(1, 20),
              actorProfiles: entities
            }),
            shieldApi.analyzeNetwork({
              actors: entities,
              networkMembers: [],
              recentEvents: evs.slice(0, 10)
            }),
            shieldApi.analyzeChronos(evs, userId)
          ]);
          
          setEscalation(escRes);
          setNetwork(netRes);
          setChronos(chronosRes.analysis);
        } catch (err) {
          console.error("Tactical analysis failed:", err);
        } finally {
          setIsChronosLoading(false);
        }
      }
    };

    fetchAndAnalyze();
  }, [userId, entities, isShieldOnline]);

  const weather = brief?.weatherForecast?.status as WeatherStatus || 'LUGN';
  const safetyRating = brief?.safetyRating ?? 7;

  if (loading) return (
    <div className="h-64 glass-card rounded-[3rem] flex flex-col items-center justify-center border-white/5 space-y-4">
