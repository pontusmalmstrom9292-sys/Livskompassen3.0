          "name": "GET OAuth Callback (simulerad)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/google/callback?code=PASTE_GOOGLE_AUTH_CODE_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["api","google","callback"],
              "query": [{ "key": "code", "value": "PASTE_GOOGLE_AUTH_CODE_HERE" }]
            }
          }
        },
        {
          "name": "GET Listfiler i Drive",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/google/files", "host": ["{{baseUrl}}"], "path": ["api","google","files"] }
          },
          "_testScript": "pm.test('Status 200', () => pm.response.to.have.status(200));\npm.test('Has files array', () => pm.expect(pm.response.json()).to.be.an('array'));"
        },
        {
          "name": "GET Exportera fil från Drive",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/google/export/REPLACE_WITH_FILE_ID",
              "host": ["{{baseUrl}}"],
              "path": ["api","google","export","REPLACE_WITH_FILE_ID"]
            }
          }
        }
      ]
    }

  ]
