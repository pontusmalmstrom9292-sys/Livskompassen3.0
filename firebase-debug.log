/** Install Postgres extension "uuid-ossp"*/
CREATE EXTENSION IF NOT EXISTS "uuid-ossp"

/** create "user" table*/
CREATE TABLE "public"."user" (
  "id" uuid NOT NULL DEFAULT uuid_generate_v4 (),
  "created_at" timestamptz NOT NULL,
  "display_name" text NOT NULL,
  "email" text NULL,
  "photo_url" text NULL,
  PRIMARY KEY ("id")
)

/** create "movie_list" table*/
CREATE TABLE "public"."movie_list" (
  "id" uuid NOT NULL DEFAULT uuid_generate_v4 (),
  "user_id" uuid NOT NULL,
  "created_at" timestamptz NOT NULL,
  "description" text NULL,
  "is_public" boolean NOT NULL,
  "name" text NOT NULL,
  "updated_at" timestamptz NOT NULL,
  PRIMARY KEY ("id"),
  CONSTRAINT "movie_list_user_id_fkey" FOREIGN KEY ("user_id") REFERENCES "public"."user" ("id") ON DELETE CASCADE
)

/** create index "movie_list_userId_idx" to table: "movie_list"*/
CREATE INDEX "movie_list_userId_idx" ON "public"."movie_list" ("user_id")

/** create "movie" table*/
CREATE TABLE "public"."movie" (
  "id" uuid NOT NULL DEFAULT uuid_generate_v4 (),
  "created_at" timestamptz NOT NULL,
  "genres" text[] NULL,
  "runtime" integer NULL,
  "summary" text NULL,
  "title" text NOT NULL,
  "year" integer NOT NULL,
  PRIMARY KEY ("id")
)

/** create "movie_list_entry" table*/
CREATE TABLE "public"."movie_list_entry" (
  "id" uuid NOT NULL DEFAULT uuid_generate_v4 (),
  "movie_id" uuid NOT NULL,
  "movie_list_id" uuid NOT NULL,
  "note" text NULL,
  "position" integer NOT NULL,
  PRIMARY KEY ("id"),
  CONSTRAINT "movie_list_entry_movie_id_fkey" FOREIGN KEY ("movie_id") REFERENCES "public"."movie" ("id") ON DELETE CASCADE,
  CONSTRAINT "movie_list_entry_movie_list_id_fkey" FOREIGN KEY ("movie_list_id") REFERENCES "public"."movie_list" ("id") ON DELETE CASCADE
)

/** create index "movie_list_entry_movieId_idx" to table: "movie_list_entry"*/
CREATE INDEX "movie_list_entry_movieId_idx" ON "public"."movie_list_entry" ("movie_id")

/** create index "movie_list_entry_movieListId_idx" to table: "movie_list_entry"*/
CREATE INDEX "movie_list_entry_movieListId_idx" ON "public"."movie_list_entry" ("movie_list_id")

/** create "watch" table*/
CREATE TABLE "public"."watch" (
  "id" uuid NOT NULL DEFAULT uuid_generate_v4 (),
  "movie_id" uuid NOT NULL,
  "user_id" uuid NOT NULL,
  "created_at" timestamptz NOT NULL,
  "location" text NULL,
  "watch_date" date NOT NULL,
  PRIMARY KEY ("id"),
  CONSTRAINT "watch_movie_id_fkey" FOREIGN KEY ("movie_id") REFERENCES "public"."movie" ("id") ON DELETE CASCADE,
  CONSTRAINT "watch_user_id_fkey" FOREIGN KEY ("user_id") REFERENCES "public"."user" ("id") ON DELETE CASCADE
)

/** create index "watch_movieId_idx" to table: "watch"*/
CREATE INDEX "watch_movieId_idx" ON "public"."watch" ("movie_id")

/** create index "watch_userId_idx" to table: "watch"*/
CREATE INDEX "watch_userId_idx" ON "public"."watch" ("user_id")

/** create "review" table*/
CREATE TABLE "public"."review" (
  "id" uuid NOT NULL DEFAULT uuid_generate_v4 (),
  "movie_id" uuid NOT NULL,
  "user_id" uuid NOT NULL,
  "watch_id" uuid NOT NULL,
  "created_at" timestamptz NOT NULL,
  "is_public" boolean NOT NULL,
  "rating" integer NOT NULL,
  "review_text" text NULL,
  "share_token" text NULL,
  "updated_at" timestamptz NOT NULL,
  PRIMARY KEY ("id"),
  CONSTRAINT "review_movie_id_fkey" FOREIGN KEY ("movie_id") REFERENCES "public"."movie" ("id") ON DELETE CASCADE,
  CONSTRAINT "review_user_id_fkey" FOREIGN KEY ("user_id") REFERENCES "public"."user" ("id") ON DELETE CASCADE,
  CONSTRAINT "review_watch_id_fkey" FOREIGN KEY ("watch_id") REFERENCES "public"."watch" ("id") ON DELETE CASCADE
)

/** create index "review_movieId_idx" to table: "review"*/
CREATE INDEX "review_movieId_idx" ON "public"."review" ("movie_id")

/** create index "review_userId_idx" to table: "review"*/
CREATE INDEX "review_userId_idx" ON "public"."review" ("user_id")

/** create index "review_watchId_idx" to table: "review"*/
