[debug] [2026-05-16T10:19:44.054Z] > 
    DO $$
    DECLARE
        role_count INTEGER;
    BEGIN
        -- Count the number of rows matching the criteria
        SELECT COUNT(*)
        INTO role_count
        FROM
          pg_auth_members m
        JOIN
          pg_roles grantee ON grantee.oid = m.member
        JOIN
          pg_roles granted ON granted.oid = m.roleid
        JOIN
          pg_roles grantor ON grantor.oid = m.grantor
        WHERE
          granted.rolname = 'firebaseowner_fdcdb_public'
          AND grantee.rolname = 'pontus.malmstrom9292@gmail.com';

        -- If no rows were found, raise an exception
        IF role_count = 0 THEN
            RAISE EXCEPTION 'Role "%", is not granted to role "%".', 'firebaseowner_fdcdb_public', 'pontus.malmstrom9292@gmail.com';
        END IF;
    END $$;

